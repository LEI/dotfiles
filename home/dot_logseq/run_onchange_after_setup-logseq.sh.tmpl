#!/bin/sh

# plugins.edn: {{ include "dot_logseq/config/plugins.edn" | sha256sum }}

set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

if ! has ghq; then
  err "ghq not found, install it to set up notes graphs"
fi

notes_dir="{{ .chezmoi.homeDir }}/notes"

if [ ! -d "$notes_dir" ]; then
  run mkdir -p "$notes_dir"
fi

setup_graph() {
  name="$1"
  url="${2:-$name}"
  link="$notes_dir/$name"

  if [ -L "$link" ]; then
    return
  fi

  run ghq get "$url"

  path_key=$(printf '%s' "$url" | sed -E 's|^git@||; s|^https?://||; s|:|/|; s|\.git$||')
  local_path="$(ghq root)/$path_key"
  if [ ! -d "$local_path" ]; then
    err "ghq could not resolve $url"
  fi

  # run git -C "$local_path" branch --set-upstream-to=origin/main
  run ln -s "$local_path" "$link"
  msg "Linked $name graph: $link -> $local_path"
}

{{- range (dig "logseq" "graphs" (list) .) }}
setup_graph {{ .name | quote }}{{ if hasKey . "url" }} {{ .url | quote }}{{ end }}
{{- end }}

