{{- if and (or .features.bash .features.zsh) (lookPath "usage" | isExecutable) -}}
{{- $dict := dict -}}
{{- $bin := concat (glob (joinPath .chezmoi.sourceDir "dot_local" "bin" "executable_*")) (glob (joinPath .chezmoi.sourceDir "script" "*")) -}}
{{- range $bin -}}
{{-   $content := include . -}}
{{-   if contains "#USAGE " $content -}}
{{-     $hash := $content | sha256sum -}}
{{-     $name := . | base | trimPrefix "executable_" -}}
{{-     if get $dict $name -}}
{{-       warnf "duplicate #USAGE for %s, skipping\n" $name -}}
{{-       continue -}}
{{-     end -}}
{{-     $relative := trimPrefix (printf "%s/" $.chezmoi.sourceDir) . -}}
{{-     $dict = merge $dict (dict $name (dict
  "path" $relative
  "hash" $hash
)) -}}
{{-   end -}}
{{- end -}}
{{- if not (empty $dict) -}}
#!/usr/bin/env bash
# Generate shell completions for scripts with #USAGE directives (dot_local/bin/* and script/*)
# patch_bash_mapfile fixes compgen -W word-splitting on paths with spaces (usage bug)

{{- range $dict | keys | sortAlpha }}
# {{ . }}: {{ get (get $dict .) "hash" }}
{{- end }}

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo "bash 4+ required, found $BASH_VERSION" >&2
  exit 1
fi

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

{{ includeTemplate "dot_config/environment.d/00-xdg.conf.tmpl" . | trim }}
{{- if .features.bash }}

bash_dir="{{ .chezmoi.homeDir }}/.local/share/bash-completion/completions"
mkdir -p "$bash_dir"
{{- end }}
{{- if .features.zsh }}

zsh_dir="{{ .chezmoi.homeDir }}/.local/share/zsh/completions"
mkdir -p "$zsh_dir"
{{- end }}

rc=0

{{- if .features.bash }}
patch_bash_mapfile() {
  local file="$1" tmp="$1.tmp" line inner
  while IFS= read -r line; do
    # shellcheck disable=SC2016
    if [[ "$line" == *'_comp_compgen -- -W "$(command '* ]]; then
      inner="${line#*\"\$(}"
      inner="${inner%)\"}"
      cat <<EOF
	if (( BASH_VERSINFO[0] >= 4 )); then
		mapfile -t COMPREPLY < <($inner)
	else
		echo >&2 "generate-completions: bash 4+ required for path completions in $file"
	fi
EOF
    else
      printf '%s\n' "$line"
    fi
  done <"$file" >"$tmp" && mv "$tmp" "$file"
}
{{- end }}

gen_completions() {
  name="$1"
  spec=$(cat)
  msg "generate-completions: $name"
{{- if .features.bash }}
  usage generate completion bash "$name" --file - <<<"$spec" >|"$bash_dir/$name" || rc=1
  if grep -q 'run=' <<<"$spec"; then
    if ! patch_bash_mapfile "$bash_dir/$name"; then
      echo >&2 "generate-completions: patch failed for $name"
      rc=1
    fi
    if grep -q '_comp_compgen -- -W' "$bash_dir/$name"; then
      echo >&2 "generate-completions: patch did not apply for $name -- usage output format may have changed"
      rc=1
    fi
  fi
{{- end }}
{{- if .features.zsh }}
  usage generate completion zsh "$name" --file - <<<"$spec" >|"$zsh_dir/_$name" || rc=1
{{- end }}
}
{{ range $dict | keys | sortAlpha }}
{{- $item := get $dict . }}
gen_completions {{ . | quote }} <<'SPEC'
{{ $content := include $item.path -}}
{{- range $line := $content | splitList "\n" -}}
{{-   if not (hasPrefix "#USAGE " $line) -}}
{{-     continue -}}
{{-   end -}}
{{-   printf "%s\n" (trimPrefix "#USAGE " $line) -}}
{{ end -}}
SPEC
{{ end }}
exit $rc
{{- end }}
{{- end }}
