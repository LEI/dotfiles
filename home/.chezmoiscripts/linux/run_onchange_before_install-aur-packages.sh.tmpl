{{- if eq .osIDLike "arch" -}}
#!/bin/sh

set -eu

if [ -z "${USER:-}" ]; then
  USER="$(id -un)"
fi

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

if ! has yay && ! has paru && ! has pamac; then
  TMPDIR="${TMPDIR:-/tmp}"
  if [ ! -d $TMPDIR/yay-bin ]; then
    dry_run sudo -E --user="$USER" git clone https://aur.archlinux.org/yay-bin.git $TMPDIR/yay-bin
  fi
  run cd $TMPDIR/yay-bin
  if [ -n "${CI:-}" ] && grep -q '^OPTIONS=.*[^!]debug' /etc/makepkg.conf; then
    dry_run sudo sed -e '/^OPTIONS=/ s/ debug / !debug /' -i /etc/makepkg.conf
  fi
  if [ -n "${CI:-}" ] && [ "$(uname -m)" = "aarch64" ]; then
    dry_run sudo sed -e 's/^#\?LocalFileSigLevel = .*/LocalFileSigLevel = Optional/' -i /etc/pacman.conf
  fi
  dry_run sudo -E --user="$USER" makepkg --install --noconfirm --syncdeps
fi

{{- if eq (env "CACHE_BUST") "true" }}
# aur hash: {{ output "sh" (joinPath .chezmoi.sourceDir "dot_local/bin/executable_list-package") "aur" | sha256sum }}
{{- end }}
msg "Installing AUR packages"

{{- $aurPackages := .packages.aur }}

{{- if empty $aurPackages }}
{{-   warnf "missing aur packages" }}
{{- end }}

aur_packages="{{ $aurPackages | keys | sortAlpha | join " " }}"

{{ includeTemplate "package-hooks.tmpl" (dict "key" "before_script" "values" .packages.aur) }}

if has yay; then
  # run sudo chown -R "$USER:$USER" /tmp/yay
  dry_run sudo -E --user="$USER" yay --sync --needed --noconfirm --quiet $aur_packages
elif has paru && ! has pamac; then
  dry_run sudo -E --user="$USER" paru --sync --needed --noconfirm --quiet $aur_packages
elif has pamac; then
  dry_run sudo -E --user="$USER" pamac install --no-confirm --quiet $aur_packages
else
  err "AUR package manager not found"
fi

{{ includeTemplate "package-hooks.tmpl" (dict "key" "after_script" "values" .packages.aur) }}

msg "Installed AUR packages"
{{ end -}}
