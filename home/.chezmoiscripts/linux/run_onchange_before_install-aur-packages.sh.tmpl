{{- if eq .osIDLike "arch" -}}
#!/bin/sh

set -eu

if [ -z "${USER:-}" ]; then
  USER="$(id -un)"
fi

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

# Run a command as $USER; if already that user, run directly
as_user() {
  if [ "$(id -un)" = "$USER" ]; then
    "$@"
  elif command -v runuser >/dev/null; then
    runuser -p -u "$USER" -- "$@"
  else
    sudo -E --user="$USER" "$@"
  fi
}

if ! has yay && ! has paru && ! has pamac; then
  TMPDIR="${TMPDIR:-/tmp}"
  if [ -n "${CI:-}" ] && grep -q '^OPTIONS=.*[^!]debug' /etc/makepkg.conf; then
    dry_run sudo sed -e '/^OPTIONS=/ s/ debug / !debug /' -i /etc/makepkg.conf
  fi
  # archlinuxarm containers ship without an initialized keyring
  if grep -q '^NAME=.*Arch Linux ARM' /etc/os-release 2>/dev/null; then
    dry_run sudo pacman-key --init
    dry_run sudo pacman-key --populate archlinuxarm
    dry_run sudo sed -e 's/^#\?LocalFileSigLevel = .*/LocalFileSigLevel = Never/' -i /etc/pacman.conf
  fi
  dry_run as_user sh -c "
    if [ -d '$TMPDIR/yay-bin' ]; then
      git -C '$TMPDIR/yay-bin' clean -fdx
    else
      git clone https://aur.archlinux.org/yay-bin.git '$TMPDIR/yay-bin'
    fi
    cd '$TMPDIR/yay-bin'
    makepkg --install --noconfirm --syncdeps
  "
fi

{{- if eq (env "CACHE_BUST") "true" }}
# aur hash: {{ output "sh" (joinPath .chezmoi.sourceDir "dot_local/bin/executable_list-package") "aur" | sha256sum }}
{{- end }}
msg "Installing AUR packages"

{{- $aurPackages := .packages.aur }}

{{- if empty $aurPackages }}
{{-   warnf "missing aur packages" }}
{{- end }}

aur_packages="{{ $aurPackages | keys | sortAlpha | join " " }}"

{{- includeTemplate "package-hooks.tmpl" (dict "key" "before_script" "values" .packages.aur) }}

if has yay; then
  # run sudo chown -R "$USER:$USER" /tmp/yay
  # shellcheck disable=SC2086
  dry_run as_user yay --sync --needed --noconfirm --quiet $aur_packages
elif has paru && ! has pamac; then
  # shellcheck disable=SC2086
  dry_run as_user paru --sync --needed --noconfirm --quiet $aur_packages
elif has pamac; then
  # shellcheck disable=SC2086
  dry_run as_user pamac install --no-confirm --quiet $aur_packages
else
  die "AUR package manager not found"
fi

{{- includeTemplate "package-hooks.tmpl" (dict "key" "after_script" "values" .packages.aur) }}

msg "Installed AUR packages"
{{ end -}}
