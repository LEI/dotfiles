{{- if eq .variantID "silverblue" -}}
#!/bin/sh
# Managed by chezmoi
# Provision snapper for /var/home on Fedora atomic

set -eu

if ! command -v snapper >/dev/null 2>&1; then
  echo "Skipping snapper setup (snapper not installed)"
  exit 0
fi

# Idempotent: nothing to do once the config exists
[ -f /etc/snapper/configs/home ] && exit 0

# Provisioning needs root, but apply runs as the user
if [ "$(id -u)" != 0 ]; then
  echo "snapper: provision as root: sudo snapper -c home create-config /var/home" >&2
  exit 0
fi

snapper -c home create-config /var/home
snapper -c home set-config \
  TIMELINE_CREATE=yes \
  TIMELINE_LIMIT_HOURLY=24 \
  TIMELINE_LIMIT_DAILY=7 \
  TIMELINE_LIMIT_WEEKLY=0 \
  TIMELINE_LIMIT_MONTHLY=0 \
  TIMELINE_LIMIT_YEARLY=0
systemctl enable --now snapper-timeline.timer snapper-cleanup.timer
{{ end -}}
