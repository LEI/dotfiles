#!/bin/sh
# env.conf: {{ include (joinPath .chezmoi.sourceDir "dot_config/environment.d/env.conf.tmpl") | sha256sum }}
# path.conf: {{ include (joinPath .chezmoi.sourceDir "dot_config/environment.d/path.conf.tmpl") | sha256sum }}
set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

if has systemctl; then
  run systemctl --user daemon-reexec
  if systemctl --user is-active --quiet process-compose; then
    run systemctl --user restart process-compose
  fi
fi
