#!/bin/sh
set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

for subvol in /var /var/home; do
  current=$(btrfs property get "$subvol" compression 2>/dev/null | awk -F= '{print $2}')
  if [ "$current" != "zstd:1" ]; then
    log "btrfs: setting compression=zstd:1 on $subvol"
    run pkexec btrfs property set "$subvol" compression zstd:1
  fi
done

# $HOME is user-owned; no pkexec needed
current=$(btrfs property get "$HOME" compression 2>/dev/null | awk -F= '{print $2}')
if [ "$current" != "zstd:1" ]; then
  log "btrfs: setting compression=zstd:1 on $HOME"
  run btrfs property set "$HOME" compression zstd:1
fi
