#!/bin/sh

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

if [ -z "${USER:-}" ]; then
  warn "USER is not set, falling back to id -un"
  USER="$(id -un)"
fi

{{- if ne .os "darwin" }}

# https://docs.brew.sh/Homebrew-on-Linux
if ! has brew; then
  if [ ! -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    msg "Installing homebrew"
    dry_run sudo mkdir -p /home/linuxbrew/.linuxbrew
    dry_run sudo chown -R "$USER:$USER" /home/linuxbrew/.linuxbrew
    run git config --global --add safe.directory /home/linuxbrew/.linuxbrew/Homebrew
    # SUDO_ASKPASS=1
    # NOTE: Homebrew/install/HEAD/install.sh -> 404
    run curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh -o /tmp/brew-install.sh
    if [ ! -s /tmp/brew-install.sh ]; then
      die "failed to download install script"
    fi
    run /bin/bash /tmp/brew-install.sh
    rm -f /tmp/brew-install.sh
    msg "Installed homebrew"
  fi
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
{{- else }}

if ! has brew; then
  msg "Installing homebrew"
  # FIXME: Need sudo access on macOS
  dry_run sudo echo
  run curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh -o /tmp/brew-install.sh
  if [ ! -s /tmp/brew-install.sh ]; then
    die "failed to download install script"
  fi
  run /bin/bash /tmp/brew-install.sh
  rm -f /tmp/brew-install.sh
  msg "Installed homebrew"
fi
{{- end }}

# https://docs.brew.sh/Installation#unattended-installation
export NONINTERACTIVE=1

dry_run brew update --quiet "$@"

{{- if .upgrade }}

dry_run brew upgrade --quiet "$@" # --dry-run
{{- end }}

# if ! [ -f ~/.config/homebrew/Brewfile ]; then
#   run brew bundle dump --file="${XDG_CONFIG_HOME:-$HOME/.config}/homebrew/Brewfile"
# fi

{{- range $type := list "brew" "cask" "mas" "vscode" }}
{{- if not (hasKey $.packages $type) }}{{ continue }}{{ end -}}
{{- $hooks := includeTemplate "package-hooks.tmpl" (dict "key" "before_script" "values" (get $.packages $type) "label" $type) | trim -}}
{{- if empty $hooks }}{{ continue }}{{ end }}
{{ $hooks }}
{{ end -}}

# run brew bundle list --global
{{- if eq (env "CACHE_BUST") "true" }}
{{- range $type := list "brew" "cask" "mas" "vscode" }}
# {{ $type }} hash: {{ output "sh" "-c" (printf "%s %s || true" (joinPath .chezmoi.sourceDir "dot_local/bin/executable_list-package") $type) | sha256sum }}
{{- end }}
{{- end }}
{{- $trustTaps := list }}
{{- if hasKey .packages "tap" }}
{{-   range $name, $_ := .packages.tap }}
{{-     if not (hasPrefix "homebrew/" $name) }}{{ $trustTaps = append $trustTaps $name }}{{ end }}
{{-   end }}
{{- end }}
{{- if $trustTaps }}
# brew 6.0 tap trust: Brewfile trusted: misses transitive deps (Homebrew/brew#22631)
if brew trust --help >/dev/null 2>&1; then
  dry_run brew trust{{ range $trustTaps }} {{ . | quote }}{{ end }}
fi
{{- end }}
dry_run brew bundle --file=/dev/stdin{{ if not .upgrade }} --no-upgrade{{ end }} "$@" <<EOF
{{ includeTemplate "Brewfile" . | trim }}
EOF

{{- range $type := list "brew" "cask" "mas" "vscode" -}}
{{- if not (hasKey $.packages $type) }}{{ continue }}{{ end -}}
{{- $hooks := includeTemplate "package-hooks.tmpl" (dict "key" "after_script" "values" (get $.packages $type) "label" $type) | trim -}}
{{- if empty $hooks }}{{ continue }}{{ end }}
{{ $hooks }}
{{- end }}
