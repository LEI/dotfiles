#!/bin/sh

set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

if [ -z "${USER:-}" ]; then
  warn "USER is not set, falling back to id -un"
  USER="$(id -un)"
fi

{{- if ne .os "darwin" }}

# https://docs.brew.sh/Homebrew-on-Linux
if ! has brew; then
  if ! [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    msg "Installing homebrew"
    dry_run sudo mkdir -p /home/linuxbrew/.linuxbrew
    dry_run sudo chown -R "$USER:$USER" /home/linuxbrew/.linuxbrew
    run git config --global --add safe.directory /home/linuxbrew/.linuxbrew/Homebrew
    # SUDO_ASKPASS=1
    # NOTE: Homebrew/install/HEAD/install.sh -> 404
    install_script="$(run curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"
    if [ -z "$install_script" ]; then
      err "failed to download install script"
    fi
    /bin/bash -c "$install_script"
    msg "Installed homebrew"
  fi
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
{{- else }}

if ! has brew; then
  msg "Installing homebrew"
  # FIXME: Need sudo access on macOS
  dry_run sudo echo
  install_script="$(run curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  if [ -z "$install_script" ]; then
    err "failed to download install script"
  fi
  /bin/bash -c "$install_script"
  msg "Installed homebrew"
fi
{{- end }}

# https://docs.brew.sh/Installation#unattended-installation
export NONINTERACTIVE=1

dry_run brew update --quiet "$@"

{{- if .upgrade }}

dry_run brew upgrade --quiet "$@" # --dry-run
{{- end }}

# if ! [ -f ~/.config/homebrew/Brewfile ]; then
#   run brew bundle dump --file="${XDG_CONFIG_HOME:-$HOME/.config}/homebrew/Brewfile"
# fi

{{- range $type := list "brew" "cask" "mas" "vscode" }}
{{- if not (hasKey $.packages $type) }}
{{-   continue }}
{{- end }}
{{- includeTemplate "package-hooks.tmpl" (dict "key" "before_script" "values" (get $.packages $type) "label" $type) -}}
{{- end }}

# run brew bundle list --global
{{- if eq (env "CACHE_BUST") "true" }}
# brew hash: {{ output "sh" "-c" (printf "%s %s || true" (joinPath .chezmoi.sourceDir "dot_local/bin/executable_list-package") "brew") | sha256sum }}
# cask hash: {{ output "sh" "-c" (printf "%s %s || true" (joinPath .chezmoi.sourceDir "dot_local/bin/executable_list-package") "cask") | sha256sum }}
# mas hash: {{ output "sh" "-c" (printf "%s %s || true" (joinPath .chezmoi.sourceDir "dot_local/bin/executable_list-package") "mas") | sha256sum }}
# vscode hash: {{ output "sh" "-c" (printf "%s %s || true" (joinPath .chezmoi.sourceDir "dot_local/bin/executable_list-package") "vscode") | sha256sum }}
{{- end }}
dry_run brew bundle --file=/dev/stdin{{ if not .upgrade }} --no-upgrade{{ end }} "$@" <<EOF
{{ includeTemplate "Brewfile" . | trim }}
EOF

{{- range $type := list "brew" "cask" "mas" "vscode" }}
{{- if not (hasKey $.packages $type) }}
{{-   continue }}
{{- end }}
{{- includeTemplate "package-hooks.tmpl" (dict "key" "after_script" "values" (get $.packages $type) "label" $type) -}}
{{- end }}
