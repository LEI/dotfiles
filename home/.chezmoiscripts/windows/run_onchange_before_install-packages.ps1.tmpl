# Set-PSDebug -Trace 1

{{- $scoopPackages := includeTemplate "package-list.tmpl" (merge (dict "packages" .packages.windows.scoop) .) | fromJson }}
{{- $wingetPackages := includeTemplate "package-list.tmpl" (merge (dict "packages" .packages.windows.winget) .) | fromJson }}

echo "Scoop: {{ lookPath "scoop" }}"

# Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser
# Invoke-RestMethod -Uri https://get.scoop.sh | Invoke-Expression

{{- if .upgrade }}
scoop update *
{{- end }}

scoop install {{ $scoopPackages | join " " }}

echo "Winget: {{ lookPath "winget" }}"

{{- if .upgrade }}
# echo "winget update --disable-interactivity --silent"
# winget update --disable-interactivity --silent

echo "winget upgrade --all --disable-interactivity --silent"
winget upgrade --all --disable-interactivity --silent
{{- end }}

echo "winget install --disable-interactivity --silent {{ $wingetPackages | join " " }}"
winget install --disable-interactivity --silent {{ $wingetPackages | join " " }}
