#!/bin/sh

# https://ghostty.org/docs/install/binary

set -eu

if command -v ghostty >/dev/null; then
  # TODO: use bash with pipefail option to run: "ghostty --version | head -n1"
  echo >&2 'Already installed {{ output "sh" "-c" "command -v ghostty || true" }}'
  exit
fi

echo >&2 "Installing ghostty"
# {{- if eq .chezmoi.os "darwin" }}
export NONINTERACTIVE=1

set -x

brew install --quiet ghostty
# {{- else if eq .osid "arch" }} Archlinux/Manjaro
set -x

sudo pacman --sync --needed --noconfirm --quiet ghostty
# {{- else if eq (get .chezmoi.osRelease "id") "debian" }}
# https://github.com/clayrisser/debian-ghostty/
export DEBIAN_FRONTEND=noninteractive

set -x

VERSION_CODENAME="$(
  . /etc/os-release
  echo "$VERSION_CODENAME"
)"
VERSION_ID="$(
  . /etc/os-release
  echo "$VERSION_ID"
)"
version_path="$VERSION_CODENAME/Debian_$VERSION_ID"
echo "deb http://download.opensuse.org/repositories/home:/clayrisser:/$version_path/ /" |
  sudo tee "/etc/apt/sources.list.d/home:clayrisser:$VERSION_CODENAME.list"
curl -fsSL "https://download.opensuse.org/repositories/home:clayrisser:$version_path/Release.key" |
  gpg --dearmor |
  sudo tee "/etc/apt/trusted.gpg.d/home_clayrisser_$VERSION_CODENAME.gpg" >/dev/null
sudo apt-get update --quiet >/dev/null
sudo -E apt-get install --quiet --yes ghostty >/dev/null
# {{- else if eq (get .chezmoi.osRelease "id") "ubuntu" }}
# https://github.com/mkasberg/ghostty-ubuntu
export DEBIAN_FRONTEND=noninteractive

set -x

ARCH="{{ .chezmoi.arch }}"
VERSION_ID="$(
  . /etc/os-release
  echo "$VERSION_ID"
)"
URL="https://github.com/mkasberg/ghostty-ubuntu/releases/download/1.1.3-0-ppa2/ghostty_1.1.3-0.ppa2_${ARCH}_$VERSION_ID.deb"
curl -LSfs "$URL" -o "$TMPDIR/ghostty.deb"
sudo apt-get install --quiet --yes "$TMPDIR/ghostty.deb"
# {{- else }}
echo >&2 "Unknown OS: $CHEZMOI_OS $CHEZMOI_OS_RELEASE_ID"
# exit 1
# {{- end }}

set +x

echo >&2 "Installed ghostty"
