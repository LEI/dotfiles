#!/bin/sh

# https://www.chezmoi.io/user-guide/advanced/install-packages-declaratively/

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

{{- $systemPackages := get .packages .packageManager }}
{{- if or (empty $systemPackages) (not (kindIs "map" $systemPackages)) }}
{{-   warnf "invalid packages %s: %s" .packageManager $systemPackages }}
{{- end }}
{{- $packageList := $systemPackages | keys | sortAlpha }}

packages="{{ $packageList | join " " }}"

{{- if eq (env "CACHE_BUST") "true" }}
# Installed hash: {{ output "sh" (joinPath .chezmoi.sourceDir "dot_local/bin/executable_list-package") .packageManager | sha256sum }}
{{- end }}
msg "Installing {{ .packageManager }} packages: $packages"
{{- includeTemplate "package-hooks.tmpl" (dict "key" "before_script" "values" $systemPackages) }}
{{- if eq .osID "alpine" }}

{{- if .container }}

# ERROR: Unable to lock database: Resource temporarily unavailable
# ERROR: Failed to open apk database: Resource temporarily unavailable
{{- end }}

dry_run sudo apk update --quiet
{{- if .upgrade }}

dry_run sudo apk upgrade --quiet
{{- end }}

# shellcheck disable=SC2086
dry_run sudo apk add --quiet $packages
{{- else if eq .osIDLike "arch" }}

{{- if .container }}

if [ -f /var/lib/pacman/db.lck ]; then
  dry_run sudo rm -f /var/lib/pacman/db.lck
fi
{{- end }}

{{- if .upgrade }}

dry_run sudo pacman --refresh --sync --sysupgrade --needed --noconfirm --quiet
{{- end }}

# shellcheck disable=SC2086
dry_run sudo pacman --sync --needed --noconfirm --quiet $packages

{{- else if eq .osIDLike "debian" }}

{{- if .container }}

for lock in \
  /var/cache/apt/archives/lock \
  /var/lib/apt/lists/lock \
  /var/lib/dpkg/lock \
  /var/lib/dpkg/lock-frontend; do
  if [ -f "$lock" ]; then
    dry_run sudo rm "$lock"
  fi
done
if [ -d /var/lib/apt/lists/partial ]; then
  # Stale symlinks in partial cause EEXIST failures and leave lists inconsistent
  dry_run sudo rm -f /var/lib/apt/lists/partial/*
fi

# https://manpages.ubuntu.com/manpages/trusty/en/man7/debconf.7.html#frontends
export DEBIAN_FRONTEND=noninteractive
{{- end }}

dry_run sudo dpkg --configure -a

dry_run sudo -E apt-get update --quiet # >/dev/null

{{- if .upgrade }}

dry_run sudo -E apt-get upgrade --quiet --yes # >/dev/null
{{- end }}

# shellcheck disable=SC2086
dry_run sudo -E apt-get install --quiet --yes $packages # >/dev/null
{{- else if and (eq .osIDLike "fedora" "rhel") (eq .packageManager "dnf") }}

{{- if eq .osIDLike "rhel" }}

# rhel-family ships a slim BaseOS/AppStream; EPEL + CRB cover the rest of the tooling
dry_run sudo dnf install --assumeyes --quiet dnf-plugins-core epel-release
dry_run sudo dnf config-manager --set-enabled crb
{{- end }}

dry_run sudo dnf update --assumeyes --quiet
{{- if .upgrade }}

dry_run sudo dnf upgrade --assumeyes --quiet
{{- end }}

# shellcheck disable=SC2086
dry_run sudo dnf install --assumeyes --quiet $packages
{{- else if eq .osIDLike "fedora" "rhel" }}

dry_run rpm-ostree refresh-md # --quiet
{{- if .upgrade }}

dry_run rpm-ostree upgrade # --quiet
{{- end }}

# shellcheck disable=SC2086
dry_run rpm-ostree install --allow-inactive --assumeyes --idempotent $packages
# --apply-live --quiet
{{- else if eq .osIDLike "opensuse" }}

{{- if .container }}

if [ -s /run/zypp.pid ]; then
  pid="$(cat /run/zypp.pid)"
  if kill -0 "$pid" 2>/dev/null; then
    dry_run sudo kill "$pid"
  fi
fi
{{- end }}

dry_run sudo zypper --quiet ref
{{- if .upgrade }}

dry_run sudo zypper --quiet update --no-confirm
{{- end }}

# shellcheck disable=SC2086
dry_run sudo zypper --quiet install --no-confirm $packages
{{- else if eq .osID "android" }}

{{- if not .container }}

# https://github.com/termux/termux-packages/blob/master/scripts/setup-termux.sh
if [ ! -d "$HOME/storage/shared" ]; then
  dry_run termux-setup-storage
fi
{{- end }}

# if [ -z "${TERMUX_APP_PACKAGE_MANAGER:-}" ]; then
#   dry_run termux-setup-package-manager
#   TERMUX_APP_PACKAGE_MANAGER=apt
# fi

# TERM=xterm termux-change-repo # apt edit-sources
# https://github.com/termux/termux-app/issues/4517#issuecomment-2831997163
dry_run ln -sf "$PREFIX/etc/termux/mirrors/default" "$PREFIX/etc/termux/chosen_mirrors"

# cat /data/data/com.termux/files/usr/etc/apt/sources.list
# dry_run apt-get update --quiet >/dev/null
dry_run pkg update --quiet

{{- if .upgrade }}

# dry_run apt-get upgrade --quiet --yes # >/dev/null
dry_run pkg upgrade --quiet --yes
{{- end }}

# shellcheck disable=SC2086
dry_run pkg install --quiet --yes $packages # >/dev/null
{{- else if eq .os "windows" }}
{{- if .upgrade }}

dry_run winget upgrade --all --disable-interactivity --silent
{{- end }}

import_file="$(mktemp)"
cat >"$import_file" <<'EOF'
{{ includeTemplate "winget.json.tmpl" . | fromJson | toPrettyJson | trim }}
EOF
dry_run winget import --disable-interactivity --import-file="$import_file"
{{- if not .upgrade }} --no-upgrade{{ end }}
# --accept-package-agreements --accept-source-agreements
{{- else }}

die "invalid OS: {{ .osID }}"
{{- end }}
{{- includeTemplate "package-hooks.tmpl" (dict "key" "after_script" "values" $systemPackages) }}
{{- if and .codespaces (eq .osIDLike "debian") }}

selected_editor="$(update-alternatives --get-selections | grep editor | tr -s ' ' | cut -d' ' -f3)"
if [ "${selected_editor##*/}" = nano ]; then
  if [ -x /usr/bin/vim.basic ]; then
    dry_run sudo update-alternatives --set editor /usr/bin/vim.basic
  elif [ -x /usr/bin/vim.tiny ]; then
    dry_run sudo update-alternatives --set editor /usr/bin/vim.tiny
  fi
fi
{{- end }}

msg "Installed {{ .packageManager }} packages"
