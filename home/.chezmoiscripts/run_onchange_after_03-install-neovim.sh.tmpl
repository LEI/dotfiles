#!/bin/bash

set -euo pipefail

source "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

# BIN_DIR="$HOME/.local/bin"
# if [ "$PATH" != "$BIN_DIR:"* ]; then
#   PATH="$BIN_DIR:${PATH//:$BIN_DIR/}"
# fi

check_nvim_version() {
  command -v nvim >/dev/null && [ "$(nvim --headless -u NONE "+echo has('nvim-0.8')" +qa 2>&1)" = 1 ]
}

{{ if .glibc231 -}}
export DEBIAN_FRONTEND=noninteractive
cmd sudo -E apt-get install --quiet --yes neovim >/dev/null
{{ else if eq .osIDLike "debian" -}}
# TODO: replace with .chezmoiexternal
if check_nvim_version; then
  echo >&2 "Already installed: {{ output .sh "-c" "command -v nvim || echo nvim" }}"
  nvim --version | head -n1
else
  echo >&2 "Installing neovim"
  # NOTE: Debian 12 has nvim 0.7.2
  VERSION="$(get_release neovim/neovim)" # v0.11.2
  NAME="nvim-linux-x86_64"
  URL="https://github.com/neovim/neovim/releases/download/$VERSION/$NAME.tar.gz"
  install_tar_gz "$URL" "$NAME/bin/nvim"
  NAME="nvim-linux-x86_64"
  sudo mv /tmp/$NAME/lib/* /usr/local/lib/
  sudo mv /tmp/$NAME/share/* /usr/local/share/
  echo >&2 "Installed neovim"
fi
{{ end -}}

check_nvim_version

cmd timeout 5m nvim --headless +LazyInstall! +qa >/dev/null

echo
