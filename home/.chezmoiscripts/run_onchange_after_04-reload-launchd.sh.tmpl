{{- if and (eq .os "darwin") .features.pc -}}
#!/bin/sh

# Reload process-compose launchd plist when config changes
# Hash: {{ includeTemplate "Library/private_LaunchAgents/com.process-compose.plist.tmpl" . | sha256sum }}

set -eu

label="com.process-compose"
plist="$HOME/Library/LaunchAgents/$label.plist"

if [ ! -f "$plist" ]; then
  echo >&2 "Plist not found: $plist"
  exit 0
fi

# Unload then reload (bootout/bootstrap is the modern API)
if launchctl print "gui/$(id -u)/$label" >/dev/null 2>&1; then
  launchctl bootout "gui/$(id -u)" "$plist" 2>/dev/null || true
fi
launchctl bootstrap "gui/$(id -u)" "$plist"
echo "Reloaded $label"
{{- end }}
