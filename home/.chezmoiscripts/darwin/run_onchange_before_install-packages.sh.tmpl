#!/bin/sh

set -eu

# https://docs.brew.sh/Installation#unattended-installation
export NONINTERACTIVE=1

set -x

brew update --quiet

{{- if .upgrade }}

brew upgrade --quiet
{{- end }}

{{- $brewPackages := includeTemplate "packages.tmpl" (mergeOverwrite . (dict "packageType" "brew")) | fromJson }}
{{- $caskPackages := includeTemplate "packages.tmpl" (mergeOverwrite . (dict "packageType" "cask")) | fromJson }}

brew bundle --file=/dev/stdin <<EOF
{{ range $brewPackages | sortAlpha -}}
brew {{ . | quote }}
{{ end -}}
{{ range $caskPackages | sortAlpha -}}
cask {{ . | quote }}
{{ end -}}
EOF
