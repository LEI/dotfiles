{
	default_bind 127.0.0.1
	# Use Caddy's internal CA for all sites; run `caddy trust` once to install it
	local_certs
	metrics
	admin localhost:2019
}

{{ range .caddySites -}}
{{- if and .feature (not (get $.features .feature)) }}{{ continue }}{{ end -}}
{{- $dt := get . "dialTimeout" -}}
{{- $rht := get . "responseHeaderTimeout" -}}
{{ .name }}.test {
	tracing {
		span {{ .name }}
	}
	reverse_proxy localhost:{{ .port }}{{ if or $dt $rht }} {
		transport http {
			{{- if $dt }}
			dial_timeout {{ $dt }}
			{{- end }}
			{{- if $rht }}
			response_header_timeout {{ $rht }}
			{{- end }}
		}
	}{{ end }}
}

{{ end -}}
# Machine-local site configs (not version-controlled)
# Example: ~/.config/caddy/sites/myproject.caddy
import {{ .chezmoi.homeDir }}/.config/caddy/sites/*.caddy
