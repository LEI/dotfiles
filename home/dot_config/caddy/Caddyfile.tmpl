{
	# debug
	default_bind 127.0.0.1
	{{- if eq .chezmoi.os "darwin" }}
	admin 127.0.0.1:2019
	{{- else }}
	admin localhost:2019
	{{- end }}
	metrics
	{{- if eq .chezmoi.os "darwin" }}
	http_port 18080
	https_port 18443
	{{- end }}
	{{- if and .features.tailscale .caddy.tailscale.oauthSecret }}
	tailscale {
		auth_key {env.TS_CADDY_AUTH_KEY}
		ephemeral false
		state_dir {{ .caddy.tailscale.stateDir | default (joinPath .chezmoi.homeDir ".local/share/caddy-tailscale") }}
	}
	{{- end }}
	# log default {
	# 	output stdout
	# 	format json
	# 	include http.log.access admin.api
	# }
	# run `caddy trust` once to install the CA
	# cert_lifetime global option does not apply to the internal issuer, so set it on the issuer directly
	# https://github.com/caddyserver/caddy/issues/6475#issuecomment-2268984122
	cert_issuer internal {
		lifetime 30d
	}
	pki {
		ca local {
			intermediate_lifetime 730d
		}
	}
}

# Metrics scraped by the prometheus container via host.docker.internal:2020.
# Plain HTTP on purpose: prometheus.yaml.tmpl uses the default http scheme; adding a
# hostname site address would force auto-HTTPS and break the scrape.
# bind 0.0.0.0 is needed because docker host-gateway can't reach the host's loopback;
# remote_ip restricts actual access to RFC1918 sources (docker bridge, lan).
# Port 9103 falls inside SELinux's default http_port_t if rebinding is ever needed.
http://:2020 {
	bind 0.0.0.0
	@prom {
		path /metrics
		remote_ip private_ranges
	}
	handle @prom {
		reverse_proxy localhost:2019 {
			header_up Host {upstream_hostport}
		}
	}
	handle {
		respond 404
	}
}

(common) {
	log {
		# output file /var/log/caddy.log
		# format json
		level info
	}
	tls {
		issuer internal {
			lifetime 365d
		}
	}
}

