{{- if and .features.tailscale .caddy.tailscale.oauthSecret -}}
{{- range $name, $s := .caddy.sites -}}
{{- if not (get $.features (get $s "feature")) }}{{ continue }}{{ end -}}
{{- if not (get $s "tailscale") }}{{ continue }}{{ end -}}

:443 {
	bind tailscale/{{ $name }}
	tls {
		get_certificate tailscale
	}
	tailscale_auth
	reverse_proxy localhost:{{ $s.port }}
}
{{ end -}}
{{- end -}}
