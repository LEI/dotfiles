{{- $file := joinPath .chezmoi.homeDir ".config/caddy/Caddyfile" -}}
{{- $liveness := dict "path" "/config/" "retries" 5 "delay" 2 -}}
{{- $testSite := "" -}}
{{- $testPath := "/" -}}
{{- range $name, $s := .caddy.sites -}}
{{-   if and (not $testSite) (get $.features (get $s "feature" | default "")) -}}
{{-     $testSite = $name -}}
{{-     $testPath = get $s "liveness" | default "/" -}}
{{-   end -}}
{{- end -}}
{{- if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}
#!/bin/sh
{{- if stat $file }}

# Caddyfile: {{ include $file | sha256sum }}
{{- end }}
{{- range glob (joinPath .chezmoi.homeDir ".config/caddy/sites/*.caddy") }}
# {{ base . }}: {{ include . | sha256sum }}
{{- end }}
# dnsmasq-test: {{ include "dot_config/caddy/.dnsmasq-test.conf" | sha256sum }}
{{- if eq .chezmoi.os "linux" }}
# dns-dnsmasq: {{ include "dot_config/caddy/.dnsmasq.conf" | sha256sum }}
# dns-resolved: {{ include "dot_config/caddy/.resolved.conf" | sha256sum }}
{{-   if .features.otel }}
# otel: {{ includeTemplate "otel.yaml.tmpl" . | sha256sum }}
{{-   end }}
{{- else if eq .chezmoi.os "darwin" }}
# pf-anchor: {{ include "dot_config/caddy/.pf.anchor" | sha256sum }}
{{- end }}

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

cert_fingerprint() {
  openssl x509 -in "$1" -noout -fingerprint -sha256 2>/dev/null
}

cert_expiry() {
  openssl x509 -in "$1" -noout -enddate 2>/dev/null | cut -d= -f2
}

cert_expiring() {
  ! openssl x509 -in "$1" -noout -checkend 2592000 >/dev/null 2>&1
}

caddyfile="${CHEZMOI_CADDY_CONFIG:-$HOME/.config/caddy/Caddyfile}"
{{- if eq .chezmoi.os "darwin" }}
caddy_data="$HOME/Library/Application Support/Caddy"
admin_addr="127.0.0.1:{{ .caddy.admin.port }}"
{{- else }}
caddy_data="$HOME/.local/share/caddy"
admin_addr="localhost:{{ .caddy.admin.port }}"
{{- end }}
pki="$caddy_data/pki/authorities/local"
root="$pki/root.crt"
intermediate="$pki/intermediate.crt"

{{- if eq .chezmoi.os "darwin" }}

# Valet sometimes coexists; if its nginx is up, sync proxies via valet and bail
valet_dir="$HOME/.config/valet"
if pgrep -q nginx && [ -f "$valet_dir/config.json" ]; then
  msg "Valet detected; configuring .test proxies via nginx instead of caddy"
  {{- range $name, $site := .caddy.sites }}
  {{- if not (get $.features (get $site "feature")) }}{{ continue }}{{ end }}
  if ! grep -q 'proxy_pass http://localhost:{{ $site.port }}' "$valet_dir/Nginx/{{ $name }}.test" 2>/dev/null; then
    run valet proxy {{ $name }} http://localhost:{{ $site.port }} --secure
  fi
  {{- end }}
  {{- range $name, $provider := .ai.providers }}
  {{- if not (hasKey $provider "domain") }}{{ continue }}{{ end }}
  if ! grep -q 'proxy_pass http://localhost:{{ $provider.port }}' "$valet_dir/Nginx/{{ $name }}.test" 2>/dev/null; then
    run valet proxy {{ $name }} http://localhost:{{ $provider.port }} --secure
  fi
  {{- end }}
  exit 0
fi
{{- end }}

if ! has caddy; then
{{- if eq .chezmoi.os "darwin" }}
  die "caddy not found; run xcaddy build first (~/.local/bin/caddy)"
{{- else }}
  msg "caddy not found; skipping setup"
  exit 0
{{- end }}
fi

if ! has openssl; then
  die "openssl not found; required for CA fingerprinting"
fi

if ! caddy fmt --config "$caddyfile" --diff >/dev/null; then
  run caddy fmt --config "$caddyfile" --diff
fi

if ! caddy validate --config "$caddyfile" >/dev/null 2>&1; then
  run caddy validate --config "$caddyfile"
fi

{{- if eq .chezmoi.os "linux" }}

# One-time: allow binding ports 80+ without root
sysctl_conf=/etc/sysctl.d/99-caddy-unprivileged-port.conf
sysctl_val='net.ipv4.ip_unprivileged_port_start=80'
if [ ! -f "$sysctl_conf" ] || ! grep -qF "$sysctl_val" "$sysctl_conf"; then
  # shellcheck disable=SC2016
  run pkexec \
    env sysctl_conf="$sysctl_conf" sysctl_val="$sysctl_val" \
    sh -euc 'printf "%s\n" "$sysctl_val" | tee "$sysctl_conf" >/dev/null && sysctl -p "$sysctl_conf"'
fi

# Route .test queries to 127.0.0.1 via NetworkManager's built-in dnsmasq
dns_src="$CHEZMOI_SOURCE_DIR/dot_config/caddy"
nm_dnsmasq_src="$dns_src/.dnsmasq.conf"
nm_test_src="$dns_src/.dnsmasq-test.conf"
resolved_src="$dns_src/.resolved.conf"
nm_dnsmasq_dest=/etc/NetworkManager/conf.d/dnsmasq.conf
nm_test_dest=/etc/NetworkManager/dnsmasq.d/test.conf
resolved_dest=/etc/systemd/resolved.conf.d/resolved.conf

nm_changed=false
resolved_changed=false

nm_diff=$(diff -u "$nm_dnsmasq_dest" "$nm_dnsmasq_src" 2>&1)
if [ -n "$nm_diff" ]; then
  nm_changed=true
fi

resolved_diff=$(diff -u "$resolved_dest" "$resolved_src" 2>&1)
if [ -n "$resolved_diff" ]; then
  resolved_changed=true
fi

if [ "$nm_changed" = true ] || [ "$resolved_changed" = true ]; then
  msg "Updating /etc/ DNS config"
  [ -n "$nm_diff" ] && printf '%s\n' "$nm_diff"
  [ -n "$resolved_diff" ] && printf '%s\n' "$resolved_diff"
  # shellcheck disable=SC2016
  run pkexec \
    env nm_changed="$nm_changed" resolved_changed="$resolved_changed" \
    nm_dnsmasq_src="$nm_dnsmasq_src" nm_dnsmasq_dest="$nm_dnsmasq_dest" \
    nm_test_src="$nm_test_src" nm_test_dest="$nm_test_dest" \
    resolved_src="$resolved_src" resolved_dest="$resolved_dest" \
    sh -euc '
      mkdir -p /etc/NetworkManager/dnsmasq.d /etc/systemd/resolved.conf.d
      if [ "$nm_changed" = true ]; then
        cp "$nm_dnsmasq_src" "$nm_dnsmasq_dest"
        cp "$nm_test_src" "$nm_test_dest"
      fi
      if [ "$resolved_changed" = true ]; then
        cp "$resolved_src" "$resolved_dest"
      fi
    '
  if [ "$nm_changed" = true ]; then
    run systemctl restart NetworkManager
  fi
  if [ "$resolved_changed" = true ]; then
    run systemctl restart systemd-resolved
  fi
fi

{{ includeTemplate "systemd-apply.sh.tmpl" (dict
  "chezmoi" .chezmoi
  "active" true
  "system" false
  "unit" "caddy"
  "liveness" $liveness
  "port" .caddy.admin.port
) -}}

{{- else if eq .chezmoi.os "darwin" }}

# launchd silently fails to open log file if directory is missing
if [ ! -d "$HOME/Library/Logs" ]; then
  run mkdir -p "$HOME/Library/Logs"
fi

# Stop brew-managed caddy so the user LaunchAgent owns 18080/18443
if [ -f /Library/LaunchDaemons/homebrew.mxcl.caddy.plist ]; then
  msg "Stopping system-level brew caddy (may prompt for sudo)"
  run sudo launchctl bootout system/homebrew.mxcl.caddy 2>/dev/null || true
fi
if [ -f "$HOME/Library/LaunchAgents/homebrew.mxcl.caddy.plist" ]; then
  msg "Stopping user-level brew caddy"
  run launchctl bootout "gui/$(id -u)/homebrew.mxcl.caddy" 2>/dev/null || true
fi

# Reclaim caddy data dir from root if previously created by sudo brew caddy
if [ -d "$caddy_data" ] && [ "$(stat -f '%Su' "$caddy_data")" != "$(id -un)" ]; then
  msg "Reclaiming ownership of $caddy_data"
  run sudo chown -R "$(id -un):$(id -gn)" "$caddy_data"
fi

# pf rdr anchor: 80 -> 18080, 443 -> 18443 on lo0
pf_src="$CHEZMOI_SOURCE_DIR/dot_config/caddy/.pf.anchor"
pf_dest=/etc/pf.anchors/caddy
pf_conf=/etc/pf.conf
pf_changed=false

if ! diff -q "$pf_dest" "$pf_src" >/dev/null 2>&1; then
  msg "Updating $pf_dest"
  run sudo cp "$pf_src" "$pf_dest"
  pf_changed=true
fi

# /etc/pf.conf: insert caddy anchor declarations in proper position
# (rdr-anchor must precede anchor/filter rules per pf grammar).
# Restore: sudo sed -i '' -e '/^rdr-anchor "caddy"$/d' -e '/^anchor "caddy"$/d' -e '/^load anchor "caddy" from /d' /etc/pf.conf
pf_clean=$(sed -e '/^rdr-anchor "caddy"$/d' \
  -e '/^anchor "caddy"$/d' \
  -e '/^load anchor "caddy" from /d' "$pf_conf")
if printf '%s' "$pf_clean" | grep -q '^rdr-anchor "com\.apple' &&
  printf '%s' "$pf_clean" | grep -q '^load anchor "com\.apple"'; then
  pf_desired=$(printf '%s\n' "$pf_clean" | awk '
{ print }
!rdr_added && /^rdr-anchor "com\.apple/ { print "rdr-anchor \"caddy\""; rdr_added=1 }
!anchor_added && /^load anchor "com\.apple"/ {
  print "anchor \"caddy\""
  print "load anchor \"caddy\" from \"/etc/pf.anchors/caddy\""
  anchor_added=1
}
')
else
  pf_desired=$(printf '%s\nrdr-anchor "caddy"\nanchor "caddy"\nload anchor "caddy" from "/etc/pf.anchors/caddy"\n' "$pf_clean")
fi

if ! printf '%s' "$pf_desired" | grep -q '^load anchor "caddy"'; then
  die "pf.conf rewrite produced incomplete output; aborting before bricking pf"
fi

if ! printf '%s\n' "$pf_desired" | diff -q - "$pf_conf" >/dev/null 2>&1; then
  msg "Updating $pf_conf with caddy anchor entries"
  run sudo sh -c 'cat >"$1"' _ "$pf_conf" <<HERE
$pf_desired
HERE
  pf_changed=true
fi

# Reload if the 443 redirect isn't active, even when config files are unchanged
if ! nc -z -w 1 127.0.0.1 443 >/dev/null 2>&1; then
  pf_changed=true
fi

if [ "$pf_changed" = true ]; then
  run sudo pfctl -e -f "$pf_conf"
fi

# Route .test queries to 127.0.0.1 via standalone dnsmasq
dns_src="$CHEZMOI_SOURCE_DIR/dot_config/caddy"
dnsmasq_conf="${HOMEBREW_PREFIX:?}/etc/dnsmasq.d/test.conf"
resolver_conf=/etc/resolver/test
if ! diff -u "$dnsmasq_conf" "$dns_src/.dnsmasq-test.conf" 2>/dev/null; then
  msg "Updating dnsmasq .test config"
  run mkdir -p "$(dirname "$dnsmasq_conf")"
  run cp "$dns_src/.dnsmasq-test.conf" "$dnsmasq_conf"
  run sudo brew services restart dnsmasq
fi
if [ ! -f "$resolver_conf" ] || ! grep -q "nameserver 127.0.0.1" "$resolver_conf"; then
  msg "Creating $resolver_conf"
  run sudo sh -c "mkdir -p $(dirname "$resolver_conf") && printf 'nameserver 127.0.0.1\n' >$resolver_conf"
fi

{{ includeTemplate "launchd-apply.sh.tmpl" (dict
  "chezmoi" .chezmoi
  "active" true
  "bootstrap" true
  "label" "com.caddy"
  "liveness" (merge $liveness (dict "host" "127.0.0.1"))
  "port" .caddy.admin.port
  "reload" `caddy reload --config "$caddyfile" --address "$admin_addr"`
) -}}
{{- end }}
# Trust CA system-wide (caddy trust handles platform-native trust store)
if ! curl --silent --fail "http://$admin_addr/pki/ca/local/trusted" | jq --exit-status '.trusted == true' >/dev/null; then
  run caddy trust --ca local
fi

{{- if eq .chezmoi.os "linux" }}

# Install CA into Firefox NSS profiles via nss-tools certutil;
# handles profiles caddy trust misses and cert rotation
if [ -d "$HOME/.mozilla/firefox" ] && has certutil; then
  current_fingerprint=$(cert_fingerprint "$root")
  for profile_dir in "$HOME/.mozilla/firefox"/*/; do
    [ -f "${profile_dir}cert9.db" ] || continue
    installed_fingerprint=$(certutil -L -d "$profile_dir" -n "Caddy Local Authority" -a 2>/dev/null | openssl x509 -noout -fingerprint -sha256 2>/dev/null)
    if [ "$current_fingerprint" != "$installed_fingerprint" ]; then
      run certutil -A -d "$profile_dir" -n "Caddy Local Authority" -t "CT,," -i "$root"
    fi
  done
fi

# caddy trust installs the root CA but not the intermediate; curl needs both to
# build the chain. Install root + intermediate into the system trust store.
ca_anchor_dir=""
ca_update_cmd=""
if has update-ca-trust; then
  ca_anchor_dir=/etc/pki/ca-trust/source/anchors
  ca_update_cmd=update-ca-trust
elif has update-ca-certificates; then
  ca_anchor_dir=/usr/local/share/ca-certificates
  ca_update_cmd=update-ca-certificates
fi

if [ -n "$ca_update_cmd" ]; then
  root_dest="$ca_anchor_dir/caddy-local-root.crt"
  intermediate_dest="$ca_anchor_dir/caddy-local-intermediate.crt"
  fingerprint_dir="$pki/installed-fps"
  root_fp_file="$fingerprint_dir/root.sha256"
  intermediate_fp_file="$fingerprint_dir/intermediate.sha256"
  if [ ! -d "$fingerprint_dir" ]; then
    run mkdir -p "$fingerprint_dir"
  fi

  current_root_fingerprint=$(cert_fingerprint "$root")
  current_intermediate_fingerprint=$(cert_fingerprint "$intermediate")
  installed_root_fingerprint=$(cat "$root_fp_file" 2>/dev/null || true)
  installed_intermediate_fingerprint=$(cat "$intermediate_fp_file" 2>/dev/null || true)

  if [ "$current_root_fingerprint" != "$installed_root_fingerprint" ] || [ "$current_intermediate_fingerprint" != "$installed_intermediate_fingerprint" ]; then
    # shellcheck disable=SC2016
    run pkexec \
      env root="$root" intermediate="$intermediate" \
      root_dest="$root_dest" intermediate_dest="$intermediate_dest" \
      ca_update_cmd="$ca_update_cmd" \
      sh -euc '
        cp "$root" "$root_dest"
        cp "$intermediate" "$intermediate_dest"
        "$ca_update_cmd"
      '
    printf '%s' "$current_root_fingerprint" >"$root_fp_file"
    printf '%s' "$current_intermediate_fingerprint" >"$intermediate_fp_file"
  fi
fi

{{- else if eq .chezmoi.os "darwin" }}

# Append caddy root CA to brew openssl bundle so brew-curl trusts .test sites
brew_openssl_dir="${HOMEBREW_PREFIX:?}/etc/openssl@3"
sed="$(which gsed 2>/dev/null || which sed)"
if [ -d "$brew_openssl_dir" ]; then
  brew_bundle="$brew_openssl_dir/cert.pem"
  caddy_marker="# Caddy Local Authority"
  if ! grep -qF "$caddy_marker" "$brew_bundle" 2>/dev/null; then
    if grep -q "$caddy_marker" "$brew_bundle" 2>/dev/null; then
      marker_line=$(grep -n "$caddy_marker" "$brew_bundle" | head -1 | cut -d: -f1)
      end_line=$(awk "NR>=$marker_line && /-----END CERTIFICATE-----/{print NR; exit}" "$brew_bundle")
      run "$sed" -i "${marker_line},${end_line}d" "$brew_bundle"
    fi
    msg "Appending caddy root CA to brew openssl bundle"
    run sh -c "{ echo '$caddy_marker'; cat '$root'; } >>'$brew_bundle'"
  fi
fi
{{- end }}

root_expiry=$(cert_expiry "$root")
if cert_expiring "$root"; then
  die "root CA expires soon: $root_expiry"
fi
intermediate_expiry=$(cert_expiry "$intermediate")
if cert_expiring "$intermediate"; then
  die "intermediate CA expires soon: $intermediate_expiry"
fi
{{- if $testSite }}
ssl_verify_result=$(
  curl --silent --max-time 5 --write-out '%{ssl_verify_result}' --output /dev/null "https://{{ $testSite }}.test{{ $testPath }}" 2>/dev/null
  :
)
if [ "${ssl_verify_result:-0}" != "0" ]; then
  die "CA not trusted: https://{{ $testSite }}.test (ssl_verify_result=${ssl_verify_result})"
fi
msg "CA trusted: https://{{ $testSite }}.test"
{{- end }}
{{ end -}}
