{{- if and (or .features.bash .features.zsh) (lookPath "usage" | isExecutable) -}}
{{- $dict := dict -}}
{{- $bins := glob (joinPath .chezmoi.sourceDir "dot_local" "bin" "executable_*") -}}
{{- $scripts := glob (joinPath .chezmoi.workingTree "script" "*") -}}
{{- range concat $bins $scripts -}}
{{-   $content := include . -}}
{{-   if not (contains "#USAGE " $content) -}}{{ continue }}{{ end -}}
{{-   $name := . | base | trimPrefix "executable_" | trimSuffix ".tmpl" -}}
{{-   if get $dict $name -}}
{{-     warnf "usage-completions: duplicate #USAGE for %s, skipping" $name -}}
{{-     continue -}}
{{-   end -}}
{{-   $dict = merge $dict (dict $name (dict
  "hash" ($content | sha256sum)
  "source" .
)) -}}
{{- end -}}
#!{{ .prefix }}/usr/bin/env bash

# Generate shell completions for scripts with #USAGE directives
# patch_bash_mapfile fixes compgen -W word-splitting on paths with spaces
{{- range $dict | keys | sortAlpha }}
# {{ . }}: {{ (get (get $dict .) "hash") }}
{{- end }}

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo >&2 "${0##*/}: bash 4+ required, found $BASH_VERSION"
  exit 1
fi

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

{{ includeTemplate "dot_config/environment.d/00-xdg.conf.tmpl" . | trim }}
{{- if .features.bash }}

bash_dir="$XDG_DATA_HOME/bash-completion/completions"
mkdir -p "$bash_dir"
{{- end }}
{{- if .features.zsh }}

zsh_dir="$XDG_DATA_HOME/zsh/completions"
mkdir -p "$zsh_dir"
{{- end }}

rc=0
names=(
  {{- range $dict | keys | sortAlpha }}
  {{ . | quote }}
  {{- end }}
)

# Remove stale completions generated by this script
remove_stale() {
  local dir="$1" prefix="$2"
  for file in "$dir/$prefix"*; do
    [ -f "$file" ] || continue
    local name="${file##*/}"
    name="${name#"$prefix"}"
    local found=0
    for m in "${names[@]}"; do
      if [ "$name" = "$m" ]; then
        found=1
        break
      fi
    done
    if [ "$found" -eq 0 ] && head -2 "$file" | grep -q '@generated by usage-cli'; then
      msg "${0##*/}: removing stale completion: $name"
      if command -v trash >/dev/null; then
        trash "$file"
      else
        rm -f "$file"
      fi
    fi
  done
}
{{- if .features.bash }}
remove_stale "$bash_dir" ""
{{- end }}
{{- if .features.zsh }}
remove_stale "$zsh_dir" "_"
{{- end }}
{{- if not (empty $dict) }}
{{- if .features.bash }}

patch_bash_mapfile() {
  local file="$1" tmp="$1.tmp" line inner
  while IFS= read -r line; do
    # shellcheck disable=SC2016
    if [[ "$line" == *'_comp_compgen -- -W "$(command '* ]]; then
      inner="${line#*\"\$(}"
      inner="${inner%)\"}"
      cat <<EOF
	if (( BASH_VERSINFO[0] >= 4 )); then
		mapfile -t COMPREPLY < <($inner)
	else
		echo "${0##*/}: bash 4+ required for path completions in $file" >&2
	fi
EOF
    else
      printf '%s\n' "$line"
    fi
  done <"$file" >"$tmp" && mv "$tmp" "$file"
}
{{- end }}

usage_generate_completion() {
  local name="$1" file="$2"
  local spec
  spec=$(grep '^#USAGE ' "$file" | sed 's/^#USAGE //')
  if [ -z "$spec" ]; then
    echo >&2 "${0##*/}: no #USAGE directives in $file"
    return 1
  fi
  msg "${0##*/}: $name"
{{- if .features.bash }}
  usage generate completion bash "$name" --file - <<<"$spec" >|"$bash_dir/$name" || rc=1
  if grep -q 'run=' <<<"$spec"; then
    if ! patch_bash_mapfile "$bash_dir/$name"; then
      echo >&2 "${0##*/}: patch failed for $name"
      rc=1
    fi
    if grep -q '_comp_compgen -- -W' "$bash_dir/$name"; then
      echo >&2 "${0##*/}: unpatched compgen -W in $name"
      rc=1
    fi
  fi
{{- end }}
{{- if .features.zsh }}
  usage generate completion zsh "$name" --file - <<<"$spec" >|"$zsh_dir/_$name" || rc=1
{{- end }}
}

# Generate completions
{{- range $dict | keys | sortAlpha }}
usage_generate_completion {{ . | quote }} {{ (get (get $dict .) "source") | quote }}
{{- end }}
{{- end }}

exit $rc
{{ end -}}
