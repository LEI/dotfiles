{{- if and (or .features.bash .features.zsh) (lookPath "usage" | isExecutable) -}}
{{- $dict := dict -}}
{{- $bins := glob (joinPath .chezmoi.homeDir ".local" "bin" "*") -}}
{{- $scripts := glob (joinPath .chezmoi.workingTree "script" "*") -}}
{{- range $bins -}}
{{-   if not (stat .) -}}
{{-     warnf "usage-completions: broken link %s" (. | base) -}}
{{-     continue -}}
{{-   end -}}
{{-   $content := include . -}}
{{-   if not (hasPrefix "#!" $content) -}}{{ continue }}{{ end -}}
{{-   if not (contains "#USAGE " $content) -}}{{ continue }}{{ end -}}
{{-   $name := . | base -}}
{{-   if get $dict $name -}}
{{-     warnf "usage-completions: duplicate #USAGE for %s, skipping" $name -}}
{{-     continue -}}
{{-   end -}}
{{-   $path := printf "$HOME/.local/bin/%s" $name -}}
{{-   $dict = merge $dict (dict $name (dict "hash" ($content | sha256sum) "path" $path)) -}}
{{- end -}}
{{- range $scripts -}}
{{-   $content := include . -}}
{{-   if not (contains "#USAGE " $content) -}}{{ continue }}{{ end -}}
{{-   $name := . | base -}}
{{-   if get $dict $name -}}
{{-     warnf "usage-completions: duplicate #USAGE for %s, skipping" $name -}}
{{-     continue -}}
{{-   end -}}
{{-   $path := printf "$CHEZMOI_WORKING_TREE/script/%s" $name -}}
{{-   $dict = merge $dict (dict $name (dict "hash" ($content | sha256sum) "path" $path)) -}}
{{- end -}}
#!{{ .prefix }}/usr/bin/env bash

# Generate shell completions for scripts with #USAGE directives
# hash: {{ $dict | toJson | sha256sum }} usage={{ output "usage" "--version" | trim }} mise={{ output "mise" "version" | trim | splitList " " | first }}

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo "${0##*/}: bash 4+ required, found $BASH_VERSION" >&2
  exit 1
fi

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

{{ includeTemplate "dot_config/environment.d/00-xdg.conf.tmpl" . | trim }}

rc=0
{{- if .features.bash }}

bash_dir="$XDG_DATA_HOME/bash-completion/completions"
mkdir -p "$bash_dir"
{{- end }}
{{- if .features.zsh }}

zsh_dir="$XDG_DATA_HOME/zsh/completions"
mkdir -p "$zsh_dir"
{{- end }}
{{- if not (empty $dict) }}
{{- if .features.bash }}

# Replace compgen -W with mapfile to handle paths with spaces
patch_bash_mapfile() {
  local file="$1" tmp="$1.tmp" line inner
  while IFS= read -r line; do
    # shellcheck disable=SC2016
    if [[ "$line" == *'_comp_compgen -- -W "$(command '* ]]; then
      inner="${line#*\"\$(}"
      inner="${inner%)\"}"
      cat <<EOF
	if (( BASH_VERSINFO[0] >= 4 )); then
		mapfile -t COMPREPLY < <($inner)
	else
		echo "\${0##*/}: bash 4+ required for path completions in \$file" >&2
	fi
EOF
    else
      printf '%s\n' "$line"
    fi
  done <"$file" >"$tmp" && mv "$tmp" "$file"
}
{{- end }}

usage_generate_completion() {
  local name="$1" file="$2"
  local spec
  spec=$(grep '^#USAGE ' "$file" | sed 's/^#USAGE //')
  if [ -z "$spec" ]; then
    echo "${0##*/}: no #USAGE directive in $file" >&2
    return 1
  fi
  msg "${0##*/}: $name"
  generated+=("$name")
{{- if .features.bash }}
  usage generate completion bash "$name" --file - <<<"$spec" >|"$bash_dir/$name" || rc=1
  if grep -q 'run=' <<<"$spec"; then
    if ! patch_bash_mapfile "$bash_dir/$name"; then
      echo "${0##*/}: patch failed for $name" >&2
      rc=1
    fi
    if grep -q '_comp_compgen -- -W' "$bash_dir/$name"; then
      echo "${0##*/}: unpatched compgen -W in $name" >&2
      rc=1
    fi
  fi
{{- end }}
{{- if .features.zsh }}
  usage generate completion zsh "$name" --file - <<<"$spec" >|"$zsh_dir/_$name" || rc=1
{{- end }}
}

generated=()

# Generate completions
{{- range $dict | keys | sortAlpha }}
usage_generate_completion {{ . | quote }} {{ (get (get $dict .) "path") | quote }}
{{- end }}

# Warn about stale completions
warn_stale() {
  local dir="$1" prefix="$2"
  for file in "$dir/$prefix"*; do
    [ -f "$file" ] || continue
    head -2 "$file" | grep -q '@generated by usage-cli' || continue
    local name="${file##*/}"
    name="${name#"$prefix"}"
    local found=false
    for m in "${generated[@]}"; do
      if [ "$name" = "$m" ]; then
        found=true
        break
      fi
    done
    if [ "$found" = false ]; then
      rel="${file#"$HOME/"}"
      echo "${0##*/}: stale completion: $name ($rel)" >&2
      # rc=1
      run rm -f "$file"
    fi
  done
}
{{- if .features.bash }}
warn_stale "$bash_dir" ""
{{- end }}
{{- if .features.zsh }}
warn_stale "$zsh_dir" "_"
{{- end }}
{{- end }}

{{- if not .features.brew }}
{{- $miseShells := list }}
{{- if .features.bash }}{{ $miseShells = append $miseShells "bash" }}{{ end }}
{{- if .features.zsh }}{{ $miseShells = append $miseShells "zsh" }}{{ end }}

# Generate mise completions (brew handles this on brew-managed systems)
# TODO: ensure this brew the only case where "mise completion" is needed,
# if it even is required for brew? (didnt look like so on macos)
if command -v mise >/dev/null; then
{{- range $miseShells }}
{{-   $prefix := "" }}{{ if eq . "zsh" }}{{ $prefix = "_" }}{{ end }}
{{-   $dir := printf "$%s_dir" . }}
  if ! run mise completion {{ . }} >|"{{ $dir }}/{{ $prefix }}mise"; then
    echo "${0##*/}: mise completion {{ . }} failed" >&2
    rc=1
  fi
{{- end }}
{{- if .features.zsh }}
  # TODO: only brew or not?
  run rm -f "${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump"
{{- end }}
fi
{{- end }}

exit $rc
{{ end -}}
