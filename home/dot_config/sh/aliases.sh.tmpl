# Deprecated: prefer init.sh functions

{{- if lookPath "eza" | isExecutable }}

# Hyperlink OSC 8 escapes leak through pipes in iTerm2
# https://github.com/eza-community/eza/issues/1156
eza() {
  if [ "$LC_TERMINAL" = "iTerm2" ] && [ ! -t 1 ]; then
    command eza "$@"
  else
    command eza --hyperlink "$@"
  fi
}
alias ls=eza

{{- else if lookPath "gls" | isExecutable }}

# export LS_COLORS="$(vivid generate tokyonight-storm)"
alias ls="gls --color"
{{- end }}

# Confirm before overwriting
alias cp="cp -i" # --interactive

# Print sizes in powers of 1024
alias df="df -h" # --human-readable

{{- if lookPath "free" | isExecutable }}

# Show with human-readable units
alias free="free --human"
{{- end }}

# Color matches
alias grep="grep --color=auto"

# List all files with colors, human-readable sizes and long format
alias la="ls -ahl"
{{- if lookPath "eza" | isExecutable }}
alias lA="la --total-size"
{{- end }}

# Print each PATH entry on a separate line
alias path='echo "$PATH" | tr ":" "\n"'

{{- if lookPath "bat" | isExecutable }}
alias cat=bat
{{- else if lookPath "batcat" | isExecutable }}
alias cat=batcat
{{- end }}

{{- if eq .os "darwin" }}

alias beep="afplay --rate 3 --time 0.3 --volume 3 /System/Library/Sounds/Glass.aiff"

# Reload the shell (i.e. invoke as a login shell)
alias reload='exec ${SHELL} -l'
{{- else }}

alias reload='exec ${SHELL} -i'

{{- if .wsl }}
# [ -f /proc/version ] && grep -iq microsoft /proc/version
if command -v wslview >/dev/null; then
  alias open=wslview
elif [ -f /mnt/c/Windows/explorer.exe ]; then
  # TODO: add /mnt/c/Windows to PATH
  alias open=/mnt/c/Windows/explorer.exe
else
  alias open=explorer.exe
fi
{{- else if lookPath "xdg-open" | isExecutable }}
alias open=xdg-open
{{- else if and (eq .os "android") (lookPath "termux-open" | isExecutable) }}
alias open=termux-open
{{- else if lookPath "code" | isExecutable }}
alias open=code
{{- end }}

{{- if lookPath "xclip" | isExecutable }}
alias pbcopy="xclip -selection clipboard"
alias pbpaste="xclip -selection clipboard -o"
{{- else if lookPath "xsel" | isExecutable }}
alias pbcopy='xsel --clipboard --input'
alias pbpaste='xsel --clipboard --output'
{{- else if and (lookPath "wl-copy" | isExecutable) (lookPath "wl-paste" | isExecutable) }}
alias pbcopy=wl-copy
alias pbpaste=wl-paste
{{- else if and (lookPath "termux-clipboard-set" | isExecutable) (lookPath "termux-clipboard-get" | isExecutable) }}
alias pbcopy=termux-clipboard-set
alias pbpaste=termux-clipboard-get
{{- end }}

{{- end }}

if ! command -v clip >/dev/null && command -v pbcopy >/dev/null; then
  clip() {
    [ -t 0 ] && pbpaste || pbcopy
  }
fi

{{- if lookPath "lazyjournal" | isExecutable }}
alias J=lazyjournal
{{- end }}

{{- if .features.ai }}

if command -v codex >/dev/null; then
  codex() {
    if [ "$#" -eq 0 ]; then
      set -- resume --last
    fi
    env codex "$@"
  }
fi
if command -v crush >/dev/null; then
  crush() {
    if [ "$#" -eq 0 ]; then
      set -- --continue
    fi
    env crush "$@"
  }
fi
if command -v gemini >/dev/null; then
  gemini() {
    if [ "$#" -eq 0 ]; then
      set -- --resume=latest
    fi
    env gemini "$@"
  }
fi
{{- end }}

{{- if eq .profile "work" }}

m365() (
  if [ ! -f "$XDG_CONFIG_HOME/secrets.d/app/m365.conf" ]; then
    echo "m365: missing $XDG_CONFIG_HOME/secrets.d/app/m365.conf" >&2
    return 1
  fi
  export_env "$XDG_CONFIG_HOME/secrets.d/app/m365.conf"
  bunx --silent @pnp/cli-microsoft365@latest "$@"
)
{{- end }}

{{- if .features.python }}

if ! command -v recover >/dev/null; then
  {{- if lookPath "recoverpy" | isExecutable }}
  alias recover="sudo recoverpy"
  {{- else if lookPath "uvx" | isExecutable }}
  alias recover="sudo uvx recoverpy"
  {{- else if lookPath "pipx" | isExecutable }}
  alias recover="sudo pipx run recoverpy"
  {{- else }}
  alias recover="sudo recoverpy"
  {{- end }}
fi
{{- end }}
