# https://github.com/b3nj5m1n/xdg-ninja/tree/main/programs
# https://github.com/twpayne/dotfiles/blob/master/home/dot_zshrc.tmpl

export XDG_DATA_HOME=$HOME/.local/share
export XDG_CONFIG_HOME=$HOME/.config
export XDG_STATE_HOME=$HOME/.local/state
export XDG_CACHE_HOME=$HOME/.cache

# export LANG=en_US.UTF-8
# export LC_ALL=en_US.UTF-8

if [ -z "${MANPAGER:-}" ]; then
  export MANPAGER="less -X"
fi

{{- if .features.docker }}
# export DOCKER_CONFIG=$XDG_CONFIG_HOME/docker
{{- end }}

editor=editor
if command -v hx >/dev/null; then
  editor=hx
elif command -v nvim >/dev/null; then
  editor=nvim
elif command -v vim >/dev/null; then
  editor=vim
elif command -v code >/dev/null; then
  editor=code
else
  editor="${VISUAL:-${EDITOR:-vi}}"
fi
export EDITOR="${EDITOR:-$editor}"
export VISUAL

export EZA_CONFIG_DIR="$XDG_CONFIG_HOME/eza"

{{- if .features.git }}
export LG_CONFIG_FILE="$XDG_CONFIG_HOME/lazygit/theme.yml,$XDG_CONFIG_HOME/lazygit/config.yml"
{{- end }}

export INPUTRC="$XDG_CONFIG_HOME/readline/inputrc"

{{- if .features.node }}
export NPM_CONFIG_USERCONFIG="$XDG_CONFIG_HOME/npm/npmrc"
{{- end }}

{{- if and .features.sql (lookPath "psql") }}
export PSQLRC=$XDG_CONFIG_HOME/psql/psqlrc
{{- end }}

export RIPGREP_CONFIG_PATH=$XDG_CONFIG_HOME/ripgrep/config

export WGETRC=$XDG_CONFIG_HOME/wget/wgetrc

# export ZDOTDIR="$XDG_CONFIG_HOME/zsh"
