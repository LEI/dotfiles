# shellcheck shell=sh

# https://github.com/grawity/dotfiles/blob/main/.environ.notes
# Static vars moved to environment.d/*.conf (identity, editor, pager)

# export LANG=en_US.UTF-8
# export LC_ALL=en_US.UTF-8

# File type colors for completions, fd, tree, etc.
if command -v dircolors >/dev/null; then
  eval "$(dircolors -b)"
elif command -v gdircolors >/dev/null; then
  eval "$(gdircolors -b)"
fi
