---
version: "0.5"

log_level: info

processes:
  {{- if .features.claude }}

  claude-task-viewer:
    namespace: apps
    description: Claude task viewer UI
    command: npx claude-task-viewer
    environment:
      - PORT=3456
    availability:
      restart: on_failure
      backoff_seconds: 10
      max_restarts: 5
      exponential_backoff: true
    readiness_probe:
      http_get:
        host: localhost
        port: 3456
        scheme: http
      initial_delay_seconds: 5
      period_seconds: 10
      timeout_seconds: 3
      failure_threshold: 3
  {{- end }}

  {{- $opencodeConf := joinPath .chezmoi.homeDir ".config" "secrets.d" "opencode.conf" }}
  {{- $opencodeSettings := joinPath .chezmoi.homeDir ".config" "opencode" "opencode.jsonc" }}
  {{- if and .features.opencode (stat $opencodeConf) }}

  {{- $server := .opencode.server }}
  {{- if and .features.tailscale .tailscale.tailnet }}
  {{-   $cors := append $server.cors (printf "https://%s" .tailscale.tailnet) }}
  {{-   $server = mergeOverwrite $server (dict "cors" $cors) }}
  {{- end }}

  # opencode attach http://127.0.0.1:4096
  opencode-server:
    namespace: apps
    description: OpenCode server
    # https://github.com/anomalyco/opencode/issues/19078
    command: >-
      test -n OPENCODE_SERVER_PASSWORD &&
      opencode serve
      {{- range $key, $value := $server }}
      {{-   if kindIs "slice" $value }}
      {{-   range $value }}
      --{{ $key }}={{ . | quote }}
      {{-   end }}
      {{-   else }}
      {{-   $isInt := or (kindIs "int64" $value) (kindIs "uint64" $value) }}
      --{{ $key }}={{ $isInt | ternary $value ($value | quote) }}
      {{-   end }}
      {{- end }}
      --print-logs
    environment:
      {{- range include $opencodeConf | trim | splitList "\n" }}
      - {{ . }}
      {{- end }}
    availability:
      restart: on_failure
      backoff_seconds: 10
      max_restarts: 5
      exponential_backoff: true
    # readiness_probe:
    #   http_get:
    #     host: {{ $server.hostname }}
    #     port: {{ $server.port }}
    #     scheme: http
    #     # headers: {}
    #     # FIXME: Error: readiness check fail - Received status code '401' does not match expected status code '200'   ║│
    #     status_code: 401
    #   initial_delay_seconds: 5
    #   period_seconds: 10
    #   timeout_seconds: 3
    #   failure_threshold: 3
  {{- end }}

{{- /* tool map: basename → tool. Default is tspin */ -}}
{{- $toolFor := dict
  "caddy.log" "hl"
  "mailpit.log" "hl"
-}}

# TODO: journalctl --unit=caddy --follow
{{- /* desc map: basename → short description */ -}}
{{- $descFor := dict
  "caddy.log" "Caddy reverse proxy"
  "mailpit.log" "Mailpit SMTP catcher"
  "supervisord.log" "Supervisor daemon"
  "php-fpm.log" "PHP-FPM"
  "mlx-lm.log" "MLX LM inference server"
  "access.log" "Nginx access"
  "error.log" "Nginx error"
-}}

{{- range glob (printf "%s/var/log/**/*.log" .brewPrefix) }}
{{- $base := base . }}
{{- $tool := default "tspin" (get $toolFor $base) }}
{{- $name := trimSuffix ".log" $base | replace "_" "-" }}
{{- $dir := dir . | base }}
{{- if ne $dir "log" }}{{- $name = printf "%s-%s" $dir $name }}{{- end }}
{{- $desc := default (printf "%s log" $name) (get $descFor $base) }}

  {{ $name }}-logs:
    namespace: logs
    description: {{ $desc | quote }}
    command: "{{ $tool }}{{ if eq $tool "hl" }} --follow --paging=never --expansion=never --local{{ else }} --follow --print{{ end }} {{ . }}"
    availability:
      restart: on_failure
      max_restarts: 0
{{- end }}

{{- if .features.sql }}
{{- range glob (joinPath .brewPrefix "var/mysql/*.err") }}
{{- $base := base . }}
{{- $name := printf "mariadb-%s" (trimSuffix ".err" $base | trimSuffix ".log" | replace "_" "-" | replace "." "-") }}

  {{ $name }}-logs:
    namespace: logs
    description: "MariaDB logs"
    command: "tspin --follow --print {{ . }}"
    availability:
      restart: on_failure
      max_restarts: 0
{{- end }}
{{- end }}

{{- if .features.otel }}

  webhook-logs:
    namespace: logs
    description: Webhook alert receiver
    # FIXME(macos): tail --follow=name --retry
    command: "tail -f {{ .chezmoi.homeDir }}/.local/state/webhook/*.log | tspin --print"
    availability:
      restart: on_failure
      max_restarts: 0
{{- end }}

{{- range glob (printf "%s/.local/state/claude/*.jsonl" .chezmoi.homeDir) }}
{{- $name := trimSuffix ".jsonl" (base .) }}

  claude-{{ $name }}-logs:
    namespace: logs
    description: Claude hooks log
    command: "hl --follow --paging=never --expansion=never --local {{ . }}"
    availability:
      restart: on_failure
      max_restarts: 0
{{- end }}

{{- /* SSH tunnel proxies from chezmoidata */ -}}
{{- range dig "processCompose" "sshProxies" (list) . -}}
{{-   $remotePort := "22" -}}
{{-   if eq .type "postgres" }}{{- $remotePort = "5432" -}}{{- end -}}
{{-   if eq .type "mysql" }}{{- $remotePort = "3306" -}}{{- end }}

  {{ .name }}:
    namespace: tunnels
    description: "{{ .type }} :{{ .localPort }} -> {{ .remoteHost }}:{{ $remotePort }} via {{ .sshTarget }}"
    command: "ssh -N -L {{ .localPort }}:{{ .remoteHost }}:{{ $remotePort }} {{ .sshTarget }}"
    availability:
      restart: on_failure
      backoff_seconds: 5
      max_restarts: 0
      exponential_backoff: true
    {{- if eq .type "postgres" }}
    readiness_probe:
      exec:
        command: "! command -v pg_isready >/dev/null || pg_isready --host=localhost --port={{ .localPort }} --username={{ .dbUser }} --dbname={{ .dbName }}"
    {{- else if eq .type "mysql" }}
    readiness_probe:
      exec:
        command: "! command -v mysqladmin >/dev/null || mysqladmin ping --host=127.0.0.1 --port={{ .localPort }} --connect-timeout=2"
    {{- end }}
      initial_delay_seconds: 5
      period_seconds: 10
      timeout_seconds: 3
      failure_threshold: 3
{{- end }}
