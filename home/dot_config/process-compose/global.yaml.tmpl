{{- $hlFollow := "hl --follow --paging=never --expansion=never --local" -}}
{{- $tspinFollow := "tspin --follow --print" -}}
---
version: "0.5"

log_level: info

processes:
  {{- if .features.claude }}
  {{- range glob (joinPath .chezmoi.homeDir ".local/state/claude/*.jsonl") }}
  {{- $name := trimSuffix ".jsonl" (base .) }}

  claude-{{ $name }}-logs:
    namespace: logs
    description: Claude hooks log
    command: "{{ $hlFollow }} {{ . }}"
    availability:
      restart: on_failure
      max_restarts: 0
  {{- end }}

  claude-task-viewer:
    namespace: apps
    description: Claude task viewer UI
    command: npx claude-task-viewer
    environment:
      - PORT=3456
    availability:
      restart: on_failure
      backoff_seconds: 10
      max_restarts: 5
      exponential_backoff: true
    readiness_probe:
      http_get:
        host: localhost
        port: 3456
        scheme: http
      initial_delay_seconds: 5
      period_seconds: 10
      timeout_seconds: 3
      failure_threshold: 3
  {{- end }}

  {{- $opencodeConf := joinPath .chezmoi.homeDir ".config" "secrets.d" "opencode.conf" }}
  {{- $opencodeSettings := joinPath .chezmoi.homeDir ".config" "opencode" "opencode.jsonc" }}
  {{- if and .features.opencode (stat $opencodeConf) }}

  {{- $server := .opencode.server }}
  {{- if and .features.tailscale .tailscale.tailnet }}
  {{-   $cors := append $server.cors (printf "https://%s" .tailscale.tailnet) }}
  {{-   $server = mergeOverwrite $server (dict "cors" $cors) }}
  {{- end }}

  # opencode attach http://127.0.0.1:4096
  opencode-server:
    namespace: apps
    description: OpenCode server
    # https://github.com/anomalyco/opencode/issues/19078
    command: >-
      test -n "$OPENCODE_SERVER_PASSWORD" &&
      opencode serve
      {{- range $key, $value := $server }}
      {{-   if kindIs "slice" $value }}
      {{-   range $value }}
      --{{ $key }}={{ . | quote }}
      {{-   end }}
      {{-   else }}
      {{-   $isInt := or (kindIs "int64" $value) (kindIs "uint64" $value) }}
      --{{ $key }}={{ $isInt | ternary $value ($value | quote) }}
      {{-   end }}
      {{- end }}
      --print-logs
    environment:
      {{- range include $opencodeConf | trim | splitList "\n" }}
      - {{ . }}
      {{- end }}
    availability:
      restart: on_failure
      backoff_seconds: 10
      max_restarts: 5
      exponential_backoff: true
    # readiness_probe:
    #   http_get:
    #     host: {{ $server.hostname }}
    #     port: {{ $server.port }}
    #     scheme: http
    #     # headers: {}
    #     # FIXME: Error: readiness check fail - Received status code '401' does not match expected status code '200'   ║│
    #     status_code: 401
    #   initial_delay_seconds: 5
    #   period_seconds: 10
    #   timeout_seconds: 3
    #   failure_threshold: 3
  {{- end }}

  {{- if .features.brew }}
  {{- $brew := dig "processCompose" "brew" dict . }}
  {{- range glob (joinPath .brewPrefix "var/log/**/*.log") }}
  {{- $base := base . }}
  {{- $dir := dir . | base }}
  {{- $key := ternary (printf "%s/%s" $dir $base) $base (ne $dir "log") }}
  {{- $meta := get $brew $key | default dict }}
  {{- $tool := get $meta "tool" | default "tspin" }}
  {{- $name := trimSuffix ".log" $base | replace "_" "-" }}
  {{- if ne $dir "log" }}{{ $name = printf "%s-%s" $dir $name }}{{ end }}
  {{- $desc := get $meta "description" | default (printf "%s log" $name) }}

  {{ $name }}-logs:
    namespace: logs
    description: {{ $desc | quote }}
    command: "{{ eq $tool "hl" | ternary $hlFollow $tspinFollow }} {{ . }}"
    availability:
      restart: on_failure
      max_restarts: 0
  {{- end }}
  {{- end }}

  {{- if and .features.brew .features.sql }}
  {{- range glob (joinPath .brewPrefix "var/mysql/*.err") }}
  {{- $base := base . }}
  {{- $name := printf "mariadb-%s" (trimSuffix ".err" $base | trimSuffix ".log" | replace "_" "-" | replace "." "-") }}

  {{ $name }}-logs:
    namespace: logs
    description: "MariaDB logs"
    command: "{{ $tspinFollow }} {{ . }}"
    availability:
      restart: on_failure
      max_restarts: 0
  {{- end }}
  {{- end }}

  {{- if .features.otel }}

  webhook-logs:
    namespace: logs
    description: Webhook alert receiver
    # tspin only accepts a single file; tail -f handles the glob
    command: "tail -f ~/.local/state/webhook/*.log | tspin --print"
    availability:
      restart: on_failure
      max_restarts: 0
  {{- end }}

  {{- range dig "processCompose" "sshProxies" list . }}
  {{-   $remotePort := "22" }}
  {{-   if eq .type "postgres" }}{{ $remotePort = "5432" }}{{ end }}
  {{-   if eq .type "mysql" }}{{ $remotePort = "3306" }}{{ end }}

  {{ .name }}:
    namespace: tunnels
    description: "{{ .type }} :{{ .localPort }} -> {{ .remoteHost }}:{{ $remotePort }} via {{ .sshTarget }}"
    command: "ssh -N -L {{ .localPort }}:{{ .remoteHost }}:{{ $remotePort }} {{ .sshTarget }}"
    availability:
      restart: on_failure
      backoff_seconds: 5
      max_restarts: 0 # unlimited
      exponential_backoff: true
    {{- if eq .type "postgres" }}
    readiness_probe:
      exec:
        command: "! command -v pg_isready >/dev/null || pg_isready --host=localhost --port={{ .localPort }} --username={{ .dbUser }} --dbname={{ .dbName }}"
    {{- else if eq .type "mysql" }}
    readiness_probe:
      exec:
        command: "! command -v mysqladmin >/dev/null || mysqladmin ping --host=127.0.0.1 --port={{ .localPort }} --connect-timeout=2"
    {{- end }}
      initial_delay_seconds: 5
      period_seconds: 10
      timeout_seconds: 3
      failure_threshold: 3
  {{- end }}
