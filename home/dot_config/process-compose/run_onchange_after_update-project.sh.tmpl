#!/bin/sh

# global: {{ includeTemplate "dot_config/process-compose/global.yaml.tmpl" . | sha256sum }}
{{- if eq .chezmoi.os "darwin" }}
# plist: {{ includeTemplate "Library/private_LaunchAgents/com.process-compose.plist.tmpl" . | sha256sum }}
{{- end }}

set -eu

# shellcheck source=../.chezmoitemplates/helpers.sh
. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

{{ if eq .chezmoi.os "darwin" -}}
label="{{ (get .services "process-compose").label }}"
{{- else -}}
label="process-compose"
{{- end }}

# socket="$HOME/.local/state/process-compose/global.sock"
# # Try hot-reload via project update first
# if [ -S "$socket" ]; then
#   if run timeout 10 pc -g project update; then
#     msg "$label: hot-reloaded"
#     exit 0
#   fi
# fi

if run timeout 10 pc -g project update; then
  # Project updated successfully / No processes were updated
  exit 0
fi

{{ if eq .chezmoi.os "darwin" -}}
plist="$HOME/Library/LaunchAgents/$label.plist"
if [ ! -f "$plist" ]; then
  die "$label: plist not found"
fi
if launchctl print "gui/$(id -u)/$label" >/dev/null 2>&1; then
  run launchctl bootout "gui/$(id -u)" "$plist" 2>/dev/null || true
fi
run launchctl bootstrap "gui/$(id -u)" "$plist"
{{- else -}}
run systemctl --user daemon-reload
run systemctl --user restart "$label"
{{- end }}
msg "$label: restarted"
