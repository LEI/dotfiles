{{- if .features.processCompose -}}
{{- $name := "process-compose" -}}
{{- $svc := dig "services" $name dict . -}}
{{- $site := dig "caddy" "sites" $name dict . -}}
#!/bin/sh

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

if ! has process-compose; then
  die "process-compose not found"
fi

{{- if eq .chezmoi.os "darwin" }}
{{ includeTemplate "launchd-apply.sh.tmpl" (merge (dict
  "chezmoi" .chezmoi
) $svc $site) }}
{{- else }}
{{ includeTemplate "systemd-apply.sh.tmpl" (merge (dict
  "chezmoi" .chezmoi
) $svc $site) }}
{{- end }}
{{- end -}}
