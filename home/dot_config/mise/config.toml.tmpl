[settings]
{{- if eq .osID "alpine" }}
# FIXME(alpine): platform error (failed to install with ubi)
disable_backends = ["ubi"]
{{- end }}
idiomatic_version_file_enable_tools = ["node", "go"]

{{- if .features.goss }}
[tasks.goss-validate]
dir = "~/.config/goss"
run = "goss --vars=vars.yaml validate"
{{- end }}

[tools]
{{- $miseTools := includeTemplate "packages.tmpl" (mergeOverwrite . (dict "packageType" "mise")) | fromJson -}}
{{- range $name, $options := $miseTools }}
{{ $name }} = "{{ get .options "version" | default "latest" }}"
{{- end }}
