{{- $miseInteractive := false -}}
{{- with lookPath "mise" -}}
{{-   $ver := output "sh" "-c" (printf "MISE_QUIET=1 %q --version" .) | splitList " " | first -}}
{{-   if $ver }}{{ $miseInteractive = semverCompare ">=2026.3.4" $ver }}{{ end -}}
{{- end -}}
[settings]
{{- if eq .osID "alpine" }}
# FIXME(alpine): platform error (failed to install with ubi)
disable_backends = ["ubi"]
{{- else if eq .osID "darwin" }}
# FIXME(darwin): HTTP status client error (403 rate limit exceeded)
# https://mise.jdx.dev/troubleshooting.html#_403-forbidden-when-installing-a-tool
disable_backends = ["aqua"]
{{- end }}
idiomatic_version_file_enable_tools = [
  # "bun",
  # "deno",
  "go",
  # "java",
  "node",
  "python",
  "ruby",
  # "terraform",
  # "tiny",
]

# experimental = {{ ne .profile "work" }}
env_shell_expand = true
lockfile = true

{{- $featMap := dict
  "homebrew" "brew"
  "nvim" "neovim"
}}
{{- $checkDirs := list }}
{{- range glob (joinPath .chezmoi.sourceDir "dot_config" "*/.check.sh") }}
{{-   $name := . | dir | base }}
{{-   $feat := get $featMap $name | default $name }}
{{-   if not (or (not (hasKey $.features $feat)) (get $.features $feat)) }}
{{-     continue }}
{{-   end }}
{{-   $checkDirs = append $checkDirs $name }}

[tasks."check:{{ $name }}"]
alias = "c:{{ $name }}"
description = {{ printf "Check %s" $feat | quote }}
# file = {{ . | quote }}
dir = {{ . | dir | quote }}
run = {{ . | base | quote }}
shell = "bash"
{{-   if $miseInteractive }}
interactive = true
{{-   end }}
{{- end }}

# chezmoi feature enabled # list --output=json | jq --compact-output
# chezmoi package diff all
# chezmoi managed | grep '.chezmoiscript\|.local/bin\|install-'
# PATH="$PATH:$HOME/.local/bin"
[tasks.check]
alias = "c"
description = "Run all checks"
depends = [
{{- range $checkDirs }}
  # {{ printf "check:%s" . | quote }},
{{- end }}
]
run = [
{{- range $checkDirs }}
  { task = {{ printf "check:%s" . | quote }} },
{{- end }}
]

{{- $updateDirs := list }}
{{- range glob (joinPath .chezmoi.sourceDir "dot_config" "*/.update.sh") }}
{{-   $name := . | dir | base }}
{{-   $feat := get $featMap $name | default $name }}
{{-   if not (or (not (hasKey $.features $feat)) (get $.features $feat)) }}
{{-     continue }}
{{-   end }}
{{-   $updateDirs = append $updateDirs $name }}

[tasks."update:{{ $name }}"]
# alias = "upd:{{ $name }}"
description = {{ printf "Update %s" $feat | quote }}
dir = {{ . | dir | quote }}
run = {{ . | base | quote }}
shell = "sh"
{{-   if $miseInteractive }}
interactive = true
{{-   end }}
{{- end }}

[tasks.update]
# alias = "U"
description = "Run all updates"
# depends = []
run = [
{{- range $updateDirs }}
  { task = {{ printf "update:%s" . | quote }} },
{{- end }}
]

{{- if .features.goss }}

[tasks.goss]
alias = "go"
description = "Validate system state with goss"
{{- if $miseInteractive }}
interactive = true
{{- end }}
# Inline sh instead of shell = "sh" so arguments pass through to the script
run = {{ printf "sh '%s'" (joinPath $.chezmoi.sourceDir "dot_config/goss/.check.sh") | quote }}
{{- end }}

{{- $images := list "alpine" "archlinux" "debian" "fedora" "termux" "ubuntu" }}
{{- range $images }}

[tasks."container:{{ . }}"]
alias = "ct:{{ . }}"
description = {{ printf "Build and test chezmoi in %s" . | quote }}
hide = true
run = "script/container {{ . }}"
{{-   if $miseInteractive }}
interactive = true
{{-   end }}
{{- end }}

[tasks."container:all"]
alias = "ct:all"
description = "Build and test chezmoi in all images"
# depends = []
run = [
{{- range $images }}
  { task = {{ printf "container:%s" . | quote }} },
{{- end }}
]
{{- if $miseInteractive }}
interactive = true
{{- end }}

{{- if .features.opencode }}

[tasks.opkg]
alias = "op"
description = "Run opkg from the local openpackage directory"
dir = "~/.openpackage/packages/local"
run = "opkg"
{{- end }}

{{- if eq .os "darwin" }}

[tasks.debian]
alias = "ta:debian"
description = "Tart debian"
interactive = true
run = [
  # "tart clone ghcr.io/cirruslabs/debian:latest debian",
  # "tart set debian --disk-size 20",
  # "nohup tart run --dir=dotfiles:.:ro --no-graphics debian &",
  "tart ip --wait=60 debian",
  "tart get --format=json debian",
  "ssh admin@$(tart ip debian) pwd",
  # "tart stop debian",
]

[tasks.tart]
alias = "ta"
description = "Tart 2.32.1"
# Images: admin/admin
# ssh admin@$(tart ip tahoe-base)
# https://github.com/orgs/cirruslabs/packages?repo_name=linux-image-templates

env.NAME = "tahoe-base"
# env.DISK = 24 # 50
# env.SOURCE = "ghcr.io/cirruslabs/macos-tahoe-base:latest"

interactive = true
run = [
  # "tart clone $SOURCE $NAME",
  # "tart set $NAME --disk-size $DISK",

  # "tart run --dir=dotfiles:.:ro {{ `{{ env.NAME }}` }}",

  # https://github.com/cirruslabs/tart/issues/303#issuecomment-1476468726
  # https://github.com/cirruslabs/tart/issues/374#issuecomment-1536518622
  "nohup tart run --dir=dotfiles:.:ro --no-graphics {{ `{{ env.NAME }}` }} &",
  # "rm nohup.out",

  # https://github.com/cirruslabs/tart/issues/374#issuecomment-1747125229
  "tart ip --wait=60 {{ `{{ env.NAME }}` }}",
  # brew install sshpass
  # sshpass -p admin ssh -o "StrictHostKeyChecking no" admin@$(tart ip sonoma-base) "uname -a"

  "tart get --format=json {{ `{{ env.NAME }}` }}",
  # tart get --format=json {{ `{{ env.NAME }}` }} | jq --raw-output .State
  # "until ...; do sleep 1; done",

  "ssh admin@$(tart ip {{ `{{ env.NAME }}` }}) ls -la '/Volumes/My Shared Files/dotfiles'",

  # "tart stop {{ `{{ env.NAME }}` }}",
  # "tart prune --older-than=0",
]
{{- end }}

{{- if eq .os "linux" }}

[tasks.timep]
# alias = "tp"
description = "Profile bash init with timep (call-stack tree)"
run = "bash -c 'source ~/.local/share/timep.bash && timep +F -c \"source ~/.bashrc\"'"
# shell = "bash"
# run = 'source ~/.local/share/timep.bash && timep +F -c "source ~/.bashrc"'
{{- end }}

{{ includeTemplate "dot_config/mise/tools.toml.tmpl" . -}}
