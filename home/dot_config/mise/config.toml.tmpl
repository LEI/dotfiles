[task_config]
includes = [
{{- $ctx := . }}
{{- range $file := glob (joinPath .chezmoi.sourceDir "dot_config" "mise" "exact_tasks" "*") }}
{{-   $contents := includeTemplate $file $ctx }}
{{-   if $contents }}
  "{{ $.chezmoi.homeDir }}/.config/mise/tasks/{{ base $file | trimSuffix ".tmpl" }}",
{{-   end }}
{{- end }}
]

[settings]
{{- if eq .osID "alpine" }}
# FIXME(alpine): platform error (failed to install with ubi)
disable_backends = ["ubi"]
{{- else if and .vm (eq .osIDLike "debian") }}
# FIXME(vm): asdf plugins write tarballs to CWD which is the read-only virtiofs mount
disable_backends = ["asdf"]
{{- else if eq .osID "darwin" }}
# FIXME(darwin): HTTP status client error (403 rate limit exceeded)
# https://mise.jdx.dev/troubleshooting.html#_403-forbidden-when-installing-a-tool
# disable_backends = ["aqua"]
{{- end }}
idiomatic_version_file_enable_tools = [
  # "bun",
  # "deno",
  "go",
  # "java",
  "node",
  "python",
  "ruby",
  # "terraform",
  # "tiny",
]

# experimental = {{ ne .profile "work" }}
env_shell_expand = true
lockfile = true

{{- $checkDirs := list }}
{{- $checks := glob (joinPath .chezmoi.sourceDir "dot_config" "*/.check.sh") }}
{{- range $checks }}
{{-   $name := . | dir | base }}
{{-   $feat := get $.featureMap $name | default $name }}
{{-   if not (or (not (hasKey $.features $feat)) (get $.features $feat)) }}
{{-     continue }}
{{-   end }}
{{-   $checkDirs = append $checkDirs $name }}

[tasks."check:{{ $name }}"]
alias = "c:{{ $name }}"
description = {{ printf "Check %s" $feat | quote }}
# file = {{ . | quote }}
dir = {{ . | dir | quote }}
run = {{ printf "bash ./%s \"$@\"" (. | base) | quote }}
{{-   if $.mise.interactive }}
interactive = true
{{-   end }}
{{- end }}

# chezmoi feature enabled # list --output=json | jq --compact-output
# chezmoi package diff all
# chezmoi managed | grep '.chezmoiscript\|.local/bin\|install-'
# PATH="$PATH:$HOME/.local/bin"
[tasks.check]
alias = "c"
description = "Run all checks"
depends = [
{{- range $checkDirs }}
  # {{ printf "check:%s" . | quote }},
{{- end }}
]
run = [
{{- range $checkDirs }}
  { task = {{ printf "check:%s" . | quote }} },
{{- end }}
]

{{- $updateDirs := list }}
{{- range glob (joinPath .chezmoi.sourceDir "dot_config" "*/.update.sh") }}
{{-   $name := . | dir | base }}
{{-   $feat := get $.featureMap $name | default $name }}
{{-   if not (or (not (hasKey $.features $feat)) (get $.features $feat)) }}
{{-     continue }}
{{-   end }}
{{-   $updateDirs = append $updateDirs $name }}

[tasks."update:{{ $name }}"]
# alias = "upd:{{ $name }}"
description = {{ printf "Update %s" $feat | quote }}
dir = {{ . | dir | quote }}
run = {{ . | base | quote }}
shell = "sh"
{{-   if $.mise.interactive }}
interactive = true
{{-   end }}
{{- end }}

[tasks.update]
# alias = "U"
description = "Run all updates"
# depends = []
run = [
{{- range $updateDirs }}
  { task = {{ printf "update:%s" . | quote }} },
{{- end }}
]

{{- if eq .os "linux" }}

[tasks.timep]
# alias = "tp"
description = "Profile bash init with timep (call-stack tree)"
# shell = "bash"
# run = 'source ~/.local/share/timep.bash && timep +F -c "source ~/.bashrc"'
run = """
bash -c 'source ~/.local/share/timep.bash && timep +F -c "source ~/.bashrc"'
"""
{{- end }}

{{ includeTemplate "dot_config/mise/tools.toml.tmpl" . -}}
