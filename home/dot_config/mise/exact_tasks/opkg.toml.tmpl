{{- if .features.opencode -}}
{{- $openpackage := get . "openpackage" | default dict -}}
{{- $platforms := get $openpackage "platforms" | default list -}}
{{- $claudeData := get . "claude" | default dict -}}
{{- $claudeMarkets := get $claudeData "marketplaces" | default dict -}}

[opkg]
alias = "op"
description = "Run opkg in the local package"
dir = "~/.openpackage/packages/local"
run = "opkg"

["opkg:list"]
alias = "ol"
description = "List opkg resources"
run = "opkg list --global"

["opkg:install"]
alias = "oi"
description = "Publish and install all opkg packages globally"
run = """
cd ~/.openpackage/packages/local || return 1
opkg publish --local --force local
opkg uninstall --global --recursive local 2>/dev/null || true
opkg install --local --platforms {{ join " " $platforms }} --global local
{{- range $name, $mkt := $claudeMarkets }}
{{- $path := get $mkt "path" }}
{{- if and $path (stat (joinPath $.chezmoi.homeDir $path "packages" $name)) }}
cd "$HOME/{{ $path }}/packages/{{ $name }}" || return 1
opkg publish --local --force {{ $name }}
opkg uninstall --global --recursive {{ $name }} 2>/dev/null || true
opkg install --local --platforms {{ join " " $platforms }} --global {{ $name }}
{{- end }}
{{- end }}
"""

["opkg:managed"]
alias = "om"
description = "List tracked target paths"
run = """
opkg list --global --json \
  | jq -r '.data.resources[] | select(.resourceType == "packages") | .resources[] \
    | recurse(.children[]?) | select(.status == "tracked") \
    | .files[]? | select(.status == "tracked") | .target' \
  | sort -u \
  | sed "s|^|$HOME/|"
"""

["opkg:unmanaged"]
alias = "ou"
description = "List untracked target paths"
run = """
opkg list --global --json \
  | jq -r '.data.resources[] | .resources[] | select(.status == "untracked") \
    | .files[]? | select(.status == "untracked") | .target \
    | select(. != ".claude.json" \
      and (startswith(".pi/") | not))' \
  | sort -u \
  | sed "s|^|$HOME/|"
"""

["opkg:tracked"]
alias = "ot"
description = "Check if a resource is tracked"
usage = 'arg "<name>" help="Resource name (e.g. packages/local)"'
run = """
opkg list --global --json \
  | jq -e --arg name "$usage_name" \
    '[.data.resources[] | select(.resourceType == "packages") | .resources[] \
      | recurse(.children[]?) | select(.name == $name and .status == "tracked")] \
    | length > 0' \
  >/dev/null
"""
{{ end -}}
