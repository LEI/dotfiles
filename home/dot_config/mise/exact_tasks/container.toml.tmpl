{{- if or .features.docker .features.podman -}}
{{- $script := joinPath .chezmoi.sourceDir ".." "script" "container" -}}
{{- $ctImages := list -}}
{{- if stat $script -}}
{{-   $ctImages = output $script "--list-images" | trim | splitList "\n" -}}
{{- end -}}

{{- range $ctImages -}}
["container:{{ . }}"]
alias = "ct:{{ . }}"
description = {{ printf "Build and test chezmoi in %s" . | quote }}
dir = {{ joinPath $.chezmoi.sourceDir ".." | quote }}
hide = true
interactive = true
run = "script/container {{ . }}"

{{ end -}}

["container:all"]
alias = "ct:all"
description = "Build and test chezmoi in all images"
interactive = true
run = [
{{- range $ctImages }}
  { task = {{ printf "container:%s" . | quote }} },
{{- end }}
]
{{ end -}}
