{{- if .features.mise }}

[plugins.mise]
inline = """
# Must be first to ensure tools are available
BENCHFMT="mise" bench eval "$(mise activate "$shell")"
"""
{{- end }}

[plugins.path]
inline = """
if [ -d "${CARGO_HOME:-$HOME/.cargo}/bin" ]; then
  pathmunge "${CARGO_HOME:-$HOME/.cargo}/bin" after
fi

if [ -n "$GOPATH" ] && [ -d "$GOPATH/bin" ]; then
  pathmunge "$GOPATH/bin" after
fi

if [ -n "$KREW_ROOT" ] && [ -d "$KREW_ROOT/bin" ]; then
  pathmunge "$KREW_ROOT/bin" after
fi

if [ -d "$HOME/.nix-profile/bin" ]; then
  pathmunge "$HOME/.nix-profile/bin" after
fi

if [ -d "$HOME/.node_modules/bin" ]; then
  pathmunge "$HOME/.node_modules/bin" after
fi
if [ -n "${npm_config_prefix:-}" ] && [ -d "$npm_config_prefix/bin" ]; then
  pathmunge "$npm_config_prefix/bin"
fi
if [ -n "${PNPM_HOME:-}" ] && [ -d "$PNPM_HOME" ]; then
  pathmunge "$PNPM_HOME"
fi

if [ -d "${XDG_DATA_HOME:-$HOME/.local/share}/nvim/mason/bin" ]; then
  pathmunge "${XDG_DATA_HOME:-$HOME/.local/share}/nvim/mason/bin" after
fi

# Source plugins after updating PATH and activating mise
source_plugins sh
"""
{{- if .features.carapace }}

# https://carapace-sh.github.io/carapace-bin/setup.html#bash
[plugins.carapace]
inline = """
if command -v carapace >/dev/null; then
  export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense' # optional
  if [ "$shell" = zsh ]; then
    autoload -U +X compinit && compinit # Fixes "zsh: command not found: compdef"
    zstyle ':completion:*' format $'\\e[2;37mCompleting %d\\e[m'
  fi
  # BENCHFMT="carapace" bench source <(carapace _carapace)
  BENCHFMT="carapace" bench source <(carapace _carapace | sed -e 's/ && +X//')
else
  echo >&2 "Command 'carapace' not found"
fi
"""
{{- end }}
{{- if .features.direnv }}

[plugins.direnv]
inline = """
BENCHFMT="direnv" bench eval "$(direnv hook "$shell")"
"""
{{- end }}

[plugins.starship]
inline = """
BENCHFMT="starship" bench eval "$(starship init "$shell")"
"""
{{- if .features.zoxide }}

[plugins.zoxide]
inline = """
BENCHFMT="zoxide" bench eval "$(zoxide init "$shell")"
"""
{{- end }}
{{- if .features.atuin }}

[plugins.atuin]
inline = """
# Must be after starship to preserve PROMPT_COMMAND
if [ "$shell" != bash ] || [ "$BLE_ENABLED" = true ] || [ "$PREEXEC_ENABLED" = true ]; then
  BENCHFMT="atuin" bench eval "$(atuin init --disable-up-arrow "$shell")"
fi
"""
{{- end }}
