  # Setting up an IMAP account
  {{- range $key, $account := .meli }}
  {{- $username := get $account "username" | default $key }}
  {{- $host := index ($username | splitList "@") 1 }}
  {{ $key }}:
    root_mailbox: INBOX
    format: imap
    send_mail:
      hostname: {{ get $account "smtp" | default (printf "smtp.%s" $host) | quote }}
      port: {{ get $account "smtp_port" | default 587 }}
      auth:
        type: auto
        username: user
        password:
          type: command_eval
          value: gpg2 --no-tty -q -d ~/.passwords/user.gpg
      security: { type: STARTTLS }
    server_hostname: {{ get $account "imap" | default (printf "imap.%s" $host) | quote }}
    # server_password: ""
    server_password_command: "bw get password {{ $username }}"
    server_username: {{ $username | quote }}
    server_port: {{ get $account "imap_port" | default 993 | quote }} # 993: imaps, 143: STARTTLS
    use_starttls: {{ get $account "start_tls" | default true }} # optional
    listing:
      index_style: Conversations
    identity: "{{ $username }}"
    display_name: {{ $account.name }}
    use_oauth2: {{ get $account "use_oauth2" | default true }}
    # Show only specific mailboxes, overriding the server's subscribed status.
    # subscribed_mailboxes: ["INBOX", "INBOX/Sent", "INBOX/Drafts", "INBOX/Junk"]
  {{- end }}

