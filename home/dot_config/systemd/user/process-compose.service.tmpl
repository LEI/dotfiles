{{- $caddy := get . "caddy" | default dict -}}
{{- $sites := get $caddy "sites" | default dict -}}
{{- $pc := get (get $sites "processCompose" | default dict) "process-compose" | default dict -}}
{{- $uds := get $pc "uds" -}}
[Unit]
Description=Process Compose global services
After=network.target

[Service]
Type=simple
NoNewPrivileges=yes
Environment=HOME=%h
Environment=PATH=%h/.local/share/mise/shims:/home/linuxbrew/.linuxbrew/bin:/usr/bin:/bin
Environment=PC_CONFIG_FILES=%h/.config/process-compose/global.yaml
Environment=PC_LOG_FILE=%h/.local/state/process-compose/process-compose.log
{{- if $uds }}
Environment=PC_SOCKET_PATH=%h/.local/state/process-compose/global.sock
{{- end }}
ExecStart=/bin/bash -lc 'exec process-compose up{{ if $uds }} --use-uds{{ else }} --port {{ $pc.port }}{{ end }} --tui=false --ordered-shutdown --logs-truncate --hide-disabled'
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
