{{- if and .gui (eq .os "darwin") -}}
{{- $duti := .duti -}}
#!/bin/sh

# associations: {{ $duti | toJson | sha256sum }}
# defaults read ~/Library/Preferences/com.apple.LaunchServices/com.apple.launchservices.secure LSHandlers

set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

if ! has duti; then
  die "duti not found"
fi

ok=0
skip=0
fail=0
unmanaged=0

report() {
  if [ -n "$2" ]; then
    msg "  $1: $2 -> $3"
  else
    msg "  $1: (unset) -> $3"
  fi
}

apply() {
  if dry_run duti -s "$@"; then
    ok=$((ok + 1))
  else
    fail=$((fail + 1))
  fi
}

set_uti() {
  bundle="$1"
  uti="$2"
  current="$(duti -d "$uti" 2>/dev/null || true)"
  if [ "$current" = "$bundle" ]; then
    skip=$((skip + 1))
    return
  fi
  report "$uti" "$current" "$bundle"
  apply "$bundle" "$uti" all
}

set_ext() {
  bundle="$1"
  ext="$2"
  # duti -x returns three lines: App.app, /path, bundle.id
  current="$(duti -x "${ext#.}" 2>/dev/null | sed -n '3p' || true)"
  if [ "$current" = "$bundle" ]; then
    skip=$((skip + 1))
    return
  fi
  report "$ext" "$current" "$bundle"
  apply "$bundle" "$ext" all
}

set_scheme() {
  bundle="$1"
  scheme="$2"
  current="$(duti -d "$scheme" 2>/dev/null || true)"
  if [ "$current" = "$bundle" ]; then
    skip=$((skip + 1))
    return
  fi
  report "$scheme" "$current" "$bundle"
  apply "$bundle" "$scheme"
}

verify_allowlist() {
  plist="$HOME/Library/Preferences/com.apple.LaunchServices/com.apple.launchservices.secure"
  bad=$(
    defaults export "$plist" - 2>/dev/null |
      plutil -convert json -o - - 2>/dev/null |
      jq -r '.LSHandlers[]? | select(.LSHandlerContentType) | select(.LSHandlerRoleAll != null)
               | "\(.LSHandlerContentType)\t\(.LSHandlerRoleAll | ascii_downcase)"' |
      awk -F'\t' '
          BEGIN {
            {{- range $duti.allowedHandlers }}
            ok["{{ lower . }}"] = 1
            {{- end }}
          }
          !($2 in ok) { print }
        '
  )
  if [ -z "$bad" ]; then
    return
  fi
  msg "Handlers outside allowlist:"
  printf '%s\n' "$bad" | while IFS='	' read -r ct h; do
    msg "  $ct -> $h"
  done
  unmanaged=$(printf '%s\n' "$bad" | grep -c '^')
}

msg "File associations (UTIs)"
{{ range $bundle, $utis := $duti.utis -}}
{{ range $utis -}}
set_uti "{{ $bundle }}" "{{ . }}"
{{ end -}}
{{ end }}
msg "File associations (extensions)"
{{ range $bundle, $exts := $duti.extensions -}}
{{ range $exts -}}
set_ext "{{ $bundle }}" ".{{ . }}"
{{ end -}}
{{ end }}
msg "URL scheme associations"
{{ range $bundle, $schemes := $duti.schemes -}}
{{ range $schemes -}}
set_scheme "{{ $bundle }}" "{{ . }}"
{{ end -}}
{{ end }}
verify_allowlist

msg "$ok changed, $skip unchanged, $fail failed, $unmanaged unmanaged"

[ "$fail" -eq 0 ] && [ "$unmanaged" -eq 0 ]
{{ end -}}
