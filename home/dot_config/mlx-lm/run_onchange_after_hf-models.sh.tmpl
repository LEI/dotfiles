{{- if get (get .ai.providers "mlx-lm") "active" -}}
{{- $mlxModels := list -}}
{{- range $name, $meta := .ai.models -}}
{{-   $id := get $meta "mlx-lm" -}}
{{-   if $id -}}
{{-     $mlxModels = append $mlxModels $id -}}
{{-   end -}}
{{- end -}}
#!/bin/sh

# models: {{ $mlxModels | toJson | sha256sum }}

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

if ! has hf; then
  warn "hf not found, skipping mlx model setup"
  exit 0
fi

{{- range $mlxModels }}
msg "ensuring {{ . }}"
run hf download {{ . }}
{{- end }}
{{ end -}}
