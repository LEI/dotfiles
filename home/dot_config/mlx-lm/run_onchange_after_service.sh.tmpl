{{- $provider := get .ai.providers "mlx-lm" -}}
#!/bin/sh

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

if ! has {{ $provider.server }}; then
  die "{{ $provider.server }} not found"
fi

# Stop brew-managed service (default port 8080, conflicts with custom plist)
if launchctl print "gui/$(id -u)/homebrew.mxcl.mlx-lm" >/dev/null 2>&1; then
  msg "stopping brew-managed mlx-lm service"
  run launchctl bootout "gui/$(id -u)/homebrew.mxcl.mlx-lm"
fi

{{ includeTemplate "launchd-apply.sh.tmpl" (merge (dict
  "chezmoi" .chezmoi
) $provider) -}}
