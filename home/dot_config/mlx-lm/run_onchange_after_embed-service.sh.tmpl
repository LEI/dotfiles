{{- $provider := get .ai.providers "mlx-embed" -}}
#!/bin/sh

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

if ! has {{ $provider.server }}; then
  die "{{ $provider.server }} not found"
fi

{{ includeTemplate "launchd-apply.sh.tmpl" (merge (dict
  "chezmoi" .chezmoi
) $provider) -}}
