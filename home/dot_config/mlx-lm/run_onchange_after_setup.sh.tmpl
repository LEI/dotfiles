{{- $provider := get .ai.providers "mlx-lm" -}}
#!/bin/sh
# plist: {{ joinPath .chezmoi.homeDir "Library/LaunchAgents/com.mlx-lm.server.plist" | include | sha256sum }}
set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

has brew || err "brew not found"
brew list mlx-lm >/dev/null 2>&1 || err "mlx-lm not installed"

GUI="gui/$(id -u)"
LABEL="{{ $provider.label }}"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"

# Stop brew-managed service (default port 8080, conflicts with custom plist)
if launchctl print "$GUI/homebrew.mxcl.mlx-lm" >/dev/null 2>&1; then
  msg "stopping brew-managed mlx-lm service"
  run launchctl bootout "$GUI/homebrew.mxcl.mlx-lm"
fi

# Reload custom service
launchctl bootout "$GUI/$LABEL" 2>/dev/null || true
msg "loading mlx-lm service (port {{ $provider.port }})"
run launchctl bootstrap "$GUI" "$PLIST"
