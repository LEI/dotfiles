{{- if (get . "github") }}
{{- $signingKey := includeTemplate "gpg-signing-key.tmpl" (dict "email" .github.email "sh" .sh) -}}
[user]
	name = {{ get .github "name" | default .name | quote }}
	email = {{ .github.email | quote }}
	signingkey = {{ $signingKey | quote }}

[commit]
	gpgsign = {{ $signingKey | not | not }}

{{- if (get .github "user") }}

[github]
	user = {{ .github.user | quote }}
	token = {{ keyring "github" .github.user | quote }}
{{- end }}
{{- end }}

