{{- if (dig "kb" "vaults" list .) -}}
#!/bin/sh

# Personal kb at ~/kb/<vault>. Mirrors notes graph setup; idempotent.

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

kb_dir="{{ .chezmoi.homeDir }}/kb"

if [ ! -d "$kb_dir" ]; then
  run mkdir -p "$kb_dir"
fi

setup_kb() {
  name="$1"
  url="${2:-}"
  target="$kb_dir/$name"

  [ -L "$target" ] && return 0
  [ -d "$target" ] && return 0

  if [ -n "$url" ]; then
    if ! has ghq; then
      die "ghq not found, install it to set up kb $name from $url"
    fi
    run ghq get "$url"
    path_key=$(printf '%s' "$url" | sed -E 's|^git@||; s|^https?://||; s|:|/|; s|\.git$||')
    local_path="$(ghq root)/$path_key"
    if [ ! -d "$local_path" ]; then
      die "ghq could not resolve $url"
    fi
    run ln -s "$local_path" "$target"
    info "Linked $name kb: $target -> $local_path"
  else
    run mkdir -p "$target"
    run git -C "$target" init --quiet
    info "Initialized local kb at $target"
  fi
}

{{ range (dig "kb" "vaults" list .) }}
setup_kb {{ .name | quote }}{{ if hasKey . "url" }} {{ .url | quote }}{{ end }}
{{- end }}
{{ end -}}
