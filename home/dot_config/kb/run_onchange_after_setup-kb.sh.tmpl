{{- $kbPaths := includeTemplate "kb-paths.tmpl" . | fromJson -}}
{{- if $kbPaths -}}
#!/bin/sh

# kb-state:
{{- range $v := $kbPaths }}
{{-   $s := lstat $v.sym }} {{ $v.name }}={{ if $s }}{{ $s.mode }}{{ else }}absent{{ end }}
{{- end }}

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

kb_dir="{{ .chezmoi.homeDir }}/kb"

if [ ! -d "$kb_dir" ]; then
  run mkdir -p "$kb_dir"
fi

setup_kb() {
  name="$1"
  local_path="$2"
  url="${3:-}"
  target="$kb_dir/$name"

  [ -L "$target" ] && return 0

  if [ -d "$target" ]; then
    [ -z "$url" ] && return 0
    die "kb $name: $target exists, cannot link to $url"
  fi

  if [ -n "$url" ]; then
    if ! has ghq; then
      die "ghq not found, install it to set up kb $name from $url"
    fi
    run ghq get "$url"
    if [ ! -d "$local_path" ]; then
      die "ghq did not resolve $url to $local_path"
    fi
    run ln -s "$local_path" "$target"
    info "Linked $name kb: $target -> $local_path"
  else
    run mkdir -p "$target"
    run git -C "$target" init --quiet
    info "Initialized local kb at $target"
  fi
}
{{ range $v := $kbPaths }}
setup_kb {{ $v.name | quote }} {{ $v.real | quote }}{{ if $v.url }} {{ $v.url | quote }}{{ end }}
{{- end }}
{{ end -}}
