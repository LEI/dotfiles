{{- $key := .features.mlx | ternary "mlx-lm" "ollama" -}}
{{- $configs := list -}}
{{- range $name, $meta := .ai.models -}}
{{-   $id := get $meta $key -}}
{{-   if not (and $id (hasKey $meta "params")) }}{{ continue }}{{ end -}}
{{-   $configs = append $configs (dict
    "id" $id
    "name" $name
    "base_model_id" $id
    "params" $meta.params
    "is_active" true) -}}
{{- end -}}
{{- $payload := dict "models" $configs -}}
#!/bin/sh

# config hash: {{ $payload | toJson | sha256sum }}

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
. "$CHEZMOI_WORKING_TREE/home/dot_config/oage/.open-webui.sh"

open_webui_auth || exit 0

open_webui_post "models/import" <<'EOF'
{{ $payload | toPrettyJson | trim }}
EOF

msg "open-webui: imported {{ len $configs }} model config(s)"
