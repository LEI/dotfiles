{{- $compose := joinPath .chezmoi.homeDir ".config/oage/compose.yaml" -}}
{{- $bifrostConfig := joinPath .chezmoi.homeDir ".config/oage/bifrost/config.json" -}}
{{- if and (stat $bifrostConfig) (eq (env "OAGE_APPLY_AUTOSTART") "true") -}}
{{- $bifrostHash := include $bifrostConfig | sha256sum -}}
#!/bin/sh

# compose: {{ include $compose | fromYaml | toJson | sha256sum }}
# bifrost: {{ $bifrostHash }}

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

compose_file="{{ $compose }}"
bifrost_hash="{{ $bifrostHash }}"
bifrost_hash_file="${XDG_STATE_HOME:-$HOME/.local/state}/oage/bifrost.hash"

# manual stack: `oage up` starts it. autostart is template-gated above on
# OAGE_APPLY_AUTOSTART so run_onchange re-triggers when the flag flips
run "${CONTAINER_PROVIDER:?}" compose --file="$compose_file" up --detach --remove-orphans

mkdir -p "$(dirname "$bifrost_hash_file")"
if [ "$(cat "$bifrost_hash_file" 2>/dev/null)" != "$bifrost_hash" ]; then
  run "${CONTAINER_PROVIDER:?}" compose --file="$compose_file" restart bifrost
  printf '%s' "$bifrost_hash" >"$bifrost_hash_file"
fi
{{ end -}}
