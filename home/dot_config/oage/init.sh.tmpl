export OAGE_CONFIG_DIR="${OAGE_CONFIG_DIR:-$HOME/.config/oage}"
# systemctl --user start podman.socket

oage() { compose-project "${OAGE_CONFIG_DIR}" "$@"; }

{{- if .features.ollama }}
{{-   $quadlet := and .features.podman (eq .os "linux") }}
{{-   $ollamaContainer := $quadlet | ternary "systemd-ollama" "oage-ollama-1" }}
{{-   $ollamaProvider := $quadlet | ternary "podman" "$CONTAINER_PROVIDER" }}

{{- if ne .os "darwin" }}
ollama() {
  set -- {{ $ollamaContainer }} ollama "$@"
  [ -t 0 ] && set -- --interactive "$@"
  [ -t 1 ] && set -- --tty "$@"
  {{ $ollamaProvider }} exec "$@"
}
{{- end }}

ollama_logs() {
{{- if eq .os "darwin" }}
  tail -f "${HOMEBREW_PREFIX:?}/var/log/ollama.log" "$@"
{{- else if $quadlet }}
  journalctl --user --unit=ollama.service --follow "$@"
{{- else }}
  {{ $ollamaProvider }} logs --follow {{ $ollamaContainer }} "$@"
{{- end }}
}
{{- end }}

ollama_list() {
  ollama list
}

ollama_rm_all() {
  # shellcheck disable=SC2046
  ollama rm $(ollama list | tail -n+2 | cut -d' ' -f1)
}

{{- if .features.mlx }}
mlx_list() {
  mlx_lm manage --scan 2>/dev/null
}

mlx_logs() {
  tail -f "${HOMEBREW_PREFIX:?}/var/log/mlx-lm.log" "$@"
}

hf_list() {
  hf cache ls "$@"
}

hf_usage() {
  hf cache ls --format=json | jq -r '.[] | "\(.repo_type)/\(.repo_id)\t\(.size_on_disk / 1073741824 * 100 | round / 100)G"'
}

hf_rm_all() {
  # shellcheck disable=SC2046
  hf cache rm --yes $(hf_usage | cut -f1)
}
{{- end }}
