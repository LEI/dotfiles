{{- if .features.oage -}}
#!/bin/sh

set -eu

secrets="$XDG_CONFIG_HOME/oage/secrets"

write_env() {
  (
    umask 177
    cat >"$secrets/$1.env"
  )
}

read_secret() {
  val=$(cat "$secrets/$1" 2>/dev/null) || {
    echo "missing secret: $1" >&2
    exit 1
  }
  [ -n "$val" ] || {
    echo "empty secret: $1" >&2
    exit 1
  }
  printf '%s' "$val"
}

bifrost_api_key=$(read_secret bifrost-api-key)
bifrost_admin_password=$(read_secret bifrost-admin-password)
notebook_encryption_key=$(read_secret notebook-encryption-key)
surreal_pass=$(read_secret surreal-pass)
webui_secret_key=$(read_secret webui-secret-key)
# Resolve the key from the keystore directly, the conf now holds an unexecuted
# keystore_get command substitution, not a literal, so text-parsing it is wrong
openrouter_api_key=
{{- if .features.keystore }}
keystore_lib="$HOME/.local/lib/sh/keystore.sh"
if [ -r "$keystore_lib" ]; then
  # shellcheck source=/dev/null
  . "$keystore_lib"
  openrouter_api_key=$(keystore_get openrouter api-key 2>/dev/null || true)
fi
{{- end }}

write_env bifrost <<EOF
BIFROST_ADMIN_PASSWORD=${bifrost_admin_password}
BIFROST_API_KEY=${bifrost_api_key}
${openrouter_api_key:+OPENROUTER_API_KEY=${openrouter_api_key}}
EOF

write_env notebook <<EOF
OPEN_NOTEBOOK_ENCRYPTION_KEY=${notebook_encryption_key}
OPENAI_COMPATIBLE_API_KEY=${bifrost_api_key}
SURREAL_USER=root
SURREAL_PASSWORD=${surreal_pass}
EOF

{{- if .features.mlx }}

write_env webui <<EOF
OPENAI_API_KEYS=${bifrost_api_key};mlx
WEBUI_SECRET_KEY=${webui_secret_key}
EOF
{{- else }}

write_env webui <<EOF
OPENAI_API_KEY=${bifrost_api_key}
WEBUI_SECRET_KEY=${webui_secret_key}
EOF
{{- end }}

write_env surrealdb <<EOF
SURREAL_USER=root
SURREAL_PASS=${surreal_pass}
EOF
{{ end -}}
