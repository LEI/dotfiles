{{- if $ollamaInCompose }}

  # https://github.com/ollama/ollama
  ollama:
    image: docker.io/ollama/ollama:0.17.7
    restart: unless-stopped
    ports:
      - "127.0.0.1:11434:11434"
    volumes:
      - ollama-data:/root/.ollama
    devices:
      - /dev/dri
    environment:
      OLLAMA_KEEP_ALIVE: -1
      OLLAMA_VULKAN: "1"

{{- end }}

  # https://github.com/maximhq/bifrost
  bifrost:
    image: maximhq/bifrost:v1.4.11
    restart: unless-stopped
    ports:
      - "127.0.0.1:8180:8080"
    volumes:
      - ./bifrost:/app/data:z
    environment:
      BIFROST_HOST: 0.0.0.0
      LOG_LEVEL: info
      OPENROUTER_API_KEY: ${OPENROUTER_API_KEY:-}
      OAGE_BIFROST_API_KEY: ${OAGE_BIFROST_API_KEY:?set OAGE_BIFROST_API_KEY in local.sh}

{{- if .features.quadlet }}
    extra_hosts:
      - host.docker.internal:host-gateway
{{- end }}
{{- if $ollamaInCompose }}

    depends_on:
      - ollama
{{- end }}

  # https://github.com/open-webui/open-webui
  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    restart: unless-stopped
    ports:
      - "127.0.0.1:8503:8080"
    volumes:
      - open-webui-data:/app/backend/data
    environment:
      - OLLAMA_BASE_URL=http://host.docker.internal:11434
      - OPENAI_API_BASE_URL=http://bifrost:8080/v1
      - OPENAI_API_KEY=${OAGE_BIFROST_API_KEY:?set OAGE_BIFROST_API_KEY in local.sh}
      - WEBUI_AUTH=false
      - WEBUI_SECRET_KEY=${OAGE_WEBUI_SECRET_KEY:?set OAGE_WEBUI_SECRET_KEY in local.sh}
      - CORS_ALLOW_ORIGIN=https://open-webui.test
      - USER_AGENT=open-webui
    extra_hosts:
      - host.docker.internal:host-gateway
    depends_on:
      - bifrost

  # https://github.com/lfnovo/open-notebook/tree/main/examples
  surrealdb:
    image: surrealdb/surrealdb:v2
    command: start --log info --user root --pass root rocksdb:/mydata/mydatabase.db
    user: root  # Required for bind mounts on Linux
    ports:
      - "127.0.0.1:8000:8000"
    volumes:
      - surreal-data:/mydata
    environment:
      - SURREAL_EXPERIMENTAL_GRAPHQL=true
    restart: always
    # pull_policy: always

  open_notebook:
    image: lfnovo/open_notebook:v1-latest
    ports:
      - "127.0.0.1:8502:8502"
      - "127.0.0.1:5055:5055"
    environment:
      - OPEN_NOTEBOOK_ENCRYPTION_KEY=${OPEN_NOTEBOOK_ENCRYPTION_KEY:?set OPEN_NOTEBOOK_ENCRYPTION_KEY in local.sh}

      # LLM routing via bifrost (OpenAI-compatible)
      - OPENAI_COMPATIBLE_BASE_URL=http://bifrost:8080/v1
      # OPENAI_COMPATIBLE_API_KEY: skipped; bifrost auth not configured

      - API_URL=https://open-notebook-api.test
      - OLLAMA_BASE_URL=http://host.docker.internal:11434

      - SURREAL_URL=ws://surrealdb:8000/rpc
      - SURREAL_USER=root
      - SURREAL_PASSWORD=root
      - SURREAL_NAMESPACE=open_notebook
      - SURREAL_DATABASE=open_notebook
    volumes:
      - notebook-data:/app/data
    depends_on:
      - surrealdb
      - bifrost
    restart: always
    # pull_policy: always

  # # CONFIG.md, index.md
  # # http://localhost:5050/global/MEMORY
  # silverbullet:
  #   image: ghcr.io/silverbulletmd/silverbullet:latest
  #   restart: unless-stopped
  #   ports:
