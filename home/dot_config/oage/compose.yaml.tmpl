  #     - SB_INDEX_PAGE=MEMORY
  #     - SB_SPACE_IGNORE="index.md,CONFIG.md,index.page,SETTINGS.md"
  #     # - SB_USER=admin:password123

volumes:
  # sandboxed-data:
  # claude-auth:

  notebook-data:
  open-webui-data:
  surreal-data:

{{- if $ollamaInCompose }}

  ollama-data:
{{- end }}
