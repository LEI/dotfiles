# Case-insensitive completion
set completion-ignore-case on

# Show completions on first ambiguous tab
set show-all-if-ambiguous on

# Symlinks to directories get a trailing slash
set mark-symlinked-directories on

# Hidden files require explicit leading dot
set match-hidden-files off

# Disable paging, show all at once
set page-completions off

# Prompt above this many completions (default: 100)
set completion-query-items 200

# Append file type indicator (like ls -F)
set visible-stats on

# Color file type indicator (like ls --color)
set colored-stats on

# Color common prefix in completions
set colored-completion-prefix on

# Don't duplicate text already after the cursor
set skip-completed-text on

# Don't expand ~ to full home path
set expand-tilde off

# UTF-8 support
set input-meta on
set output-meta on
set convert-meta off

# Flash screen instead of audible beep
set bell-style visible

# Show completion type suffix (@ for symlinks, / for dirs)
set mark-directories on

# Up/Down search history using typed prefix
"\e[A": history-search-backward
"\e[B": history-search-forward

# Tab cycles forward, Shift-Tab cycles backward
TAB: menu-complete
"\e[Z": menu-complete-backward

# Alt-Delete kills the next word
"\e[3;3~": kill-word
