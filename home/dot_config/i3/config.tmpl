default_border $border_style $border_width
default_floating_border $border_style $border_width

for_window [all] title_window_icon padding 5px

# for_window [all] title_format %title ｜ %class ｜ %instance
# for_window [class=".*"] title_format %title ｜ <span font="mono 9">%class</span> ｜ <span size="smaller">%instance</span>

# no_focus [window_role="pop-up"]
# no_focus [class="plasmashell" window_type="on_screen_display"]
no_focus [class="Rustdesk"]

# include ~/.config/i3/config.d/*.conf
# include config.d/assignments.conf

# Floating windows
for_window [class="(?i)blueman-manager"] floating enable
for_window [class="(?i)lxappearance"] floating enable
for_window [class="(?i)mplayer"] floating enable
for_window [class="(?i)pavucontrol"] floating enable
for_window [class="(?i)rustdesk"] floating enable
for_window [class="(?i)seahorse"] floating enable
for_window [title="Preferences$"] floating enable
for_window [title="^Configuration Errors$"] floating enable
for_window [window_role="pop-up"] floating enable
for_window [window_role="task_dialog"] floating enable

# Application workspaces
# assign [class="Thunar"] number 2
# assign [class="(?i)firefox"] number 3
# for_window [class="Seahorse"] move scratchpad

focus_follows_mouse off

title_align center

gaps inner 5px
gaps outer -5px
# smart_gaps inverse_outer
# smart_gaps on

# Make the currently focused window a scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+Shift+parenright move scratchpad

# Show the first scratchpad window
bindsym $mod+minus scratchpad show
bindsym $mod+degree scratchpad show

# Show the sup-mail scratchpad window, if any.
# bindsym mod4+s [title="^Sup ::"] scratchpad show

# Update status bar
bindsym --release Caps_Lock exec pkill -SIGRTMIN+11 i3status-rs
