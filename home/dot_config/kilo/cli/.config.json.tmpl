{
  "version": "1.0.0",
  "mode": "code",
  "telemetry": false,
  "provider": "litellm",
  "providers": [
    {{- /* {
      "id": "litellm",
      "provider": "openai",
      "openAiBaseUrl": "",
      "openAiApiKey": "",
      "apiModelId": "github_copilot/gpt-4o"
    } */ -}}
  ],
  "autoApproval": {
    "enabled": true,
    "read": {
      "enabled": true,
      "outside": false
    },
    "write": {
      "enabled": true,
      "outside": true,
      "protected": false
    },
    "browser": {
      "enabled": false
    },
    "retry": {
      "enabled": false,
      "delay": 10
    },
    "mcp": {
      "enabled": true
    },
    "mode": {
      "enabled": true
    },
    "subtasks": {
      "enabled": true
    },
    "execute": {
      "enabled": true,
      "allowed": ["ls", "cat", "echo", "pwd"],
      "denied": ["rm -rf", "sudo rm", "mkfs", "dd if="]
    },
    "question": {
      "enabled": false,
      "timeout": 60
    },
    "todo": {
      "enabled": true
    }
  },
  "theme": "kilo",
  "customThemes": {}
}
