#!/bin/sh

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

# DISPLAY: {{ env "DISPLAY" | default "unset" }}
if [ -z "${DISPLAY:-}" ]; then
  echo "WARN: skipping xrdb merge (no display)" >&2
  exit 0
fi

# TODO: auto reload on change
# include (joinPath .chezmoi.homeDir ".Xresources") | sha256sum
# include (joinPath .chezmoi.homeDir ".config/X11/xresources") | sha256sum
# run xrdb -merge ~/.Xresources

# xrdb -load "$XDG_CONFIG_HOME/X11/xresources"
xrdb -merge "$XDG_CONFIG_HOME/X11/xresources"
