{{- if eq .os "darwin" -}}
#!/bin/sh

set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

if [ -d "$HOME/Library/Application Support/Code" ] && ! [ -L "$HOME/Library/Application Support/Code" ]; then
  run rmdir "$HOME/Library/Application Support/Code"
  run ln -s "$HOME/.config/Code" "$HOME/Library/Application Support/Code"
fi
{{ else if eq .osID "fedora" -}}
#!/bin/sh

set -eux

flatpak run com.visualstudio.code --install-extension zokugun.sync-settings

# TODO: ~/.config/Code -> /var/home/$USER/.var/app/com.visualstudio.code/config/Code
{{ end -}}
