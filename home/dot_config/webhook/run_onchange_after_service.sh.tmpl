{{- if .features.otel -}}
{{- $name := "webhook" -}}
{{- $svc := get .services $name -}}
{{- $site := get .caddy.sites $name -}}
{{- $path := joinPath .chezmoi.homeDir ".config/webhook/hooks.yaml" -}}
#!/bin/sh

{{- if stat $path }}

# hooks: {{ include $path | sha256sum }}
{{- end }}
set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

if ! has webhook; then
  die "webhook not found"
fi

if [ ! -d "$HOME/.local/state/webhook" ]; then
  run mkdir -p "$HOME/.local/state/webhook"
fi

{{- if eq .chezmoi.os "darwin" }}
{{ includeTemplate "launchd-apply.sh.tmpl" (merge (dict
  "chezmoi" .chezmoi
) $svc $site) }}
{{- else }}
{{ includeTemplate "systemd-apply.sh.tmpl" (merge (dict
  "chezmoi" .chezmoi
) $svc $site) }}
{{- end }}
# Manual test:
# curl -X POST http://localhost:9000/hooks/alert -H 'Content-Type: application/json' \
#   -d '{"status":"firing","alerts":[{"labels":{"alertname":"test"},"annotations":{}}]}'
{{ end -}}
