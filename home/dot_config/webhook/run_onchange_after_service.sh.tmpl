{{- if .features.otel -}}
{{- $svc := .services.webhook -}}
{{- $site := get (get .caddy.sites "otel") "webhook" -}}
{{- $path := joinPath .chezmoi.homeDir ".config/webhook/hooks.yaml" -}}
#!/bin/sh

{{- if stat $path }}

# hooks: {{ include $path | sha256sum }}
{{- end }}
set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

if ! has webhook; then
  die "webhook not found"
fi

if [ ! -d "$HOME/.local/state/webhook" ]; then
  run mkdir -p "$HOME/.local/state/webhook"
fi

{{ includeTemplate "launchd-apply.sh.tmpl" (merge (dict "chezmoi" .chezmoi) $svc $site) }}
# Manual test:
# curl -X POST http://localhost:9000/hooks/alert -H 'Content-Type: application/json' \
#   -d '{"status":"firing","alerts":[{"labels":{"alertname":"test"},"annotations":{}}]}'
{{ end -}}
