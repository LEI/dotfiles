# yamllint disable rule:indentation
---
os: {{ .os }}
arch: {{ .arch }}
hostname: {{ .hostname }}
profile:{{- if .profile }} {{ .profile }}{{ end }}
wsl: {{ .wsl }}
rootImmutable: {{ has (get .chezmoi.osRelease "variantID") (list "silverblue" "kinoite" "sericea" "onyx" "lazurite" "bazzite" "aurora" "bluefin") }}
features: {{- .features | toYaml | trim | nindent 2 }}

{{- $src := joinPath .chezmoi.sourceDir "dot_config" }}
{{- $files := glob (printf "%s/*/.goss.yaml" $src) }}
{{- $enabled := list }}
{{- range $files }}
{{- if not (get $.features (base (dir .))) }}{{ continue }}{{ end }}
{{- $enabled = append $enabled . }}
{{- end }}
{{- if $enabled }}
featureChecks:
{{- range $enabled }}
  - {{ . }}
{{- end }}
{{- end }}

# Health checks: merged from caddy.sites + ai.providers
# url = https://<name>.test<health>; status defaults to 200
checks:
{{- if hasKey . "caddy" }}
{{- range $feat, $sites := .caddy.sites }}
{{- if not (get $.features $feat) }}{{ continue }}{{ end }}
{{- range $name, $site := $sites }}
{{- if hasKey $site "enabled" }}{{ if not (get $site "enabled") }}{{ continue }}{{ end }}{{ end }}
  {{ $name }}:
    url: https://{{ $name }}.test{{ get $site "health" | default "" }}
{{- end }}
{{- end }}
{{- end }}
{{- if and (hasKey . "ai") (get $.features "caddy") }}
{{- range $name, $provider := .ai.providers }}
{{- if not (hasKey $provider "domain") }}{{ continue }}{{ end }}
{{- if hasKey $provider "enabled" }}{{ if not (get $provider "enabled") }}{{ continue }}{{ end }}{{ end }}
  {{ $name }}:
    url: https://{{ $provider.domain }}{{ get $provider "health" | default "" }}
{{- end }}
{{- end }}

{{- $scripts := glob (joinPath .chezmoi.sourceDir "dot_config/goss/exact_check/*.sh*") }}
{{- if $scripts }}
scripts:
{{- range $scripts }}
  - {{ base . | trimSuffix ".tmpl" }}
{{- end }}
{{- end }}

{{- if hasKey . "ai" }}
localProvider: {{ get .ai "localProvider" | quote }}
ai: {{- .ai | toYaml | trim | nindent 2 }}
{{- end }}
