{{- $userBus := false }}
{{- if eq .os "linux" }}
{{-   $userBus = stat (printf "/run/user/%d/bus" .chezmoi.uid) }}
{{- end }}
{{- if and (eq .os "linux") (stat "/run/systemd/system") -}}
---
command:
{{- if $userBus }}
  systemctl-failed:
    title: No failed user services
    exec: systemctl --user --failed --no-legend --no-pager
    exit-status: 0
    stdout: ['!/failed/']
    timeout: 3000
{{- end }}
{{- range $name, $svc := get . "services" | default dict }}
{{-   if not (get $.features (get $svc "feature")) }}{{ continue }}{{ end }}
{{-   $active := get $svc "active" }}
{{-   $unit := get $svc "unit" }}
{{-   if not $unit }}{{ continue }}{{ end }}
  systemd-{{ $name }}:
    title: {{ $name }} systemd user service ({{ if $active }}active{{ else }}inactive{{ end }})
    exec: systemctl --user is-active --quiet {{ $unit }}
    exit-status: {{ if $active }}0{{ else }}{ gt: 0 }{{ end }}
    timeout: 3000
{{- end }}
{{- if .features.ai }}
{{-   range $name, $provider := .ai.providers }}
{{-     if not (hasKey $provider "unit") }}{{ continue }}{{ end }}
{{-     if and (hasKey $.features $name) (not (get $.features $name)) }}{{ continue }}{{ end }}
{{-     $active := get $provider "active" }}
  systemd-{{ $name }}:
    title: {{ $name }} AI provider ({{ if $active }}active{{ else }}inactive{{ end }})
    exec: systemctl --user is-active --quiet {{ $provider.unit }}
    exit-status: {{ if $active }}0{{ else }}{ gt: 0 }{{ end }}
    timeout: 3000
{{-   end }}
{{- end }}
{{ end -}}
