{{- if and (eq .os "linux") (stat "/run/systemd/system") -}}
{{- $localProvider := get .ai "localProvider" | default "" -}}
---
command:
  systemctl-failed:
    exec: systemctl --user --failed --quiet --no-legend --no-pager
    exit-status: 0
    stdout: ['!/failed/']
    timeout: 3000
{{- range $name, $svc := get . "services" | default dict }}
{{- if not (get $.features (get $svc "feature")) }}{{ continue }}{{ end }}
{{- $unit := get $svc "unit" }}
{{- if not $unit }}{{ continue }}{{ end }}
  systemd-{{ $name }}:
    exec: systemctl --user is-active --quiet {{ $unit }}
    exit-status: 0
    timeout: 3000
{{- end }}
{{- if .features.ai }}
{{- range $name, $p := .ai.providers }}
{{- if not (hasKey $p "unit") }}{{ continue }}{{ end }}
{{- $active := or (eq $name $localProvider) (eq (get $p "parent" | default "") $localProvider) }}
  systemd-{{ $name }}:
    exec: systemctl --user is-active --quiet {{ $p.unit }}
    exit-status: {{ if $active }}0{{ else }}{ gt: 0 }{{ end }}
    timeout: 3000
{{- end }}
{{- end }}
{{ end -}}
