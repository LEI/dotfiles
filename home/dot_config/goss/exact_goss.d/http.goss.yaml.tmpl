{{- $checks := dict -}}
{{- $autostart := dict
  "otel" (env "OTEL_APPLY_AUTOSTART")
  "oage" (env "OAGE_APPLY_AUTOSTART") -}}
{{- if and (hasKey . "caddy") (hasKey .caddy "sites") -}}
{{- range $name, $site := .caddy.sites -}}
{{- $feat := get $site "feature" -}}
{{- if not (get $.features $feat) }}{{ continue }}{{ end -}}
{{- /* skip liveness for stacks an apply leaves stopped */ -}}
{{- if and (hasKey $autostart $feat) (ne (get $autostart $feat) "true") }}{{ continue }}{{ end -}}
{{- if hasKey $site "enabled" }}{{ if not (get $site "enabled") }}{{ continue }}{{ end }}{{ end -}}
{{- $health := get $site "liveness" -}}
{{- if not $health }}{{ continue }}{{ end -}}
{{- $entry := dict "url" (printf "https://%s.test%s" $name $health) -}}
{{- if get $site "body" }}{{ $_ := set $entry "body" (get $site "body") }}{{ end -}}
{{- if get $site "statusCode" }}{{ $_ := set $entry "status" (get $site "statusCode") }}{{ end -}}
{{- $_ := set $checks $name $entry -}}
{{- end -}}
{{- end -}}
{{- if and (hasKey . "ai") (get $.features "caddy") -}}
{{- range $name, $provider := .ai.providers -}}
{{- if not (hasKey $provider "domain") }}{{ continue }}{{ end -}}
{{- if not (get $provider "active") }}{{ continue }}{{ end -}}
{{- $entry := dict "url" (printf "https://%s%s" $provider.domain (get $provider "liveness")) -}}
{{- if get $provider "body" }}{{ $_ := set $entry "body" (get $provider "body") }}{{ end -}}
{{- $_ := set $checks $name $entry -}}
{{- end -}}
{{- end -}}
{{- range $name, $svc := get . "services" | default dict -}}
{{- if not (get $.features (get $svc "feature")) }}{{ continue }}{{ end -}}
{{- if and (eq $.os "darwin") (not (get $svc "label")) }}{{ continue }}{{ end -}}
{{- if and (eq $.os "linux") (not (get $svc "unit")) }}{{ continue }}{{ end -}}
{{- $probe := includeTemplate "probe.yaml.tmpl" (dict
  "probe" (get $svc "liveness")
  "port" (get $svc "port")) | fromYaml -}}
{{- if not $probe.url }}{{ continue }}{{ end -}}
{{- $_ := set $checks $name (dict
  "url" $probe.url
  "status" $probe.statusCode) -}}
{{- end -}}
{{- if $checks -}}
---
http:
{{- range $name, $check := $checks }}
  {{ $check.url }}:
    title: {{ $name }}
{{- $status := get $check "status" | default 200 }}
    status: {{ $status }}
    timeout: 5000
{{- if hasKey $check "body" }}
    body:
      - {{ index $check "body" | quote }}
{{- end }}
{{- end }}
{{ end -}}
