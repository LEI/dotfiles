{{- if eq .os "darwin" -}}
---
command:
{{- range $name, $svc := get . "services" | default dict }}
{{-   if not (get $.features (get $svc "feature")) }}{{ continue }}{{ end }}
{{-   $active := get $svc "active" }}
  launchd-{{ $name }}:
    title: {{ $name }} launchd agent ({{ if $active }}active{{ else }}inactive{{ end }})
    exec: launchctl print gui/$(id -u)/{{ $svc.label }} 2>/dev/null | grep -q 'pid ='
    exit-status: {{ if $active }}0{{ else }}{ gt: 0 }{{ end }}
    timeout: 3000
{{- end }}
{{- if .features.ai }}
{{-   range $name, $provider := .ai.providers }}
{{-     if not (hasKey $provider "label") }}{{ continue }}{{ end }}
{{-     $active := get $provider "active" }}
  launchd-{{ $name }}:
    title: {{ $name }} AI provider ({{ if $active }}active{{ else }}inactive{{ end }})
    exec: launchctl print gui/$(id -u)/{{ $provider.label }} 2>/dev/null | grep -q 'pid ='
    exit-status: {{ if $active }}0{{ else }}{ gt: 0 }{{ end }}
    timeout: 3000
{{-   end }}
{{- end }}
{{ end -}}
