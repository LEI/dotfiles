{{- $jqVersion := "" -}}
{{- $yqVersion := "" -}}
{{- if lookPath "jq" | isExecutable -}}
{{-   $jqVersion = output "sh" "-c" "jq --version | cut -d'-' -f2" -}}
{{- end -}}
{{- if lookPath "yq" | isExecutable -}}
{{-   $yqVersion = output "sh" "-c" "yq --version | awk '{print $4}' | tr -d 'v'" -}}
{{- end -}}
---
{{- if or $jqVersion $yqVersion }}
matching:
{{- end }}

{{- if $jqVersion }}

  jq_version:
    title: Check jq version matches semver constraint
    content:
      - {{ $jqVersion | trim | quote }}
    matches:
      semver-constraint: ">= 1.8.0 < 2.0.0"
{{- end }}

{{- if $yqVersion }}

  yq_version:
    title: Check yq version matches semver constraint
    content:
      - {{ $yqVersion | trim | quote }}
    matches:
      semver-constraint: ">= 4.0.0 < 5.0.0"
{{- end }}

command:

  jq:
    title: Verify jq is installed
    {{- if eq .osIDLike "debian" "fedora" }}
    exec: sh -c 'PATH="{{ .brewPrefix }}/bin:$PATH" jq --version'
    {{- else }}
    exec: jq --version
    {{- end }}
    exit-status: 0
    timeout: 2000

  yq:
    title: Verify yq is installed
    {{- if eq .osIDLike "debian" "fedora" }}
    exec: sh -c 'PATH="{{ .brewPrefix }}/bin:$PATH" yq --version'
    {{- else }}
    exec: yq --version
    {{- end }}
    exit-status: 0
    timeout: 2000
