mount:
  /:
    exists: true
{{- if not $rootImmutable }}
    usage:
      lt: 90
{{- end }}
{{- if $rootImmutable }}
  {{ env "HOME" | dir }}:
    exists: true
    timeout: 1000
    opts:
      - rw
    usage:
      lt: 95
{{- end }}

