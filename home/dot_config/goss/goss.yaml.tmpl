{{- $ports := dict
  "docker-plain" 2375
  "docker-tls" 2376
  "telnet" 23
  "vnc" 5900
-}}

{{- $rootImmutable := has (get .chezmoi.osRelease "variantID") (list
  "silverblue"
  "kinoite"
  "sericea"
  "onyx"
  "lazurite"
  "bazzite"
  "aurora"
  "bluefin"
) -}}

{{- $gossDir := joinPath .chezmoi.homeDir ".config/goss" -}}
{{- $src := joinPath .chezmoi.sourceDir "dot_config" -}}
{{- $gossDirFiles := glob (joinPath $gossDir "goss.d/*.goss.yaml") -}}
{{- $featureFiles := list -}}
{{- range glob (joinPath $src "*/.goss.yaml") -}}
{{-   $feat := base (dir .) -}}
{{-   if and (hasKey $.features $feat) (not (get $.features $feat)) }}{{ continue }}{{ end -}}
{{-   $featureFiles = append $featureFiles . -}}
{{- end -}}

# https://github.com/goss-org/goss/blob/master/docs/goss.yaml
---
addr:
{{- range $name := keys $ports | sortAlpha }}
  127.0.0.1:{{ index $ports $name }}:
    title: {{ $name }}
    reachable: false
    timeout: 500
{{- end }}
{{- if .features.ai }}
{{-   range $name, $provider := .ai.providers }}
{{-     if not (hasKey $provider "port") }}{{ continue }}{{ end }}
{{-     $active := hasKey $provider "active" | ternary (get $provider "active") false }}
  127.0.0.1:{{ $provider.port }}:
    title: {{ $name }} ({{ $active | ternary "active" "inactive" }})
    reachable: {{ $active }}
    timeout: 1000
{{-   end }}
{{- end }}

file:
  /etc/hosts:
    exists: true
    mode: "0644"
    owner: root
    group: {{ eq .os "linux" | ternary "root" "wheel" }}
    filetype: file
  /etc/passwd:
    exists: true
    mode: "0644"
    owner: root
    group: {{ eq .os "linux" | ternary "root" "wheel" }}
    filetype: file

dns:
  localhost:
    addrs:
{{- if not .wsl }}
      - ::1
{{- end }}
      - 127.0.0.1
    resolvable: true

# group:
