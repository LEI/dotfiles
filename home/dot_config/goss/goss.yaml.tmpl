{{- $scripts := glob (joinPath .chezmoi.sourceDir "dot_config/goss/exact_check/*.sh*") }}
{{- $hasCommands := or
    (eq .os "darwin")
    (and (eq .os "linux") (ne (env "CONTAINER_PROVIDER") ""))
    $scripts }}

# System health
{{- if $hasCommands }}
command:
{{- if eq .os "darwin" }}
  docker-engine:
    exec: docker info --format '{{ `{{ "{{.ServerVersion}}" }}` }}'
    exit-status: 0
    timeout: 5000
{{- range $name, $svc := get . "services" | default dict }}
{{- if not (get $.features (get $svc "feature")) }}{{ continue }}{{ end }}
  launchd-{{ $name }}:
    exec: launchctl print gui/$(id -u)/{{ $svc.label }} 2>/dev/null | grep -q 'pid ='
    exit-status: 0
    timeout: 3000
{{- end }}
{{- range $name, $p := .ai.providers }}
{{- if not (hasKey $p "label") }}{{ continue }}{{ end }}
{{- $active := or (eq $name $localProvider) (eq (get $p "parent" | default "") $localProvider) }}
  launchd-{{ $name }}:
    exec: launchctl print gui/$(id -u)/{{ $p.label }} 2>/dev/null | grep -q 'pid ='
    exit-status: {{ if $active }}0{{ else }}{ gt: 0 }{{ end }}
    timeout: 3000
{{- end }}
{{- end }}
{{- if and (eq .os "linux") (ne (env "CONTAINER_PROVIDER") "") }}
  container-engine:
    exec: {{ env "CONTAINER_PROVIDER" }} info --format '{{ `{{ "{{.ServerVersion}}" }}` }}'
    exit-status: 0
    timeout: 5000
{{- end }}
{{- range $scripts }}
  check-{{ trimSuffix ".sh" (trimSuffix ".tmpl" (base .)) }}:
    exec: sh check/{{ trimSuffix ".tmpl" (base .) }}
    exit-status: 0
    timeout: 120000
{{- end }}
{{- end }}

{{- if eq .os "linux" }}
service:
{{- range $name, $svc := get . "services" | default dict }}
{{- if not (get $.features (get $svc "feature")) }}{{ continue }}{{ end }}
  # {{ $name }}:
  #   enabled: true
  #   running: true
{{- end }}
{{- if .features.ai }}
{{- range $name, $p := .ai.providers }}
{{- if not (hasKey $p "label") }}{{ continue }}{{ end }}
{{- $active := or (eq $name $localProvider) (eq (get $p "parent" | default "") $localProvider) }}
  {{ $name }}:
    enabled: {{ $active }}
    running: {{ $active }}
{{- end }}
{{- end }}
{{- end }}

{{- $src := joinPath .chezmoi.sourceDir "dot_config" }}
{{- $gossFiles := glob (printf "%s/*/.goss.yaml" $src) }}
{{- $enabledFiles := list }}
{{- range $gossFiles }}
{{- if not (get $.features (base (dir .))) }}{{ continue }}{{ end }}
{{- $enabledFiles = append $enabledFiles . }}
{{- end }}
{{- if $enabledFiles }}

gossfile:
{{- range $enabledFiles }}
  {{ . }}: {}
{{- end }}
{{- end }}

# Health checks from caddy.sites + ai.providers
{{- $checks := dict }}
{{- if hasKey . "caddy" }}
{{- range $feat, $sites := .caddy.sites }}
{{- if not (get $.features $feat) }}{{ continue }}{{ end }}
{{- range $name, $site := $sites }}
{{- if hasKey $site "enabled" }}{{ if not (get $site "enabled") }}{{ continue }}{{ end }}{{ end }}
{{- $entry := dict "url" (printf "https://%s.test%s" $name (get $site "health" | default "")) }}
{{- if get $site "body" }}{{ $_ := set $entry "body" (get $site "body") }}{{ end }}
{{- $_ := set $checks $name $entry }}
{{- end }}
{{- end }}
{{- end }}
{{- if and (hasKey . "ai") (get $.features "caddy") }}
{{- range $name, $provider := .ai.providers }}
{{- if not (hasKey $provider "domain") }}{{ continue }}{{ end }}
{{- if not (or (eq $name $localProvider) (eq (get $provider "parent") $localProvider)) }}{{ continue }}{{ end }}
{{- $entry := dict "url" (printf "https://%s%s" $provider.domain (get $provider "health" | default "")) }}
{{- if get $provider "body" }}{{ $_ := set $entry "body" (get $provider "body") }}{{ end }}
{{- $_ := set $checks $name $entry }}
{{- end }}
{{- end }}
{{- if $checks }}

http:
{{- range $name, $check := $checks }}
  {{ $check.url }}:
    status: 200
    timeout: 5000
{{- if hasKey $check "body" }}
    body:
      - {{ index $check "body" | quote }}
{{- end }}
{{- end }}
{{- end }}
