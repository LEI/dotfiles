# https://consented.io/do-not-track
DO_NOT_TRACK=1

{{- $ca := "" }}
{{- $caPathNew := "/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem" }}
{{- $caPathOld := "/etc/pki/tls/certs/ca-bundle.crt" }}

{{- if stat $caPathNew }}
{{-   $ca = $caPathNew }}
{{- else if stat $caPathOld }}
{{-   $ca = $caPathOld }}
{{- end }}

{{- if $ca }}

# System CA bundle for brew curl and Python (Fedora 44 removed ca-bundle.crt)
CURL_CA_BUNDLE={{ $ca }}
SSL_CERT_FILE={{ $ca }}
{{- end }}
