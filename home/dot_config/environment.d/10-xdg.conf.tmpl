# Config path redirects: tools that don't follow XDG by default, alphabetical by var name
# shellcheck disable=SC2034
{{- if .features.rust }}
CARGO_HOME=$XDG_DATA_HOME/cargo
{{- end }}
{{- if lookPath "curl" | isExecutable }}
CURL_HOME=$XDG_CONFIG_HOME/curl
{{- end }}
{{- if .features.docker }}
DOCKER_CONFIG=$XDG_CONFIG_HOME/docker
{{- end }}
{{- if lookPath "eza" | isExecutable }}
EZA_CONFIG_DIR=$XDG_CONFIG_HOME/eza
{{- end }}
{{- if .features.ruby }}
GEM_SPEC_CACHE=$XDG_CACHE_HOME/gem
{{- end }}
{{- if .features.go }}
GOPATH=$XDG_DATA_HOME/go
{{- end }}
INPUTRC=$XDG_CONFIG_HOME/readline/inputrc
{{- if .features.kube }}
KREW_ROOT=$HOME/.krew
KUBECONFIG=${KUBECONFIG:-$HOME/.kube/config}
KUBERC=$XDG_CONFIG_HOME/kube/kuberc.yaml
{{- end }}
{{- if lookPath "less" | isExecutable }}
LESSHISTFILE=$XDG_STATE_HOME/less/history
{{- end }}
{{- if .features.git }}
LG_CONFIG_FILE=$XDG_CONFIG_HOME/lazygit/theme.yml,$XDG_CONFIG_HOME/lazygit/config.yml
{{- end }}
{{- if .features.node }}
NPM_CONFIG_USERCONFIG=$XDG_CONFIG_HOME/npm/npmrc
npm_config_prefix=$XDG_DATA_HOME/npm
PNPM_HOME=$XDG_DATA_HOME/pnpm
{{- end }}
{{- if .features.ai }}
PI_CONFIG_DIR=$XDG_CONFIG_HOME/pi
PI_CODING_AGENT_DIR=$XDG_CONFIG_HOME/pi/agent
{{- end }}
{{- /* lookPath "psql" | isExecutable */ -}}
{{- if .features.sql }}
PSQLRC=$XDG_CONFIG_HOME/psql/psqlrc
{{- end }}
{{- if lookPath "rg" | isExecutable }}
RIPGREP_CONFIG_PATH=$XDG_CONFIG_HOME/ripgrep/config
{{- end }}
{{- if .features.rust }}
RUSTUP_HOME=$XDG_DATA_HOME/rustup
{{- end }}
{{- if lookPath "starship" | isExecutable }}
STARSHIP_CONFIG=$XDG_CONFIG_HOME/starship/starship.toml
{{- end }}
{{- if .features.kube }}
TALOSCONFIG=${TALOSCONFIG:-$HOME/.talos/config}
{{- end }}
{{- if lookPath "wget" | isExecutable }}
WGETRC=$XDG_CONFIG_HOME/wget/wgetrc
{{- end }}
