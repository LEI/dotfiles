{{- if and .features.otel .features.oage -}}
#!/bin/sh

# provider: {{ env "CONTAINER_PROVIDER" }}

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

if ! "$CONTAINER_PROVIDER" info >/dev/null 2>&1; then
  msg "SKIP: $CONTAINER_PROVIDER is not running"
  exit 0
fi

if ! "$CONTAINER_PROVIDER" network inspect monitoring >/dev/null 2>&1; then
  run "$CONTAINER_PROVIDER" network create monitoring
fi
{{ end -}}
