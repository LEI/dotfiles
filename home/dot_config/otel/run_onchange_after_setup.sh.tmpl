{{- $compose := joinPath .chezmoi.homeDir ".config/otel/compose.yaml" -}}
{{- if stat $compose -}}
{{- $prometheusConfig := joinPath .chezmoi.homeDir ".config/otel/prometheus.yaml" -}}
{{- $alertRulesDir := joinPath .chezmoi.homeDir ".config/otel/exact_alerts" -}}
{{- $otelCollectorConfig := joinPath .chezmoi.homeDir ".config/otel/otel-collector-config.yaml" -}}
{{- $grafanaProvDir := joinPath .chezmoi.homeDir ".config/otel/exact_grafana/exact_provisioning" -}}
{{- $lokiConfig := joinPath .chezmoi.homeDir ".config/otel/loki.yaml" -}}
{{- $tempoConfig := joinPath .chezmoi.homeDir ".config/otel/tempo.yaml" -}}
{{- $alertContent := "" -}}
{{- range glob (printf "%s/*.yaml" $alertRulesDir) -}}
{{-   $alertContent = printf "%s%s" $alertContent (include .) -}}
{{- end -}}
#!/bin/sh
set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"
# shellcheck source=home/dot_local/lib/sh/install.sh
. "$lib_dir/sh/install.sh"

compose_file="{{ $compose }}"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/otel"
mkdir -p "$state_dir"

provider="${CONTAINER_PROVIDER:?}"
compose() {
  run "$provider" compose --file="$compose_file" "$@"
}

# compose hash: "{{ include $compose | fromYaml | toJson | sha256sum }}"
compose up --detach --remove-orphans

reload_if_changed() {
  name="$1"
  hash="$2"
  shift 2
  hash_file="$state_dir/$name.hash"
  if [ "$(cat "$hash_file" 2>/dev/null || true)" = "$hash" ]; then
    return 0
  fi
  log "reloading $name config"
  run "$@"
  printf '%s' "$hash" >"$hash_file"
}

prometheus_hash="{{ include $prometheusConfig | sha256sum }}{{ sha256sum $alertContent }}"
reload_if_changed prometheus "$prometheus_hash" \
  retry 10 2 curl -fsS -X POST http://localhost:9090/-/reload

# /-/reload can return 200 while the container still reads a stale bind-mount,
# so verify the running config via the self-metric and restart on drift.
prometheus_loaded() {
  curl -fsS http://localhost:9090/metrics 2>/dev/null |
    grep -qE '^prometheus_config_last_reload_successful 1$'
}
if ! retry 30 1 prometheus_loaded; then
  log "prometheus running a stale or invalid config, restarting"
  compose restart prometheus
  retry 30 1 prometheus_loaded || die "prometheus config never loaded"
fi

otelcol_hash="{{ include $otelCollectorConfig | sha256sum }}"
reload_if_changed otel-collector "$otelcol_hash" \
  compose restart otel-collector
# FIXME: compose exec otel-collector kill -HUP 1

grafana_netrc=""
grafana_reload() {
  if [ -z "$grafana_netrc" ]; then
    grafana_secret="${XDG_CONFIG_HOME:-$HOME/.config}/otel/secrets/grafana-admin-password"
    if ! grafana_pass=$(cat "$grafana_secret"); then
      die "missing grafana-admin-password"
    fi
    grafana_netrc=$(mktemp)
    trap 'rm -f "$grafana_netrc"' EXIT
    (
      umask 177
      printf 'machine localhost login admin password %s\n' "$grafana_pass" >"$grafana_netrc"
    )
  fi
  run curl -fsS --netrc-file "$grafana_netrc" -X POST "http://localhost:3033/api/admin/provisioning/$1/reload"
  echo
}

{{- range list "alerting" "dashboards" "datasources" }}
{{- $section := . }}
{{- $dir := joinPath $grafanaProvDir $section }}
{{- $dirContent := "" }}
{{- range glob (printf "%s/*.yaml" $dir) }}
{{-   $dirContent = printf "%s%s" $dirContent (include .) }}
{{- end }}

grafana_{{ $section }}_hash="{{ sha256sum $dirContent }}"
reload_if_changed "grafana-{{ $section }}" "$grafana_{{ $section }}_hash" \
  grafana_reload {{ $section }}
{{- end }}

grafana_pass=""
grafana_secret="${XDG_CONFIG_HOME:-$HOME/.config}/otel/secrets/grafana-admin-password"
if [ -f "$grafana_secret" ]; then
  grafana_pass=$(cat "$grafana_secret")
fi

create_grafana_sa() {
  sa_name="$1"
  sa_role="$2"
  token_name="$3"
  token_file="$4"
  if [ -s "$token_file" ]; then
    return 0
  fi
  if [ -z "$grafana_pass" ]; then
    die "no grafana-admin-password; cannot create $sa_name service account"
  fi
  log "creating grafana MCP $sa_name service account ($sa_role)"
  sa_id=$(curl -fsS -u "admin:$grafana_pass" \
    "http://localhost:3033/api/serviceaccounts/search?query=$sa_name&limit=1" |
    jq -r --arg name "$sa_name" '.serviceAccounts[] | select(.name == $name) | .id // empty' | head -1)
  if [ -z "$sa_id" ]; then
    sa_id=$(curl -fsS -u "admin:$grafana_pass" \
      -X POST http://localhost:3033/api/serviceaccounts \
      -H 'Content-Type: application/json' \
      -d "$(printf '{"name":"%s","role":"%s"}' "$sa_name" "$sa_role")" | jq -r '.id')
  fi
  token=$(curl -fsS -u "admin:$grafana_pass" \
    -X POST "http://localhost:3033/api/serviceaccounts/$sa_id/tokens" \
    -H 'Content-Type: application/json' \
    -d "$(printf '{"name":"%s"}' "$token_name")" | jq -r '.key')
  (
    umask 177
    printf '%s' "$token" >"$token_file"
  )
  log "grafana MCP $sa_name token written"
}

# Read-only SA (Viewer): default for safe day-to-day operations
create_grafana_sa mcp Viewer mcp-token \
  "${XDG_CONFIG_HOME:-$HOME/.config}/otel/secrets/grafana-mcp-token"

# Admin SA (Admin): only used when write operations are explicitly needed
# Admin role required for folders:create in Grafana 13 (Editor can't create folders)
create_grafana_sa mcp-admin Admin mcp-admin-token \
  "${XDG_CONFIG_HOME:-$HOME/.config}/otel/secrets/grafana-mcp-token-admin"

loki_hash="{{ include $lokiConfig | sha256sum }}"
reload_if_changed loki "$loki_hash" \
  compose restart loki

tempo_hash="{{ include $tempoConfig | sha256sum }}"
reload_if_changed tempo "$tempo_hash" \
  compose restart tempo
{{ end -}}
