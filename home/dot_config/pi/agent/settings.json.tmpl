{{- $profile := index .ai.profiles .pi.profile -}}
{{- $parts := splitList "/" $profile.coding -}}
{{- $provider := first $parts -}}
{{- $model := join "/" (rest $parts) -}}
{
  "lastChangelogVersion": "{{ .pi.version }}",
  "defaultProvider": {{ $provider | quote }},
  "defaultModel": {{ $model | quote }},
  "defaultThinkingLevel": "off",
  "enableInstallTelemetry": false,
  "packages": ["npm:pi-telemetry-otel@0.1.1"]
}
