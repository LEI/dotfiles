{{- if eq .osIDLike "debian" "fedora" -}}
#!/bin/sh

# https://ghostty.org/docs/install/binary

set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

if has ghostty; then
  msg "Ghostty already installed"
  run ghostty --version | head -n1
  exit
fi

msg "Installing ghostty"

{{- if eq .osID "debian" }}

# https://github.com/clayrisser/debian-ghostty
export DEBIAN_FRONTEND=noninteractive

. /etc/os-release
if [ "$VERSION_ID" -lt 13 ]; then
  msg "Adding clayrisser repository for Debian $VERSION_CODENAME"
  version_path="$VERSION_CODENAME/Debian_$VERSION_ID"
  echo "deb http://download.opensuse.org/repositories/home:/clayrisser:/$version_path/ /" |
    dry_run sudo tee "/etc/apt/sources.list.d/home:clayrisser:$VERSION_CODENAME.list"
  dry_run curl -fsSL "https://download.opensuse.org/repositories/home:clayrisser:$version_path/Release.key" |
    dry_run gpg --dearmor |
    dry_run sudo tee "/etc/apt/trusted.gpg.d/home_clayrisser_$VERSION_CODENAME.gpg" >/dev/null
else
  msg "Adding clayrisser repository for Debian sid"
  dry_run curl -fsSL https://download.opensuse.org/repositories/home:clayrisser:sid/Debian_Unstable/Release.key |
    dry_run gpg --dearmor |
    dry_run sudo tee /etc/apt/keyrings/home_clayrisser_sid.gpg >/dev/null
  dry_run sudo tee /etc/apt/sources.list.d/home:clayrisser:sid.sources >/dev/null <<EOF
Types: deb
URIs: http://download.opensuse.org/repositories/home:/clayrisser:/sid/Debian_Unstable/
Suites: /
Signed-By: /etc/apt/keyrings/home_clayrisser_sid.gpg
EOF
fi

dry_run sudo apt-get update --quiet >/dev/null
dry_run sudo -E apt-get install --quiet --yes ghostty >/dev/null

{{- else if eq .osID "ubuntu" }}

# https://github.com/mkasberg/ghostty-ubuntu
export DEBIAN_FRONTEND=noninteractive

version="$(get_release mkasberg/ghostty-ubuntu)"
SUFFIX="${version##*-}" # ppa2
version="${version%-*}" # 1.1.3-0
ARCH="$CHEZMOI_ARCH"
. /etc/os-release
URL="https://github.com/mkasberg/ghostty-ubuntu/releases/download/${version}-${SUFFIX}/ghostty_${version}.${SUFFIX}_${ARCH}_$VERSION_ID.deb"

msg "Downloading ghostty $version"
dry_run curl -LSfs "$URL" -o "$TMPDIR/ghostty.deb"
dry_run sudo apt-get install --quiet --yes "$TMPDIR/ghostty.deb"

{{- else if eq .osID "fedora" }}

if has dnf; then
  msg "Installing ghostty via dnf copr"
  dry_run sudo dnf copr enable --assumeyes --quiet scottames/ghostty
  # dry_run sudo dnf install --nogpgcheck --repofrompath 'terra,https://repos.fyralabs.com/terra$releasever' terra-release
  dry_run sudo dnf install --assumeyes --quiet ghostty
elif has rpm-ostree; then
  msg "Installing ghostty via rpm-ostree"
  . /etc/os-release
  url="https://copr.fedorainfracloud.org/coprs/scottames/ghostty/repo/fedora-${VERSION_ID}/scottames-ghostty-fedora-${VERSION_ID}.repo"
  file=/etc/yum.repos.d/_copr:copr.fedorainfracloud.org:scottames:ghostty.repo
  dry_run curl -fsSL "$url" | dry_run sudo tee "$file" >/dev/null
  dry_run rpm-ostree refresh-md
  dry_run rpm-ostree install --allow-inactive --assumeyes --idempotent ghostty
else
  die "unsupported package manager"
fi

{{- end }}

msg "Installed ghostty"
{{ end -}}
