---
# https://github.com/chezmoi/dotfiles/blob/master/.chezmoi.yaml.tmpl
{{- $ephemeral := env "CHEZMOI_EPHEMERAL" | not | not }}
{{- $headless := env "CHEZMOI_HEADLESS" | not | not }}
{{- $preset := env "CHEZMOI_PRESET" | default (ne .chezmoi.os "windows" | ternary "font" "text") }}
{{- $profile := env "CHEZMOI_PROFILE" }}
{{- $system := env "CHEZMOI_SYSTEM" | default ($headless | ternary "server" "client") }}
{{- $upgrade := eq (env "CHEZMOI_UPGRADE") "true" }}

{{- $homeDir := .chezmoi.homeDir | default (env "HOME") }}
{{- $binDir := joinPath $homeDir ".local" "bin" }}
{{- $brewPrefix := "/usr/local" }}
{{- if eq .chezmoi.os "linux" }}{{ $brewPrefix = "/home/linuxbrew/.linuxbrew" }}
{{- else if eq .chezmoi.arch "arm64" }}{{ $brewPrefix = "/opt/homebrew" }}
{{- end }}

{{- $ci := eq (env "CI") "true" }}
{{- $codespaces := env "CODESPACES" | not | not }}
{{- $container := includeTemplate "container.tmpl" dict | trim }}
{{- $isContainer := not (empty $container) }}
{{- $devContainer := env "REMOTE_CONTAINERS" | not | not }}

{{- $interactive := stdinIsATTY }}

{{- $vm := false }}
{{- if and (eq .chezmoi.os "darwin") (lookPath "sysctl" | isExecutable) }}
{{-   $vm = eq (output "sysctl" "-n" "kern.hv_vmm_present" | trim) "1" }}
{{- else if and (eq .chezmoi.os "linux") (lookPath "systemd-detect-virt" | isExecutable) }}
{{-   $vm = ne (output "sh" "-c" "systemd-detect-virt 2>/dev/null || true" | trim) "none" }}
{{- end }}

{{- $wsl := and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}

{{- /* (eq .chezmoi.username "root" "ubuntu" "vagrant" "vscode") */ -}}
{{- if or $ci $codespaces $isContainer $devContainer $vm }}
{{-   $ephemeral = true }}
{{-   $headless = true }}
{{- else if $interactive }}
{{-   $ephemeral = promptBoolOnce . "ephemeral" "ephemeral" }}
{{-   $headless = promptBoolOnce . "headless" "headless" }}
{{- end }}

{{- $profileChoices := list "minimal" "personal" "work" }}
{{- if and $interactive (not $profile) }}
{{-   $profile = promptChoiceOnce . "profile" "profile" $profileChoices }}
{{- else if and (not $profile) (not $ephemeral) }}
{{-   fail "profile is required: set CHEZMOI_PROFILE or run chezmoi init interactively" }}
{{- end }}

{{- writeToStdout (printf "Profile: %s (ephemeral: %v, headless: %v)\n" $profile $ephemeral $headless) }}

{{- if and $isContainer .chezmoi.config.verbose }}
{{-   warnf "container type: %s" $container }}
{{- end }}
{{- if and $vm .chezmoi.config.verbose }}
{{-   warnf "virtual machine" }}
{{- end }}

{{- $osID := get .chezmoi.osRelease "id" | default .chezmoi.os }}
{{- $osIDLikeRaw := get .chezmoi.osRelease "idLike" | default $osID }}
{{- $osIDLike := $osIDLikeRaw }}
{{- if kindIs "array" $osIDLikeRaw }}
{{-   $osIDLike = first $osIDLikeRaw }}
{{- else if kindIs "string" $osIDLikeRaw }}
{{-   $osIDLike = $osIDLikeRaw | splitList " " | first }}
{{- end }}
{{- $osVersion := get .chezmoi.osRelease "versionID" }}
{{- if and (eq $osID "linux") (eq (env "HOME") "/data/data/com.termux/files/home") }}
{{-   $osID = "android" }}
{{- end }}

{{- $variantID := get (get .chezmoi "osRelease" | default dict) "variantID" }}

{{- $hardware := includeTemplate "hardware.json.tmpl" (dict "chezmoi" .chezmoi) | fromJson }}

{{- $hostname := .chezmoi.hostname }}
{{- $computerName := "" }}
{{- $softwareVersion := dict }}
{{- if and (eq .chezmoi.os "darwin") (lookPath "scutil" | isExecutable) }}
{{-   $hostname = output "scutil" "--get" "LocalHostName" | trim }}
{{-   $computerName = output "scutil" "--get" "ComputerName" | trim }}
{{-   if lookPath "sw_vers" | isExecutable }}
{{-     $parts := output "sw_vers" | replaceAllRegex "\\t\\t" " " | replaceAllRegex "\\t" " " | splitList "\n" }}
{{-     $_ := set $softwareVersion "productName" (index (index $parts 0 | splitList ": ") 1) }}
{{-     $_ := set $softwareVersion "productVersion" (index (index $parts 1 | splitList ": ") 1 | float64) }}
{{-     $_ := set $softwareVersion "buildVersion" (index (index $parts 2 | splitList ": ") 1) }}
{{-   end }}
{{- else if eq $hostname "docker" "podman" }}
{{-   $hostname = output "sh" "-c" "hostname 2>/dev/null || echo" | trim | default $hostname }}
{{- end }}

{{- $user := env "USER" }}
{{- if not $user }}
{{-   $user = lookPath "id" | isExecutable | ternary (output "id" "-un" | trim) "" }}
{{- end }}
{{- $name := env "NAME" | default $user }}
{{- $email := env "EMAIL" | default (printf "%s@localhost" $user) }}
{{- $accessToken := "" }}

{{- if hasKey . "name" }}
{{-   $name = .name }}
{{- else if env "GIT_CONFIG_USER_NAME" }}
{{-   $name = env "GIT_CONFIG_USER_NAME" }}
{{- else if $interactive }}
{{-   $name = promptString "name" $name }}
{{- end }}

{{- if hasKey . "email" }}
{{-   $email = .email }}
{{- else if env "GIT_CONFIG_USER_EMAIL" }}
{{-   $email = env "GIT_CONFIG_USER_EMAIL" }}
{{- else if $interactive }}
{{-   $email = promptString "email" $email }}
{{- end }}

{{- if and (hasKey . "passwordManager") (hasKey .passwordManager "accessToken") }}
{{-   $accessToken = .passwordManager.accessToken }}
{{- else if env "BWS_ACCESS_TOKEN" }}
{{-   $accessToken = env "BWS_ACCESS_TOKEN" }}
{{- else if and $interactive }}
{{-   $accessToken = promptString "BWS accessToken (optional)" $accessToken }}
{{- end }}

{{- if $interactive }}
{{-   writeToStdout "💡 Tip: you can re-enter your name and email with `chezmoi init --data=false`.\n" }}
{{- end }}

# /lib/x86_64-linux-gnu/libc.so.6: version `GLIBC_2.32' not found
{{- $libc := includeTemplate "libc.tmpl" . | trim }}

{{- $mise := dict "interactive" false "version" "" -}}
{{- with lookPath "mise" -}}
{{-   $version := output "sh" "-c" (printf "MISE_QUIET=1 %q --version || true" .) | splitList " " | first -}}
{{-   if $version -}}
{{-     $_ := set $mise "version" $version -}}
{{-     $_ := set $mise "interactive" (semverCompare ">=2026.3.4" $version) -}}
{{-   end -}}
{{- end -}}

{{- $usage := dict "version" "" -}}
{{- with lookPath "usage" -}}
{{-   $version := output "usage" "--version" | trim -}}
{{-   if $version -}}
{{-     $_ := set $usage "version" $version -}}
{{-   end -}}
{{- end -}}

{{- $featureMap := dict
  "cargo" "rust"
  "homebrew" "brew"
  "gem" "ruby"
  "krew" "kube"
  "npm" "node"
  "nvim" "neovim"
  "pi" "ai"
-}}

{{- $data := dict
  "arch" .chezmoi.arch
  "chassisType" $hardware.system.chassisType
  "chassisVendor" $hardware.system.vendor
  "computerName" $computerName
  "ci" $ci
  "codespaces" $codespaces
  "container" $isContainer
  "devContainer" $devContainer
  "ephemeral" $ephemeral
  "featureMap" $featureMap
  "gui" (and (ne $profile "minimal") (not (or $ephemeral $headless)))
  "hardware" $hardware
  "headless" $headless
  "hostname" $hostname
  "libc" $libc
  "mise" $mise
  "os" .chezmoi.os
  "osID" $osID
  "osIDLike" $osIDLike
  "osVersion" $osVersion
  "passwordManager" (dict "accessToken" $accessToken)
  "profile" $profile
  "sessionType" (env "XDG_SESSION_TYPE")
  "softwareVersion" $softwareVersion
  "system" $system
  "usage" $usage
  "variantID" $variantID
  "vm" $vm
  "wsl" $wsl

  "email" $email
  "name" $name
}}

{{- $features := includeTemplate "features.json.tmpl" $data | fromJson }}
{{- $_ := set $data "features" $features }}

{{- if and $features.caddy $features.tailscale -}}
{{-   $caddyTailscaleOauthSecret := "" -}}
{{-   if not $headless -}}
{{-     $caddyTailscaleOauthSecret = promptStringOnce . "caddy.tailscale.oauthSecret" "Caddy Tailscale OAuth client secret (leave empty to skip; run chezmoi edit-config to set later)" -}}
{{-   end -}}
{{-   $_ := set $data "caddy" (dict "tailscale" (dict "oauthSecret" $caddyTailscaleOauthSecret)) -}}
{{- end -}}

{{- if $features.btrfs -}}
{{-   $btrfsBackupUuid := "" -}}
{{-   if not $headless -}}
{{-     $btrfsBackupUuid = promptStringOnce . "btrfs.backup.deviceUuid" "btrfs backup partition UUID (leave empty to skip)" -}}
{{-   end -}}
{{-   $_ := set $data "btrfs" (dict "backup" (dict "deviceUuid" $btrfsBackupUuid)) -}}
{{- end -}}

{{- $containerProvider := env "CONTAINER_PROVIDER" }}
{{- if not $containerProvider }}
{{-   if lookPath "podman" | isExecutable }}{{ $containerProvider = "podman" }}
{{-   else if lookPath "docker" | isExecutable }}{{ $containerProvider = "docker" }}
{{-   end }}
{{- end }}

{{- $timezone := includeTemplate "timezone.tmpl" $data | trim }}
{{- $_ := set $data "timezone" $timezone }}

# https://www.chezmoi.io/user-guide/encryption/age/
# encryption: age
# age:
#   identity: {{ env "HOME" }}/key.txt
#   recipient: age12wkemshyplj4chhlz5e8tf9klsyuyxjuuzz6r0nxapjf4zq0sepqcdhfn0

{{- if eq $osID "windows" }}
interpreters:
  sh:
    command: {{ lookPath "sh" }} # "C:\\Windows\\System32\\bash.exe" # Get-Command bash
{{- else if ne $osID "android" }}
# https://www.chezmoi.io/user-guide/advanced/install-your-password-manager-on-init/
hooks:
  read-source-state:
    pre:
      command: "{{ .chezmoi.sourceDir }}/.install-password-manager.sh"
{{- end }}

sourceDir: {{ .chezmoi.sourceDir | quote }}

data:
  prefix: {{ eq $data.os "android" | ternary "/data/data/com.termux/files" "" | quote }}
  brewPrefix: {{ $brewPrefix | quote }}
  containerProvider: {{ $containerProvider | quote }}
  theme: tokyonight
  user: {{ $user | quote }}
{{ $data | toYaml | indent 2 }}
  preset: {{ $preset | quote }}
  upgrade: {{ $upgrade }}

  symbols:
    prompt: {{ eq $preset "font" | ternary " " ">" | quote }}
    error: {{ eq $preset "font" | ternary " " "x" | quote }}
  # term: truecolor

{{- if and $features.git $accessToken (lookPath "bws" | isExecutable) }}

  # https://www.chezmoi.io/user-guide/password-managers/bitwarden/#bitwarden-secrets-cli
  git:
{{ (bitwardenSecrets "0ecca3dd-3404-47d5-8a14-b333014a23ca" $accessToken).value | fromYaml | toYaml | indent 4 }}
{{- if eq $profile "personal" }}
    personal:
{{ (bitwardenSecrets "300f9f66-dccf-4de8-8249-b3330154d542" $accessToken).value | fromYaml | toYaml | indent 6 }}
{{- end }}
{{- if eq $profile "work" }}
    work:
{{ (bitwardenSecrets "ff633e02-2cc7-4dc4-87f8-b3330154baf8" $accessToken).value | fromYaml | toYaml | indent 6 }}
{{- end }}
{{- end }}

{{- if and $features.mail $accessToken (lookPath "bws" | isExecutable) }}

  mail:
    accounts:
{{ (bitwardenSecrets "f8af12df-ee8e-4146-9272-b32f00a37b5e" $accessToken).value | fromYaml | toYaml | indent 6 }}
    queries:
{{ (bitwardenSecrets "76589c60-aae2-4c2f-b500-b32f00750c0a" $accessToken).value | fromYaml | toYaml | indent 6 }}
{{- end }}

{{- $packageManagerMap := dict
  "alpine" "apk"
  "android" "termux"
  "arch" "pacman"
  "darwin" "brew"
  "debian" "apt"
  "fedora" (lookPath "dnf" | isExecutable | ternary "dnf" "rpm")
  "opensuse" "zypper"
  "rhel" (lookPath "dnf" | isExecutable | ternary "dnf" "rpm")
  "windows" "winget"
}}
{{- $packageManager := get $packageManagerMap $osIDLike }}
  packageManager: {{ $packageManager | quote }}
{{- $packages := includeTemplate "packages-data.yaml.tmpl" (mergeOverwrite (dict) $data (dict
  "arch" .chezmoi.arch
  "chezmoi" .chezmoi
  "defaultType" $packageManager
  "os" .chezmoi.os
  "osID" $osID
  "osIDLike" $osIDLike
  "packageManager" $packageManager
  "packages" (get . "packages" | default (dict $packageManager dict))
  "variantID" $variantID
)) | fromYaml }}
  packages:
{{ $packages | toYaml | indent 4 }}

{{- if and $features.tailscale (lookPath "tailscale" | isExecutable) }}

  tailscale:
    tailnet: {{ output "sh" "-c" "tailscale status --json 2>/dev/null | jq -r '.CertDomains[0] // empty' || true" | trim | quote }}
    ips: {{ output "sh" "-c" "tailscale status --json 2>/dev/null | jq -r '.Self.TailscaleIPs // empty' || true" | default "[]" | fromJson }}
{{- end }}

{{- if $features.ai }}
  ai:
    localProfile: {{ $features.mlx | ternary "mlx-local" "ollama-local" }}
    localProvider: {{ $features.mlx | ternary "mlx-lm" "ollama" }}
    providers:
      llama-server:
        active: false
      mlx-embed:
        active: {{ $features.mlx }}
      mlx-lm:
        active: {{ $features.mlx }}
      ollama:
        active: {{ and $features.ollama (not $features.mlx) }}
      vllm-mlx:
        active: false
{{- end }}

{{- if $features.ollama }}
  ollama:
    version: "0.21.0"
{{-   if eq .chezmoi.os "darwin" }}
    service: brew
{{-   else if and (lookPath "podman" | isExecutable) (stat "/run/systemd/system") }}
    container: systemd-ollama
    service: quadlet
{{-   else if $containerProvider }}
    container: oage-ollama-1
    service: compose
{{-   end }}
{{- end }}

{{- /* Discover data dirs: union of dirs containing .data.yaml or create_*local.yaml */ -}}
{{- $dataDirSet := dict -}}
{{- range glob (joinPath .chezmoi.sourceDir "**" ".data.yaml") -}}
{{-   $rel := . | dir | trimPrefix (printf "%s/" $.chezmoi.sourceDir) -}}
{{-   $_ := set $dataDirSet $rel "" -}}
{{- end -}}
{{- range glob (joinPath .chezmoi.sourceDir "**" "create_*local.yaml*") -}}
{{-   $rel := . | dir | trimPrefix (printf "%s/" $.chezmoi.sourceDir) -}}
{{-   $_ := set $dataDirSet $rel "" -}}
{{- end -}}
{{- $always := list "apis" "process-compose" -}}
{{- $splice := list "process-compose" -}}
{{- range $dir := keys $dataDirSet | sortAlpha -}}
{{-   $key := base $dir | trimPrefix "dot_" -}}
{{-   if or (has $key $always) (get $features $key) -}}
{{-     if has $key $splice -}}
{{-       $pcData := includeTemplate "data.tmpl" (dict "dir" $dir "chezmoi" $.chezmoi) | trim -}}
{{-       if and $pcData (ne $pcData "{}") }}
{{ $pcData | indent 2 }}
{{-       end -}}
{{-     else if eq $key "openpackage" -}}
{{-       $platforms := list -}}
{{-       if $features.claude }}{{- $platforms = append $platforms "claude" -}}{{- end -}}
{{-       if $features.codex }}{{- $platforms = append $platforms "codex" -}}{{- end -}}
{{-       if $features.opencode }}{{- $platforms = append $platforms "opencode" -}}{{- end -}}
{{-       if $features.pi }}{{- $platforms = append $platforms "pimono" -}}{{- end -}}
{{-       $opkgData := includeTemplate "data.tmpl" (dict "dir" $dir "chezmoi" $.chezmoi) | fromYaml | default dict -}}
{{-       $_ := set $opkgData "platforms" $platforms }}

  openpackage:
{{ $opkgData | toYaml | indent 4 -}}
{{-     else }}

  {{ $key }}:
{{ includeTemplate "data.tmpl" (dict "dir" $dir "chezmoi" $.chezmoi) | indent 4 -}}
{{-     end -}}
{{-   end -}}
{{- end }}

diff:
  # exclude:
  #   - externals
  #   - scripts
# {{- if lookPath "difft" | isExecutable }}
#   # https://github.com/twpayne/chezmoi/discussions/2097
#   command: difft
#   args: [--color=always, --skip-unchanged]
#   pager: cat # less
# {{- else if lookPath "delta" | isExecutable }}
#   pager: delta
# {{- else if $codespaces }}
#   # command: code
#   # args: [--wait, --diff]
# {{- end }}

github:
  refreshPeriod: 12h

# WARN: only one of env or scriptEnv may be set
# env: {}
scriptEnv:
  # USER: {{ $user }}

  LIBC: {{ $libc | quote }}

{{- if eq $osID "debian" }}
  DEBIAN_FRONTEND: noninteractive
{{- end }}

{{- if $features.brew }}
  HOMEBREW_BAT: "1"
  # HOMEBREW_GITHUB_API_TOKEN: ""
  HOMEBREW_NO_ANALYTICS: "1"
  HOMEBREW_NO_ASK: "1"
  HOMEBREW_NO_AUTO_UPDATE: "1"
  HOMEBREW_NO_ENV_HINTS: "1"
  HOMEBREW_PREFIX: {{ env "HOMEBREW_PREFIX" | default $brewPrefix | quote }}
  NONINTERACTIVE: "1"
{{- end }}

{{- if ne $osID "windows" }}
{{- $paths := without (env "PATH" | splitList ":") "/usr/bin" }}
{{ $paths | join "\n" | comment "# " | indent 2 }}
{{- end }}

  TMPDIR: {{ coalesce .chezmoi.config.tempDir (env "TMPDIR") (env "TMP") "/tmp" | quote }}

# Files and directories not group writeable
# umask: 0o022
