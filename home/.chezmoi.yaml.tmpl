---
# https://github.com/chezmoi/dotfiles/blob/master/.chezmoi.yaml.tmpl
{{- $ephemeral := env "CHEZMOI_EPHEMERAL" | not | not -}}
{{- $headless := env "CHEZMOI_HEADLESS" | not | not -}}
{{- $preset := env "CHEZMOI_PRESET" | default (ne .chezmoi.os "windows" | ternary "font" "text") -}}
{{- $profile := env "CHEZMOI_PROFILE" -}}
{{- $upgrade := eq (env "CHEZMOI_UPGRADE" | default (ne $profile "work" | ternary "true" "false")) "1" "true" -}}

{{- $homeDir := .chezmoi.homeDir | default (env "HOME") -}}
{{- $binDir := joinPath $homeDir ".local" "bin" -}}

{{- $ci := eq (env "CI") "true" -}}
{{- $codespaces := env "CODESPACES" | not | not -}}
{{- $devContainer := env "REMOTE_CONTAINERS" | not | not -}}

{{- $interactive := stdinIsATTY -}}
{{- $wsl := and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}

{{- /* (eq .chezmoi.username "root" "ubuntu" "vagrant" "vscode") */ -}}
{{- if or $ci $codespaces $devContainer -}}
{{-   $ephemeral = true -}}
{{-   $headless = true -}}
{{- else if $interactive -}}
{{-   $ephemeral = promptBoolOnce . "ephemeral" "ephemeral" -}}
{{-   $headless = promptBoolOnce . "headless" "headless" -}}
{{- end -}}

{{- $profileChoices := list "minimal" "personal" "work" -}}
{{- if and $interactive (not $profile) -}}
{{-   $profile = promptChoiceOnce . "profile" "profile" $profileChoices -}}
{{- end -}}

{{- $osID := get .chezmoi.osRelease "id" | default .chezmoi.os -}}
{{- $osIDLike := get .chezmoi.osRelease "idLike" | default $osID -}}
{{- $osVersion := get .chezmoi.osRelease "versionID" -}}
{{- if and (eq $osID "linux") (eq (env "HOME") "/data/data/com.termux/files/home") -}}
{{-   $osID = "android" -}}
{{- end -}}

{{- $sep := ":" -}}
{{- $sh := "sh" -}}
{{- if eq $osID "windows" -}}
{{-   $sep = ";" -}}
{{-   $sh = "bash" -}}
{{- end -}}

{{- $chassisType := includeTemplate "chassis-type.tmpl" (dict "chezmoi" .chezmoi "sh" $sh) -}}
{{- $container := includeTemplate "container.tmpl" dict -}}
{{- if $container -}}
{{-   warnf "container type: %s" $container -}}
{{- end -}}

# /lib/x86_64-linux-gnu/libc.so.6: version `GLIBC_2.32' not found
{{- $lddVersion := eq .chezmoi.os "linux" | ternary (output $sh "-c" "ldd --version 2>&1 | awk '/(^ldd|^Version)/ {print $NF}'" | trim) "3" -}}
{{- $glibc231 := le (float64 $lddVersion) 2.31 -}}
{{- /* $glibc231 := or
  (and (eq $osID "debian") (le (int $osVersion) 11))
  (and (eq $osID "ubuntu") (le (float64 $osVersion) 20.04))
*/ -}}

{{- $hostname := .chezmoi.hostname -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $hostname = output "scutil" "--get" "LocalHostName" | trim -}}
{{- else if eq $hostname "docker" "podman" -}}
{{-   $hostname = output $sh "-c" "hostname 2>/dev/null || echo" | trim | default $hostname -}}
{{- end -}}

{{- $user := env "USER" | default "me" -}}
{{- $name := env "NAME" | default (env "USER") -}}
{{- $email := env "EMAIL" | default (printf "%s@localhost" $user) -}}
{{- $accessToken := "" -}}

{{- if hasKey . "name" -}}
{{-   $name = .name -}}
{{- else if env "GIT_CONFIG_USER_NAME" -}}
{{-   $name = env "GIT_CONFIG_USER_NAME" -}}
{{- else if $interactive -}}
{{-   $name = promptString "name" $name -}}
{{- end -}}

{{- if hasKey . "email" -}}
{{-   $email = .email -}}
{{- else if env "GIT_CONFIG_USER_EMAIL" -}}
{{-   $email = env "GIT_CONFIG_USER_EMAIL" -}}
{{- else if $interactive -}}
{{-   $email = promptString "email" $email -}}
{{- end -}}

{{- if hasKey . "accessToken" -}}
{{-   $accessToken = .accessToken -}}
{{- else if env "BWS_ACCESS_TOKEN" -}}
{{-   $accessToken = env "BWS_ACCESS_TOKEN" -}}
{{- else if and $interactive -}}
{{-   $accessToken = promptString "BWS accessToken (optional)" $accessToken -}}
{{- end -}}

{{- if $interactive -}}
{{-   writeToStdout "💡 Tip: you can re-enter your name and email with `chezmoi init --data=false`.\n" -}}
{{- end -}}

{{- $baseContext := dict
  "accessToken" $accessToken
  "codespaces" $codespaces
  "container" $container
  "devContainer" $devContainer
  "ephemeral" $ephemeral
  "glibc231" $glibc231
  "headless" $headless
  "hostname" $hostname
  "os" .chezmoi.os
  "osID" $osID
  "osIDLike" $osIDLike
  "osVersion" $osVersion
  "profile" $profile
  "sessionType" (env "XDG_SESSION_TYPE")
  "wsl" $wsl
}}
{{- $features := includeTemplate "features.tmpl" $baseContext | fromJson -}}
{{- $_ := set $baseContext "features" $features }}
{{- $context := mergeOverwrite . $baseContext }}

# https://www.chezmoi.io/user-guide/encryption/age/
# encryption: age
# age:
#   identity: {{ env "HOME" }}/key.txt
#   recipient: age12wkemshyplj4chhlz5e8tf9klsyuyxjuuzz6r0nxapjf4zq0sepqcdhfn0

{{- if eq $osID "windows" }}
interpreters:
  sh:
    command: bash # "C:\\Windows\\System32\\bash.exe" # Get-Command bash
{{- else }}
# https://www.chezmoi.io/user-guide/advanced/install-your-password-manager-on-init/
hooks:
  read-source-state:
    pre:
      command: "{{ .chezmoi.sourceDir }}/.install-password-manager.sh"
{{- end }}

sourceDir: {{ .chezmoi.sourceDir | quote }}

data:
{{ $baseContext | toYaml | indent 2 }}
  chassisType: {{ $chassisType | quote }}
  preset: {{ $preset | quote }}
  sh: {{ $sh | quote }}
  symbols:
    prompt: {{ eq $preset "font" | ternary " " ">" | quote }}
    error: {{ eq $preset "font" | ternary " " "x" | quote }}
  # term: truecolor

  # Upgrade packages
  upgrade: {{ $upgrade }}

  email: {{ $email | quote }}
  name: {{ $name | quote }}

  # https://www.chezmoi.io/user-guide/password-managers/bitwarden/#bitwarden-secrets-cli
{{- if $accessToken }}
  git:
{{ (bitwardenSecrets "0ecca3dd-3404-47d5-8a14-b333014a23ca" $accessToken).value | fromYaml | toYaml | indent 4 }}
{{- if eq $profile "personal" }}
    personal:
{{ (bitwardenSecrets "300f9f66-dccf-4de8-8249-b3330154d542" $accessToken).value | fromYaml | toYaml | indent 6 }}
{{- end }}
{{- if eq $profile "work" }}
    work:
{{ (bitwardenSecrets "ff633e02-2cc7-4dc4-87f8-b3330154baf8" $accessToken).value | fromYaml | toYaml | indent 6 }}
{{- end }}

  mail:
    accounts:
{{ (bitwardenSecrets "f8af12df-ee8e-4146-9272-b32f00a37b5e" $accessToken).value | fromYaml | toYaml | indent 6 }}
    queries:
{{ (bitwardenSecrets "76589c60-aae2-4c2f-b500-b32f00750c0a" $accessToken).value | fromYaml | toYaml | indent 6 }}

{{- else }}
  git: {}
  mail: {}
{{- end }}

{{- $packageManagerMap := dict
  "alpine" "apk"
  "android" "termux"
  "arch" "pacman"
  "darwin" "brew"
  "debian" "apt"
  "fedora" "dnf"
  "windows" "winget"
}}

{{- $ignoreContext := mergeOverwrite $context (dict
  "accessToken" $accessToken
  "email" $email
  "wsl" $wsl
) }}
{{- $ignore := list }}
{{- range $line := includeTemplate ".chezmoiignore" $ignoreContext | splitList "\n" }}
{{-   if or (eq $line "") (eq (substr 0 1 $line) "#") }}
{{-     continue }}
{{-   end }}
{{-   $ignore = append $ignore $line }}
{{- end }}

{{- $packageFiles := list }}
{{- range $path := glob (printf "%s/**/.packages.yaml" .chezmoi.sourceDir) }}
{{-   $ok := true }}
{{-   range $excluded := $ignore }}
{{-     $relative := trimPrefix $.chezmoi.sourceDir $path | replaceAllRegex "^/dot_" "." }}
{{-     $prefix := substr 0 (sub (len $excluded) 1 | int) $relative }}
{{-     $excluded = trimSuffix "/" $excluded }}
{{-     if eq $prefix $excluded }}
{{-       warnf "ignored: %s" $relative -}}
{{-       $ok = false }}
{{-       continue }}
{{-     end }}
{{-   end }}
{{-   if not $ok }}
{{-     continue }}
{{-   end }}
{{-   $packageFiles = append $packageFiles $path }}
{{- end }}

{{- $packageContext := mergeOverwrite $context (dict
  "chassisType" $chassisType
  "defaultType" ""
  "packageFiles" $packageFiles
  "packages" dict
) }}

{{- $packageManager := get $packageManagerMap $osIDLike }}
{{- $packages := includeTemplate "packages" (mergeOverwrite $packageContext (dict
  "packageType" $packageManager
  "defaultType" $packageManager
)) | fromJson }}
  packageManager: {{ $packageManager | quote }}
  packages:
    {{ $packageManager }}: {{ $packages | toJson }}

{{- if eq $osIDLike "arch" }}
{{- $aurPackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "aur")) | fromJson }}
    aur: {{ $aurPackages | toJson }}
{{- end }}

{{- if $features.brew }}
{{- $brewPackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "brew")) | fromJson }}
    brew: {{ $brewPackages | toJson }}
{{- if eq .chezmoi.os "darwin" }}
{{- $caskPackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "cask")) | fromJson }}
    cask: {{ $caskPackages | toJson }}
{{- $masPackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "mas")) | fromJson }}
    mas: {{ $masPackages | toJson }}
{{- end }}
{{- $vscodePackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "vscode")) | fromJson }}
    vscode: {{ $vscodePackages | toJson }}
{{- end }}

{{- if eq .chezmoi.os "windows" }}
{{- $scoopPackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "scoop")) | fromJson }}
    scoop: {{ $scoopPackages | toJson }}
{{- end }}

{{- if $features.mise }}
{{- $misePackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "mise")) | fromJson }}
    mise: {{ $misePackages | toJson }}
{{- end }}

{{- if $features.go }}
{{- $goPackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "go")) | fromJson }}
    go: {{ $goPackages | toJson }}
{{- end }}

{{- if $features.node }}
{{- $nodePackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "npm")) | fromJson }}
    npm: {{ $nodePackages | toJson }}
{{- end }}

{{- if $features.python }}
{{- $pipPackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "pip")) | fromJson }}
    pip: {{ $pipPackages | toJson }}
{{- $pipxPackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "pipx")) | fromJson }}
    pipx: {{ $pipxPackages | toJson }}
{{- $uvPackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "uv")) | fromJson }}
    uv: {{ $uvPackages | toJson }}
{{- end }}

{{- if $features.ruby }}
{{- $rubyGems := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "gem")) | fromJson }}
    gem: {{ $rubyGems | toJson }}
{{- end }}

{{- if $features.rust }}
{{- $cargoPackages := includeTemplate "packages" (mergeOverwrite $packageContext (dict "packageType" "cargo")) | fromJson }}
    cargo: {{ $cargoPackages | toJson }}
{{- end }}

diff:
  # exclude:
  #   - externals
  #   - scripts
{{- if lookPath "difft" | isExecutable }}
  # https://github.com/twpayne/chezmoi/discussions/2097
  command: difft
  args: [--color=always, --skip-unchanged]
  pager: cat # less
{{- else if lookPath "delta" | isExecutable }}
  pager: delta
{{- else if $codespaces }}
  # command: code
  # args: [--wait, --diff]
{{- end }}

env: {}

github:
  refreshPeriod: 12h

scriptEnv:
{{- if ne $osID "windows" }}
  PATH: "{{ $binDir }}{{ $sep }}{{ env "PATH" | replaceAllRegex (printf "%s%s" $sep $binDir) "" }}"
{{- end }}
  TMPDIR: {{ coalesce .chezmoi.config.tempDir (env "TMPDIR") (env "TMP") "/tmp" | quote }}
{{- if or $features.brew (eq .chezmoi.os "darwin") }}
  HOMEBREW_BAT: "1"
  # HOMEBREW_GITHUB_API_TOKEN: ""
  HOMEBREW_NO_ANALYTICS: "1"
  HOMEBREW_NO_AUTO_UPDATE: "1"
  HOMEBREW_NO_ENV_HINTS: "1"
  NONINTERACTIVE: "1"
{{- end }}
{{- if eq $osID "debian" }}
  DEBIAN_FRONTEND: noninteractive
{{- end }}

# Files and directories not group writeable
# umask: 0o022
