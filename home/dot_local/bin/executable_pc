#!/bin/sh

# Process-compose wrapper for global and project management with UDS

set -eu

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

global=false
if [ "${1:-}" = "-g" ] || [ "${1:-}" = "--global" ]; then
  global=true
  shift
fi

if [ "$global" = true ]; then
  export PC_CONFIG_FILES="$XDG_CONFIG_HOME/process-compose/global.yaml"
  export PC_SOCKET_PATH="$XDG_STATE_HOME/process-compose/global.sock"
else
  # For project mode, use temp directory like default but with hash instead of PID
  dir_hash=$(pwd | shasum | head -c 8)
  export PC_SOCKET_PATH="/tmp/process-compose-$dir_hash.sock"
fi

if [ $# -gt 0 ]; then
  cmd="$1"
  shift
  case "$cmd" in
  a) cmd=attach ;;
  d) cmd=down ;;
  l) cmd=list ;;
  r) cmd=restart ;;
  s) cmd=stop ;;
  u) cmd=up ;;
  esac
  set -- "$cmd" "$@"
fi

if [ $# -eq 0 ]; then
  # process-compose --use-uds up --detached
  set -- process list
fi

# Always use UDS, disable TUI for up command
if [ "${1:-}" = "up" ]; then
  exec process-compose --use-uds --tui=false "$@"
else
  exec process-compose --use-uds "$@"
fi
