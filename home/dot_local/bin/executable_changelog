#!/bin/bash
# Show changes since the last git pull
#USAGE arg "[command]" help="Command to run (default: log)" {
#USAGE   choices "log" "diff"
#USAGE }

set -eu

cmd="${1:-}"
[ $# -gt 0 ] && shift
newline=$'\n'
reflog="$(git reflog | grep -A1 pull | head -2 | cut -d' ' -f1)"
case "$cmd" in
  diff) git diff "$@" "${reflog//$newline/..}" ;;
  *) git log --oneline "$@" "${reflog//*$newline/}~1..${reflog//$newline*/}" ;;
esac
