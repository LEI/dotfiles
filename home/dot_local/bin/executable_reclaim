#!/bin/sh
#MISE description="List reclaimable disk paths (read-only)"
#USAGE arg "[group]..." help="Groups to list (default: all)" {
#USAGE   choices "caches" "containers" "ios" "logs" "trash" "vms" "xcode"
#USAGE }
#USAGE example "reclaim | xargs -0 du -sh | sort -hr" help="parents, largest first"
#USAGE example "reclaim | xargs -0 du -sh | sort -hr | head" help="top 10 growers"
#USAGE example "reclaim | xargs -0 du -shc | tail -1" help="grand total"
#USAGE example "reclaim caches | xargs -0 trash" help="trash dev caches"
#USAGE example "du -d 1 -h ~/.cache | sort -hr" help="drill into one parent"

set -eu

lib_dir="$HOME/.local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"

# Newline-separate when on a TTY (readable), NUL-separate when piped (safe with spaces)
if [ -t 1 ]; then
  emit_path() { printf '%s\n' "$1"; }
else
  emit_path() { printf '%s\0' "$1"; }
fi

keep() {
  for p; do [ -e "$p" ] && emit_path "$p"; done
  return 0
}

emit() {
  case "$1" in
  caches)
    keep \
      ~/.bun/install/cache \
      ~/.bundle/cache \
      ~/.cache \
      ~/.cargo/registry \
      ~/.cocoapods/repos \
      ~/.composer/cache \
      ~/.deno \
      ~/.gem \
      ~/.gradle/caches \
      ~/.ivy2/cache \
      ~/.lmstudio \
      ~/.m2/repository \
      ~/.npm/_cacache \
      ~/.nuget/packages \
      ~/.ollama \
      ~/.pub-cache \
      ~/.rustup/toolchains \
      ~/.sbt \
      ~/.swiftpm \
      ~/.yarn/cache \
      ~/Library/Caches \
      ~/Library/pnpm/store \
      ~/go/pkg/mod
    ;;
  containers)
    keep \
      ~/.docker \
      ~/.local/share/containers \
      ~/.local/share/docker \
      "$HOME/Library/Containers/com.docker.docker"
    ;;
  ios) keep "$HOME/Library/Application Support/MobileSync/Backup" ;;
  logs)
    keep \
      ~/.local/state \
      ~/Library/Logs \
      /opt/homebrew/var/log \
      /usr/local/var/log
    ;;
  trash)
    keep \
      ~/.Trash \
      ~/.local/share/Trash
    ;;
  vms)
    keep \
      ~/.colima \
      ~/.lima \
      ~/.orbstack \
      ~/.tart \
      ~/.vagrant.d \
      ~/.config/libvirt \
      "$HOME/VirtualBox VMs"
    ;;
  xcode)
    keep \
      "$HOME/Library/Developer/CoreSimulator" \
      "$HOME/Library/Developer/Xcode/Archives" \
      "$HOME/Library/Developer/Xcode/DerivedData" \
      "$HOME/Library/Developer/Xcode/iOS DeviceSupport" \
      "$HOME/Library/Developer/Xcode/macOS DeviceSupport" \
      "$HOME/Library/Developer/Xcode/watchOS DeviceSupport"
    ;;
  *)
    err "unknown group: $1"
    return 1
    ;;
  esac
}

groups=""
while [ $# -gt 0 ]; do
  case "$1" in
  -h | --help)
    usage exec --help bash "$0"
    exit 0
    ;;
  -*)
    err "unknown flag: $1"
    exit 2
    ;;
  *)
    groups="${groups:+$groups }$1"
    shift
    ;;
  esac
done

: "${groups:=caches containers ios logs trash vms xcode}"

for group in $groups; do
  emit "$group" || true
done
