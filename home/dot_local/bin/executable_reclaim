#!/bin/sh
#MISE description="List reclaimable disk paths (read-only)"
#USAGE arg "[group]..." help="Groups to list (default: all except toolchain, hf, ollama, claudevm)" {
#USAGE   choices \
#USAGE     "app" \
#USAGE     "cache" \
#USAGE     "claudevm" \
#USAGE     "dep" \
#USAGE     "hf" \
#USAGE     "ios" \
#USAGE     "log" \
#USAGE     "ollama" \
#USAGE     "toolchain" \
#USAGE     "trash" \
#USAGE     "vm" \
#USAGE     "xcode"
#USAGE }
#USAGE example "reclaim cache | xargs -0 du -sh | sort -hr" help="one group, biggest first"
#USAGE example "reclaim | xargs -0 du -shc | tail -1" help="grand total"
#USAGE example "reclaim cache | xargs -0 trash" help="wipe a group"

set -eu

lib_dir="$HOME/.local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"

# Newline-separate when on a TTY (readable), NUL-separate when piped (safe with spaces)
if [ -t 1 ]; then
  emit_path() { printf '%s\n' "$1"; }
else
  emit_path() { printf '%s\0' "$1"; }
fi

keep() {
  for p; do [ -e "$p" ] && emit_path "$p"; done
  return 0
}

emit() {
  case "$1" in
  cache)
    # XDG/macOS cache roots; subdirs are spec-sanctioned trashable
    keep "${XDG_CACHE_HOME:-$HOME/.cache}"/*/ ~/Library/Caches/*/
    ;;
  app)
    # Chromium/Electron caches under app data; regenerated on launch
    app_support="$HOME/Library/Application Support"
    keep \
      "$app_support"/*/Cache \
      "$app_support"/*/"Code Cache" \
      "$app_support"/*/GPUCache \
      "$app_support"/*/DawnGraphiteCache \
      "$app_support"/*/DawnWebGPUCache
    ;;
  dep)
    # Package manager download caches (regeneratable via re-install/build)
    keep \
      ~/.bun/install/cache \
      ~/.bundle/cache \
      ~/.cargo/registry \
      ~/.cocoapods/repos \
      ~/.composer/cache \
      ~/.gem/gems \
      ~/.gradle/caches \
      ~/.ivy2/cache \
      ~/.local/share/pnpm/store \
      ~/.m2/repository \
      ~/.npm/_cacache \
      ~/.nuget/packages \
      ~/.pub-cache \
      ~/.yarn/cache \
      ~/Library/pnpm/store \
      "${GOPATH:-$HOME/go}/pkg/mod"
    ;;
  toolchain)
    # Installed compiler/runtime versions (reinstall via tool CLI)
    keep ~/.rustup/toolchains
    ;;
  hf)
    # HuggingFace local cache; per-repo dirs are self-contained
    hf_hub="${HF_HOME:-$HOME/.cache/huggingface}/hub"
    keep "$hf_hub"/models--* "$hf_hub"/datasets--*
    ;;
  ollama)
    # Ollama model store; path-rm canonical only for bulk wipe
    keep "${OLLAMA_MODELS:-$HOME/.ollama/models}"
    ;;
  claudevm)
    # Claude Desktop local-agent sandbox VM image (re-downloaded on demand)
    keep "$HOME/Library/Application Support/Claude/vm_bundles"
    ;;
  ios) keep "$HOME/Library/Application Support/MobileSync/Backup" ;;
  log)
    keep \
      ~/.local/state \
      ~/Library/Logs \
      /opt/homebrew/var/log \
      /usr/local/var/log
    ;;
  trash)
    keep \
      ~/.Trash \
      ~/.local/share/Trash
    ;;
  vm)
    # Stop the VM first; trashing a live disk image corrupts it
    keep \
      ~/.colima \
      ~/.lima \
      ~/.tart \
      ~/.vagrant.d \
      "$HOME/VirtualBox VMs"
    ;;
  xcode)
    keep \
      "$HOME/Library/Developer/CoreSimulator" \
      "$HOME/Library/Developer/Xcode/Archives" \
      "$HOME/Library/Developer/Xcode/DerivedData" \
      "$HOME/Library/Developer/Xcode/iOS DeviceSupport" \
      "$HOME/Library/Developer/Xcode/macOS DeviceSupport" \
      "$HOME/Library/Developer/Xcode/watchOS DeviceSupport"
    ;;
  *)
    err "unknown group: $1"
    return 1
    ;;
  esac
}

groups=""
while [ $# -gt 0 ]; do
  case "$1" in
  -h | --help)
    usage exec --help bash "$0"
    exit 0
    ;;
  -*)
    err "unknown flag: $1"
    exit 2
    ;;
  *)
    groups="${groups:+$groups }$1"
    shift
    ;;
  esac
done

: "${groups:=app cache dep ios log trash vm xcode}"

for group in $groups; do
  emit "$group" || true
done
