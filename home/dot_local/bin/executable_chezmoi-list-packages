#!/bin/sh

# Usage: chezmoi list-packages [manager]

set -eu

key=default
context=.

if [ $# -gt 0 ]; then
  key="$1"
  shift
fi

if [ "$key" != default ] && [ "$key" != . ]; then
  context='(mergeOverwrite . (dict "packageType" "'"$key"'"))'
fi

# echo >&2 "$key packages:"
chezmoi execute '{{ includeTemplate "list-packages.tmpl" '"$context"' }}' "$@"
