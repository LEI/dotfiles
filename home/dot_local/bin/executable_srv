#!/bin/bash

set -euo pipefail

conf="${XDG_CONFIG_HOME:-$HOME/.config}/srv/hosts.yaml"

die() {
  echo >&2 "srv: $*"
  exit 1
}

field() {
  val=$(yq -r ".hosts.$1.$2" "$conf")
  if [ "$val" = "null" ]; then
    return
  fi
  printf '%s' "$val"
}

if [ ! -f "$conf" ]; then
  die "config not found: $conf"
fi

if ! command -v yq >/dev/null; then
  die "yq required"
fi

usage() {
  cat <<'EOF'
Usage: srv [name] [logs|command...]

  srv              list configured hosts
  srv <name>       open interactive shell
  srv <name> logs  stream logs (pipeable)
  srv <name> cmd   run command on host
EOF
}

debug=false
case "${1:-}" in
  -d|--debug) debug=true; shift ;;
  -h|--help) usage; exit ;;
esac

# No args: list hosts
if [ $# -eq 0 ]; then
  yq -r '.hosts | keys[]' "$conf"
  exit
fi

name="$1"
shift

host=$(field "$name" ssh)
if [ -z "$host" ]; then
  die "unknown host '$name'"
fi
dir=$(field "$name" dir)

tty_flag="-t"

if [ "${1:-}" = "logs" ]; then
  shift
  cmd=$(field "$name" logs.cmd)
  if [ -z "$cmd" ]; then
    die "no log command for '$name'"
  fi
  # Default pipe from config when no extra args and stdout is a terminal
  pipe=""
  if [ $# -eq 0 ] && [ -t 1 ]; then
    pipe=$(field "$name" logs.pipe)
  fi
  if [ $# -gt 0 ]; then
    cmd="$cmd $*"
  fi
  # Omit -t when piped (caller or config pipe) to avoid \r\n stair effect
  if [ ! -t 1 ] || [ -n "$pipe" ]; then
    tty_flag=""
  fi
  set -- "$cmd"
elif [ $# -eq 0 ]; then
  set -- "exec \$SHELL -l"
fi

ssh_args=(ssh)
[ -n "$tty_flag" ] && ssh_args+=("$tty_flag")
ssh_args+=("$host" "cd '$dir' && $*")

run() {
  if [ -n "${pipe:-}" ]; then
    "$@" | $pipe
  else
    "$@"
  fi
}

if [ "$debug" = true ]; then
  echo "ssh${tty_flag:+ $tty_flag} $host \"cd '$dir' && $*\"${pipe:+ | $pipe}"
else
  run "${ssh_args[@]}"
fi
