#!/bin/bash
#MISE description="Manage remote hosts via SSH"
#USAGE flag "-d --debug" help="Print SSH command instead of running it"
#USAGE arg "[name]" help="Host name from config"
#USAGE complete "name" run="srv"
#USAGE arg "[command]..." help="Command to run (or 'logs' for log streaming)"
#USAGE complete "command" run="echo logs"

set -euo pipefail

CONF="${XDG_CONFIG_HOME:-$HOME/.config}/srv/hosts.yaml"

die() {
  echo "srv: $*" >&2
  exit 1
}

field() {
  local val
  val=$(yq -r ".hosts.$1.$2" "$CONF")
  if [ "$val" = "null" ]; then
    return
  fi
  printf '%s' "$val"
}

[ -f "$CONF" ] || die "config not found: $CONF"
command -v yq >/dev/null || die "yq required"

debug=false
while [ $# -gt 0 ]; do
  case "$1" in
  -d | --debug)
    debug=true
    shift
    ;;
  -h | --help)
    if command -v usage >/dev/null; then
      usage exec --help bash "$0"
    else
      echo "Usage: srv [-d] [name] [logs|command...]"
    fi
    exit
    ;;
  --usage)
    grep '^#USAGE' "$0" | sed 's/^#USAGE //'
    exit
    ;;
  *) break ;;
  esac
done

if [ $# -eq 0 ]; then
  yq -r '.hosts | keys[]' "$CONF"
  exit
fi

name="$1"
shift

host=$(field "$name" ssh)
if [ -z "$host" ]; then
  die "unknown host: $name"
fi
dir=$(field "$name" dir)

ssh_opts=(-t)
pipe=""

if [ "${1:-}" = "logs" ]; then
  shift
  cmd=$(field "$name" logs.cmd)
  [ -n "$cmd" ] || die "no log command for '$name'"

  if [ $# -gt 0 ]; then
    cmd="$cmd $*"
  fi

  # Use config pipe when no extra args and stdout is a terminal
  if [ $# -eq 0 ] && [ -t 1 ]; then
    pipe=$(field "$name" logs.pipe)
  fi

  # Omit -t when piped to avoid \r\n stair effect
  if [ ! -t 1 ] || [ -n "$pipe" ]; then
    ssh_opts=()
  fi
elif [ $# -gt 0 ]; then
  cmd="$*"
else
  # shellcheck disable=SC2016
  cmd='exec $SHELL -l'
fi

if [ -n "$dir" ]; then
  remote="cd $(printf '%q' "$dir") && $cmd"
else
  remote="$cmd"
fi

if [ "$debug" = true ]; then
  echo "ssh${ssh_opts[*]:+ ${ssh_opts[*]}} $host \"$remote\"${pipe:+ | $pipe}"
  exit
fi

if [ -n "$pipe" ]; then
  # shellcheck disable=SC2029
  ssh ${ssh_opts[@]+"${ssh_opts[@]}"} "$host" "$remote" | eval "$pipe"
else
  # shellcheck disable=SC2029
  ssh ${ssh_opts[@]+"${ssh_opts[@]}"} "$host" "$remote"
fi
