#!/bin/sh

# Attach to an existing session or create a new session

set -eu

TERM=tmux-256color

if [ $# -eq 0 ]; then
	if [ -n "${TMUX:-}" ]; then
		set -- ls
	elif tmux has-session 2>/dev/null; then
		set -- attach
	else
		set -- new-session \; run-shell '#{@resurrect-restore-script-path}'
	fi
fi

case "$*" in
-u\ NONE) set -- -f/dev/null -Ltmp ;;
esac

case "$1" in
current-config) set -- -Lfoo -f/dev/null start\; show -g ;; # start-server; show-options --global
default-config) set -- -Lfoo -f/dev/null start\; show -gw ;; # start-server; show-window-options --global
esac

exec tmux -- "$@"
