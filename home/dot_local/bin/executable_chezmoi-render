#!/usr/bin/env bash
# Usage: chezmoi-render <directory> [templates...]
# Renders managed templates to a staging directory.
# Use -q/--quiet to suppress output.

set -euo pipefail

dest="${1:?usage: chezmoi-render <directory> [templates...]}"
shift

quiet=false
templates=()
for arg in "$@"; do
  case "$arg" in
    -q|--quiet)
      quiet=true
      ;;
    *)
      templates+=("$arg")
      ;;
  esac
done

mkdir -p "$dest"

if [ "$quiet" != true ]; then
  printf 'Output: %s\n' "${dest#$PWD/}" >&2
fi

source_dir="$(chezmoi source-path)"
if [ -z "$source_dir" ]; then
  printf 'error: could not determine source directory\n' >&2
  exit 1
fi
prefix="${source_dir#$PWD/}"

# Strip prefix from explicit template paths
if [ ${#templates[@]} -gt 0 ]; then
  fixed=()
  for t in "${templates[@]}"; do
    fixed+=("${t#$prefix/}")
  done
  templates=("${fixed[@]}")
fi

# Get all templates if none provided (find all .tmpl files in source, excluding config)
if [ ${#templates[@]} -eq 0 ]; then
  cd "$source_dir"
  mapfile -t templates < <(find . -name '*.tmpl' -type f | grep -v '^./.chezmoi.yaml.tmpl$' | sort)
fi

if [ ${#templates[@]} -eq 0 ]; then
  exit 0
fi

# Resolve source paths to target paths (use absolute paths)
cd "$source_dir"
mapfile -t targets < <(printf '%s\n' "${templates[@]}" | sed "s|^|$source_dir/|" | xargs chezmoi target-path)

render() {
  local src="$1"
  local target="$2"

  if [ -z "$src" ] || [ -z "$target" ]; then
    return 1
  fi

  local rel="${target#"$HOME"/}"
  local out="$dest/$rel"
  local base
  base=$(basename "$src")

  mkdir -p "${out%/*}"

  local cmd=(chezmoi execute-template --file "$source_dir/$src")
  local input="/dev/null"

  if [[ "$base" == modify_* ]]; then
    cmd+=(--with-stdin)
    if [ -f "$target" ]; then
      input="$target"
    fi
  fi

  "${cmd[@]}" <"$input" >"$out"
}

export -f render
export dest source_dir

max_jobs=$(nproc 2>/dev/null || echo 4)
total=${#templates[@]}

if ! paste <(printf '%s\n' "${templates[@]}") <(printf '%s\n' "${targets[@]}") \
  | xargs -P "$max_jobs" -n 2 bash -c 'render "$@"' _; then
  printf 'error: template rendering failed\n' >&2
  exit 1
fi

if [ "$quiet" != true ]; then
  printf 'Rendered: %d templates\n' "$total" >&2
fi
