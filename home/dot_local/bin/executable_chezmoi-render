#!/usr/bin/env bash
# Render managed templates to a staging directory
#USAGE flag "-o --output <directory>" help="Output directory (default: mktemp -d)"
#USAGE flag "-q --quiet" help="Suppress output"
#USAGE flag "-v --verbose" help="Print each file as it is rendered"
#USAGE arg "[templates]..." help="Templates to render"
#USAGE complete "templates" run="git ls-files 'home/**/*.tmpl' 'home/**/modify_*' ':(exclude)home/.chezmoi.yaml.tmpl'"
# TODO: consider accepting directories and expanding to contained templates;
# if added, update completion to also offer dirs (type=path or git ls-files -d)

set -euo pipefail
shopt -s lastpipe

if ((BASH_VERSINFO[0] < 4)); then
  echo "bash 4+ required, found $BASH_VERSION" >&2
  exit 1
fi

case "${1:-}" in
-h | --help)
  if command -v usage >/dev/null; then
    usage exec --help bash "$0"
  else
    echo "Usage: chezmoi-render [-o <directory>] [-q] [-v] [templates...]"
  fi
  exit 0
  ;;
--usage)
  grep '^#USAGE' "$0" | sed 's/^#USAGE //'
  exit 0
  ;;
esac

dest=""
quiet=false
verbose=false
templates=()
while [ $# -gt 0 ]; do
  case "$1" in
  -o | --output)
    dest="$2"
    shift 2
    ;;
  -q | --quiet)
    quiet=true
    shift
    ;;
  -v | --verbose)
    verbose=true
    shift
    ;;
  --)
    shift
    break
    ;;
  *)
    templates+=("$1")
    shift
    ;;
  esac
done
templates+=("$@")

if [ -z "$dest" ]; then
  dest="$(mktemp -d)"
  printf '%s\n' "$dest"
fi

mkdir -p "$dest"

if [ "$quiet" != true ]; then
  printf 'chezmoi-render: output dir: %s\n' "${dest#"$PWD"/}" >&2
fi

source_dir="$(chezmoi source-path)"
if [ -z "$source_dir" ]; then
  printf 'error: could not determine source directory\n' >&2
  exit 1
fi
prefix="${source_dir#"${source_dir%/*}"/}"

# Strip prefix from explicit template paths
if [ ${#templates[@]} -gt 0 ]; then
  fixed=()
  for t in "${templates[@]}"; do
    fixed+=("${t#"$prefix"/}")
  done
  templates=("${fixed[@]}")
fi

# Get all templates if none provided
if [ ${#templates[@]} -eq 0 ]; then
  cd "$source_dir"
  mapfile -t templates < <(find . \( -name '*.tmpl' -o -name 'modify_*' \) -type f | grep -v '^./.chezmoi.yaml.tmpl$' | sort -u)
fi

if [ ${#templates[@]} -eq 0 ]; then
  exit 0
fi

# Resolve source paths to target paths
cd "$source_dir"
sources=()
for t in "${templates[@]}"; do
  sources+=("$source_dir/$t")
done
printf '%s\0' "${sources[@]}" | xargs -0 chezmoi target-path | mapfile -t targets
if [ "${PIPESTATUS[1]}" -ne 0 ]; then
  echo "error: chezmoi target-path failed for:" >&2
  printf '  %s\n' "${sources[@]}" >&2
  exit 1
fi
if [ "${#targets[@]}" -ne "${#templates[@]}" ]; then
  echo "error: target-path returned ${#targets[@]} paths for ${#templates[@]} templates" >&2
  exit 1
fi

render() {
  local src="$1"
  local target="$2"

  if [ -z "$src" ] || [ -z "$target" ]; then
    return 1
  fi

  local rel="${target#"$HOME"/}"
  local out="$dest/$rel"
  local base
  base=$(basename "$src")

  # if [ "$verbose" = true ]; then
  #   printf 'render: %s -> %s\n' "$src" "$out" >&2
  # elif [ "$quiet" != true ]; then
  #   printf 'render: %s -> %s\n' "${src#./}" "$rel" >&2
  # fi

  mkdir -p "${out%/*}"

  local cmd=(chezmoi execute-template --file "$source_dir/$src")
  local input="/dev/null"

  if [[ "$base" == modify_* ]]; then
    cmd+=(--with-stdin)
    if [ -f "$target" ]; then
      input="$target"
    fi
  fi

  "${cmd[@]}" <"$input" >"$out" && exit_code=0 || exit_code=$?
  if [ "$exit_code" -ne 0 ]; then
    echo "render failed: exit code $exit_code" >&2
  fi
  return "$exit_code"
}

total=${#templates[@]}

failed=0
for i in "${!templates[@]}"; do
  render "${templates[$i]}" "${targets[$i]}" || ((++failed))
done
if [ "$failed" -gt 0 ]; then
  printf 'error: %d template(s) failed to render\n' "$failed" >&2
  exit 1
fi

if [ "$quiet" != true ]; then
  printf 'Rendered: %d templates\n' "$total" >&2
fi
