#!/usr/bin/env bash
# Render managed templates to a staging directory
#USAGE flag "-l --list" help="List available templates"
#USAGE flag "-o --output <directory>" help="Output directory (default: mktemp -d)"
#USAGE flag "-q --quiet" help="Suppress output"
#USAGE flag "-v --verbose" help="Print each file as it is rendered"
#USAGE arg "[templates]..." help="Templates to render (use -- to pass flags to chezmoi execute-template)"
#USAGE complete "templates" run="chezmoi-render --list"

set -euo pipefail
shopt -s lastpipe

lib_dir="$HOME/.local/lib"
# shellcheck source=home/dot_local/lib/bash/require.sh
source "$lib_dir/bash/require.sh"

require_bash 4

case "${1:-}" in
-h | --help)
  if command -v usage >/dev/null; then
    usage exec --help bash "$0"
  else
    echo "Usage: chezmoi-render [-l] [-o dir] [-q] [-v] [templates...] [-- chezmoi-flags...]"
  fi
  exit 0
  ;;
--usage)
  grep '^#USAGE' "$0" | sed 's/^#USAGE //'
  exit 0
  ;;
-l | --list)
  prefix="${2:-}"
  git ls-files \
    'home/**/*.tmpl' \
    'home/**/modify_*' \
    ':(exclude)home/.chezmoi.yaml.tmpl' |
    if [ -n "$prefix" ]; then
      sed -n "s|^${prefix%/}/||p" | sed 's|/.*|/|' | sort -u |
        sed "s|^|${prefix%/}/|"
    else
      cat
    fi
  exit 0
  ;;
esac

dest=""
templates=()
chezmoi_args=()
verbosity="${CHEZMOI_RENDER_VERBOSITY:-1}"

while [ $# -gt 0 ]; do
  case "$1" in
  -o | --output)
    dest="$2"
    shift 2
    ;;
  -q | --quiet)
    verbosity=0
    shift
    ;;
  -v | --verbose)
    verbosity=2
    shift
    ;;
  --)
    shift
    chezmoi_args=("$@")
    break
    ;;
  *)
    templates+=("$1")
    shift
    ;;
  esac
done

if [ -z "$dest" ]; then
  dest="$(mktemp -d)"
  printf '%s\n' "$dest"
fi

mkdir -p "$dest"

if [ "$verbosity" -ge 1 ]; then
  printf '%s: output dir: %s\n' "${0##*/}" "${dest#"$PWD"/}" >&2
fi

persistent_state_dir="$(mktemp -d)"
persistent_state="$persistent_state_dir/chezmoi-state.json"
trap 'rm -rf "$persistent_state_dir"' EXIT

source_dir="$(git rev-parse --show-toplevel)"
if [ -z "$source_dir" ]; then
  printf 'error: could not determine source directory\n' >&2
  exit 1
fi
prefix="${source_dir#"${source_dir%/*}"/}"

# Strip prefix and expand directories to contained templates
if [ ${#templates[@]} -gt 0 ]; then
  fixed=()
  for t in "${templates[@]}"; do
    t="${t#"$prefix"/}"
    if [ -d "$source_dir/$t" ]; then
      while IFS= read -r f; do
        fixed+=("$f")
      done < <(
        find "$source_dir/$t" \( -name '*.tmpl' -o -name 'modify_*' \) -type f |
          sed "s|^$source_dir/||" |
          grep -v '\.chezmoi\.yaml\.tmpl$' |
          sort -u
      )
    else
      fixed+=("$t")
    fi
  done
  templates=("${fixed[@]}")
fi

# Discover all templates when none provided
if [ ${#templates[@]} -eq 0 ]; then
  cd "$source_dir"
  mapfile -t templates < <(
    find . \( -name '*.tmpl' -o -name 'modify_*' \) -type f |
      grep -v '\.chezmoi\.yaml\.tmpl$' |
      sort -u
  )
fi

if [ ${#templates[@]} -eq 0 ]; then
  exit 0
fi

# Resolve source paths to target paths
cd "$source_dir"
sources=()
for t in "${templates[@]}"; do
  sources+=("$source_dir/$t")
done
printf '%s\0' "${sources[@]}" |
  xargs -0 chezmoi target-path --no-tty --source "$source_dir" --persistent-state="$persistent_state" |
  mapfile -t targets
if [ "${PIPESTATUS[1]}" -ne 0 ]; then
  echo "error: chezmoi target-path failed for:" >&2
  printf '  %s\n' "${sources[@]}" >&2
  exit 1
fi
if [ "${#targets[@]}" -ne "${#templates[@]}" ]; then
  echo "error: target-path returned ${#targets[@]} paths for ${#templates[@]} templates" >&2
  exit 1
fi

render() {
  local src="$1"
  local target="$2"

  if [ -z "$src" ] || [ -z "$target" ]; then
    return 1
  fi

  local rel="${target#"$HOME"/}"
  local out="$dest/$rel"
  local base
  base=$(basename "$src")

  if [ "$verbosity" -ge 2 ]; then
    printf 'render: %s -> %s\n' "$src" "$out" >&2
  elif [ "$verbosity" -ge 1 ]; then
    printf 'render: %s\n' "$rel" >&2
  fi

  mkdir -p "${out%/*}"

  local cmd=(
    chezmoi execute-template
    --source "$source_dir"
    --persistent-state="$persistent_state"
    ${chezmoi_args[@]+"${chezmoi_args[@]}"}
    --file "$source_dir/$src"
  )
  local input="/dev/null"

  if [[ "$base" == modify_* ]]; then
    cmd+=(--with-stdin)
    if [ -f "$target" ]; then
      input="$target"
    fi
  fi

  "${cmd[@]}" <"$input" >"$out" && exit_code=0 || exit_code=$?
  if [ "$exit_code" -ne 0 ]; then
    echo "render failed: exit code $exit_code" >&2
  fi
  return "$exit_code"
}

total=${#templates[@]}

failed=0
for i in "${!templates[@]}"; do
  render "${templates[$i]}" "${targets[$i]}" || ((++failed))
done
if [ "$failed" -gt 0 ]; then
  printf 'error: %d template(s) failed to render\n' "$failed" >&2
  exit 1
fi

if [ "$verbosity" -ge 1 ]; then
  printf 'Rendered: %d templates\n' "$total" >&2
fi
