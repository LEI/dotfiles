main() {
  ip="$1"
  shift
  if [ $# -eq 0 ]; then
    set -- --time=33
  fi
  # https://users.aalto.fi/~tontti/posts/jq-and-human-readable-bytes/
  format='def bytes:
  def _bytes(v; u):
    if (u | length) == 1 or (u[0] == "" and v < 10000) or v < 1000 then
      "\(v *100 | round /100) \(u[0])B"
    else
      _bytes(v/1000; u[1:])
    end;
  _bytes(.; ":k:M:G:T:P:E:Z:Y" / ":");
select(.event=="interval") | .data.sum.bits_per_second | bytes'
  iperf3 --client "$ip" --json-stream "$@" |
    jq --raw-output --unbuffered "$format" |
    npx cli-plot -w 100 -h 10
}

main "$@"
