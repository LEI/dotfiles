#!/usr/bin/env nu

# Parses chezmoi --debug structured logs,
# shows slowest operations and phase summary

def phase_of [msg: string] {
  match ($msg | split row " " | first) {
    "defaultPreApplyFunc" | "Lstat" => "apply",
    "Output" | "Run" => "exec",
    "ReadDir" | "ReadFile" | "ReadLink" | "Stat" => "read",
    "Close" | "Get" | "Set" => "state",
    _ => "other"
  }
}

def duration_ms [msg: string] {
  let m = $msg | parse --regex 'duration=(?P<v>[0-9.]+)(?P<u>ms|µs|s)'
  if ($m | is-empty) {
    0.0
  } else {
    let v = $m.0.v | into float
    if $m.0.u == "s" {
      $v * 1000
    } else if $m.0.u == "µs" {
      $v / 1000
    } else {
      $v
    }
  }
}

def redact [msg: string] {
  $msg
    | str replace --all $env.HOME "~"
    | str replace --regex '--access-token \S+' '--access-token [REDACTED]'
    | str replace --regex ' (output|value|err)=.*$' ''
}

def main [
  subcommand?: string  # "init", "apply", or empty for "init --apply"
  --lines (-n): int = 20
  --summary (-s)
  ...rest: string
] {
  let args = match $subcommand {
    "init" => ["init"],
    "apply" => ["apply"],
    null => ["init" "--apply"],
    _ => {
      print -e "subcommand must be 'init', 'apply', or omitted"
      exit 1
    }
  }

  let chezmoi_args = ["chezmoi" "--debug" ...$args "--dry-run" ...$rest]
  print -e $"Running: ($chezmoi_args | str join ' ')"

  let tmp = (mktemp)
  run-external ...$chezmoi_args err> $tmp
  let raw = open $tmp | collect
  rm $tmp

  let entries = $raw
    | lines
    | parse "time={ts} level={level} msg={msg}"
    | where ts != ""
    | insert dt { |r| $r.ts | into datetime }

  let n = $entries | length
  if $n < 2 {
    print -e "No log entries parsed"
    return
  }

  let wall_ms = (($entries | last).dt - ($entries | first).dt) / 1ms
  let ext = $entries | where msg =~ "duration="
  let ext_ms = if ($ext | length) > 0 {
    $ext | each { |r| duration_ms $r.msg } | math sum
  } else {
    0.0
  }

  print $"Wall time: ($wall_ms / 1000 | math round --precision 3)s \(($n) log entries)"
  print $"External commands: ($ext | length) \(($ext_ms / 1000 | math round --precision 3)s)\n"

  let phases = $entries
    | group-by { |r| phase_of $r.msg }
    | items { |phase, rows|
        let span = (($rows | last).dt - ($rows | first).dt) / 1ms
        {
          phase: $phase,
          entries: ($rows | length),
          span: $"($span / 1000 | math round --precision 3)s"
        }
      }
    | sort-by entries --reverse

  print "Phase summary:"
  print ($phases | table)

  if $summary { return }

  let gaps = $entries
    | zip ($entries | skip 1)
    | each { |pair|
        {
          gap: (($pair.1.dt - $pair.0.dt) / 1ms),
          msg: (redact $pair.1.msg)
        }
      }
    | sort-by gap --reverse
    | first $lines

  print $"\nTop ($lines) slowest gaps:"
  $gaps
    | each { |e|
        let g = $e.gap | math round --precision 1 | fill --alignment right --width 7
        $"  ($g)ms  ($e.msg)"
      }
    | str join "\n"
    | print
}
