{{- if or .features.docker .features.podman -}}
#!/bin/sh
# Run docker/podman compose for a project directory

set -eu

dir="${1:?dir required}"
shift

provider="${CONTAINER_PROVIDER:?CONTAINER_PROVIDER not set}"

compose() {
  echo >&2 "$provider compose --project-directory=$dir $*"
  $provider compose --project-directory="$dir" "$@"
}

# Default: start services then tail logs
if [ $# -eq 0 ]; then
  compose up --build --detach
  set -- logs --follow --since=1m
fi

compose "$@"
{{- end }}
