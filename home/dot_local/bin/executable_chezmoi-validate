#!/bin/sh
# Validate chezmoi templates by rendering them
#USAGE arg "[files]..." help="Template files to validate"

set -eu

run_check() {
  cat "$@" |
    chezmoi execute-template \
      --dry-run \
      --no-tty \
      --refresh-externals=never \
      --with-stdin \
      >/dev/null
}

run_check_for_each() {
  for f in "$@"; do
    # echo "Checking: $f" >&2
    run_check "$f" || on_error "$f"
  done
}

on_error() {
  echo
  echo "Failed to render template: $f" >&2
  echo
  exit 1
}

main() {
  if [ $# -eq 0 ]; then
    echo "check: no arguments" >&2
    exit
  fi
  echo "Checking: $*" >&2
  run_check "$@" || run_check_for_each "$@"
}

main "$@"
