#!/bin/sh

# Provision and read OS keystore secrets for the secrets.d confs.
# The confs' keystore_get calls are the source of truth: init scans and
# prompts for any not yet stored.

set -eu

lib_dir="$HOME/.local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=/dev/null
. "$lib_dir/sh/keystore.sh"

secrets_dir="${XDG_CONFIG_HOME:-$HOME/.config}/secrets.d"

# Emit "service account" for every keystore_get call declared in the confs
scan_secrets() {
  grep -rhoE 'keystore_get[[:space:]]+[^ )"]+[[:space:]]+[^ )"]+' "$secrets_dir" 2>/dev/null |
    awk '{print $2, $3}' | sort -u
}

# Prompt on the terminal and read one line without echoing it
read_secret() {
  trap 'stty echo </dev/tty 2>/dev/null; exit 130' INT TERM
  printf '%s' "$1" >/dev/tty
  stty -echo </dev/tty
  IFS= read -r secret_value </dev/tty
  stty echo </dev/tty
  trap - INT TERM
  printf '\n' >/dev/tty
  printf '%s' "$secret_value"
}

cmd_init() {
  [ -e /dev/tty ] || {
    err "init needs a terminal to prompt for secrets"
    return 1
  }
  pairs=$(scan_secrets)
  [ -n "$pairs" ] || {
    info "no keystore_get secrets declared under $secrets_dir"
    return 0
  }
  printf '%s\n' "$pairs" | while read -r service account; do
    [ -n "$service" ] || continue
    if [ -n "$(keystore_get "$service" "$account" 2>/dev/null || true)" ]; then
      info "$service/$account present, skipping"
      continue
    fi
    value=$(read_secret "Enter $service/$account (blank to skip): ")
    [ -n "$value" ] || {
      warn "$service/$account skipped"
      continue
    }
    if printf %s "$value" | keystore_set "$service" "$account" >/dev/null; then
      info "$service/$account stored"
    else
      err "$service/$account store failed"
    fi
    value=
  done
}

cmd_status() {
  scan_secrets | while read -r service account; do
    if [ -n "$(keystore_get "$service" "$account" 2>/dev/null || true)" ]; then
      printf '%s/%s\tpresent\n' "$service" "$account"
    else
      printf '%s/%s\tMISSING\n' "$service" "$account"
    fi
  done
}

# Flag applied confs whose secret assignment holds a plaintext literal instead of
# a command substitution. A create_ conf does not self-heal on apply, so a stale
# key lingers; this is what surfaces it. OPENCODE_SERVER_PASSWORD is a locally
# generated value, exempt.
cmd_audit() {
  find "$secrets_dir" -type f -name '*.conf' 2>/dev/null | while read -r file; do
    while IFS= read -r line; do
      case "$line" in '#'* | '') continue ;; *=*) ;; *) continue ;; esac
      lhs=${line%%=*} rhs=${line#*=}
      case "$lhs" in *KEY | *TOKEN | *PASSWORD | *SECRET) ;; *) continue ;; esac
      [ "$lhs" = OPENCODE_SERVER_PASSWORD ] && continue
      rhs=${rhs#\"} rhs=${rhs%\"}
      case "$rhs" in \$\(*\) | '') continue ;; esac
      printf '%s: %s\n' "${file#"$HOME"/}" "$lhs"
    done <"$file"
  done | { grep . && exit 1 || exit 0; }
}

usage() {
  echo "usage: ${0##*/} {get|set|init|status|audit} [SERVICE ACCOUNT]" >&2
}

cmd=${1:-init}
[ $# -eq 0 ] || shift
case "$cmd" in
get) keystore_get "$@" ;;
set) keystore_set "$@" ;;
init) cmd_init ;;
status | list) cmd_status ;;
audit) cmd_audit ;;
-h | --help | help) usage ;;
*)
  err "unknown subcommand: $cmd"
  usage
  exit 1
  ;;
esac
