{{- $pc := get (get .caddy.sites "processCompose") "process-compose" -}}
{{- $uds := get $pc "uds" -}}
#!/bin/sh
# Process-compose wrapper for global and project management
#USAGE flag "-g --global" help="Target the global instance"
#USAGE arg "[command]" help="Subcommand: a/attach, d/down, l/list, r/restart, s/stop, u/up"
#USAGE arg "[args]..." help="Arguments passed to process-compose"

set -eu

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

global=false
if [ "${1:-}" = "-g" ] || [ "${1:-}" = "--global" ]; then
  global=true
  shift
fi

if [ "$global" = true ]; then
  export PC_CONFIG_FILES="$XDG_CONFIG_HOME/process-compose/global.yaml"
{{- if $uds }}
  export PC_SOCKET_PATH="$XDG_STATE_HOME/process-compose/global.sock"
{{- else }}
  export PC_PORT_NUM={{ $pc.port }}
{{- end }}
else
  dir_hash=$(pwd | shasum | head -c 8)
  export PC_SOCKET_PATH="/tmp/process-compose-$dir_hash.sock"
fi

if [ $# -gt 0 ]; then
  cmd="$1"
  shift
  case "$cmd" in
  a) cmd=attach ;;
  d) cmd=down ;;
  l) cmd=list ;;
  r) cmd=restart ;;
  s) cmd=stop ;;
  u) cmd=up ;;
  esac
  set -- "$cmd" "$@"
fi

if [ $# -eq 0 ]; then
  set -- process list
fi

# Global: {{ if $uds }}UDS{{ else }}TCP port {{ $pc.port }}{{ end }}; project always UDS
if [ "$global" = true ] && [ "${1:-}" = "up" ]; then
  exec process-compose {{ if $uds }}--use-uds {{ end }}--tui=false "$@"
elif [ "$global" = true ]; then
  exec process-compose {{ if $uds }}--use-uds {{ end }}"$@"
elif [ "${1:-}" = "up" ]; then
  exec process-compose --use-uds --tui=false "$@"
else
  exec process-compose --use-uds "$@"
fi
