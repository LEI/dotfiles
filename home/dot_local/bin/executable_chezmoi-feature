#!/bin/sh
# List, check, and toggle chezmoi features
#USAGE arg "[action]" help="Action to perform" {
#USAGE   choices "list" "enabled" "toggle"
#USAGE }
#USAGE flag "-o --output <format>" help="Output format" {
#USAGE   choices "text" "json" "yaml"
#USAGE }
#USAGE arg "[feature]..." help="Features to check or toggle"

set -eu

usage() {
  echo "Usage: chezmoi feature [list|enabled|toggle] [-h|--help]" >&2
  echo "  [-o|--output=text|json|yaml]" >&2
  echo "  [feature...]" >&2
}

get_format() {
  format=
  case "$output" in
  '' | text) ;;
  json) format="toPrettyJson" ;;
  yaml) format="toYaml" ;;
  *)
    echo "${0##*/}: invalid output format: $output" >&2
    usage
    return 1
    ;;
  esac
  echo "$format"
}

list_features() {
  output="$1"
  shift
  format="$(get_format "$output")"
  if [ -n "$format" ]; then
    chezmoi execute "{{ .features | $format }}"
  else
    # shellcheck disable=SC2016
    chezmoi execute '{{ range $key, $value := .features }}{{ $key }}
{{ end -}}'
  fi
}

list_enabled_features() {
  output="$1"
  shift
  format="$(get_format "$output")"
  if [ -n "$format" ]; then
    chezmoi execute "{{ .features | $format }}"
  else
    # shellcheck disable=SC2016
    chezmoi execute '{{ range $key, $value := .features }}{{ if $value }}{{ $key }}
{{ end }}{{ end -}}'
  fi
}

get_feature() {
  key="$1"
  # # shellcheck disable=SC2016
  # value="$(chezmoi execute "{{ get .features \"$key\" }}")"
  # echo "$value"
  jq ".$key == true" "$HOME/.local/state/chezmoi/features.json"
}

toggle_feature() {
  key="$1"
  features_file="$HOME/.local/state/chezmoi/features.json"

  if ! jq -e ". | has(\"$key\")" "$features_file" >/dev/null; then
    echo "${0##*/}: unknown feature: $key" >&2
    return 2
  fi

  # Get current state before toggle
  current_state=$(jq ".$key" "$features_file")

  if command -v sponge >/dev/null; then
    jq ".\"$key\" = (if .\"$key\" then false else true end)" "$features_file" | sponge "$features_file"
  else
    tmp=$(mktemp)
    jq ".\"$key\" = (if .\"$key\" then false else true end)" "$features_file" > "$tmp" && mv "$tmp" "$features_file"
  fi

  # Report the new state (inverted from current_state)
  if [ "$current_state" = "true" ]; then
    echo "$key: disabled"
  else
    echo "$key: enabled"
  fi
}

if [ $# -eq 0 ]; then
  # usage
  # exit 0
  set -- list
fi

action=
output=text
while [ $# -gt 0 ]; do
  case "$1" in
  list | enabled | toggle)
    action="$1"
    shift
    break
    ;;
  -*=*)
    key="${1%%=*}"
    value="${1#*=}"
    shift
    set -- "$key" "$value" "$@"
    ;;
  -o | --output)
    shift
    output="$1"
    shift
    ;;
  -o*)
    output="${1#-o}"
    shift
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  *)
    value="$(get_feature "$1")"
    if [ "$value" = false ]; then
      echo "${0##*/}: feature disabled: $1" >&2
      exit 1
    elif [ "$value" != true ]; then
      echo "${0##*/}: unknown value: $1 ($value)" >&2
      exit 2
    fi
    # echo "chezmoi feature: feature enabled: $1" >&2
    shift
    ;;
  esac
done

case "$action" in
'')
  # list_features | wc -l
  ;;
list)
  list_features "$output"
  ;;
enabled)
  list_enabled_features "$output"
  ;;
toggle)
  if [ $# -eq 0 ]; then
    echo "${0##*/}: toggle requires at least one feature" >&2
    usage
    exit 1
  fi
  for feature in "$@"; do
    toggle_feature "$feature" || exit $?
  done
  ;;
*)
  echo "${0##*/}: invalid action: $action" >&2
  usage
  exit 1
  ;;
esac
