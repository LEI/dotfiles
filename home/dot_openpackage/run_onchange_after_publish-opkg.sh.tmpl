{{- if and (or .features.claude .features.opencode) (lookPath "node" | isExecutable) (not .ephemeral) -}}
#!/bin/sh

{{- $pkg := joinPath .chezmoi.sourceDir "dot_openpackage/packages/exact_local" -}}
{{- $hashes := list -}}
{{- range glob (joinPath $pkg "**/*.md") -}}
{{- $hashes = append $hashes (include . | sha256sum) -}}
{{- end }}
# local: {{ join "\n" $hashes | sha256sum }}

set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

LOCAL_PACKAGE_PATH="{{ .chezmoi.homeDir }}/.openpackage/packages/local"
PACKAGE_NAME="local"

# Returns true if the package is already installed globally
opkg_installed() {
  opkg list --global --json 2>/dev/null |
    jq -e "[.data.resources[] | .resources[] | select(.name == \"packages/$1\" and .status == \"tracked\")] | length > 0" \
      >/dev/null 2>&1
}

if [ ! -d "$LOCAL_PACKAGE_PATH" ]; then
  die "Package directory not found: $LOCAL_PACKAGE_PATH"
fi

if [ ! -f "$LOCAL_PACKAGE_PATH/openpackage.yml" ]; then
  die "Package manifest not found: $LOCAL_PACKAGE_PATH/openpackage.yml"
fi

# Publish local opkg package to registry
# TODO: replace cd with: mise run opkg -- publish --local --force "$PACKAGE_NAME"
# eventually pin opkg to a specific version via mise (npm:opkg@<version>)
cd "$LOCAL_PACKAGE_PATH"
run opkg publish --local --force "$PACKAGE_NAME"

# Uninstall first so renamed or deleted resources are removed
if opkg_installed "$PACKAGE_NAME"; then
  run opkg uninstall --global --recursive "$PACKAGE_NAME"
fi

# Install to platforms enabled in features
run opkg install --local --platforms
{{- if .features.claude }} claude{{ end }}
{{- if .features.opencode }} opencode{{ end }} --global "$PACKAGE_NAME"

# Clean up workspace created by opkg
trash "$CHEZMOI_WORKING_TREE/.openpackage" 2>/dev/null || true

echo "Package '$PACKAGE_NAME' published and installed"
{{ end -}}
