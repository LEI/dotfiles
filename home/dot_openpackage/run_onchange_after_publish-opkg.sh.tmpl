{{- if and .features.openpackage (lookPath "node" | isExecutable) (not .ephemeral) -}}
#!/bin/sh

{{- /* Trigger hashes: a change to any rendered comment value below re-runs this */ -}}
{{- /* script on apply. Cover local package source, marketplace package sources */ -}}
{{- /* (so skill/command edits re-fire, not just rules), and installed rules/agents. */ -}}
{{- $pkg := joinPath .chezmoi.sourceDir "dot_openpackage/packages/exact_local" -}}
{{- $hashes := list -}}
{{- range glob (joinPath $pkg "**/*.md") -}}
{{-   $hashes = append $hashes (include . | sha256sum) -}}
{{- end }}
# local: {{ join "\n" $hashes | sha256sum }}

{{- $mktHashes := list -}}
{{- range $entry := includeTemplate "opkg-marketplace-packages.tmpl" . | fromJson -}}
{{-   range glob (joinPath $entry.src "**/*.md") -}}
{{-     $mktHashes = append $mktHashes (include . | sha256sum) -}}
{{-   end -}}
{{- end }}
# marketplace sources: {{ join "\n" $mktHashes | sha256sum }}

{{- $installed := list -}}
{{- if .features.claude -}}
{{-   range glob (joinPath .chezmoi.homeDir ".claude/rules/**/*.md") -}}
{{-     $installed = append $installed (include . | sha256sum) -}}
{{-   end -}}
{{-   range glob (joinPath .chezmoi.homeDir ".claude/agents/*.md") -}}
{{-     $installed = append $installed (include . | sha256sum) -}}
{{-   end -}}
{{- end -}}
{{- if .features.opencode -}}
{{-   range glob (joinPath .chezmoi.homeDir ".config/opencode/agents/*.md") -}}
{{-     $installed = append $installed (include . | sha256sum) -}}
{{-   end -}}
{{- end }}
# installed: {{ join "\n" $installed | sha256sum }}

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

{{ includeTemplate "dot_openpackage/.opkg-install.tmpl" . -}}

# Repo owns global opkg install: anything in registry not in managed list is stale
registry_dir="$HOME/.openpackage/registry"
if [ -d "$registry_dir" ]; then
  for entry in "$registry_dir"/*; do
    [ -d "$entry" ] || continue
    name="${entry##*/}"
    case "$managed" in *" $name "*) continue ;; esac
    msg "Removing stale opkg registry: $name"
    if opkg_installed "$name"; then
      trace opkg uninstall --global --recursive "$name"
    fi
    trace trash "$entry"
  done
fi

# Per-package symlinks point rules dirs at package sources.
# Strays (e.g. dual installs) are caught by `mise --cd ~/.openpackage run opkg:unmanaged` in bats.
ensure_symlink() {
  target="$1" link="$2"
  if [ -L "$link" ] && [ "$(readlink "$link")" = "$target" ]; then
    return 0
  fi
  if [ -e "$link" ] || [ -L "$link" ]; then
    msg "unmanaged: $link (expected symlink to $target; remove and re-apply)"
    exit_code=1
    return 0
  fi
  trace ln -sn "$target" "$link"
}

{{- /* Rule sources [{name, src}]; opencode reads realpaths in opencode.jsonc, so only claude symlinks */ -}}
{{- $rules := includeTemplate "opkg-rule-paths.tmpl" . | fromJson -}}
{{- $ruleBases := list -}}
{{- if .features.claude -}}{{- $ruleBases = append $ruleBases (dict "platform" "claude" "dir" (joinPath .chezmoi.homeDir ".claude/rules")) -}}{{- end -}}
{{- if and $rules $ruleBases }}
{{- range $base := $ruleBases }}

mkdir -p {{ $base.dir | quote }}
{{- range $entry := $rules }}
{{-   if or (not (has $entry.name (list "claude" "opencode"))) (eq $entry.name $base.platform) }}
ensure_symlink {{ $entry.src | quote }} {{ printf "%s/%s" $base.dir $entry.name | quote }}
{{-   end }}
{{- end }}

# Prune orphans: trash a symlink whose source is gone or no longer in the rule set
{{-   $desiredRules := list }}
{{-   range $entry := $rules }}
{{-     if or (not (has $entry.name (list "claude" "opencode"))) (eq $entry.name $base.platform) }}
{{-       $desiredRules = append $desiredRules $entry.name }}
{{-     end }}
{{-   end }}
desired=" {{ join " " $desiredRules }} "
for link in {{ $base.dir | quote }}/*; do
  [ -L "$link" ] || continue
  name="${link##*/}"
  case "$desired" in
  *" $name "*)
    if [ -e "$link" ]; then
      continue
    fi
    ;;
  esac
  msg "Removing orphaned opkg rule symlink: $name"
  trace trash "$link"
done
{{- end }}
{{- end }}

{{- /* Skill sources [{name, src}]; symlinked into the standard SKILL.md discovery dirs (claude reads ~/.claude/skills, goose/pi read ~/.agents/skills, opencode reads both). */ -}}
{{- $skills := includeTemplate "opkg-skill-paths.tmpl" . | fromJson -}}
{{- $skillBases := list -}}
{{- if .features.claude -}}{{- $skillBases = append $skillBases (joinPath .chezmoi.homeDir ".claude/skills") -}}{{- end -}}
{{- $skillBases = append $skillBases (joinPath .chezmoi.homeDir ".agents/skills") -}}
{{- if and $skills $skillBases }}
{{- range $base := $skillBases }}

mkdir -p {{ $base | quote }}
{{- range $entry := $skills }}
ensure_symlink {{ $entry.src | quote }} {{ printf "%s/%s" $base $entry.name | quote }}
{{- end }}

# Prune orphans: trash a symlink whose source is gone or no longer in the skill set
{{-   $desiredSkills := list }}
{{-   range $entry := $skills }}
{{-     $desiredSkills = append $desiredSkills $entry.name }}
{{-   end }}
desired=" {{ join " " $desiredSkills }} "
for link in {{ $base | quote }}/*; do
  [ -L "$link" ] || continue
  name="${link##*/}"
  case "$desired" in
  *" $name "*)
    if [ -e "$link" ]; then
      continue
    fi
    ;;
  esac
  msg "Removing orphaned opkg skill symlink: $name"
  trace trash "$link"
done
{{- end }}
{{- end }}

# Clean up workspace created by opkg
workspace="$CHEZMOI_WORKING_TREE/.openpackage"
if [ -e "$workspace" ]; then
  trace trash "$workspace"
fi

exit "$exit_code"
{{ end -}}
