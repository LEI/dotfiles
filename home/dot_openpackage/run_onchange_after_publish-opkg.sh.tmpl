{{- if and .features.opencode (lookPath "node" | isExecutable) (not .ephemeral) -}}
#!/bin/sh

# sq: {{ include "dot_openpackage/packages/local/skills/sq/SKILL.md" | sha256sum }}

set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

LOCAL_PACKAGE_PATH="{{ .chezmoi.homeDir }}/.openpackage/packages/local"
PACKAGE_NAME="local"

if [ ! -d "$LOCAL_PACKAGE_PATH" ]; then
  err "Package directory not found: $LOCAL_PACKAGE_PATH"
fi

if [ ! -f "$LOCAL_PACKAGE_PATH/openpackage.yml" ]; then
  err "Package manifest not found: $LOCAL_PACKAGE_PATH/openpackage.yml"
fi

# Publish local opkg package to registry
# TODO: replace with after_script: mise run opkg publish --local --force local
cd "$LOCAL_PACKAGE_PATH"
run npx opkg publish --local --force "$PACKAGE_NAME"

# Install to opencode
run npx opkg install --local --platforms opencode --global "$PACKAGE_NAME"

# Clean up workspace created by opkg
trash "$CHEZMOI_WORKING_TREE/.openpackage" 2>/dev/null || true

echo "Package '$PACKAGE_NAME' published and installed"
{{ end -}}
