{{- if and (or .features.claude .features.opencode) (lookPath "node" | isExecutable) (not .ephemeral) -}}
#!/bin/sh
# marketplace packages: {{ .claude.marketplaces | toJson | sha256sum }}

{{- $pkg := joinPath .chezmoi.sourceDir "dot_openpackage/packages/exact_local" -}}
{{- $hashes := list -}}
{{- range glob (joinPath $pkg "**/*.md") -}}
{{- $hashes = append $hashes (include . | sha256sum) -}}
{{- end }}
# local: {{ join "\n" $hashes | sha256sum }}

{{- $installed := list -}}
{{- if .features.claude -}}
{{- range glob (joinPath .chezmoi.homeDir ".claude/rules/**/*.md") -}}
{{- $installed = append $installed (include . | sha256sum) -}}
{{- end -}}
{{- range glob (joinPath .chezmoi.homeDir ".claude/agents/*.md") -}}
{{- $installed = append $installed (include . | sha256sum) -}}
{{- end -}}
{{- end -}}
{{- if .features.opencode -}}
{{- range glob (joinPath .chezmoi.homeDir ".config/opencode/agents/*.md") -}}
{{- $installed = append $installed (include . | sha256sum) -}}
{{- end -}}
{{- end }}
# installed: {{ join "\n" $installed | sha256sum }}

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"

opkg() {
  command opkg "$@" | cat
}

opkg_installed() {
  opkg list --global --json 2>/dev/null |
    jq -e "[.data.resources[] | .resources[] | select(.name == \"packages/$1\" and .status == \"tracked\")] | length > 0" \
      >/dev/null 2>&1
}

# Trash install dirs left by an opkg package
purge_install() {
  name="$1"
  for base in "$HOME/.claude" "$HOME/.config/opencode"; do
    for type in rules agents skills; do
      target="$base/$type/$name"
      [ -L "$target" ] && continue
      [ -d "$target" ] || continue
      trace trash "$target"
    done
  done
}

install_package() {
  name="$1" path="$2"

  if [ ! -d "$path" ]; then
    echo "Package not found, skipping: $path"
    return 0
  fi
  if [ ! -f "$path/openpackage.yml" ]; then
    echo "No manifest at $path, skipping"
    return 0
  fi

  cd "$path"
  run opkg publish --local --force "$name"

  if opkg_installed "$name"; then
    run opkg uninstall --global --recursive "$name"
  fi
  purge_install "$name"

  run opkg install --local --platforms {{ join " " .openpackage.platforms }} --global "$name"

  echo "Package '$name' published and installed"
}

install_package "local" "{{ .chezmoi.homeDir }}/.openpackage/packages/local"

# Discover packages from marketplace paths
{{- if hasKey .claude "marketplaces" }}
{{-   range $mktName, $mkt := .claude.marketplaces }}
{{-     $path := get $mkt "path" }}
{{-     if $path }}
{{-       $packagesRoot := joinPath $.chezmoi.homeDir $path "packages" }}
{{-       if stat $packagesRoot }}
{{-         range glob (joinPath $packagesRoot "*") }}
{{-           $pkgName := base . }}
{{-           if ne $pkgName "local" }}
install_package {{ $pkgName | quote }} {{ . | quote }}
{{-           end }}
{{-         end }}
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}

# Build managed packages list (local + marketplace packages)
managed=" local "
{{- if hasKey .claude "marketplaces" }}
{{-   range $mktName, $mkt := .claude.marketplaces }}
{{-     $path := get $mkt "path" }}
{{-     if $path }}
{{-       $packagesRoot := joinPath $.chezmoi.homeDir $path "packages" }}
{{-       if stat $packagesRoot }}
{{-         range glob (joinPath $packagesRoot "*") }}
{{-           $pkgName := base . }}
{{-           if ne $pkgName "local" }}
managed="$managed {{ $pkgName }} "
{{-           end }}
{{-         end }}
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}

# Repo owns global opkg install: anything in registry not in managed list is stale
registry_dir="$HOME/.openpackage/registry"
if [ -d "$registry_dir" ]; then
  for entry in "$registry_dir"/*; do
    [ -d "$entry" ] || continue
    name="${entry##*/}"
    case "$managed" in *" $name "*) continue ;; esac
    msg "Removing stale opkg registry: $name"
    if opkg_installed "$name"; then
      trace opkg uninstall --global --recursive "$name"
    fi
    purge_install "$name"
    trace trash "$entry"
  done
fi

# Refuse to clobber a real directory at the link path
ensure_symlink() {
  target="$1"
  link="$2"

  if [ -e "$link" ] && [ ! -L "$link" ]; then
    echo "ERROR: $link exists and is not a symlink. Remove it first." >&2
    return 1
  fi

  if [ ! -L "$link" ] || [ "$(readlink "$link")" != "$target" ]; then
    ln -sn "$target" "$link"
  fi
}

link_rules() {
  name="$1" src="$2"
  target="$HOME/.claude/rules/$name"
  ensure_symlink "$src" "$target"
}

{{- $rules := list -}}
{{- range $mktName, $mkt := .claude.marketplaces -}}
{{-   $path := get $mkt "path" -}}
{{-   if not $path -}}{{- continue -}}{{- end -}}
{{-   $packagesRoot := joinPath $.chezmoi.homeDir $path "packages" -}}
{{-   if not (stat $packagesRoot) -}}{{- continue -}}{{- end -}}
{{-   range $pkgDir := glob (joinPath $packagesRoot "*") -}}
{{-     $pkgName := base $pkgDir -}}
{{-     $rulesDir := joinPath $pkgDir "rules" -}}
{{-     if stat $rulesDir -}}
{{-       $rules = append $rules (dict "name" $pkgName "src" $rulesDir) -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- if $rules }}

mkdir -p "$HOME/.claude/rules"
{{- range $entry := $rules }}
link_rules {{ $entry.name | quote }} {{ $entry.src | quote }}
{{- end }}
{{- end }}

# Clean up workspace created by opkg
workspace="$CHEZMOI_WORKING_TREE/.openpackage"
if [ -e "$workspace" ]; then
  trace trash "$workspace"
fi
{{ end -}}
