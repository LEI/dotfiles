{{- $packages := list (dict "name" "local" "src" (joinPath .chezmoi.homeDir ".openpackage/packages/local")) -}}
{{- $packages = concat $packages (includeTemplate "opkg-marketplace-packages.tmpl" . | fromJson) -}}
{{- /* dig keeps this renderable without the openpackage feature (e.g. in containers) */ -}}
{{- $platformArgs := "" -}}
{{- with dig "openpackage" "platforms" list . -}}
{{-   $platformArgs = printf " --platforms %s" (join " " .) -}}
{{- end -}}
opkg() {
  # CI=true forces non-interactive mode so opkg emits full output
  # instead of the truncated clack spinner when run on a TTY
  CI=true command opkg "$@"
}

opkg_installed() {
  # probe: a missing package makes opkg list error, treat that as not installed
  opkg list --global --json "$1" 2>/dev/null |
    jq -e '[.data.resources[] | .resources[] | .name] | length > 0' \
      >/dev/null 2>&1
}

publish_package() {
  name="$1" path="$2"
  if [ ! -f "$path/openpackage.yml" ]; then
    echo "No manifest at $path, skipping"
    return 1
  fi
  # Publish from a copy: opkg publish can move a package's resources into the
  # registry, and the source path is the live marketplace tree, so publishing
  # in place would empty it. Stage a copy and publish from there instead.
  stage=$(mktemp -d) || return 1
  cp -R "$path" "$stage/$name" || {
    rm -rf "$stage"
    return 1
  }
  (cd "$stage/$name" && opkg publish --local --force) || {
    rm -rf "$stage"
    return 1
  }
  rm -rf "$stage"
  if opkg_installed "$name"; then
    opkg uninstall --global --recursive "$name" || exit_code=$?
  fi
}

# Per-resource install: a whole-package install auto-namespaces resources
# (e.g. ~/.claude/agents/local-search.md); per-resource keeps natural paths.
install_resource() {
  name="$1"
  shift
  opkg install --local{{ $platformArgs }} \
    --conflicts overwrite --force "$@" --global "$name"
}

exit_code=0
# Publish all packages before installing any, so a dependent resolves its
# dependency (e.g. claude and private depend on kb) from the registry
# regardless of alphabetical publish order.
{{ range $entry := $packages }}
publish_package {{ $entry.name | quote }} {{ $entry.src | quote }} || exit_code=1
{{- end }}
{{ range $entry := $packages }}
{{- range glob (joinPath $entry.src "agents/*.md") }}
install_resource {{ $entry.name | quote }} --agents {{ base . | trimSuffix ".md" | quote }} || exit_code=1
{{- end }}
{{- range glob (joinPath $entry.src "commands/*.md") }}
install_resource {{ $entry.name | quote }} --commands {{ base . | trimSuffix ".md" | quote }} || exit_code=1
{{- end }}
echo "Package {{ $entry.name }} published and installed"
{{ end }}
managed="{{ range $entry := $packages }} {{ $entry.name }}{{ end }} "
