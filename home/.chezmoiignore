# TODO: move to ~/.config/git/config
.gitconfig

.config/helix/config.yaml
.config/helix/languages.yaml
.config/starship.yaml
.config/topgrade/topgrade.yaml

{{- if ne .email "firstname.lastname@company.com" }}
# Ignore .company-directory unless configured with a company email
.company-directory # note that the pattern is not dot_company-directory
{{- end }}

{{- if ne .email "me@home.org" }}
.personal-file
{{- end }}

{{- if not .features.bash }}
# .bash_aliases
# .bash_profile
.bashrc
.config/bash/
.config/blesh/
{{- end }}

{{- if not .features.zsh }}
.config/zsh/
# .zprofile
.zshrc
{{- end }}

{{- if and (not .features.bash) (not .features.zsh) }}
.config/atuin/
.config/bat/
.config/curlrc
.config/readline/
.config/sh/
.config/wget/
.local/bin/
{{- end }}

{{- if not .features.docker }}
# .config/docker/
.config/sh/plugins/docker.sh
.local/bin/d
{{- end }}

{{- if not .features.ghostty }}
.config/ghostty/
{{- end }}

{{- if not .features.git }}
.config/git/
.config/lazygit/
# FIXME: mod.nu.tmpl loops on source directory
# .config/nushell/modules/git.nu
# NOTE: feature should be named "git-config"
# .config/sh/plugins/git.sh
.gitconfig
.local/bin/g
{{- end }}

{{- if not .features.go }}
.chezmoiscripts/*-install-go.sh
{{- end }}

{{- if not .features.helix }}
.config/helix/
{{- end }}

{{- if not .features.kube }}
# .chezmoiscripts/*-install-kubectl.sh
.config/k9s/
.config/krew/
.config/sh/plugins/kubectl.sh
.local/bin/k
{{- end }}

{{- if not .features.mise }}
.chezmoiscripts/*-install-tools.sh
.config/mise/
# .config/sh/plugins/mise.sh
{{- end }}

{{- if not .features.neovim }}
.chezmoiscripts/*-install-neovim.sh
.config/cspell/
.config/nvim/
.local/share/nvim
{{- end }}

{{- if not .features.node }}
.chezmoiscripts/*-install-node.sh
.config/npm/
{{- end }}

{{- if not .features.nushell }}
# .chezmoiscripts/*.nu
# .config/*/*.nu
.config/nushell/
*.nu
{{- end }}

{{- if not .features.rust }}
.chezmoiscripts/*-install-rust.sh
{{- end }}

{{- if not .features.sql }}
# .chezmoiscripts/*-install-sql.sh
.config/psql/
{{- end }}

{{- if not .features.tmux }}
.config/tmux/
.local/bin/t
{{- end }}

{{- if not .features.topgrade }}
.config/topgrade/
{{- end }}

{{- if not .features.vim }}
.config/vim/
# .vim/
.vimrc.local
{{- end }}

{{- if not .features.void }}
.config/Void/
.void-editor/
{{- end }}

{{- if not .features.vscode }}
.config/Code/
{{- end }}

{{- if not .features.vscodium }}
.config/VSCodium/
{{- end }}

{{- if not .features.zellij }}
.config/zellij/
{{- end }}

{{ if not .codespaces -}}
.vscode-remote/
{{ end -}}

{{ if or .ephemeral (eq .accessToken "") -}}
.install-password-manager.sh
{{ end -}}

{{- if or (ne .osid "arch") (ne .osid "darwin") }}
.config/Code/
.config/VSCodium/
.config/Void/
.void-editor/
{{- end }}

{{- if ne .osid "darwin" }}
.chezmoiscripts/darwin/**
.config/homebrew/
# .config/karabiner/
# .hammerspoon/
.macos
{{- end }}

{{- if ne .chezmoi.os "linux" }}
.chezmoiscripts/install-packages.sh
.hushlogin
{{- end }}

{{- if ne .osid "windows" }}
*.ps1
.chezmoiscripts/windows/**
{{- else }}
.config/
.install-password-manager.sh
.void-editor/
{,.chezmoiscripts/}*.sh
{{- end }}
