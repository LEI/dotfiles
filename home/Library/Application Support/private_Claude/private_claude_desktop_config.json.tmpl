{{- $dataHome := env "XDG_DATA_HOME" | default (joinPath .chezmoi.homeDir ".local" "share") -}}
{{- $dataDir := env "CLAUDE_DATA_DIR" | default (joinPath $dataHome "claude") -}}
{
  "preferences": {
    "quickEntryShortcut": {
      "accelerator": "Alt+Space"
    },
    "chillingSlothLocation": {
      "customPath": {{ joinPath $dataDir "worktrees" | quote }}
    },
    "coworkScheduledTasksEnabled": true,
    "ccdScheduledTasksEnabled": true,
    "sidebarMode": "epitaxy",
    "dockBounceEnabled": true,
    "coworkWebSearchEnabled": true,
    "launchPreviewpersistSession": true,
    "keepAwakeEnabled": false
  }
}
{{- /* No newline at end of file */ -}}
