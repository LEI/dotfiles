{{- $p := get .ai.providers "llama-server" -}}
{{- includeTemplate "launchd-agent.plist.tmpl" (dict
      "label" $p.label
      "args" (list
        (printf "%s/opt/llama.cpp/bin/llama-server" .brewPrefix)
        "--host" "127.0.0.1"
        "--port" ($p.port | toString)
        "--models-dir" (printf "%s/Library/Caches/llama.cpp" .chezmoi.homeDir))
      "env" (dict
        "HOME" .chezmoi.homeDir
        "PATH" (printf "%s/.local/bin:%s/bin:%s/sbin:/usr/bin:/bin:/usr/sbin:/sbin" .chezmoi.homeDir .brewPrefix .brewPrefix))
      "log" (printf "%s/var/log/llama-server.log" .brewPrefix)
      "workdir" (printf "%s/var" .brewPrefix)) -}}
