{{- $provider := get .ai.providers "llama-server" -}}
{{- includeTemplate "launchd-agent.plist.tmpl" (dict
      "active" (get $provider "active" | default false)
      "label" $provider.label
      "args" (list
        (joinPath .brewPrefix "opt/llama.cpp/bin/llama-server")
        "--host" "127.0.0.1"
        "--port" ($provider.port | toString)
        "--models-dir" (joinPath .chezmoi.homeDir "Library/Caches/llama.cpp"))
      "env" (dict
        "HOME" .chezmoi.homeDir
        "PATH" (printf "%s/.local/bin:%s/bin:%s/sbin:/usr/bin:/bin:/usr/sbin:/sbin" .chezmoi.homeDir .brewPrefix .brewPrefix))
      "log" (joinPath .brewPrefix "var/log/llama-server.log")
      "workdir" (joinPath .brewPrefix "var")) -}}
