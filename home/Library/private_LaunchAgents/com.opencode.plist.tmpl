{{- $opencode := get . "opencode" | default dict -}}
{{- $server := get $opencode "server" | default dict -}}

{{- $svc := get .services "opencode" -}}

{{- $enabled := get $server "enabled" | default false -}}
{{- if $enabled -}}

{{- $stateDir := printf "%s/.local/state/opencode" .chezmoi.homeDir -}}

{{- $env := dict
  "HOME" .chezmoi.homeDir
-}}

{{- includeTemplate "launchd-agent.plist.tmpl" (dict
  "label" "com.opencode"
  "args" (list (printf "%s/.config/opencode/opencode-serve.sh" .chezmoi.homeDir))
  "env" $env
  "stdout" (printf "%s/stdout.log" $stateDir)
  "stderr" (printf "%s/stderr.log" $stateDir))
-}}
{{- end -}}
