{{- $p := get .ai.providers "mlx-lm" -}}
{{- $server := get $p "server" | default "mlx_lm.server" -}}
{{- if eq $server "mlx_lm.server" -}}
{{-   $bin := printf "%s/opt/mlx-lm/bin/mlx_lm.server" .brewPrefix -}}
{{-   includeTemplate "launchd-agent.plist.tmpl" (dict
        "label" $p.label
        "args" (list $bin "--host" "127.0.0.1" "--port" ($p.port | toString) "--chat-template-args" `{"enable_thinking":true}`)
        "env" (dict
          "HOME" .chezmoi.homeDir
          "PATH" (printf "%s/.local/bin:%s/bin:%s/sbin:/usr/bin:/bin:/usr/sbin:/sbin" .chezmoi.homeDir .brewPrefix .brewPrefix))
        "log" (printf "%s/var/log/mlx-lm.log" .brewPrefix)
        "workdir" (printf "%s/var" .brewPrefix)) }}
{{- else -}}
{{-   $bin := printf "%s/.local/bin/%s" .chezmoi.homeDir $server -}}
{{-   includeTemplate "launchd-agent.plist.tmpl" (dict
        "label" $p.label
        "args" (list $bin "--host" "127.0.0.1" "--port" ($p.port | toString))
        "env" (dict
          "HOME" .chezmoi.homeDir
          "PATH" (printf "%s/.local/bin:%s/bin:%s/sbin:/usr/bin:/bin:/usr/sbin:/sbin" .chezmoi.homeDir .brewPrefix .brewPrefix))
        "log" (printf "%s/var/log/mlx-lm.log" .brewPrefix)
        "workdir" (printf "%s/var" .brewPrefix)) }}
{{- end -}}
