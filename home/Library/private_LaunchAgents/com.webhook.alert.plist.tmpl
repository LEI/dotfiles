{{- $svc := .services.webhook -}}
{{- $site := get .caddy.sites "webhook" -}}
{{- $stateDir := joinPath .chezmoi.homeDir ".local/state/webhook" -}}
{{- includeTemplate "launchd-agent.plist.tmpl" (dict
      "label" $svc.label
      "args" (list
        (joinPath .brewPrefix "bin/webhook")
        "--hooks" (joinPath .chezmoi.homeDir ".config/webhook/hooks.yaml")
        "--port" ($site.port | toString)
        "--verbose")
      "env" (dict
        "HOME" .chezmoi.homeDir
        "PATH" (printf "%s/.local/bin:%s/bin:%s/sbin:/usr/bin:/bin:/usr/sbin:/sbin" .chezmoi.homeDir .brewPrefix .brewPrefix))
      "stdout" (joinPath $stateDir "stdout.log")
      "stderr" (joinPath $stateDir "stderr.log")) -}}
