{{- $svc := .services.webhook -}}
{{- $site := get (get .caddy.sites "otel") "webhook" -}}
{{- $stateDir := printf "%s/.local/state/webhook" .chezmoi.homeDir -}}
{{- includeTemplate "launchd-agent.plist.tmpl" (dict
      "label" $svc.label
      "args" (list
        (printf "%s/bin/webhook" .brewPrefix)
        "--hooks" (printf "%s/.config/webhook/hooks.yaml" .chezmoi.homeDir)
        "--port" ($site.port | toString)
        "--verbose")
      "env" (dict
        "HOME" .chezmoi.homeDir
        "PATH" (printf "%s/.local/bin:%s/bin:%s/sbin:/usr/bin:/bin:/usr/sbin:/sbin" .chezmoi.homeDir .brewPrefix .brewPrefix))
      "stdout" (printf "%s/stdout.log" $stateDir)
      "stderr" (printf "%s/stderr.log" $stateDir)) -}}
