{{- $pc := get .caddy.sites "process-compose" -}}
{{- $uds := get $pc "uds" -}}
{{- $stateDir := joinPath .chezmoi.homeDir ".local/state/process-compose" -}}
{{- $args := list
      (joinPath .brewPrefix "bin/process-compose")
      "up" "--tui=false"
      "--ordered-shutdown" "--logs-truncate" "--hide-disabled" -}}
{{- if $uds -}}
{{-   $args = append $args "--use-uds" -}}
{{- else -}}
{{-   $args = concat $args (list "--port" ($pc.port | toString)) -}}
{{- end -}}
{{- $env := dict
      "HOME" .chezmoi.homeDir
      "PATH" (printf "%s/.local/bin:%s/bin:%s/sbin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/.local/share/cargo/bin" .chezmoi.homeDir .brewPrefix .brewPrefix)
      "PC_CONFIG_FILES" (joinPath .chezmoi.homeDir ".config/process-compose/global.yaml")
      "PC_LOG_FILE" (joinPath $stateDir "process-compose.log") -}}
{{- if $uds -}}
{{-   $_ := set $env "PC_SOCKET_PATH" (joinPath $stateDir "global.sock") -}}
{{- end -}}
{{- includeTemplate "launchd-agent.plist.tmpl" (dict
      "label" "com.process-compose"
      "args" $args
      "env" $env
      "stdout" (joinPath $stateDir "stdout.log")
      "stderr" (joinPath $stateDir "stderr.log")) -}}
