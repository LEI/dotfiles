{{- $pc := get (get .caddy.sites "processCompose") "process-compose" -}}
{{- $uds := get $pc "uds" -}}
{{- $stateDir := printf "%s/.local/state/process-compose" .chezmoi.homeDir -}}
{{- $args := list
      (printf "%s/bin/process-compose" .brewPrefix)
      "up" "--tui=false"
      "--ordered-shutdown" "--logs-truncate" "--hide-disabled" -}}
{{- if $uds -}}
{{-   $args = append $args "--use-uds" -}}
{{- else -}}
{{-   $args = concat $args (list "--port" ($pc.port | toString)) -}}
{{- end -}}
{{- $env := dict
      "HOME" .chezmoi.homeDir
      "PATH" (printf "%s/.local/bin:%s/bin:%s/sbin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/.local/share/cargo/bin" .chezmoi.homeDir .brewPrefix .brewPrefix)
      "PC_CONFIG_FILES" (printf "%s/.config/process-compose/global.yaml" .chezmoi.homeDir)
      "PC_LOG_FILE" (printf "%s/process-compose.log" $stateDir) -}}
{{- if $uds -}}
{{-   $_ := set $env "PC_SOCKET_PATH" (printf "%s/global.sock" $stateDir) -}}
{{- end -}}
{{- includeTemplate "launchd-agent.plist.tmpl" (dict
      "label" "com.process-compose"
      "args" $args
      "env" $env
      "stdout" (printf "%s/stdout.log" $stateDir)
      "stderr" (printf "%s/stderr.log" $stateDir)) -}}
