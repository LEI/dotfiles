{{- $provider := get .ai.providers "ollama" -}}
{{- $ollama := get . "ollama" | default dict -}}
{{- $service := get $ollama "service" -}}
{{- $active := get $provider "active" -}}
{{- if $service -}}
#!/bin/sh

set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

{{- if eq $service "brew" }}
{{ includeTemplate "brew-apply.sh.tmpl" (dict
  "active" $active
  "formula" "ollama"
  "port" $provider.port
  "liveness" $provider.liveness) }}
{{- else if eq $service "compose" }}
{{-   if $active }}
{{- includeTemplate "health-check.sh.tmpl" (merge (dict "name" "ollama" "active" $active) $provider) }}
{{-   end }}
{{- else if eq $service "quadlet" }}
{{- $containerFile := joinPath .chezmoi.homeDir ".config/containers/systemd/ollama.container" -}}
# container: {{ include $containerFile | sha256sum }}
# Pre-pull image to avoid systemd timeout
{{-   $version := $ollama.version | default "0.21.0" }}
msg "ollama: pulling image docker.io/ollama/ollama:{{ $version }}..."
run podman pull "docker.io/ollama/ollama:{{ $version }}"
{{ includeTemplate "systemd-apply.sh.tmpl" (dict
  "chezmoi" .chezmoi
  "active" $active
  "unit" "ollama.container"
  "port" $provider.port
  "liveness" $provider.liveness
) | trim }}
{{ end -}}
{{ end -}}
