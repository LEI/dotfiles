{{- $hardware := get . "hardware" | default dict -}}
{{- if get (get .ai.providers "ollama") "active" -}}
{{- $ollamaModels := list -}}
{{- range $name, $meta := .ai.models -}}
{{-   $id := get $meta "ollama" -}}
{{-   if and $id (or (get $hardware "gpuAccelerated") (get $meta "cpu")) -}}
{{-     $ollamaModels = append $ollamaModels $id -}}
{{-   end -}}
{{- end -}}
{{- if $ollamaModels -}}
#!/bin/sh

# models: {{ $ollamaModels | toJson | sha256sum }}

set -eu

lib_dir="$CHEZMOI_WORKING_TREE/home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
. "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/run.sh
. "$lib_dir/sh/run.sh"
. "$HOME/.ollama/init.sh"

if ! run ollama list; then
  die "ollama list: exit code $?"
fi

{{- range $ollamaModels }}
run ollama pull {{ . }}
{{- end }}
{{ end -}}
{{ end -}}
