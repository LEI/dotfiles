{{- if (get .ai.providers "ollama").enabled -}}
{{- $ollamaModels := list -}}
{{- range $name, $meta := .ai.models -}}
{{-   $id := get $meta "ollama" -}}
{{-   if $id -}}
{{-     $ollamaModels = append $ollamaModels $id -}}
{{-   end -}}
{{- end -}}
#!/bin/sh

# models: {{ $ollamaModels | toJson | sha256sum }}

set -eu

. "$CHEZMOI_WORKING_TREE/home/.chezmoitemplates/helpers.sh"

if ! run ollama list; then
  die "ollama list: exit code $?"
fi

{{- range $ollamaModels }}
run ollama pull {{ . }}
{{- end }}
{{ end -}}
