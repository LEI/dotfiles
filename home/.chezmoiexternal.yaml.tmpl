---
# https://www.chezmoi.io/user-guide/include-files-from-elsewhere/

{{- if .codespaces }}
.vscode-remote/User/globalStorage/zokugun.sync-settings/repository:
  type: git-repo
  url: {{ .headless | ternary "https://github.com/lei/vscode-settings.git" "git@github.com:lei/vscode-settings.git" | quote }}
  refreshPeriod: 168h
{{- end }}

{{- if .features.void }}
.config/Void/User/globalStorage/zokugun.sync-settings/repository:
  type: git-repo
  url: {{ .headless | ternary "https://github.com/lei/vscode-settings.git" "git@github.com:lei/vscode-settings.git" | quote }}
  refreshPeriod: 168h
{{- end }}

{{- if .features.vscode }}
.config/Code/User/globalStorage/zokugun.sync-settings/repository:
  type: git-repo
  url: {{ .headless | ternary "https://github.com/lei/vscode-settings.git" "git@github.com:lei/vscode-settings.git" | quote }}
  refreshPeriod: 168h
{{- end }}

{{- if .features.vscodium }}
.config/VSCodium/User/globalStorage/zokugun.sync-settings/repository:
  type: git-repo
  url: {{ .headless | ternary "https://github.com/lei/vscode-settings.git" "git@github.com:lei/vscode-settings.git" | quote }}
  refreshPeriod: 168h
{{- end }}

.config/nushell/functions/extract.nu:
  type: file
  url: https://raw.githubusercontent.com/nushell/nu_scripts/refs/heads/main/modules/data_extraction/ultimate_extractor.nu
  refreshPeriod: 168h

# ~/nu_scripts/themes/nu-themes
.config/nushell/themes/tokyo-storm.nu:
  type: file
  url: https://raw.githubusercontent.com/nushell/nu_scripts/refs/heads/main/themes/nu-themes/tokyo-storm.nu
  refreshPeriod: 168h

{{- if eq .chezmoi.os "linux" }}
# .local/bin/uv:
#   type: "archive-file"
#   url: # gitHubLatestReleaseAssetURL "astral-sh/uv" "uv-x86_64-unknown-linux-gnu.tar.gz" | quote
#   refreshPeriod: "72h"
#   executable: true
#   path: "uv-x86_64-unknown-linux-gnu/uv"
{{- end }}
