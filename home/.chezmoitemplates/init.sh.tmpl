{{- $shell := get . "shell" -}}
{{- if and $shell (lookPath .shell | isExecutable) -}}
SHELL={{ lookPath .shell | quote }}
{{ end -}}
shell="${SHELL##*/}"

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

if [[ $- != *i* ]]; then
  return
fi

source "$XDG_CONFIG_HOME/sh/lib/bench.sh"
bench_source "$HOME/.profile"

# Shell options
if [ -f "$XDG_CONFIG_HOME/$shell/options.$shell" ]; then
  source "$XDG_CONFIG_HOME/$shell/options.$shell"
fi

if [ -z "${USER:-}" ]; then
  USER="$(id -un)"
fi

# Load environment variables before other scripts (e.g. INPUTRC before ble.sh)
if [ -f "$XDG_CONFIG_HOME/sh/environment.sh" ]; then
  bench_source "$XDG_CONFIG_HOME/sh/environment.sh"
fi

{{- if and (eq $shell "bash") (ne .osID "alpine") (ne .os "windows") }}

# ble.sh includes its own preexec; never load both
if [ -f "$XDG_DATA_HOME/blesh/ble.sh" ]; then
  # Remove default prompt command
  if [ -n "${PROMPT_COMMAND:-}" ] && [[ "$PROMPT_COMMAND" = *"\033]0;"* ]]; then
    export PROMPT_COMMAND=
  fi
  bench_source "$XDG_DATA_HOME/blesh/ble.sh" --attach=none --rcfile "$XDG_CONFIG_HOME/blesh/config.sh"
elif [ -f "$XDG_DATA_HOME/bash-preexec.sh" ]; then
  bench_source "$XDG_DATA_HOME/bash-preexec.sh"
fi
{{- end }}

{{ includeTemplate "init-tools.sh.tmpl" . | trim }}

{{- if and .features.sheldon (lookPath "sheldon" | isExecutable) }}
# https://github.com/rossmacarthur/sheldon#loading-plugins
if [ "$shell" = bash ]; then
  export SHELDON_CONFIG_FILE="$XDG_CONFIG_HOME/sheldon/bash.toml"
fi
if command -v sheldon >/dev/null; then
  BENCHFMT=sheldon bench eval "$(sheldon source)"
else
  echo "init: command not found: sheldon" >&2
fi
{{- end }}

if [ -f "$XDG_CONFIG_HOME/sh/aliases.sh" ]; then
  bench_source "$XDG_CONFIG_HOME/sh/aliases.sh"
fi

# Per-shell config: .conf for variables (via export_env), .sh for shell code
for _conf in "$XDG_CONFIG_HOME/$shell/"*.conf; do
  if [ -f "$_conf" ]; then
    export_env "$_conf"
  fi
done
for _conf in "$XDG_CONFIG_HOME/$shell/"*.sh; do
  if [ -f "$_conf" ]; then
    bench_source "$_conf"
  fi
done
unset _conf

if [ -f "$HOME/.${shell}rc.local" ]; then
  # shellcheck disable=SC1090
  bench_source "$HOME/.${shell}rc.local"
fi

{{- if and (eq $shell "bash") (ne .osID "alpine") (ne .os "windows") }}

# https://github.com/akinomyoga/ble.sh#13-set-up-bashrc
if [[ ${BLE_VERSION-} ]]; then
  ble-attach
fi
{{- end }}
