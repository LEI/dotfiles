# Bootstrap: lib/ contains infrastructure sourced before everything else
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
source "$XDG_CONFIG_HOME/sh/lib/export.sh"
if [ -d "$XDG_CONFIG_HOME/environment.d" ]; then
  export_env "$XDG_CONFIG_HOME/environment.d/"*.conf
fi
source "$XDG_CONFIG_HOME/sh/lib/pathmunge.sh"
source "$XDG_CONFIG_HOME/sh/lib/bench.sh"

# Source local environment variables
[ -f "$XDG_CONFIG_HOME/sh/local.sh" ] && source "$XDG_CONFIG_HOME/sh/local.sh"

# Non-interactive command mode; see environment.plist (BASH_ENV)
# https://github.com/neovide/neovide/discussions/3175
if [[ $- == *c* ]] && [[ $- != *i* ]]; then
  # [[ "${BASH_EXECUTION_STRING:-}" == "{{ lookPath "nvim" }} --embed -p" ]]
  # BASH_CONFIG="neovide"
  PATH="$PATH:$HOME/.local/bin"
  if [ -z "${MISE_SHELL:-}" ]; then
    PATH="$PATH:$XDG_DATA_HOME/mise/shims"
  fi
  source "$XDG_CONFIG_HOME/sh/environment.sh"
  return
fi

if [[ $- != *i* ]]; then
  # We are being invoked from a non-interactive shell.  If this
  # is an SSH session (as in "ssh host command"), source
  # /etc/profile so we get PATH and other essential variables.
  [[ -n "${SSH_CLIENT:-}" ]] && source /etc/profile
  return
fi

# Remove default prompt command
if [ -n "${PROMPT_COMMAND:-}" ] && [[ "$PROMPT_COMMAND" = *"\033]0;"* ]]; then
  export PROMPT_COMMAND=
fi

{{- $shell := get . "shell" }}
{{- if empty $shell }}
{{-   warnf "missing shell (bash or zsh)" }}
{{- end }}

shell="{{ $shell }}" # ${SHELL##*/}

if [ -z "${USER:-}" ]; then
  USER="$(id -un)"
fi

if [ "$shell" = bash ]; then IS_BASH=true; else IS_BASH=false; fi
{{- if eq .osID "alpine" }}
BLE_ENABLED="${BLE_ENABLED:-false}"
PREEXEC_ENABLED=${PREEXEC_ENABLED:-$IS_BASH}
{{- else }}
BLE_ENABLED="${BLE_ENABLED:-$IS_BASH}"
PREEXEC_ENABLED="${PREEXEC_ENABLED:-false}"
{{- end }}

# Load environment variables before other scripts (e.g. INPUTRC before ble.sh)
[ -f "$XDG_CONFIG_HOME/sh/environment.sh" ] && . "$XDG_CONFIG_HOME/sh/environment.sh"

# Component init files, generated from chezmoi source tree at render time.
# Feature-gated components are absent when the feature is off (chezmoiignore).
# Tool activations (mise, starship, etc.) are sourced separately below in explicit order.
{{- $src := .chezmoi.sourceDir }}
{{- $dotcfg := joinPath $src "dot_config" }}
{{- $toolDirs := list "atuin" "carapace" "direnv" "mise" "starship" "zoxide" }}
for _f in \
  "$XDG_CONFIG_HOME/sh/functions/"*.sh \
{{- range glob (joinPath $src "dot_*/init.sh") }}
  "$HOME/{{ . | trimPrefix $src | trimPrefix "/" | replaceAllRegex "^dot_" "." }}" \
{{- end }}
{{- range glob (joinPath $dotcfg "*/init.sh") }}
{{-   $dir := . | trimPrefix $dotcfg | trimPrefix "/" | dir }}
{{-   if not (has $dir $toolDirs) }}
  "$XDG_CONFIG_HOME/{{ . | trimPrefix $dotcfg | trimPrefix "/" }}" \
{{-   end }}
{{- end }}
; do
  [ -f "$_f" ] && . "$_f"
done
unset _f

if [ -d "$HOME/bin" ]; then
  pathmunge "$HOME/bin"
fi

{{- if .features.brew }}

# Homebrew
brew_prefix="${HOMEBREW_PREFIX:-{{ .brewPrefix }}}"

if [ -x "$brew_prefix/bin/brew" ]; then
  eval "$("$brew_prefix/bin/brew" shellenv)"
fi

{{- if .features.bash }}

if [ -d "$brew_prefix/opt/bash/bin" ]; then
  pathmunge "$brew_prefix/opt/bash/bin" replace
fi
{{- end }}

{{- if .features.ruby }}

if [ -d "$brew_prefix/opt/ruby/bin" ]; then
  pathmunge "$brew_prefix/opt/ruby/bin" replace
fi

# ruby_version="${ruby_version:-3.4.0}"
# if [ -n "$GEM_USER_HOME" ] && [ -d "$GEM_USER_HOME" ]; then
#   pathmunge "$GEM_USER_HOME" replace
# fi
{{- end }}
{{- end }}

if [ "$BLE_ENABLED" = true ] && [ -f "$XDG_DATA_HOME/blesh/ble.sh" ]; then
  . "$XDG_DATA_HOME/blesh/ble.sh" --rcfile "$XDG_CONFIG_HOME/blesh/config.sh" # --noattach
fi
if [ "$PREEXEC_ENABLED" = true ] && [ -f "$XDG_DATA_HOME/bash-preexec.sh" ]; then
  . "$XDG_DATA_HOME/bash-preexec.sh"
fi

{{- if .features.carapace }}

if [ -d "$XDG_CONFIG_HOME/carapace/bin" ]; then
  pathmunge "$XDG_CONFIG_HOME/carapace/bin" after
fi
{{- end }}

{{- if and .features.sheldon (lookPath "sheldon" | isExecutable) }}
# https://github.com/rossmacarthur/sheldon#loading-plugins
eval "$(SHELDON_CONFIG_FILE="$XDG_CONFIG_HOME/sheldon/$shell.toml" sheldon source)"
{{- else }}
{{ includeTemplate "init-tools.sh.tmpl" . }}
{{- end }}

{{- if and .features.ai .features.git }}
# if command -v gh >/dev/null; then
#   eval "$(gh copilot alias -- "$shell")"
# fi
{{ end }}
[ -f "$XDG_CONFIG_HOME/sh/aliases.sh" ] && . "$XDG_CONFIG_HOME/sh/aliases.sh"

# Per-shell config: .conf for variables (via export_env), .sh for shell code
for _f in "$XDG_CONFIG_HOME/$shell/"*.conf; do
  [ -f "$_f" ] && export_env "$_f"
done
for _f in "$XDG_CONFIG_HOME/$shell/"*.sh; do
  case "${_f##*/}" in init.sh) continue ;; esac
  [ -f "$_f" ] && . "$_f"
done
unset _f

[ -f "$HOME/.${shell}rc.local" ] && . "$HOME/.${shell}rc.local"

# https://github.com/akinomyoga/ble.sh#13-set-up-bashrc
if [ "$BLE_ENABLED" = true ] && [ -f "$XDG_DATA_HOME/blesh/ble.sh" ]; then
  [[ ! ${BLE_VERSION-} ]] || ble-attach
fi
