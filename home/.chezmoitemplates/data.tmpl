{{- $dir := get . "dir" -}}
{{- $dataFile := joinPath $dir ".data.yaml" -}}
{{- $data := dict -}}
{{- if stat (joinPath .chezmoi.sourceDir $dataFile) -}}
{{-   $data = include $dataFile | fromYaml -}}
{{- end -}}
{{- $targetDir := $dir | replace "dot_" "." -}}
{{- $localFile := joinPath .chezmoi.homeDir $targetDir "local.yaml" -}}
{{- if stat $localFile -}}
{{-   $local := include $localFile | fromYaml -}}
{{-   range $key, $localValue := $local -}}
{{-     $dataValue := get $data $key -}}
{{-     if and (kindIs "map" $dataValue) (kindIs "map" $localValue) -}}
{{-       $data = set $data $key (merge $dataValue $localValue) -}}
{{-     else -}}
{{-       $data = set $data $key $localValue -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{ $data | toYaml | trim }}
