{{- /* Skill sources [{name, src}] (per-skill dir), shared by publish-opkg symlinks and the opencode.jsonc allowlist. Mirrors opkg-rule-paths.tmpl. */ -}}
{{- $skills := list -}}
{{- $localSkillsDir := joinPath .chezmoi.homeDir ".openpackage/packages/local/skills" -}}
{{- if stat $localSkillsDir -}}
{{-   range $skillDir := glob (joinPath $localSkillsDir "*") -}}
{{-     if stat (joinPath $skillDir "SKILL.md") -}}
{{-       $skills = append $skills (dict "name" (base $skillDir) "src" $skillDir) -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- range $mktName, $mkt := dig "claude" "marketplaces" (dict) . -}}
{{-   $path := get $mkt "path" -}}
{{-   if not $path -}}{{- continue -}}{{- end -}}
{{-   $packagesRoot := joinPath $.chezmoi.homeDir $path "packages" -}}
{{-   if not (stat $packagesRoot) -}}{{- continue -}}{{- end -}}
{{-   range $pkgDir := glob (joinPath $packagesRoot "*") -}}
{{-     if eq (base $pkgDir) "local" -}}{{- continue -}}{{- end -}}
{{-     $skillsDir := joinPath $pkgDir "skills" -}}
{{-     if not (stat $skillsDir) -}}{{- continue -}}{{- end -}}
{{-     range $skillDir := glob (joinPath $skillsDir "*") -}}
{{-       if stat (joinPath $skillDir "SKILL.md") -}}
{{-         $skills = append $skills (dict "name" (base $skillDir) "src" $skillDir) -}}
{{-       end -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- /* Dedup by name, first occurrence wins so the local dir keeps precedence, then stable sort */ -}}
{{- $byName := dict -}}
{{- range $s := $skills -}}
{{-   if not (hasKey $byName $s.name) -}}{{- $byName = set $byName $s.name $s -}}{{- end -}}
{{- end -}}
{{- $sorted := list -}}
{{- range $n := (keys $byName | sortAlpha) -}}{{- $sorted = append $sorted (index $byName $n) -}}{{- end -}}
{{- $sorted | toJson }}
