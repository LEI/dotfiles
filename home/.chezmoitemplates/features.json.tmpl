{{- $fr := hasPrefix "fr" .hostname }}
{{- $mb := hasPrefix "mb" .hostname }}
{{- $ai := and
    (not .container)
    (eq .osIDLike "arch" "darwin" "fedora")
    (ne .profile "minimal")
    (or $fr $mb)
-}}
{{- $mlx := and (eq .os "darwin") (eq .arch "arm64") -}}
{{- $ollama := and $ai .hardware.gpuAccelerated -}}
{{- $docker := and (eq .osIDLike "arch" "darwin" "fedora") .gui -}}
{{- $podman := and (eq .osIDLike "arch" "darwin" "fedora") .gui -}}
{{- $features := (dict
  "ai" $ai
  "atuin" (and
    (ne .osID "alpine")
    (not (or
      (and (eq .osID "debian") (le (int .osVersion) 12))
      (and (eq .osID "ubuntu") (lt (float64 .osVersion) 24.04))))
    (ne .profile "minimal"))
  "bash" (or .ci .ephemeral (ne .profile "minimal"))
  "bat" (ne .profile "minimal")
  "caddy" (and (eq .osIDLike "arch" "darwin" "debian" "fedora") (not (or .ephemeral .headless)))
  "bottom" .gui
  "brew" (not (eq .osIDLike "alpine" "android" "windows"))
  "carapace" true
  "claude" $ai
  "codex" $ai
  "direnv" true
  "docker" $docker
  "eza" (ne .profile "minimal")
  "fd" (ne .profile "minimal")
  "gemini" $ai
  "ghostty" (and
    (or (eq .libc "gnu") (eq .os "darwin"))
    (not (and (eq .osID "ubuntu") (le (float64 .osVersion) 22.04)))
    (not (eq .os "android" "windows"))
    .gui)
  "git" true
  "go" (and (ne .profile "minimal") (eq .osIDLike "alpine" "arch" "darwin" "debian" "fedora") (not (or .ephemeral .headless)))
  "goose" $ai
  "goss" (ne .profile "minimal")
  "gpg" (and (ne .profile "minimal") (eq .osIDLike "arch" "darwin"))
  "helix" (and
    (not (and (eq .osIDLike "debian") (eq .libc "gnu")))
    (not (or .ephemeral .headless)))
  "i3" (and (eq .osIDLike "arch") .gui)
  "iterm2" (eq .os "darwin")
  "kb" (and (ne .profile "minimal") (eq .osIDLike "arch" "darwin" "fedora") (not (or .ephemeral .headless)))
  "kube" (and (eq .profile "personal") (eq .osIDLike "arch" "darwin" "debian" "fedora") (not (or .ephemeral .headless)))
  "kilo" $ai
  "lla" false
  "logseq" (and (ne .profile "minimal") .gui (eq .osIDLike "arch" "darwin" "fedora") (not (or .ephemeral .headless)))
  "mail" (and (eq .osIDLike "arch") (not (empty .passwordManager.accessToken)))
  "milvus" (or $mlx $ollama)
  "mise" true
  "mlx" $mlx
  "neovim" (and
    (not (eq .osIDLike "alpine"))
    (or (not (or .ephemeral .headless)) .wsl))
  "node" (and
    (not (eq .osIDLike "alpine"))
    (or (eq .os "android") (not (or .ephemeral .headless))))
  "nushell" .gui
  "oage" (and $ai (or $docker $podman))
  "ollama" $ollama
  "opencode" $ai
  "openpackage" $ai
  "pi" $ai
  "otel" (and $ai (or $docker $podman))
  "php" false
  "podman" $podman
  "processCompose" $ai
  "python" true
  "qdrant" (or $mlx $ollama)
  "rest" false
  "ripgrep" true
  "ruby" (and (ne .profile "minimal") (not (eq .os "windows")) (not (or .ephemeral .headless)))
  "rust" (and (ne .profile "minimal") (eq .osIDLike "arch" "darwin" "debian" "fedora") (not (or .ephemeral .headless)))
  "sh" (or .ci .ephemeral (ne .profile "minimal"))
  "sheldon" (ne .os "windows")
  "shpool" false
  "sql" (and (eq .osIDLike "arch" "darwin" "debian" "fedora") (not (or .ephemeral .headless)))
  "ssh" false
  "starship" true
  "steam" (and (eq .osIDLike "arch" "fedora" "windows") (eq .profile "personal"))
  "sway" false
  "tailscale" (and (ne .os "android") (eq .profile "personal") (not (or .ephemeral .headless)))
  "tmux" (eq .osIDLike "alpine" "android" "arch" "darwin" "debian" "fedora")
  "tofu" (and (ne .profile "minimal") (eq .osIDLike "arch" "darwin"))
  "toolbox" (eq .osIDLike "fedora")
  "topgrade" (and .gui (or (eq .os "android") (ne .libc "musl")))
  "vim" (and
    (not (eq .osIDLike "alpine"))
    (not (or .ephemeral .headless)))
  "void" (and (eq .osIDLike "arch") .gui)
  "vscode" (and (eq .osIDLike "arch" "fedora" "darwin") .gui)
  "vscodium" (and (eq .osIDLike "arch" "fedora") .gui)
  "zellij" (eq .osIDLike "alpine" "android" "arch" "darwin" "debian" "fedora" "windows")
  "zoxide" true
  "zsh" (or .ci .ephemeral (ne .profile "minimal"))
  "backup" (and (eq .osIDLike "fedora") (eq .profile "personal") (not .ephemeral))
  "btrfs" (and (eq .osIDLike "fedora") (ne .variantID "") (not .ephemeral) (lookPath "btrfs" | isExecutable))
) -}}
{{- /* "node" (eq .osIDLike "android" "arch" "darwin" "debian" "fedora" "windows")*/ -}}
{{- /* "lla" (eq .osID "arch" "darwin") */ -}}

{{- if eq .osID "alpine" }}
{{- $features = mergeOverwrite $features (dict
) -}}
{{- else if eq .osID "android" }}
{{- $features = mergeOverwrite $features (dict
  "claude" true
) -}}
{{- else if eq .osIDLike "arch" }}
{{- $features = mergeOverwrite $features (dict
  "php" true
  "ssh" true
) -}}
{{- else if eq .os "darwin" }}
{{- $features = mergeOverwrite $features (dict
  "php" true
  "ssh" true
) -}}
{{- else if eq .osIDLike "debian" }}
{{- $features = mergeOverwrite $features (dict
  "php" true
  "ssh" true
) -}}
{{- else if eq .osIDLike "fedora" }}
{{- $features = mergeOverwrite $features (dict
  "ssh" true
) -}}
{{- else if eq .os "windows" }}
{{- $features = mergeOverwrite $features (dict
) -}}
{{- end }}

{{- if or .ephemeral .headless }}
{{- $features = mergeOverwrite $features (dict
  "go" false
  "tmux" false
  "zellij" false
) -}}
{{- end }}

{{- range $name, $default := $features }}
{{- $key := upper (printf "FEATURE_%s" $name) -}}
{{- $value := env $key -}}
{{- if empty $value -}}
{{-   $value = $default -}}
{{- end -}}
{{- $_ := set $features $name $value -}}
{{- end -}}

{{- $features | toJson }}
