{{- $signingKey := get . "signingkey" | default (includeTemplate "gpg-signing-key.tmpl" (dict "email" .email "sh" .sh)) | trim -}}

[user]
	name = {{ .name | trim | quote }}
	email = {{ .email | trim | quote }}
	signingkey = {{ $signingKey | quote }}

[commit]
	gpgsign = {{ $signingKey | not | not }}
