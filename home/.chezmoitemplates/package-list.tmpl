{{- $packages := list }}

{{- range $index, $pkg := .packages }}
{{-   $packageName := "" }}
{{-   if kindIs "map" $pkg }}
{{-     $packageName = get $pkg "name" }}
{{-   else if kindIs "string" $pkg }}
{{-     $packageName = $pkg }}
{{-     $pkg = dict "name" $packageName }}
{{-   end }}

{{-   if and (eq $.osid "windows") (not (contains "." $packageName)) }}
{{-     $packageName = get $pkg "windows" | default (printf "%[1]s.%[1]s" $packageName) }}
{{-   end }}

{{-   $feature := get $pkg "feature" | default nil }}
{{-   if $feature }}
{{-     if and (ne (substr 0 4 $feature) "not ") (get $.features $feature | default false | not) }}
{{-       continue }}
{{-     else if and (eq (substr 0 4 $feature) "not ") (get $.features (substr 4 (len $feature) $feature) | default false | not) }}
{{-       continue }}
{{-     end }}
{{-   end }}

{{-   $os := get $pkg "os" | default nil }}
{{-   if $os }}
{{-     if and (ne (substr 0 4 $os) "not ") (ne $.chezmoi.os $os) }}
{{-       continue }}
{{-     else if and (eq (substr 0 4 $os) "not ") (eq $.chezmoi.os (substr 4 (len $os) $os)) }}
{{-       continue }}
{{-     end }}
{{-   end }}

{{-   $id := get $pkg "id" | default nil }}
{{-   if $id }}
{{-     if and (ne (substr 0 4 $id) "not ") (ne $.chezmoi.osRelease.id $id) }}
{{-       continue }}
{{-     else if and (eq (substr 0 4 $id) "not ") (eq $.chezmoi.osRelease.id (substr 4 (len $id) $id)) }}
{{-       continue }}
{{-     end }}
{{-   end }}

{{-   $idLike := get $pkg "idLike" | default nil }}
{{-   if $idLike }}
{{-     if and (ne (substr 0 4 $idLike) "not ") (ne (get $.chezmoi.osRelease "idLike" | default $.chezmoi.osRelease.id) $idLike) }}
{{-       continue }}
{{-     else if and (eq (substr 0 4 $idLike) "not ") (eq (get $.chezmoi.osRelease "idLike" | default $.chezmoi.osRelease.id) (substr 4 (len $idLike) $idLike)) }}
{{-       continue }}
{{-     end }}
{{-   end }}

{{-   $packages = append $packages $packageName }}
{{- end }}
{{- $packages | toJson -}}
