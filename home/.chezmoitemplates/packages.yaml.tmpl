    enabled: {{ and (not (eq .osIDLike "debian" "fedora")) (ne .profile "minimal") }}
    nameOverwrite:
      windows: ducaale.xh
  yazi:
    enabled: {{ not (eq .osIDLike "alpine" "debian" "fedora") }}
    nameOverwrite:
      darwin: yazi ffmpeg sevenzip poppler resvg imagemagick # font-symbols-only-nerd-font
