---
# vi: ft=yaml.template
# https://www.chezmoi.io/user-guide/advanced/install-packages-declaratively/
commonPackages:
  7zip:
    nameOverwrite:
      windows: 7zip.7zip
  autossh:
    enabled: {{ and (get .features "ssh") (not (eq .osIDLike "debian" "windows")) }}
  bandwhich: # netshow, slurm
    enabled: {{ and (not (eq .osIDLike "android" "debian" "fedora" "windows")) (ne .profile "minimal") }}
  bkt:
    enabled: {{ not (eq .osIDLike "android" "arch" "alpine" "debian" "fedora" "windows") }}
