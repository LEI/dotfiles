    type: '{{ eq .osIDLike "arch" | ternary "aur" nil }}'
  unzip:
  up:
    enabled: {{ eq .osIDLike "arch" "darwin" }}
    # usage: lshw |& up
  usage:
    enabled: {{ get .features "mise" }}
    type: mise
  uv:
    enabled: {{ and (get .features "python") (eq .osIDLike "alpine" "android" "arch" "fedora" "windows") }}
    nameOverwrite:
      windows: astral-sh.uv
  util-linux: { enabled: {{ eq .os "android" "linux" }} }
  viddy: # watch
    enabled: {{ and (eq .osIDLike "alpine" "arch" "darwin") (ne .profile "minimal") }}
    nameOverwrite:
      arch: viddy-bin
    type: '{{ eq .osIDLike "arch" | ternary "aur" nil }}'
