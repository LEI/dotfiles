    enabled: {{ and (eq .osIDLike "arch" "darwin") (ne .profile "minimal") }}
  nvtop: # nvitop, qmassa
    enabled: {{ and (eq .os "linux") (not (eq .osIDLike "alpine" "debian")) (not .headless) }}
