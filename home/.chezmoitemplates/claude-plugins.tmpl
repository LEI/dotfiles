{{- $claude := get . "claude" | default dict -}}
{{- $claudeMarketplaces := get $claude "marketplaces" | default dict -}}
{{- $claudePlugins := get $claude "plugins" | default dict -}}
{{- $marketplaces := dict -}}
{{- range $name, $info := $claudeMarketplaces -}}
{{-   if hasKey $info "repo" -}}
{{-     $marketplaces = set $marketplaces $name (dict "repo" $info.repo) -}}
{{-   else -}}
{{-     $marketplaces = set $marketplaces $name (dict "path" (printf "%s/%s" $.chezmoi.homeDir $info.path)) -}}
{{-   end -}}
{{- end -}}
{{- $plugins := list -}}
{{- range (keys $claudePlugins | sortAlpha) -}}
{{-   $marketplace := . -}}
{{-   range (get $claudePlugins $marketplace) -}}
{{-     if kindIs "string" . -}}
{{-       $plugins = append $plugins (dict "name" . "marketplace" $marketplace) -}}
{{-     else -}}
{{-       $entry := dict "name" .name "marketplace" $marketplace -}}
{{-       if get . "version" }}{{ $entry = set $entry "version" .version }}{{ end -}}
{{-       $plugins = append $plugins $entry -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- dict "plugins" $plugins "marketplaces" $marketplaces | toJson }}
