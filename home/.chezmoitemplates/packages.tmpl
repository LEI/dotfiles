{{- $defaultType := get . "defaultType" | default (get .packageManagerMap .osIDLike) -}}
{{- $packageType := get . "packageType" | default $defaultType -}}
{{- $packages := dict -}}

{{- $p := includeTemplate "packages.yaml.tmpl" . | fromYaml -}}
{{- $common := $p.commonPackages -}}
{{- $commonPackages := includeTemplate "parse-packages.tmpl" (dict
  "chezmoi" .chezmoi
  "defaultType" $defaultType
  "features" .features
  "os" .os
  "osID" .osID
  "osIDLike" .osIDLike
  "packageType" $packageType
  "packages" $common
) | fromJson -}}
{{- $packages = merge $packages $commonPackages -}}

{{- $extraPackages := includeTemplate "parse-packages.tmpl" (dict
  "chezmoi" .chezmoi
  "defaultType" $defaultType
  "features" .features
  "os" .os
  "osID" .osID
  "osIDLike" .osIDLike
  "packageType" $packageType
  "packages" .extraPackages
) | fromJson -}}
{{- $packages = merge $packages $extraPackages -}}

{{- $os := get (get $p.osPackages .osIDLike) $packageType -}}
{{- $osPackages := dict -}}
{{- if $os -}}
{{- $osPackages := includeTemplate "parse-packages.tmpl" (dict
  "chezmoi" .chezmoi
  "defaultType" $packageType
  "features" .features
  "os" .os
  "osID" .osID
  "osIDLike" .osIDLike
  "packageType" $packageType
  "packages" $os
) | fromJson -}}
{{- $packages = merge $packages $osPackages -}}
{{- end -}}

{{- if and (get .features "python") (eq $packageType $defaultType) }}
{{-   $pythonPackages := includeTemplate "dot_config/mise/system-python-packages.tmpl" . | trim | splitList "\n" -}}
{{-   range $name := without $pythonPackages "" -}}
{{-     if eq (substr 0 1 $name) "#" -}}
{{-       continue -}}
{{-     end -}}
{{-     if not (eq $.osID "darwin") -}}
{{-       $prefix := "python" -}}
{{-       if eq $.osID "alpine" -}}
{{-         $prefix = "py3" -}}
{{-       else if eq $.osIDLike "debian" "fedora" -}}
{{-         $prefix = "python3" -}}
{{-       end -}}
{{-       $name = printf "%s-%s" $prefix $name -}}
{{-     end -}}
{{- /*     $packages = append $packages $name */ -}}
{{-     if get $packages $name -}}
{{-       warnf "Overriding package (python) %s (%s -> %s)" $name (get (get $packages $name) "options") dict -}}
{{-     end -}}
{{-     $_ := $packages | setValueAtPath $name dict -}}
{{-   end -}}
{{- end }}

{{- $packages | toJson -}}
