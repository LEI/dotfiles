{{- /* Emit before/after install hooks from package values via pluck.tmpl */ -}}
{{- $key := get . "key" -}}
{{- $values := get . "values" -}}
{{- $scripts := includeTemplate "pluck.tmpl" (dict "key" $key "values" $values) | trim -}}
{{- if $scripts }}
# {{ if eq .key "before_script" }}Before{{ else }}After{{ end }} script{{ with get . "label" }} ({{ . }}){{ end }}:
{{ $scripts | trim }}
{{ end -}}
