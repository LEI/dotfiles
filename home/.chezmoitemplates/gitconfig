{{- $signingKey := get . "signingkey" | default (includeTemplate "gpg-signing-key.tmpl" (dict "email" .email)) -}}
{{- $gpg := lookPath "gpg" -}}

[user]
	name = {{ .name | trim | quote }}
	email = {{ .email | trim | quote }}
	signingkey = {{ $signingKey | quote }}

[commit]
	gpgsign = {{ $signingKey | not | not }}

{{- if and $signingKey $gpg }}

[gpg]
	program = {{ $gpg }}
{{- end }}
