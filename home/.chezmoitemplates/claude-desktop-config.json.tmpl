{{- $stateHome := env "XDG_STATE_HOME" | default (joinPath .chezmoi.homeDir ".local" "state") -}}
{{- $stateDir := env "CLAUDE_STATE_DIR" | default (joinPath $stateHome "claude") -}}
{
  "preferences": {
    {{- if eq .os "darwin" }}
    "quickEntryShortcut": {
      "accelerator": "Alt+Space"
    },
    {{- end }}
    "chillingSlothLocation": {
      "customPath": {{ joinPath $stateDir "worktrees" | quote }}
    },
    "launchPreviewPersistSession": false,
    "launchPreviewPersistedWorkspaces": [],
    "dispatchCodeTasksPermissionMode": "default",
    "coworkScheduledTasksEnabled": true,
    "ccdScheduledTasksEnabled": true,
    "sidebarMode": "epitaxy",
    "dockBounceEnabled": true,
    "coworkWebSearchEnabled": true,
    "keepAwakeEnabled": false
    {{- if eq .osIDLike "fedora" }},
    "localAgentModeTrustedFolders": [
      "/usr/lib/claude-desktop/node_modules/electron/dist/resources/app.asar"
    ]
    {{- end }}
  }
}{{- /* No newline at end of file */ -}}
