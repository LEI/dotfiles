{{- /* config-only value, no detection: a per-machine local.yaml override wins,
  else empty inside a container, no engine is nested in a throwaway container,
  else an OS-aware default (docker on darwin, podman elsewhere). Never read
  back CONTAINER_PROVIDER from the environment here, that would re-freeze a
  stale value */ -}}
{{- $local := includeTemplate "data.tmpl" (dict "dir" "" "chezmoi" .chezmoi) | fromYaml -}}
{{- $containerProvider := get $local "containerProvider" -}}
{{- if and (not $containerProvider) (not (get . "container")) -}}
{{-   $containerProvider = eq .chezmoi.os "darwin" | ternary "docker" "podman" -}}
{{- end -}}
{{- with $containerProvider }}{{ . }}
{{ end -}}
