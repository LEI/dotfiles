{{- $shell := get . "shell" }}
{{- $init := list "bash" "zsh" }}
{{- $ordered := list "mise" "carapace" "direnv" "starship" "zoxide" "atuin" }}
{{- if .features.brew }}
{{-   $ordered = prepend $ordered "homebrew" }}
{{- end }}
{{- $featureMap := dict
  "claude" "ai"
  "gem" "ruby"
  "krew" "kube"
  "npm" "node"
  "nvim" "neovim"
  "pi" "ai"
-}}

# Order matters: mise first, carapace before completions, starship before atuin
for _tool in {{ $ordered | join " " }}; do
  if ! [ -f "$XDG_CONFIG_HOME/$_tool/init.sh" ]; then
    echo >&2 "warning: init file not found for $_tool: $XDG_CONFIG_HOME/$_tool/init.sh"
    continue
  fi
  BENCHFMT="$_tool" bench source "$XDG_CONFIG_HOME/$_tool/init.sh"
done
unset _tool

# Feature init files
{{- $src := .chezmoi.sourceDir }}
{{- $dotcfg := joinPath $src "dot_config" }}
{{- $exclude := concat $init $ordered }}
for _feat in \
{{- range glob (joinPath $src "dot_*/init.sh*") }}
  {{- $name := . | dir | base | trimPrefix "dot_" }}
  {{- if has $name $exclude }}
  {{- /*  warnf "excluded: %s .%s/init.sh" $shell $name */ -}}
  {{-   continue }}
  {{- end }}
  {{- if not (get $.features (get $featureMap $name | default $name)) }}
  {{-   warnf "disabled: %s .%s/init.sh" $shell $name }}
  {{-   continue }}
  {{- end }}
  "$HOME/.{{ $name }}/{{ . | base | trimSuffix ".tmpl" }}" \
{{- end }}
{{- range glob (joinPath $dotcfg "*/init.sh*") }}
  {{- $name := . | dir | base }}
  {{- if has $name $exclude }}
  {{- /*  warnf "excluded: %s .%s/init.sh" $shell $name */ -}}
  {{-   continue }}
  {{- end }}
  {{- if not (get $.features (get $featureMap $name | default $name)) }}
  {{-   warnf "disabled: %s .%s/init.sh" $shell $name }}
  {{-   continue }}
  {{- end }}
  "$XDG_CONFIG_HOME/{{ $name }}/{{ . | base | trimSuffix ".tmpl" }}" \
{{- end }}
; do
  if ! [ -f "$_feat" ]; then
    echo >&2 "warning: init file not found: $_feat"
    continue
  fi
  source "$_feat"
done
unset _feat

{{- if .features.rust }}

# if [ -f "${CARGO_HOME:-$HOME/.cargo}/env" ]; then
#   . "${CARGO_HOME:-$HOME/.cargo}/env"
# fi
if [ -d "${CARGO_HOME:-$HOME/.cargo}/bin" ]; then
  pathmunge "${CARGO_HOME:-$HOME/.cargo}/bin" after
fi
{{- end }}
{{- if .features.go }}

if [ -n "$GOPATH" ] && [ -d "$GOPATH/bin" ]; then
  pathmunge "$GOPATH/bin" after
fi
{{- end }}

if [ -d "$HOME/.nix-profile/bin" ]; then
  pathmunge "$HOME/.nix-profile/bin" after
fi
