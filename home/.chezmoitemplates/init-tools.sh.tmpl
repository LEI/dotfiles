{{- $shell := get . "shell" }}
{{- $init := list "bash" "zsh" }}
{{- $orderedRaw := list "homebrew" "mise" "carapace" "direnv" "starship" "zoxide" "atuin" }}
{{- $ordered := list }}
{{- range $orderedRaw }}
{{-   $feat := get $.featureMap . | default . }}
{{-   $enabled := true }}
{{-   if hasKey $.features $feat }}
{{-     $enabled = get $.features $feat }}
{{-   end }}
{{-   if $enabled }}
{{-     $ordered = append $ordered . }}
{{-   end }}
{{- end }}
{{- if ne $shell "zsh" -}}
# shellcheck shell=bash
{{ end -}}

# Order matters: mise first, carapace before completions, starship before atuin
for _tool in {{ $ordered | join " " }}; do
  if ! [ -f "$XDG_CONFIG_HOME/$_tool/init.sh" ]; then
    echo "warning: init file not found for $_tool: $XDG_CONFIG_HOME/$_tool/init.sh" >&2
    continue
  fi
  bench "$_tool" source "$XDG_CONFIG_HOME/$_tool/init.sh"
done
unset _tool

{{- $exclude := concat $init $ordered }}
{{- $homeInit := glob (joinPath .chezmoi.sourceDir "dot_*/init.sh*") -}}
{{- $configInit := glob (joinPath (joinPath .chezmoi.sourceDir "dot_config") "*/init.sh*") -}}
{{- $files := list -}}
{{- range $index, $path := concat $homeInit $configInit }}
  {{- $name := $path | dir | base | trimPrefix "dot_" | trimSuffix "/init.sh" | trimSuffix "/init.sh.tmpl" }}
  {{- if has $name $exclude }}
  {{-   continue }}
  {{- end }}
  {{- if not (get $.features (get $.featureMap $name | default $name)) }}
  {{-   continue }}
  {{- end }}
  {{- $files = append $files ($path | trimSuffix ".tmpl"
    | replaceAllRegex "/dot_" "/."
    | replace (joinPath $.chezmoi.sourceDir "dot_config") "$XDG_CONFIG_HOME"
    | replace (joinPath $.chezmoi.sourceDir) "$HOME") -}}
{{- end }}
for _feat in {{ $files | sortAlpha | join " \\\n  " }}; do
  if ! [ -f "$_feat" ]; then
    echo "warning: init file not found: $_feat" >&2
    continue
  fi
  if hash bench_source 2>/dev/null; then
    # shellcheck source=/dev/null
    bench_source "$_feat"
  else
    # shellcheck source=/dev/null
    source "$_feat"
  fi
done
unset _feat
