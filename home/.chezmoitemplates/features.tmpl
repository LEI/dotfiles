{{- $features := (dict
  "ai" false
  "atuin" false
  "bash" true
  "docker" false
  "ghostty" false
  "git" true
  "go" false
  "goss" false
  "helix" .glibc231
  "kube" false
  "mise" true
  "neovim" false
  "node" false
  "nushell" true
  "php" false
  "python" false
  "ruby" false
  "rust" false
  "sql" false
  "tmux" false
  "tofu" false
  "topgrade" true
  "vim" false
  "void" false
  "vscode" false
  "vscodium" false
  "zellij" false
  "zsh" false
) -}}

{{- if ne .profile "minimal" }}
{{- $features = mergeOverwrite $features (dict
  "atuin" true
  "bash" true
  "docker" (or (lookPath "docker") (lookPath "podman") | not | not)
  "git" true
  "helix" true
  "kube" (lookPath "kubectl" | not | not)
  "nushell" true
  "python" true
  "tofu" (lookPath "tofu" | not | not)
  "ruby" true
  "topgrade" true
) -}}
{{- end }}

{{- if or (hasPrefix "fr" .hostname) (hasPrefix "mb" .hostname) -}}
{{- $features = mergeOverwrite $features (dict
  "ai" true
) -}}
{{- end }}

{{- if eq .osID "alpine" }}
{{- $features = mergeOverwrite $features (dict
  "docker" false
  "go" false
  "kube" false
  "neovim" false
  "node" false
  "rust" false
  "tmux" false
  "vim" false
  "zellij" false
) -}}
{{- else if eq .osID "android" }}
{{- $features = mergeOverwrite $features (dict
  "docker" false
  "kube" false
  "neovim" true
  "tmux" true
  "vim" true
  "zellij" true
) -}}
{{- else if eq .osIDLike "arch" }}
{{- $features = mergeOverwrite $features (dict
  "docker" true
  "ghostty" true
  "go" true
  "goss" true
  "kube" true
  "neovim" true
  "node" true
  "php" true
  "rust" true
  "sql" true
  "tmux" true
  "vim" true
  "void" true
  "vscode" true
  "vscodium" true
  "zellij" true
  "zsh" true
) -}}
{{- else if eq .osIDLike "debian" }}
{{- $features = mergeOverwrite $features (dict
  "atuin" (not .glibc231)
  "docker" false
  "ghostty" (not .glibc231)
  "go" true
  "helix" (not .glibc231)
  "kube" false
  "neovim" true
  "node" true
  "php" true
  "rust" true
  "sql" true
  "tmux" true
  "topgrade" (not .glibc231)
  "vim" true
  "zellij" true
) -}}
{{- else if eq .chezmoi.os "darwin" }}
{{- $features = mergeOverwrite $features (dict
  "bash" false
  "docker" true
  "ghostty" true
  "git" false
  "go" true
  "kube" true
  "neovim" true
  "node" true
  "php" true
  "rust" true
  "sql" true
  "tmux" true
  "vim" true
  "zellij" true
  "zsh" false
) -}}
{{- else if eq .chezmoi.os "windows" }}
{{- $features = mergeOverwrite $features (dict
  "docker" false
  "kube" false
) -}}
{{- end }}

{{- if or .codespaces .devContainer .ephemeral .headless }}
{{- $features = mergeOverwrite $features (dict
  "ghostty" false
  "go" false
  "helix" false
  "neovim" false
  "node" false
  "rust" false
  "vim" false
) -}}
{{- end }}

{{- range $name, $default := $features }}
{{- $key := upper (printf "FEATURE_%s" $name) -}}
{{- $value := includeTemplate "env.tmpl" (dict "key" $key "default" $default) | fromJson -}}
{{- $_ := set $features $name $value -}}
{{- end -}}

{{- $features | toJson -}}
