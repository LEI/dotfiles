{{- $features := (dict
  "ai" false
  "atuin" false
  "bash" true
  "brew" (not (eq .osIDLike "alpine" "android" "windows"))
  "docker" false
  "ghostty" false
  "git" true
  "go" (eq .osIDLike "arch" "darwin" "debian" "fedora")
  "goss" false
  "helix" false
  "i3" (eq .osIDLike "arch")
  "kube" false
  "mail" false
  "mise" true
  "neovim" false
  "node" false
  "nushell" true
  "php" false
  "python" false
  "ruby" false
  "rust" false
  "shpool" false
  "sql" false
  "ssh" false
  "steam" (and (eq .osIDLike "arch") (eq .profile "personal"))
  "tmux" (eq .osIDLike "alpine" "android" "arch" "darwin" "debian" "fedora")
  "tofu" false
  "topgrade" true
  "vim" false
  "void" (eq .osIDLike "arch")
  "vscode" (eq .osIDLike "arch" "darwin")
  "vscodium" (eq .osIDLike "arch")
  "zellij" (eq .osIDLike "alpine" "android" "arch" "darwin" "debian" "fedora")
  "zsh" false
) -}}

{{- if ne .profile "minimal" }}
{{- $features = mergeOverwrite $features (dict
  "atuin" true
  "bash" true
  "docker" (and (or (lookPath "docker" | isExecutable) (lookPath "podman" | isExecutable)) (eq .osIDLike "arch" "darwin" "debian" "fedora"))
  "git" true
  "helix" true
  "kube" (lookPath "kubectl" | isExecutable)
  "nushell" true
  "python" true
  "tofu" (lookPath "tofu" | isExecutable)
  "ruby" true
  "topgrade" true
) -}}
{{- end }}

{{- if or (hasPrefix "fr" .hostname) (hasPrefix "mb" .hostname) -}}
{{- $features = mergeOverwrite $features (dict
  "ai" true
) -}}
{{- end }}

{{- if eq .osID "alpine" }}
{{- $features = mergeOverwrite $features (dict
  "kube" false
  "neovim" false
  "node" false
  "rust" false
  "vim" false
) -}}
{{- else if eq .osID "android" }}
{{- $features = mergeOverwrite $features (dict
  "kube" false
  "neovim" true
  "vim" true
) -}}
{{- else if eq .osIDLike "arch" }}
{{- $features = mergeOverwrite $features (dict
  "ghostty" true
  "goss" true
  "kube" true
  "mail" (not (empty .accessToken))
  "neovim" true
  "node" true
  "php" true
  "rust" true
  "sql" true
  "ssh" true
  "vim" true
  "zsh" true
) -}}
{{- else if eq .os "darwin" }}
{{- $features = mergeOverwrite $features (dict
  "bash" true
  "ghostty" true
  "git" true
  "kube" true
  "mail" false
  "neovim" true
  "node" true
  "php" true
  "rust" true
  "sql" true
  "ssh" true
  "vim" true
  "zsh" false
) -}}
{{- else if eq .osIDLike "debian" }}
{{- $features = mergeOverwrite $features (dict
  "atuin" (not .glibc231)
  "ghostty" (and (not .glibc231) (not (and (eq .osID "ubuntu") (le (float64 .osVersion) 22.04))))
  "helix" (not .glibc231)
  "kube" false
  "neovim" true
  "node" true
  "php" true
  "rust" true
  "sql" true
  "ssh" true
  "topgrade" (not .glibc231)
  "vim" true
) -}}
{{- else if eq .osIDLike "fedora" }}
{{- $features = mergeOverwrite $features (dict
  "ghostty" true
  "goss" true
  "kube" true
  "mail" false
  "neovim" true
  "node" true
  "rust" true
  "sql" true
  "ssh" true
  "vim" true
  "zsh" true
) -}}
{{- else if eq .os "windows" }}
{{- $features = mergeOverwrite $features (dict
  "kube" false
  "neovim" true
  "vim" true
) -}}
{{- end }}

{{- if or .ephemeral .headless }}
{{- $features = mergeOverwrite $features (dict
  "ghostty" false
  "go" false
  "helix" false
  "neovim" false
  "node" false
  "rust" false
  "tmux" false
  "vim" false
  "zellij" false
) -}}
{{- end }}

{{- range $name, $default := $features }}
{{- $key := upper (printf "FEATURE_%s" $name) -}}
{{- $value := includeTemplate "env.tmpl" (dict "key" $key "default" $default) | fromJson -}}
{{- $_ := set $features $name $value -}}
{{- end -}}

{{- $features | toJson -}}
