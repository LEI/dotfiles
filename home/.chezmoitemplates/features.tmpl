{{- $data := includeTemplate ".chezmoidata/features.yaml" | fromYaml -}}
{{- $features := $data.baseFeatures -}}

{{- if eq .osid "alpine" }}

{{- /* Alpine */ -}}
{{- $features = mergeOverwrite $features (dict
) -}}

{{- else if eq .osid "android" }}

{{- /* Termux */ -}}
{{- $features = mergeOverwrite $features (dict
) -}}

{{- else if eq .osid "arch" }}

{{- /* Archlinux/Manjaro */ -}}
{{- $features = mergeOverwrite $features (dict
  "ghostty" true
  "go" true
  "node" true
  "rust" true
) -}}

{{- else if eq .osid "debian" }}

{{- /* Debian/Ubuntu */ -}}
{{- $features = mergeOverwrite $features (dict
  "ghostty" true
  "go" true
  "node" true
  "rust" true
) -}}

{{- else if eq .osid "darwin" }}

{{- /* macOS */ -}}
{{- $features = mergeOverwrite $features (dict
  "bash" false
  "ghostty" true
  "git" false
  "go" true
  "node" true
  "rust" true
  "zsh" false
) -}}

{{- end }}

{{- if .codespaces }}
{{- $features = mergeOverwrite $features (dict "ghostty" false) -}}
{{- end }}

{{- $features | toJson -}}
