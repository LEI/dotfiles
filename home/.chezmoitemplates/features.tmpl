{{- $data := includeTemplate ".chezmoidata/features.yaml" | fromYaml -}}
{{- $features := $data.baseFeatures -}}

{{- if eq .osid "alpine" }}

{{- /* Alpine */ -}}
{{- $features = mergeOverwrite $features (dict
  "docker" false
) -}}

{{- else if eq .osid "android" }}

{{- /* Termux */ -}}
{{- $features = mergeOverwrite $features (dict
  "neovim" true
  "vim" true
) -}}

{{- else if eq .osid "arch" }}

{{- /* Archlinux/Manjaro */ -}}
{{- $features = mergeOverwrite $features (dict
  "ai" true
  "docker" true
  "ghostty" true
  "go" true
  "kube" true
  "neovim" true
  "node" true
  "rust" true
  "vim" true
) -}}

{{- else if eq .osid "debian" }}

{{- /* Debian/Ubuntu */ -}}
{{- $features = mergeOverwrite $features (dict
  "docker" false
  "ghostty" true
  "go" true
  "kube" true
  "neovim" true
  "node" true
  "rust" true
  "vim" true
) -}}

{{- else if eq .chezmoi.os "darwin" }}

{{- /* macOS */ -}}
{{- $features = mergeOverwrite $features (dict
  "ai" true
  "bash" false
  "docker" true
  "ghostty" true
  "git" false
  "go" true
  "kube" true
  "neovim" true
  "node" true
  "rust" true
  "vim" true
  "zsh" false
) -}}

{{- end }}

{{- if .codespaces }}
{{- $features = mergeOverwrite $features (dict
  "ghostty" false
  "go" false
  "helix" false
  "neovim" false
  "node" false
  "rust" false
  "vim" true
) -}}
{{- end }}

{{- $features | toJson -}}
