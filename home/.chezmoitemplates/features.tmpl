{{- $features := (dict
  "ai" false
  "atuin" false
  "bash" false
  "bat" true
  "bottom" false
  "brew" (not (eq .osIDLike "alpine" "android" "windows"))
  "carapace" true
  "direnv" true
  "docker" false
  "eza" true
  "ghostty" false
  "git" false
  "go" false
  "goss" false
  "gpg" false
  "helix" false
  "i3" (and (eq .osIDLike "arch" "debian") (not .headless))
  "kube" false
  "lla" false
  "logseq" false
  "mail" (and (eq .osIDLike "arch") (not (empty .accessToken)))
  "mise" true
  "neovim" false
  "node" (eq .osIDLike "android" "arch" "darwin" "debian" "fedora")
  "nushell" true
  "php" false
  "podman" false
  "python" false
  "ripgrep" true
  "ruby" false
  "rust" false
  "shpool" false
  "sql" false
  "ssh" false
  "steam" (and (eq .osIDLike "arch") (eq .profile "personal"))
  "sway" false
  "tmux" (eq .osIDLike "alpine" "android" "arch" "darwin" "debian" "fedora")
  "tofu" false
  "topgrade" false
  "vim" false
  "void" (eq .osIDLike "arch")
  "vscode" (eq .osIDLike "arch" "darwin")
  "vscodium" (eq .osIDLike "arch")
  "zellij" (eq .osIDLike "alpine" "android" "arch" "darwin" "debian" "fedora")
  "zoxide" true
  "zsh" false
) -}}

{{- if ne .profile "minimal" }}
{{- $features = mergeOverwrite $features (dict
  "atuin" (not (or
    (and (eq .osID "debian") (le (int .osVersion) 12))
    (and (eq .osID "ubuntu") (le (float64 .osVersion) 24.04))
  ))
  "bash" true
  "bottom" true
  "docker" (or (lookPath "docker" | isExecutable) (eq .osIDLike "arch" "darwin" "debian" "fedora"))
  "ghostty" (and (not .glibc231) (not (and (eq .osID "ubuntu") (le (float64 .osVersion) 22.04))) (not (eq .os "android" "windows")))
  "git" (eq .osIDLike "arch" "darwin")
  "go" (eq .osIDLike "alpine" "arch" "darwin" "debian" "fedora")
  "gpg" (eq .osIDLike "arch" "darwin")
  "helix" true
  "kube" (or (lookPath "kubectl" | isExecutable) (eq .osIDLike "arch" "darwin" "debian" "fedora"))
  "lla" (eq .osID "arch" "darwin")
  "logseq" (eq .osIDLike "arch" "darwin")
  "nushell" true
  "podman" (or (lookPath "podman" | isExecutable) (eq .osIDLike "arch" "darwin" "debian" "fedora"))
  "python" true
  "ruby" true
  "tofu" (or (lookPath "tofu" | isExecutable) (eq .osIDLike "arch" "darwin"))
  "topgrade" (and (ne .osIDLike "fedora") (not .ephemeral) (not .glibc231))
  "zsh" true
) -}}
{{- end }}

{{- if or (hasPrefix "fr" .hostname) (hasPrefix "mb" .hostname) -}}
{{- $features = mergeOverwrite $features (dict
  "ai" true
) -}}
{{- end }}

{{- if eq .osID "alpine" }}
{{- $features = mergeOverwrite $features (dict
  "neovim" false
  "node" false
  "rust" false
  "vim" false
) -}}
{{- else if eq .osID "android" }}
{{- $features = mergeOverwrite $features (dict
  "neovim" true
  "vim" true
) -}}
{{- else if eq .osIDLike "arch" }}
{{- $features = mergeOverwrite $features (dict
  "goss" true
  "neovim" true
  "php" true
  "rust" true
  "sql" true
  "ssh" true
  "vim" true
) -}}
{{- else if eq .os "darwin" }}
{{- $features = mergeOverwrite $features (dict
  "neovim" true
  "php" true
  "rust" true
  "sql" true
  "ssh" true
  "vim" true
) -}}
{{- else if eq .osIDLike "debian" }}
{{- $features = mergeOverwrite $features (dict
  "helix" (not .glibc231)
  "neovim" true
  "php" true
  "rust" true
  "sql" true
  "ssh" true
  "vim" true
) -}}
{{- else if eq .osIDLike "fedora" }}
{{- $features = mergeOverwrite $features (dict
  "goss" true
  "neovim" true
  "rust" true
  "sql" true
  "ssh" true
  "vim" true
) -}}
{{- else if eq .os "windows" }}
{{- $features = mergeOverwrite $features (dict
  "neovim" true
  "vim" true
) -}}
{{- end }}

{{- if or .ephemeral .headless }}
{{- $features = mergeOverwrite $features (dict
  "ghostty" false
  "go" false
  "helix" false
  "neovim" false
  "node" false
  "ruby" false
  "rust" false
  "tmux" false
  "vim" false
  "zellij" false
) -}}
{{- end }}

{{- range $name, $default := $features }}
{{- $key := upper (printf "FEATURE_%s" $name) -}}
{{- $value := includeTemplate "env.tmpl" (dict "key" $key "default" $default) | fromJson -}}
{{- $_ := set $features $name $value -}}
{{- end -}}

{{- $features | toJson -}}
