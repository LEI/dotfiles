{{- $active := eq (get . "active" | toString) "true" -}}
{{- $unit := get . "unit" | default "UNIT" -}}
{{- $reload := get . "reload" -}}
{{- $system := eq (get . "system" | toString) "true" -}}
{{- $ctl := $system | ternary "systemctl" "systemctl --user" -}}
{{- $dir := get . "dir" -}}

{{- $suffix := $unit | splitList "." | last -}}
{{- if not (eq $suffix ".container" ".service") -}}
{{-   $suffix = "service" -}}
{{-   $unit = printf "%s.%s" $unit $suffix -}}
{{- end -}}
{{- $name := $unit | splitList "." | first -}}

{{- $isQuadlet := hasSuffix $unit ".container" -}}
{{- if not $dir -}}
{{-   if $isQuadlet -}}
{{-     $dir = joinPath .chezmoi.homeDir ".config/containers/systemd" -}}
{{-   else -}}
{{-     $dir = joinPath .chezmoi.homeDir ".config/systemd/user" -}}
{{-   end -}}
{{- end -}}

{{- $unitFile := joinPath $dir $unit -}}

{{- $state := "unknown" -}}
{{- if lookPath "systemctl" | isExecutable -}}
{{-   $state = output "sh" "-c" (printf "%s show %s --property=ActiveState --value 2>/dev/null || true" $ctl $name) | trim | default "not found" -}}
{{- end -}}

# shellcheck shell=sh

{{- if stat $unitFile }}

# unit: {{ include $unitFile | sha256sum }}
{{- end }}

# status: {{ $state }}

if ! command -v systemctl >/dev/null; then
  die "systemctl not found"
fi

run {{ $ctl }} daemon-reload
{{- if $active }}

if {{ $ctl }} is-active --quiet {{ $name }}; then
{{-   if $reload }}
  if ! run {{ $reload }}; then
    msg "{{ $name }}: reload failed"
    run {{ $ctl }} reload-or-restart {{ $name }}
  fi
{{-   else }}
  run {{ $ctl }} reload-or-restart {{ $name }}
{{-   end }}
else
{{-   if $isQuadlet }}
  run {{ $ctl }} start {{ $name }}
{{-   else }}
  run {{ $ctl }} enable --now {{ $name }}
{{-   end }}
fi

# Ensure boot-enabled for system services (not preset-disabled)
{{- if $system }}
if ! {{ $ctl }} is-enabled --quiet {{ $name }} 2>/dev/null; then
  run {{ $ctl }} enable {{ $name }}
fi
{{- end }}

if ! {{ $ctl }} is-active --quiet {{ $name }}; then
  run {{ $ctl }} status {{ $name }} --no-pager || true
  die "{{ $unit }}: failed to start"
fi

{{- includeTemplate "health-check.sh.tmpl" (merge (dict "name" $name) .) }}
{{- else }}
{{-   if $isQuadlet }}

if {{ $ctl }} is-active --quiet {{ $name }} 2>/dev/null; then
  msg "stopping quadlet {{ $unit }}"
  run {{ $ctl }} stop {{ $name }}
fi
{{-   else }}

if {{ $ctl }} is-enabled --quiet {{ $name }} 2>/dev/null; then
  msg "disabling service {{ $unit }}"
  run {{ $ctl }} disable --now {{ $name }}
fi
{{-   end }}
{{- end }}
