{{- $active := get . "active" -}}
{{- $unit := get . "unit" | default "UNIT" -}}
{{- $health := get . "health" -}}
{{- $port := get . "port" -}}
{{- $dir := get . "dir" -}}

{{- $suffix := $unit | splitList "." | last -}}
{{- if not (eq $suffix ".container" ".service") -}}
{{-   $suffix = "service" -}}
{{-   $unit = printf "%s.%s" $unit $suffix -}}
{{- end -}}
{{- $name := $unit | splitList "." | first -}}

{{- $isQuadlet := hasSuffix $unit ".container" -}}
{{- if not $dir -}}
{{-   if $isQuadlet -}}
{{-     $dir = joinPath .chezmoi.homeDir ".config/containers/systemd" -}}
{{-   else -}}
{{-     $dir = joinPath .chezmoi.homeDir ".config/systemd/user" -}}
{{-   end -}}
{{- end -}}

{{- $sourceFile := joinPath $dir $unit -}}
{{- $status := "" -}}
{{- if lookPath "systemctl" | isExecutable -}}
{{-   $status = output "sh" "-c" (printf "systemctl --user show %s --property=ActiveState --value 2>/dev/null || true" $name) | trim -}}
{{-   if $status -}}
# status: {{ $status }}
{{   end -}}
{{- end -}}

if ! command -v systemctl >/dev/null; then
  die "systemctl not found"
fi

run systemctl --user daemon-reload
{{- if $active }}
{{-   if not $isQuadlet }}
if systemctl --user is-active --quiet {{ $name }}; then
  run systemctl --user restart {{ $name }}
else
  run systemctl --user enable --now {{ $name }}
fi
{{-   else }}
if ! systemctl --user is-active --quiet {{ $name }}; then
  run systemctl --user start {{ $name }}
fi
{{-   end }}
if ! systemctl --user is-active --quiet {{ $name }}; then
  run systemctl --user status {{ $name }} --no-pager || true
  die "{{ $unit }}: failed to start"
fi

# FIXME: no tpl
{{-   if and $port $health }}
{{-     $url := printf "http://localhost:%d%s" $port $health }}
{{-     if not (output "sh" "-c" (printf "curl --silent --fail --max-time 5 %s >/dev/null 2>&1" $url) | trim) }}
msg "{{ $unit }}: unhealthy, restarting"
run systemctl --user restart {{ $name }}
{{-     end }}
{{-   end }}
{{- else }}
{{-   if not $isQuadlet }}
if systemctl --user is-enabled --quiet {{ $name }} 2>/dev/null; then
  msg "disabling service {{ $unit }}"
  run systemctl --user disable --now {{ $name }}
fi
{{-   end }}
{{- end }}
