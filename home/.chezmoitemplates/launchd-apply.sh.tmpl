{{- $active := eq (get . "active" | toString) "true" -}}
{{- $label := get . "label" -}}
{{- $bootstrap := eq (get . "bootstrap" | toString) "true" -}}
{{- $reload := get . "reload" -}}
{{- $system := eq (get . "system" | toString) "true" -}}
{{- $uid := output "id" "-u" | trim -}}

{{- $plistFile := "" -}}
{{- $domain := "" -}}
{{- $target := "" -}}
{{- $sudo := "" -}}
{{- if $system -}}
{{-   $plistFile = printf "/Library/LaunchDaemons/%s.plist" $label -}}
{{-   $domain = "system" -}}
{{-   $target = printf "system/%s" $label -}}
{{-   $sudo = "sudo " -}}
{{- else -}}
{{-   $plistFile = joinPath .chezmoi.homeDir "Library/LaunchAgents" (printf "%s.plist" $label) -}}
{{-   $domain = printf "gui/%s" $uid -}}
{{-   $target = printf "gui/%s/%s" $uid $label -}}
{{- end -}}

{{- $stateProbe := printf `out=$(launchctl print %s 2>/dev/null) &&
  echo "$out" | grep -m1 'state = ' | sed 's/.*state = //' ||
  echo 'not loaded'` $target -}}
{{- $state := output "sh" "-c" $stateProbe | trim | default "unknown" -}}

# shellcheck shell=sh

{{- if stat $plistFile }}

# plist: {{ include $plistFile | sha256sum }}
{{- end }}
# status: {{ $state }}

plist={{ $plistFile | quote }}

{{- if $active }}
if [ ! -f "$plist" ]; then
  die "{{ $label }}: plist not found"
fi

if ! {{ $sudo }}launchctl list "{{ $label }}" >/dev/null 2>&1; then
{{- if $bootstrap }}
  run {{ $sudo }}launchctl enable "{{ $target }}"
  run {{ $sudo }}launchctl bootstrap "{{ $domain }}" "$plist"
{{- else }}
  run {{ $sudo }}launchctl load "$plist"
{{- end }}
else
{{- if $reload }}
  if ! run {{ $reload }}; then
    msg "{{ $label }}: reload failed, restarting"
{{-   if $bootstrap }}
    run {{ $sudo }}launchctl kickstart -k "{{ $target }}"
{{-   else }}
    run {{ $sudo }}launchctl unload "$plist"
    run {{ $sudo }}launchctl load "$plist"
{{-   end }}
  fi
{{- else if $bootstrap }}
  run {{ $sudo }}launchctl kickstart -k "{{ $target }}"
{{- else }}
  run {{ $sudo }}launchctl unload "$plist"
  run {{ $sudo }}launchctl load "$plist"
{{- end }}
fi
{{- includeTemplate "health-check.sh.tmpl" (merge (dict "name" $label) .) }}
{{- else }}
if {{ $sudo }}launchctl list "{{ $label }}" >/dev/null 2>&1; then
  msg "unloading service {{ $label }}"
{{- if $bootstrap }}
  run {{ $sudo }}launchctl bootout "{{ $target }}" 2>/dev/null || true
{{- else }}
  run {{ $sudo }}launchctl kill SIGTERM "{{ $target }}" 2>/dev/null || true
  run {{ $sudo }}launchctl unload "$plist" 2>/dev/null || true
{{- end }}
fi
{{- end }}
