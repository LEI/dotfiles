{{- $active := eq (get . "active" | toString) "true" -}}
{{- $label := get . "label" -}}
{{- $bootstrap := eq (get . "bootstrap" | toString) "true" -}}
{{- $reload := get . "reload" -}}
{{- $uid := output "id" "-u" | trim -}}

{{- $plistFile := joinPath .chezmoi.homeDir "Library/LaunchAgents" (printf "%s.plist" $label) -}}

{{- $state := output "sh" "-c" (printf "out=$(launchctl print gui/%s/%s 2>/dev/null) && echo \"$out\" | grep -m1 'state = ' | sed 's/.*state = //' || echo 'not loaded'" $uid $label) | trim | default "unknown" -}}

# shellcheck shell=sh

{{- if stat $plistFile }}

# plist: {{ include $plistFile | sha256sum }}
{{- end }}
# status: {{ $state }}

plist="$HOME/Library/LaunchAgents/{{ $label }}.plist"

{{- if $active }}
if [ ! -f "$plist" ]; then
  die "{{ $label }}: plist not found"
fi

if ! launchctl list "{{ $label }}" >/dev/null 2>&1; then
{{- if $bootstrap }}
  run launchctl enable "gui/{{ $uid }}/{{ $label }}"
  run launchctl bootstrap "gui/{{ $uid }}" "$plist"
{{- else }}
  run launchctl load "$plist"
{{- end }}
else
{{- if $reload }}
  if ! run {{ $reload }}; then
    msg "{{ $label }}: reload failed, restarting"
{{-   if $bootstrap }}
    run launchctl kickstart -k "gui/{{ $uid }}/{{ $label }}"
{{-   else }}
    run launchctl unload "$plist"
    run launchctl load "$plist"
{{-   end }}
  fi
{{- else if $bootstrap }}
  run launchctl kickstart -k "gui/{{ $uid }}/{{ $label }}"
{{- else }}
  run launchctl unload "$plist"
  run launchctl load "$plist"
{{- end }}
fi
{{- includeTemplate "health-check.sh.tmpl" (merge (dict "name" $label) .) }}
{{- else }}
if launchctl list "{{ $label }}" >/dev/null 2>&1; then
  msg "unloading service {{ $label }}"
{{- if $bootstrap }}
  run launchctl bootout "gui/{{ $uid }}/{{ $label }}" 2>/dev/null || true
{{- else }}
  run launchctl kill SIGTERM "gui/{{ $uid }}/{{ $label }}" 2>/dev/null || true
  run launchctl unload "$plist" 2>/dev/null || true
{{- end }}
fi
{{- end }}
