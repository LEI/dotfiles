<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>{{ get . "label" }}</string>
  <key>ProgramArguments</key>
  <array>
{{- range (get . "args" | default list) }}
    <string>{{ . }}</string>
{{- end }}
  </array>
{{- $keepalive := true -}}
{{- if hasKey . "keepalive" }}{{ $keepalive = get . "keepalive" }}
{{- else if hasKey . "active" }}{{ $keepalive = get . "active" }}{{ end }}
  <key>KeepAlive</key>
  <{{ $keepalive }}/>
{{- if and (hasKey . "active") (not (get . "active")) }}
  <key>Disabled</key>
  <true/>
{{- end }}
  <key>ThrottleInterval</key>
  <integer>{{ get . "throttle" | default 30 }}</integer>
  <key>ProcessType</key>
  <string>Background</string>
{{- with (get . "interval") }}
  <key>StartInterval</key>
  <integer>{{ . }}</integer>
{{- end }}
{{- with (get . "runatload") }}
  <key>RunAtLoad</key>
  <{{ . }}/>
{{- end }}
{{- with (get . "env") }}
  <key>EnvironmentVariables</key>
  <dict>
{{-   range $k, $v := . }}
    <key>{{ $k }}</key>
    <string>{{ $v }}</string>
{{-   end }}
  </dict>
{{- end }}
{{- if (get . "log") }}
  <key>StandardErrorPath</key>
  <string>{{ get . "log" }}</string>
  <key>StandardOutPath</key>
  <string>{{ get . "log" }}</string>
{{- else }}
{{-   with (get . "stderr") }}
  <key>StandardErrorPath</key>
  <string>{{ . }}</string>
{{-   end }}
{{-   with (get . "stdout") }}
  <key>StandardOutPath</key>
  <string>{{ . }}</string>
{{-   end }}
{{- end }}
{{- with (get . "workdir") }}
  <key>WorkingDirectory</key>
  <string>{{ . }}</string>
{{- end }}
</dict>
</plist>
