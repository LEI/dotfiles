{{- $active := eq (get . "active" | toString) "true" -}}
{{- $formula := get . "formula" | default "FORMULA" -}}
{{- $reload := get . "reload" -}}
{{- $system := eq (get . "system" | toString) "true" -}}
{{- $sudo := $system | ternary "sudo " "" -}}
{{- $domain := $system | ternary "system" (printf "gui/%s" (output "id" "-u" | trim)) -}}
{{- $svcProbe := printf `brew services info %s --json 2>/dev/null |
  jq -r '.[0].service_name // empty' ||
  true` $formula -}}
{{- $svcName := output "sh" "-c" $svcProbe | trim -}}
{{- $state := "unknown" -}}
{{- if $svcName -}}
{{-   $stateProbe := printf `launchctl print %s/%s 2>/dev/null |
  grep -m1 'state = ' | sed 's/.*state = //' ||
  true` $domain $svcName -}}
{{-   $state = output "sh" "-c" $stateProbe | trim | default "not loaded" -}}
{{- end -}}
# shellcheck shell=sh

# status: {{ $state }}

if ! has brew; then
  die "brew not found"
fi
{{- if $active }}
if ! run {{ $sudo }}brew services list | grep -q "{{ $formula }}.*started"; then
  run {{ $sudo }}brew services start {{ $formula }}
{{- if $reload }}
else
  if ! run {{ $reload }}; then
    msg "{{ $formula }}: reload failed, restarting"
    run {{ $sudo }}brew services restart {{ $formula }}
  fi
{{- else }}
else
  run {{ $sudo }}brew services restart {{ $formula }}
{{- end }}
fi
{{- includeTemplate "health-check.sh.tmpl" (merge (dict "name" $formula) .) }}
{{- else }}
if run {{ $sudo }}brew services list | grep -q "{{ $formula }}.*started"; then
  msg "stopping service {{ $formula }}"
  run {{ $sudo }}brew services stop {{ $formula }}
fi
{{- end }}
