{{- /* opkg marketplace packages, shared by publish-opkg and opkg-managed. Returns JSON [{name, src}]. Every package publishes so it registers in the opkg closure, letting dependents resolve it; rule files still deploy via symlink (opkg-rule-paths.tmpl), not this list. */ -}}
{{- $pkgs := list -}}
{{- range $mktName, $mkt := dig "claude" "marketplaces" (dict) . -}}
{{-   $path := get $mkt "path" -}}
{{-   if not $path -}}{{- continue -}}{{- end -}}
{{-   $packagesRoot := joinPath $.chezmoi.homeDir $path "packages" -}}
{{-   if not (stat $packagesRoot) -}}{{- continue -}}{{- end -}}
{{-   range $pkgDir := glob (joinPath $packagesRoot "*") -}}
{{-     $pkgName := base $pkgDir -}}
{{-     if eq $pkgName "local" -}}{{- continue -}}{{- end -}}
{{-     $pkgs = append $pkgs (dict "name" $pkgName "src" $pkgDir) -}}
{{-   end -}}
{{- end -}}
{{- $pkgs | toJson }}
