#!/bin/sh
# Statusline wrapper: writes per-session context data, delegates to dashboard
# stdin: JSON from Claude Code (context_window, session_id, ...)
# stdout: passthrough from delegate command ("$@")

INPUT=$(cat)
DIR="${XDG_STATE_HOME:-$HOME/.local/state}/claude/sessions"
SID=$(printf '%s' "$INPUT" | jq -r '.session_id // empty' 2>/dev/null)

if [ -n "$SID" ]; then
  mkdir -p "$DIR"
  printf '%s' "$INPUT" > "$DIR/$SID.json"

  # Prune stale session files older than 2 days
  find "$DIR" -type f -name '*.json' -mtime +2 -delete 2>/dev/null
fi

printf '%s' "$INPUT" | exec "$@"
