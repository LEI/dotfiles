{{- $data := includeTemplate "claude-plugins.tmpl" . | fromJson -}}
{{- $marketplaces := $data.marketplaces -}}
{{- $plugins := $data.plugins -}}
#!/bin/bash

# marketplaces: {{ $marketplaces | toJson | sha256sum }}
# plugins: {{ $plugins | toJson | sha256sum }}
{{- range $plugins }}
{{-   $marketplace := get $marketplaces .marketplace }}
{{-   if and $marketplace (not (hasKey $marketplace "repo")) }}
{{-     $path := printf "%s/plugins/%s/.claude-plugin/plugin.json" $marketplace.path .name }}
{{-     if stat $path }}
# local:{{ .name }}@{{ .marketplace }}: {{ include $path | sha256sum }}
{{-     end }}
{{-   end }}
{{- end }}

set -euo pipefail

plugin_file=~/.claude/plugins/installed_plugins.json
marketplace_file=~/.claude/plugins/known_marketplaces.json
{{- range (keys $marketplaces | sortAlpha) }}
{{- $name := . }}
{{- $info := get $marketplaces . }}

if ! jq -e '.["{{ $name }}"]' "$marketplace_file" >/dev/null 2>&1; then
  echo "Registering marketplace: {{ $name }}" >&2
  {{- if hasKey $info "repo" }}
  claude plugin marketplace add "{{ $info.repo }}"
  {{- else }}
  claude plugin marketplace add "{{ $info.path }}"
  {{- end }}
else
  echo "Marketplace already registered: {{ $name }}" >&2
fi
{{- end }}
{{- range $plugins }}
{{- $marketplace := get $marketplaces .marketplace }}
{{- if or (eq .marketplace "claude-plugins-official") $marketplace }}

if jq -e '.plugins["{{ .name }}@{{ .marketplace }}"] | length > 0' "$plugin_file" >/dev/null 2>&1; then
  echo "Plugin already installed: {{ .name }}@{{ .marketplace }}" >&2
else
  echo "Installing plugin: {{ .name }}@{{ .marketplace }}" >&2
  claude plugin install --scope=user "{{ .name }}@{{ .marketplace }}"
fi
{{- if and $marketplace (not (hasKey $marketplace "repo")) }}

echo "Updating plugin: {{ .name }}@{{ .marketplace }}" >&2
claude plugin update --scope=user "{{ .name }}@{{ .marketplace }}"
{{- end }}
{{- end }}
{{- end }}

{{- $claude := get . "claude" | default dict -}}
{{- $keep := dict -}}
{{- range $plugins -}}
{{-   $_ := set $keep (printf "%s@%s" .name .marketplace) true -}}
{{- end -}}
{{- range get $claude "keepPlugins" | default list -}}
{{-   $_ := set $keep . true -}}
{{- end }}

# Remove user-scoped plugins not in managed or keep set
stale_found=false
while IFS= read -r key; do
  [ -n "$key" ] || continue
  marketplace="${key##*@}"
  [ "$marketplace" = "private" ] && continue
  case "$key" in
  {{- range (keys $keep | sortAlpha) }}
  {{ . }}) continue ;;
  {{- end }}
  esac
  if [ "${CHEZMOI_PLUGIN_UNINSTALL:-}" = true ]; then
    echo "Uninstalling plugin: $key" >&2
    claude plugin uninstall --scope=user "$key"
  else
    echo "  claude plugin uninstall --scope=user \"$key\"" >&2
    stale_found=true
  fi
done < <(jq -r '
  .plugins | to_entries[]
  | select(.value | map(select(.scope == "user")) | length > 0)
  | .key
' "$plugin_file")
if [ "$stale_found" = true ]; then
  echo >&2 "Stale plugins found, run: CHEZMOI_PLUGIN_UNINSTALL=true chezmoi apply"
  exit 1
fi

claude plugin list
