{{- $data := includeTemplate "claude-plugins.tmpl" . | fromJson -}}
{{- $mkts := $data.marketplaces -}}
{{- $plugins := $data.plugins -}}
#!/bin/bash
# marketplaces: {{ $mkts | toJson | sha256sum }}
# plugins: {{ $plugins | toJson | sha256sum }}
set -euo pipefail

plugin_file=~/.claude/plugins/installed_plugins.json
marketplace_file=~/.claude/plugins/known_marketplaces.json
{{- range $name, $info := $mkts }}

if ! jq -e '.["{{ $name }}"]' "$marketplace_file" >/dev/null 2>&1; then
  echo >&2 "Registering marketplace: {{ $name }}"
  {{- if hasKey $info "repo" }}
  claude plugin marketplace add "{{ $info.repo }}"
  {{- else }}
  claude plugin marketplace add "{{ $info.path }}"
  {{- end }}
else
  echo >&2 "Marketplace already registered: {{ $name }}"
fi
{{- end }}
{{- range $plugins }}
{{- $mkt := get $mkts .marketplace }}
{{- if or (eq .marketplace "claude-plugins-official") $mkt }}

if jq -e '.plugins["{{ .name }}@{{ .marketplace }}"] | length > 0' "$plugin_file" >/dev/null 2>&1; then
  echo >&2 "Plugin already installed: {{ .name }}@{{ .marketplace }}"
else
  echo >&2 "Installing plugin: {{ .name }}@{{ .marketplace }}"
  claude plugin install --scope=user "{{ .name }}@{{ .marketplace }}"
fi
{{- if and $mkt (not (hasKey $mkt "repo")) }}

echo >&2 "Updating plugin: {{ .name }}@{{ .marketplace }}"
claude plugin update --scope=user "{{ .name }}@{{ .marketplace }}"
{{- end }}
{{- end }}
{{- end }}
