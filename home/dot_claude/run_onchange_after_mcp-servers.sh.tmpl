{{- $_ := . | setValueAtPath "client" "claude" -}}
{{- $defs := includeTemplate "mcp.jsonc" . | fromJsonc -}}
{{- $mcp := includeTemplate "dot_claude/.mcp.json.tmpl" . | fromJson -}}

{{- $servers := dict -}}
{{- range $mcp -}}
{{-   if hasKey $defs.servers . -}}
{{-     $_ := $servers | setValueAtPath . (index $defs.servers .) -}}
{{-   end -}}
{{- end -}}
#!{{ .prefix }}/usr/bin/env bash

set -euo pipefail

if ! command -v jq >/dev/null 2>&1; then
  echo "jq required but not found" >&2
  exit 1
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "claude not found, skipping MCP sync" >&2
  exit 0
fi

mcp_sync() {
  local name=$1 expected=$2
  local current normalized
  current=$(jq -Sc --arg n "$name" '.mcpServers[$n] // empty' ~/.claude.json 2>/dev/null || true)
  normalized=$(printf '%s' "$expected" | jq -Sc .)
  if [ "$current" = "$normalized" ]; then
    echo "MCP server up to date: $name" >&2
    return
  fi
  echo "Updating MCP server: $name" >&2
  if claude mcp get "$name" >/dev/null 2>&1; then
    claude mcp remove "$name"
  fi
  claude mcp add-json --scope=user "$name" "$expected"
}

{{- range (keys $servers | sortAlpha) }}
# shellcheck disable=SC2016
mcp_sync {{ . | squote }} {{ index $servers . | toJson | squote }}
{{- end }}

{{- $stale := list -}}
{{- range $mcp -}}
{{-   if not (hasKey $servers .) -}}
{{-     $stale = append $stale . -}}
{{-   end -}}
{{- end -}}
{{- if $stale }}

# Remove servers disabled on this machine
# shellcheck disable=SC2043
for name in {{ $stale | sortAlpha | join " " }}; do
  if claude mcp get "$name" >/dev/null 2>&1; then
    echo "Removing disabled MCP server: $name" >&2
    claude mcp remove "$name"
  fi
done
{{- end }}

claude mcp list
