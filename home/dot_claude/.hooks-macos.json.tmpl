{{- $claudeDir := env "CLAUDE_CONFIG_DIR" | default (joinPath .chezmoi.homeDir ".claude") -}}
{
  "Notification": [
    {
      "matcher": "*",
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "PermissionDenied": [
    {
      "matcher": "*",
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "PermissionRequest": [
    {
      "matcher": "*",
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "timeout": 86400,
          "type": "command"
        }
      ]
    }
  ],
  "PostCompact": [
    {
      "matcher": "auto",
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    },
    {
      "matcher": "manual",
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "*",
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "PostToolUseFailure": [
    {
      "matcher": "*",
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "matcher": "",
      "hooks": [
        {
          "command": "echo 'Summarize each active task: what was done, what remains, and the concrete next step. Persist key discoveries.'",
          "type": "command"
        }
      ]
    },
    {
      "matcher": "auto",
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    },
    {
      "matcher": "manual",
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "*",
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "echo 'Check TaskList for pending tasks. Use AskUserQuestion for important decisions.'"
        }
      ]
    },
    {
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "StopFailure": [
    {
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "SubagentStart": [
    {
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "SubagentStop": [
    {
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "command": "python3 '{{ $claudeDir }}/hooks/claude-island-state.py'",
          "type": "command"
        }
      ]
    }
  ]
}
