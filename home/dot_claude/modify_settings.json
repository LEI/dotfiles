{{- /* chezmoi:modify-template */ -}}
{{- $sandboxEnabled := false -}}
{{- $model := "" -}}
{{- $data := includeTemplate "claude-plugins.tmpl" . | fromJson -}}
{{- $plugins := list -}}
{{- range $data.plugins -}}
{{-   $plugins = append $plugins (printf "%s@%s" .name .marketplace) -}}
{{- end -}}
{{- $plugins = sortAlpha $plugins -}}
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  {{- if not (empty $model) }}
  "model": {{ $model | quote }},
  {{- end }}
  "cleanupPeriodDays": 365,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "DISABLE_AUTOUPDATER": "1",
    "ECC_HOOK_PROFILE": "minimal",
    "ENABLE_TOOL_SEARCH": "true",
    "MAX_THINKING_TOKENS": "8000",
    "MCP_CONNECTION_NONBLOCKING": "true",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_LOG_USER_PROMPTS": "1",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_METRICS_EXPORTER": "otlp",
    "XDG_CACHE_HOME": "{{ .chezmoi.homeDir }}/.cache",
    "XDG_CONFIG_HOME": "{{ .chezmoi.homeDir }}/.config",
    "XDG_DATA_HOME": "{{ .chezmoi.homeDir }}/.local/share",
    "XDG_STATE_HOME": "{{ .chezmoi.homeDir }}/.local/state"
  },
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Bash(basename *)",
      "Bash(claude mcp get *)",
      "Bash(claude mcp list)",
      "Bash(claude plugin list)",
      "Bash(cat *)",
      "Bash(column *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(date)",
      {{- if eq .os "darwin" }}
      "Bash(defaults read *)",
      {{- end }}
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(fd *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gh issue list *)",
      "Bash(gh issue search *)",
      "Bash(gh issue status *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh search *)",
      "Bash(git describe *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git ls-remote *)",
      "Bash(git ls-tree *)",
      "Bash(git remote -v *)",
      "Bash(git remote -v)",
      "Bash(git show *)",
      "Bash(git stash list *)",
      "Bash(git stash list)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git worktree list *)",
      "Bash(glab ci list *)",
      "Bash(glab ci status *)",
      "Bash(glab ci view *)",
      "Bash(glab issue list *)",
      "Bash(glab issue view *)",
      "Bash(glab mr diff *)",
      "Bash(glab mr list *)",
      "Bash(glab mr view *)",
      "Bash(glab pipeline get *)",
      "Bash(glab pipeline list *)",
      "Bash(glab repo view *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(mise current *)",
      "Bash(mise list *)",
      "Bash(pwd)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(sha256sum *)",
      "Bash(sleep *)",
      "Bash(sort *)",
      "Bash(sq *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(test *)",
      "Bash(tr *)",
      "Bash(tree)",
      "Bash(true)",
      "Bash(uname *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(xxd)",
      "Bash(yq *)",
      "Glob",
      "Grep",
      "KillShell",
      "LSP",
      "Read",
      "Read(**/.env.example)",
      {{- if and .features.sql (eq .os "darwin") }}
      "Read(~/Library/DBeaverData/workspace*/General/Scripts/**)",
      {{- end }}
      "Read(~/notes/{{ .profile }}/{journal,pages}/**)",
      "Skill(hookify:list)",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "ToolSearch",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.gitlab.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gitlab.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch",
      "mcp__claude-context__*",
      "mcp__context7__*",
      "mcp__deep-wiki__*",
      "mcp__grep_app__*",
      "mcp__open-notebook__*"
    ],
    "deny": [
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(**/*.pfx)",
      "Edit(./secrets/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.ssh/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.pfx)",
      "Read(./secrets/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.ssh/**)",
      "TodoWrite",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/*.pfx)",
      "Write(./secrets/**)",
      "Write(~/.gnupg/**)",
      "Write(~/.ssh/**)"
    ],
    "ask": [
      "Bash(awk *)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(export *)",
      "Bash(unset *)",
      "Bash(fd * --exec *)",
      "Bash(fd * --exec-batch *)",
      "Bash(fd * -X *)",
      "Bash(fd * -x *)",
      "Bash(fd --exec*)",
      "Bash(fd -X*)",
      "Bash(fd -x*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec *)",
      "Bash(find * -execdir *)",
      "Bash(find * -fprint*)",
      "Bash(find * -ok *)",
      "Bash(find * -okdir *)",
      "Bash(find -delete*)",
      "Bash(find -exec*)",
      "Bash(find -fprint*)",
      "Bash(find -ok*)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(rm *)",
      "Bash(sed * -I*)",
      "Bash(sed * -i*)",
      "Bash(sed -I*)",
      "Bash(sed -i*)",
      "Bash(sort * --output *)",
      "Bash(sort * -o *)",
      "Bash(sort --output*)",
      "Bash(sort -o*)",
      "Bash(sq * --output*)",
      "Bash(sq * -o*)",
      "Bash(sq --output*)",
      "Bash(sq -o*)",
      "Bash(sq sql *CREATE*)",
      "Bash(sq sql *DELETE*)",
      "Bash(sq sql *UPDATE*)",
      "Bash(trash *)",
      "Bash(yq * --inplace *)",
      "Bash(yq * -i *)",
      "Bash(yq --inplace*)",
      "Bash(yq -i*)",
      "Edit",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(~/.aws/**)",
      "Edit(~/.azure/**)",
      "Edit(~/.config/glab-cli/config.yml)",
      "Edit(~/.config/gh/hosts.yml)",
      "Edit(~/.docker/config.json)",
      "Edit(~/.gem/credentials)",
      "Edit(~/.git-credentials)",
      "Edit(~/.kube/config)",
      "Edit(~/.netrc)",
      "Edit(~/.npmrc)",
      "Edit(~/.pypirc)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/glab-cli/config.yml)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.docker/config.json)",
      "Read(~/.gem/credentials)",
      "Read(~/.git-credentials)",
      "Read(~/.kube/config)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Write",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(~/.aws/**)",
      "Write(~/.azure/**)",
      "Write(~/.config/glab-cli/config.yml)",
      "Write(~/.config/gh/hosts.yml)",
      "Write(~/.docker/config.json)",
      "Write(~/.gem/credentials)",
      "Write(~/.git-credentials)",
      "Write(~/.kube/config)",
      "Write(~/.netrc)",
      "Write(~/.npmrc)",
      "Write(~/.pypirc)",
      "ExitPlanMode",
      "NotebookEdit"
    ],
    "defaultMode": "{{ true | ternary "plan" "default" }}",
    "disableBypassPermissionsMode": "disable",
    {{- $notesDirs := includeTemplate "notes.tmpl" . | fromJson }}
    "additionalDirectories": {{ $notesDirs | toPrettyJson | indent 4 | trim }}
  },
  "enableAllProjectMcpServers": false,
  "hooks": {{ include "dot_claude/.hooks.json" | fromJson | toPrettyJson | indent 4 | trim }},
  {{- $node := lookPath "node" }}
  {{- if .features.mise }}
  {{-   $node = "mise exec node@lts --" }}
  {{- end }}
  {{- $dashboard := glob (print .chezmoi.homeDir "/.claude/plugins/cache/claude-dashboard/claude-dashboard/*/dist/index.js") | sortAlpha | last }}
  {{- $statusline := print .chezmoi.homeDir "/.claude/statusline.sh" }}
  {{- if and $node $dashboard }}
  "statusLine": {
    "type": "command",
    "command": {{ printf "%s %s %s" $statusline $node $dashboard | toJson }},
    "padding": 0
  },
  {{- end }}
  {{- $managedPlugins := dict -}}
  {{- range $plugins -}}
  {{-   $_ := set $managedPlugins . true -}}
  {{- end }}
  "enabledPlugins": {{ merge $managedPlugins (get (get .chezmoi "stdin" | default "{}" | fromJson) "enabledPlugins" | default dict) | toPrettyJson | indent 2 | trim }},
  {{- $extraMarketplaces := dict -}}
  {{- range $name, $info := $data.marketplaces -}}
  {{-   if hasKey $info "repo" -}}
  {{-     $_ := set $extraMarketplaces $name (dict "source" (dict "repo" $info.repo "source" "github")) -}}
  {{-   else if hasKey $info "path" -}}
  {{-     $_ := set $extraMarketplaces $name (dict "source" (dict "path" $info.path "source" "directory")) -}}
  {{-   end -}}
  {{- end }}
  "extraKnownMarketplaces": {{ $extraMarketplaces | toPrettyJson | indent 2 | trim }},
  "sandbox": {
    "enabled": {{ $sandboxEnabled }},
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "*.github.com",
        "*.githubusercontent.com",
        "*.gitlab.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "{{ env "GITLAB_HOST" | default "gitlab.com" }}"
      ]
    }
  },
  "alwaysThinkingEnabled": false,
  "showClearContextOnPlanAccept": true{{/* https://github.com/anthropics/claude-code/issues/37688 */}},
  "plansDirectory": "./.claude/plans",
  "autoMemoryEnabled": true,
  "showThinkingSummaries": true,
  "autoUpdates": false,
  "skills": {
    "audit": true,
    "claude-automation-recommender": true,
    "claude-dashboard:check-usage": true,
    "claude-dashboard:setup": true,
    "claude-dashboard:update": true,
    "claude-md-improver": true,
    "claude-md-management:revise-claude-md": true,
    "cleanup": true,
    "code-review:code-review": true,
    "code-simplifier:code-simplifier": true,
    "commit-commands:clean_gone": true,
    "commit-commands:commit": true,
    "commit-commands:commit-push-pr": true,
    "everything-claude-code:agentic-engineering": true,
    "everything-claude-code:agent-harness-construction": true,
    "everything-claude-code:ai-first-engineering": true,
    "everything-claude-code:api-design": true,
    "everything-claude-code:article-writing": true,
    "everything-claude-code:autonomous-loops": true,
    "everything-claude-code:backend-patterns": true,
    "everything-claude-code:claw": true,
    "everything-claude-code:coding-standards": true,
    "everything-claude-code:configure-ecc": true,
    "everything-claude-code:content-hash-cache-pattern": true,
    "everything-claude-code:continuous-agent-loop": true,
    "everything-claude-code:continuous-learning": true,
    "everything-claude-code:continuous-learning-v2": true,
    "everything-claude-code:cost-aware-llm-pipeline": true,
    "everything-claude-code:database-migrations": true,
    "everything-claude-code:deployment-patterns": true,
    "everything-claude-code:docker-patterns": true,
    "everything-claude-code:e2e": true,
    "everything-claude-code:e2e-testing": true,
    "everything-claude-code:eval-harness": true,
    "everything-claude-code:evolve": true,
    "everything-claude-code:frontend-patterns": true,
    "everything-claude-code:frontend-slides": true,
    "everything-claude-code:go-build": true,
    "everything-claude-code:go-review": true,
    "everything-claude-code:go-test": true,
    "everything-claude-code:golang-patterns": true,
    "everything-claude-code:golang-testing": true,
    "everything-claude-code:instinct-export": true,
    "everything-claude-code:instinct-import": true,
    "everything-claude-code:instinct-status": true,
    "everything-claude-code:iterative-retrieval": true,
    "everything-claude-code:learn-eval": true,
    "everything-claude-code:nanoclaw-repl": true,
    "everything-claude-code:plan": true,
    "everything-claude-code:postgres-patterns": true,
    "everything-claude-code:projects": true,
    "everything-claude-code:promote": true,
    "everything-claude-code:python-patterns": true,
    "everything-claude-code:python-review": true,
    "everything-claude-code:python-testing": true,
    "everything-claude-code:regex-vs-llm-structured-text": true,
    "everything-claude-code:search-first": true,
    "everything-claude-code:security-review": true,
    "everything-claude-code:security-scan": true,
    "everything-claude-code:skill-create": true,
    "everything-claude-code:skill-stocktake": true,
    "everything-claude-code:strategic-compact": true,
    "everything-claude-code:tdd": true,
    "everything-claude-code:tdd-workflow": true,
    "everything-claude-code:verification-loop": true,
    "feature-dev:feature-dev": true,
    "frontend-design": true,
    "hookify:configure": true,
    "hookify:help": true,
    "hookify:hookify": true,
    "hookify:list": true,
    "hookify:writing-rules": true,
    "journal": true,
    "keybindings-help": true,
    "local:sq": true,
{{- range .claudeDisabledSkills }}
    {{ . | quote }}: false,
{{- end }}
    "local:quality": true,
    "reflect": true,
    "standup": true
  },
  "voiceEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  }
}
