{{- /* chezmoi:modify-template */ -}}
{{- $stdin := get .chezmoi "stdin" | default "{}" | fromJson -}}
{{- $kbPaths := includeTemplate "kb-paths.tmpl" . | fromJson -}}
{{- $kbHome := .chezmoi.homeDir -}}
{{- $kbDirs := list -}}
{{- if $kbPaths -}}
{{-   $kbDirs = append $kbDirs "~/kb" -}}
{{- end -}}
{{- range $kbPaths -}}
{{-   $r := .real -}}
{{-   if hasPrefix $kbHome $r -}}
{{-     $r = printf "~%s" (trimPrefix $kbHome $r) -}}
{{-   end -}}
{{-   $kbDirs = append $kbDirs $r -}}
{{- end -}}
{{- $claude := get . "claude" | default dict -}}

{{- $tiers := get $claude "tiers" | default dict -}}

{{- $localYaml := joinPath .chezmoi.homeDir ".claude/local.yaml" -}}
{{- $local := dict -}}
{{- if stat $localYaml -}}
{{-   $local = include $localYaml | fromYaml | default dict -}}
{{- end -}}

{{- $providers := get $claude "providers" | default dict -}}
{{- $provider := get $local "provider" -}}
{{- $prefix := $provider | splitList "-" | first -}}
{{- if and $provider (not (hasKey $providers $prefix)) -}}
{{-   warnf "claude: provider %q not in providers, ignoring" $provider -}}
{{-   $provider = "" -}}
{{-   $prefix = "" -}}
{{- end -}}
{{- $endpoint := get $providers $prefix | default dict -}}

{{- $remoteControl := true -}}
{{- $sandboxEnabled := false -}}

{{- $tierDefault := eq .profile "work" | ternary "max" "pro" -}}
{{- $tier := get $local "tier" | default $tierDefault -}}
{{- if not (hasKey $tiers $tier) -}}
{{-   warnf "claude: tier %q not in tiers, using %q" $tier $tierDefault -}}
{{-   $tier = $tierDefault -}}
{{- end -}}
{{- $settings := get $tiers $tier | default dict -}}

{{- $model := get $settings "model" | default (get $stdin "model") -}}
{{- $subagent := get $settings "subagent" -}}
{{- /* effortLevel: per-machine, prefer the live stdin value, tier fallback, omit if unset */ -}}
{{- $effort := get $stdin "effortLevel" | default (get $settings "effort") -}}

{{- $data := includeTemplate "claude-plugins.tmpl" . | fromJson -}}

{{- $plugins := list -}}
{{- range $data.plugins }}
{{-   $plugins = append $plugins (printf "%s@%s" .name .marketplace) }}
{{- end }}
{{- $plugins = sortAlpha $plugins -}}
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 365,
  "env": {
    {{- if .features.otel }}
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    {{- end }}
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    {{- if not (empty $subagent) }}
    "CLAUDE_CODE_SUBAGENT_MODEL": {{ $subagent | quote }},
    {{- end }}
    {{- if $endpoint }}
    "ANTHROPIC_AUTH_TOKEN": ""{{/* Force apiKeyHelper in /status */}},
    "ANTHROPIC_BASE_URL": {{ get $endpoint "url" | quote }},
    {{- if hasKey $endpoint "models" }}
    {{-   $models := get $endpoint "models" }}
    {{-   if get $models "opus" }}
    "ANTHROPIC_DEFAULT_OPUS_MODEL": {{ get $models "opus" | quote }},
    {{-   end }}
    {{-   if get $models "sonnet" }}
    "ANTHROPIC_DEFAULT_SONNET_MODEL": {{ get $models "sonnet" | quote }},
    {{-   end }}
    {{-   if get $models "haiku" }}
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": {{ get $models "haiku" | quote }},
    {{-   end }}
    {{- end }}
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    {{- end }}
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_UPDATES": "1",
    "DO_NOT_TRACK": "{{ $remoteControl | ternary "0" "1" }}",
    {{- if has "everything-claude-code@everything-claude-code" $plugins }}
    "ECC_HOOK_PROFILE": "minimal",
    {{- end }}
    "ENABLE_TOOL_SEARCH": "true",
    "MAX_THINKING_TOKENS": "8000",
    "MCP_CONNECTION_NONBLOCKING": "1",
{{- if .features.otel }}
{{- $otel := includeTemplate "otel.yaml.tmpl" . | fromYaml -}}
{{- $keys := keys $otel | sortAlpha -}}
{{- range $i, $key := $keys -}}
{{- if $i }},{{ end }}
    "{{ $key }}": "{{ index $otel $key }}"
{{- end }},
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_LOG_USER_PROMPTS": "1",
{{- end }}
    "XDG_CACHE_HOME": {{ joinPath .chezmoi.homeDir ".cache" | quote }},
    "XDG_CONFIG_HOME": {{ joinPath .chezmoi.homeDir ".config" | quote }},
    "XDG_DATA_HOME": {{ joinPath .chezmoi.homeDir ".local/share" | quote }},
    "XDG_STATE_HOME": {{ joinPath .chezmoi.homeDir ".local/state" | quote }}
  },
  {{- $scriptPath := joinPath .chezmoi.homeDir ".claude/api-key-helper.sh" }}
  {{- if and $provider (stat $scriptPath) }}
  "apiKeyHelper": {{ printf "%s %s" $scriptPath $provider | quote }},
  {{- end }}
