    "defaultMode": "{{ env "CLAUDE_DEFAULT_MODE" | default "default" }}",
    "disableBypassPermissionsMode": "disable",
    "additionalDirectories": {{ $kbDirs | default list | toPrettyJson | indent 4 | trim }}
  },
  {{- if not (empty $model) }}
  "model": {{ $model | quote }},
  {{- end }}
  "enableAllProjectMcpServers": false,
  "hooks": {{ (get $stdin "hooks" | default dict) | toPrettyJson | indent 2 | trim }},
  "enableWorkflows": true,
  {{- $statusline := print .chezmoi.homeDir "/.claude/statusline.sh" }}
  {{- if stat $statusline }}
  "statusLine": {
    "type": "command",
    "command": {{ $statusline | toJson }},
    "padding": 0
  },
  {{- end }}
  {{- $managedPlugins := dict -}}
  {{- range $plugins -}}
  {{-   $_ := set $managedPlugins . true -}}
  {{- end }}
  "enabledPlugins": {{ merge $managedPlugins (get $stdin "enabledPlugins" | default dict) | toPrettyJson | indent 2 | trim }},
  {{- $extraMarketplaces := dict -}}
  {{- range $name, $info := $data.marketplaces -}}
  {{-   if hasKey $info "repo" -}}
  {{-     $_ := set $extraMarketplaces $name (dict "source" (dict "repo" $info.repo "source" "github")) -}}
  {{-   else if hasKey $info "path" -}}
  {{-     $_ := set $extraMarketplaces $name (dict "source" (dict "path" $info.path "source" "directory")) -}}
  {{-   end -}}
  {{- end }}
  "extraKnownMarketplaces": {{ $extraMarketplaces | toPrettyJson | indent 2 | trim }},
  "sandbox": {
    "enabled": {{ $sandboxEnabled }},
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "*.github.com",
        "*.githubusercontent.com",
        "*.gitlab.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "{{ env "GITLAB_HOST" | default "gitlab.com" }}"
      ]
    }
  },
  "alwaysThinkingEnabled": false,
  {{- with $effort }}
  "effortLevel": {{ . | quote }},
  {{- end }}
  "awaySummaryEnabled": false,
  "showClearContextOnPlanAccept": true{{/* https://github.com/anthropics/claude-code/issues/37688 */}},
  "plansDirectory": "./.claude/plans",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "autoMemoryEnabled": true,
  "showThinkingSummaries": true,
  "skipWorkflowUsageWarning": true,
  "editorMode": "vim",
  "verbose": true,
  "switchModelsOnFlag": false,
  "remoteControlAtStartup": false,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "autoUpdates": false
}
