      "Bash(fd * -x *)",
      "Bash(fd --exec*)",
      "Bash(fd -X*)",
      "Bash(fd -x*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec *)",
      "Bash(find * -execdir *)",
      "Bash(find * -fprint*)",
      "Bash(find * -ok *)",
      "Bash(find * -okdir *)",
      "Bash(find -delete*)",
      "Bash(find -exec*)",
      "Bash(find -fprint*)",
      "Bash(find -ok*)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(rm *)",
      "Bash(sed * -I*)",
      "Bash(sed * -i*)",
      "Bash(sed -I*)",
      "Bash(sed -i*)",
      "Bash(sort * --output *)",
      "Bash(sort * -o *)",
      "Bash(sort --output*)",
      "Bash(sort -o*)",
      "Bash(sq * --output*)",
      "Bash(sq * -o*)",
      "Bash(sq --output*)",
      "Bash(sq -o*)",
      "Bash(trash *)",
      "Bash(yq * --inplace *)",
      "Bash(yq * -i *)",
      "Bash(yq --inplace*)",
      "Bash(yq -i*)",
      "Edit",
      "ExitPlanMode",
      "MultiEdit",
      "NotebookEdit",
      "TaskCreate",
      "TaskUpdate",
      "Write"
    ],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable"
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/bash_safety.sh"
          }
        ]
      },
      {
        "matcher": "TaskCreate|TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/task_info.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/lint.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Compaction imminent. Include in the summary: current task state (pending/in-progress subjects and key context), any uncommitted decisions or discoveries, and enough detail for the next turn to orient without tool calls.'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Before finishing: run TaskList and review task status. Mark completed tasks done. Persist any session discoveries to memory files (not just task descriptions). Ensure pending/in-progress tasks have self-contained descriptions for the next session.'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Use session tasks proactively: create before coding, mark in_progress when starting, completed when done. Check TaskList for pending tasks. For multi-step work, break into tasks with dependencies (addBlocks/addBlockedBy). Descriptions must be self-contained: root cause, specific files, approach, and done criteria.'"
          }
        ]
      }
    ]
  },
  {{- $dashboardPaths := glob (joinPath .chezmoi.homeDir ".claude/plugins/cache/claude-dashboard/claude-dashboard/*/dist/index.js") }}
  {{- if $dashboardPaths }}
  "statusLine": {
    "type": "command",
    "command": "{{ lookPath "node" }} {{ last $dashboardPaths }}"
  },
  {{- end }}
  "enabledPlugins": {
    {{- range $index, $value := $plugins }}
    {{ $value | quote }}: true{{ if ne (add $index 1) (len $plugins) }},{{ end }}
    {{- end }}
  },
  {{- $eccMkt := dict "everything-claude-code" (dict "source" (dict "source" "github" "repo" "affaan-m/everything-claude-code")) -}}
  "extraKnownMarketplaces": {{ merge $eccMkt (get (.chezmoi.stdin | fromJson) "extraKnownMarketplaces" | default dict) | toPrettyJson | indent 2 | trim }},
  "sandbox": {
    "enabled": {{ $sandboxEnabled }},
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "*.github.com",
        "*.githubusercontent.com",
        "*.gitlab.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "{{ env "GITLAB_HOST" | default "gitlab.com" }}"
      ]
    }
  },
  "alwaysThinkingEnabled": true,
  "autoUpdates": false,
