{{- /* chezmoi:modify-template */ -}}
{{- $sandboxEnabled := false -}}
{{- $model := "" -}}
{{- $plugins := list
  "beads@beads-marketplace"
  "claude-code-setup@claude-plugins-official"
  "claude-dashboard@claude-dashboard"
  "claude-md-management@claude-plugins-official"
  "code-review@claude-plugins-official"
  "code-simplifier@claude-plugins-official"
  "commit-commands@claude-plugins-official"
  "everything-claude-code@everything-claude-code"
  "feature-dev@claude-plugins-official"
  "frontend-design@claude-plugins-official"
  "hookify@claude-plugins-official"
  "local@local"
  "security-guidance@claude-plugins-official"
-}}
{{- $plugins := concat $plugins (env "CLAUDE_CODE_PLUGINS" | splitList ",") | sortAlpha -}}
{{- /* "agent-sdk-dev@claude-plugins-official" per-project */ -}}
{{- /* "github@claude-plugins-official" per-project */ -}}
{{- /* "gitlab@claude-plugins-official" per-project */ -}}
{{- /* "greptile@claude-plugins-official" needs API key */ -}}
{{- /* "php-lsp@claude-plugins-official" per-project */ -}}
{{- /* "plugin-dev@claude-plugins-official" plugin authoring only */ -}}
{{- /* "skill-creator@claude-plugins-official" plugin authoring only */ -}}
{{- /* "pr-review-toolkit@claude-plugins-official" overlaps code-review */ -}}
{{- /* "semgrep@claude-plugins-official" needs semgrep installed */ -}}
{{- /* "supabase@claude-plugins-official" needs supabase project */ -}}
{{- /* "typescript-lsp@claude-plugins-official" per-project */ -}}
{
