#!/usr/bin/env bash
#MISE description="Lint #USAGE specs and shell script conventions"
#USAGE flag "-q --quiet" help="Only print errors and summary"
#USAGE flag "-v --verbose" help="Print full usage spec for each file"
#USAGE arg "[file]..." help="Files to check (default: git ls-files)"
#USAGE complete "file" run="git ls-files 'script/*' 'home/dot_local/bin/executable_*'"

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo "bash 4+ required, found $BASH_VERSION" >&2
  exit 1
fi

if ! command -v usage >/dev/null; then
  exit 0
fi

quiet="${VALIDATE_USAGE_QUIET:-${VALIDATE_QUIET:-false}}"
verbose="${VALIDATE_USAGE_VERBOSE:-${VALIDATE_VERBOSE:-false}}"

while [ $# -gt 0 ]; do
  case "$1" in
  -q | --quiet)
    quiet=true
    shift
    ;;
  -v | --verbose)
    verbose=true
    shift
    ;;
  -h | --help)
    if command -v usage >/dev/null; then
      usage exec --help bash "$0"
    else
      echo "Usage: validate-usage [-q] [-v] [file...]"
    fi
    exit
    ;;
  --usage)
    grep '^#USAGE' "$0" | sed 's/^#USAGE //'
    exit
    ;;
  --)
    shift
    break
    ;;
  *) break ;;
  esac
done

if [ $# -eq 0 ]; then
  mapfile -t files < <(git ls-files '*.sh' '*.bash' '*.bats' 'script/*' 'home/dot_local/bin/executable_*')
  set -- "${files[@]}"
fi

warnings=0
errors=0
checked=0

for f in "$@"; do
  case "$f" in *.awk) continue ;; esac
  checked=$((checked + 1))

  if ! head -1 "$f" | grep -q '^#!'; then
    continue
  fi

  # #MISE description required in script/ (mise tasks)
  case "$f" in
  script/*)
    if ! grep -q '^#MISE description=' "$f"; then
      echo "$f: error: missing #MISE description" >&2
      errors=$((errors + 1))
    fi
    ;;
  esac

  # Description comment required after shebang
  case "$f" in
  script/* | */executable_*)
    if ! sed -n '2p' "$f" | grep -q '^#'; then
      if [ "$quiet" != true ]; then
        echo "$f: warning: missing description comment after shebang" >&2
      fi
      warnings=$((warnings + 1))
    fi
    ;;
  esac

  # Lint #USAGE spec
  spec=
  if grep -q '^#USAGE ' "$f"; then
    spec=$(grep '^#USAGE ' "$f" | sed 's/^#USAGE //')
  fi
  if [ -n "$spec" ] && ! usage lint <(echo "$spec") >/dev/null; then
    errors=$((errors + 1))
    continue
  fi

  if [ "$quiet" = true ]; then
    continue
  fi

  if [ "$verbose" = true ] && [ -n "$spec" ]; then
    echo "$f: ok"
    echo "  ${spec//$'\n'/$'\n  '}"
  else
    echo "$f: ok"
  fi
done

if ((errors > 0 || warnings > 0)); then
  echo "$checked checked, $errors error(s), $warnings warning(s)" >&2
elif [ "$quiet" != true ]; then
  echo "$checked checked, all passed" >&2
fi
exit "$((errors > 0))"
