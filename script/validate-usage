#!/usr/bin/env bash
#MISE alias="vu"
#MISE description="Lint #USAGE specs and shell script conventions"
#USAGE flag "-q --quiet" help="Only print errors and summary"
#USAGE flag "-v --verbose" help="Print full usage spec for each file"
#USAGE arg "[file]..." help="Files to check (default: git ls-files)"
#USAGE complete "file" run="git ls-files 'script/*' 'home/dot_local/bin/executable_*'"

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo "bash 4+ required, found $BASH_VERSION" >&2
  exit 1
fi

if ! command -v usage >/dev/null; then
  exit 0
fi

verbosity=${VALIDATE_USAGE_VERBOSITY:-${VALIDATE_VERBOSITY:-1}}

while [ $# -gt 0 ]; do
  case "$1" in
  -q | --quiet)
    verbosity=0
    shift
    ;;
  -v | --verbose)
    verbosity=2
    shift
    ;;
  -h | --help)
    if command -v usage >/dev/null; then
      usage exec --help bash "$0"
    else
      echo "Usage: validate-usage [-q] [-v] [file...]"
    fi
    exit
    ;;
  --usage)
    grep '^#USAGE' "$0" | sed 's/^#USAGE //'
    exit
    ;;
  --)
    shift
    break
    ;;
  -*)
    echo "validate-usage: unknown option: $1" >&2
    exit 2
    ;;
  *) break ;;
  esac
done

if [ $# -eq 0 ]; then
  mapfile -t files < <(git ls-files 'script/*' 'home/dot_local/bin/executable_*')
  set -- "${files[@]}"
fi

errors=0
warnings=0
checked=0

for f in "$@"; do
  case "$f" in *.awk) continue ;; esac
  checked=$((checked + 1))

  shebang=$(head -1 "$f")
  case "$shebang" in
  '#!'*sh*) ;;
  '#!'*)
    [ "$verbosity" -ge 2 ] && echo "SKIP $f: non-shell shebang"
    continue
    ;;
  *) continue ;;
  esac

  ok=true

  if grep -q '^#MISE hide=true' "$f"; then
    [ "$verbosity" -ge 2 ] && echo "SKIP $f: hidden"
    continue
  fi

  case "$f" in
  script/*)
    if ! grep -q '^#MISE description=' "$f"; then
      echo "FAIL $f: missing #MISE description"
      errors=$((errors + 1))
      ok=false
    fi
    ;;
  esac

  if ! grep -q '^#USAGE' "$f"; then
    # echo "FAIL $f: missing #USAGE directives"
    # errors=$((errors + 1))
    # ok=false
    [ "$verbosity" -ge 1 ] && echo "WARN $f: missing #USAGE directives"
    warnings=$((warnings + 1))
    continue
  fi

  if ! sed -n '2p' "$f" | grep -q '^#'; then
    [ "$verbosity" -ge 1 ] && echo "WARN $f: no description after shebang"
    warnings=$((warnings + 1))
  fi

  if grep -q '^#USAGE arg ' "$f" &&
    ! grep -q '^#USAGE \s*choices ' "$f" &&
    ! grep -q '^#USAGE complete ' "$f"; then
    [ "$verbosity" -ge 1 ] && echo "WARN $f: has args but no choices or complete directive"
    warnings=$((warnings + 1))
  fi

  # Lint #USAGE spec
  spec=
  if grep -q '^#USAGE ' "$f"; then
    spec=$(grep '^#USAGE ' "$f" | sed 's/^#USAGE //')
  fi
  if [ -n "$spec" ] && ! usage lint <(echo "$spec") >/dev/null; then
    errors=$((errors + 1))
    ok=false
  fi

  if [ "$ok" = true ] && [ "$verbosity" -ge 2 ]; then
    echo "PASS $f"
    # [ -n "$spec" ] && echo "  ${spec//$'\n'/$'\n  '}"
  fi
done

if [ "$verbosity" -ge 1 ]; then
  summary="$((checked - errors)) passed, $errors failed"
  if [ "$warnings" -gt 0 ]; then
    summary="$summary, $warnings warnings"
  fi
  echo "validate-usage: $summary" >&2
fi
exit "$((errors > 0))"
