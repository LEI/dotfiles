#!/usr/bin/env bash

# https://www.chezmoi.io/reference/commands/docker/

set -euo pipefail

# EPHEMERAL="${EPHEMERAL:-false}"
# HEADLESS="${HEADLESS:-false}"
# PROFILE="${PROFILE:-minimal}"

PROVIDER="${PROVIDER:-podman}"
PREFIX="${PREFIX:-}" # Termux prefix
prefix=              # /opt or HOME

usage() {
  echo >&2 "Usage: container [bootstrap|<image>]"
  echo >&2
  echo >&2 "Examples:"
  # echo >&2 "  container alpine ps --all"
  echo >&2 "  container alpine up --build --detach"
  echo >&2 "  container alpine logs --follow --since=1m"
  # echo >&2 "  container alpine attach --no-stdin"
  echo >&2 "  container alpine [check|test]"
  echo >&2
  echo >&2 "Images: alpine, archlinux, debian, ubuntu, fedora"
}

compose_file() {
  local interactive=true
  # local sh_args=eux
  # if [ "$interactive" = true ]; then
  #   sh_args="i$sh_args"
  # fi
  cat <<EOF
---
services:
  $name:
    # container_name: "${name}-${tag}"
    image: "$image"
    environment:
$(for e in "${environment[@]}"; do echo "      - $e"; done)
    # entrypoint: ["/bin/sh", "-ceiux"]
    command:
      - sh
      - -ceiux
      - |
$(for c in "${command[@]}"; do echo "        $c"; done)
    volumes:
$(for v in "${volumes[@]}"; do echo "      - $v"; done)
    stdin_open: $interactive
    tty: $interactive
    user: $container_user
    working_dir: $working_dir
EOF
}

compose() {
  local home=/root
  local container_user=root
  # if [ "$user" = test ]; then
  #   container_user=root
  # fi
  if [ "$user" != root ]; then
    home="/home/$user"
  fi
  local working_dir="$home/.local/share/chezmoi"
  local bootstrap="./script/container bootstrap"
  # if [ "$user" != root ] && [ "$user" != ubuntu ]; then
  #   command+=(
  #     "if ! id $user; then useradd -ms /bin/bash $user; fi"
  #     "usermod -aG wheel $user"
  #     "sed -i 's/^# %wheel ALL=(ALL:ALL) NOPASSWD: ALL/%wheel ALL=(ALL:ALL) NOPASSWD: ALL/' /etc/sudoers"
  #     # FIXME: not compatible with mounted volume
  #     # "chown -R $user:$user $home"
  #     # "su $user"
  #   )
  #   bootstrap="su - $user -c 'ls -lah .local/share; cd \"$working_dir\"; ls -lah $bootstrap'"
  # fi
  command+=(
    "[ -f $prefix/install.done ] || touch $prefix/install.done"
    "$bootstrap"
  )
  volumes+=(
    # "$HOME/.local/share/chezmoi:/root/.local/share/chezmoi"
    "$HOME/.local/share/chezmoi:$home/.local/share/chezmoi"
    # ".:$working_dir"
  )
  if [ $# -eq 0 ]; then
    set -- ps --all
  elif [ $# -eq 1 ]; then
    if [ "$1" = check ]; then
      set -- exec -T "$name" ./script/check
    elif [ "$1" = test ]; then
      set -- exec -T "$name" ./script/test --pretty
    fi
  fi
  echo >&2 "$PROVIDER compose --file=- $*"
  compose_file="$(compose_file)"
  # if command -v yq >/dev/null; then
  #   if ! yq --output-format=yaml . >&2 <<<"$compose_file"; then
  #     echo >&2 "container: yaml error in compose file"
  #     echo >&2 "$compose_file"
  #   fi
  # else
  echo >&2 "$compose_file"
  # fi
  $PROVIDER compose --file=- "$@" <<EOF
$compose_file
EOF
}

bootstrap() {
  if [ $# -ne 0 ]; then
    echo >&2 "WARN: ignoring bootstrap args: $*"
  fi

  # Ensure chezmoi is available
  BIN_DIR="$HOME/.local/bin"
  PATH="$PATH:$BIN_DIR"

  # FIXME(termux): ble.sh: updating binders..../script/container: line 112:
  # 2764 Segmentation fault (core dumped) bash -i
  export BLE_ENABLED=false

  # export CHEZMOI_PROFILE=$PROFILE
  export CI=true

  if [ "${DEBUG:-}" = true ]; then
    set -- --debug "$@"
  fi

  if [ "${VERBOSE:-true}" = true ]; then
    set -- --verbose "$@"
  fi

  local bootstrap=("./script/bootstrap")
  if [ -n "$PREFIX" ]; then
    # Install chezmoi with package manager to avoid error on tag:
    # latest: critical %s: unsupported platform\n android/386
    # x86_64: android/amd64
    # i686: android/386
    # aarch64, arm: exec format error
    command -v chezmoi >/dev/null || pkg install --quiet --yes chezmoi
    # "tls: failed to verify certificate: x509: certificate signed by unknown authority"
    command -v proot >/dev/null || pkg install --quiet --yes proot
    bootstrap=(
      proot -b "$PREFIX/etc/resolv.conf:/etc/resolv.conf" -b "$PREFIX/etc/tls:/etc/ssl"
      "${bootstrap[@]}"
    )
  fi

  set -x

  # mkdir -p "$HOME/.config/"{atuin,bash,bat,blesh,carapace/specs,curl,eza,mise,nushell/{functions,modules,themes},procs,readline,ripgrep,sh/{functions,plugins},starship,wget,yamllint,zsh}
  "${bootstrap[@]}" --force --no-tty "$@"

  # ./script/check
  # ./script/test --pretty # --filter-tags '!bench,!check,!chezmoi'

  # Keep the container running
  bash -i
  # bash -l
  # watch -n60 chezmoi status
}

container() {
  if [ -z "$prefix" ]; then
    # prefix="$HOME/.local/share"
    prefix="/opt" # "$HOME/.local/state"
  fi
  local user=root
  # Environment must contain at least one element be a mapping
  local environment=("CONTAINER_NAME=$name")
  # NOTE: container is recreated when command changes
  local command=()
  local volumes=()
  # if [ -z "$tag" ]; then
  #   image="$name:latest"
  #   tag=latest
  # fi
  if [ -n "${GITHUB_TOKEN:-}" ]; then
    env+=("GITHUB_TOKEN=$GITHUB_TOKEN")
  fi
  case "$name" in
  alpine)
    environment+=(
      "LANG=C"
      # "USER=$user"
    )
    command+=(
      "[ -f $prefix/install.done ] || apk update --quiet"
      "[ -f $prefix/install.done ] || apk add bash curl" # sudo unzip
    )
    compose "$@"
    ;;
  archlinux)
    user="test"
    environment+=(
      "LANG=C"
      # "USER=$user"
    )
    command+=(
      # "pacman -Sy --needed --noconfirm --quiet sudo which"
      "[ -f $prefix/install.done ] || pacman --sync --needed --noconfirm --quiet --refresh sudo which"

      # user=$user
      # pacman --sync --needed --noconfirm --quiet --refresh sudo which
      # useradd -ms /bin/bash "$user"
      # usermod -aG wheel "$user"
      # sed -i 's/^# %wheel ALL=(ALL:ALL) NOPASSWD: ALL/%wheel ALL=(ALL:ALL) NOPASSWD: ALL/' /etc/sudoers
      # echo -n "$user:$user" | chpasswd -e "$user"
    )
    compose "$@"
    ;;
  debian | ubuntu)
    if [ "$image" = ubuntu ]; then
      user=ubuntu
    fi
    environment+=(
      "DEBIAN_FRONTEND=noninteractive"
      "LANG=C"
      "TZ=${TZ:-Etc/UTC}" # ubuntu
      # "USER=$user"
    )
    command+=(
      "[ -f $prefix/install.done ] || apt-get update --quiet"
      "[ -f $prefix/install.done ] || apt-get install --no-install-recommends --quiet --yes ca-certificates curl locales" # sudo unzip
      # "rm -rf /var/lib/apt/lists/*"
    )
    compose "$@"
    ;;
  fedora)
    environment+=(
      "DEBIAN_FRONTEND=noninteractive"
      "LANG=C"
      # "USER=$user"
    )
    command+=(
      "[ -f $prefix/install.done ] || dnf update --assumeyes --quiet"
      "[ -f $prefix/install.done ] || dnf install -y -q which unzip"
      # "dnf clean all"
    )
    compose "$@"
    ;;

  # macOS
  # https://github.com/sickcodes/Docker-OSX#building-a-headless-osx-container
  # https://github.com/sickcodes/Docker-OSX/issues/492
  macos)
    # Arch: sudo pacman -S xorg-xhost && xhost +
    # Windows: /mnt/wslg/.X11-unix:/tmp/.X11-unix
    image=docker.io/sickcodes/docker-osx:auto # ${tag:-auto}
    environment+=(
      # "GENERATE_UNIQUE=true"
      # "MASTER_PLIST_URL="
      # "NONINTERACTIVE=1"
      # "OSX_COMMANDS='echo OK; ioreg -l | grep IOPlatformSerialNumber'"
    )
    # command+=()
    volumes+=("/tmp/.X11-unix:/tmp/.X11-unix")
    compose "--publish=50922:10022" "$@"
    ;;

  # docker run -it --rm termux/termux-docker:latest bash -c "apt update && apt install -yq clang"
  android | termux)
    user=a0_test
    image=docker.io/termux/termux-docker:x86_64
    environment+=(
      # "USER=$user"
    )
    # TODO: pre-select mirrors with termux-change-repo
    command+=()
    # PREFIX=/data/data/com.termux/files/usr
    prefix=/data/data/com.termux/files/home # /.local/state
    compose "$@"
    ;;

  *)
    echo >&2 "container: invalid image: $image"
    usage
    exit 1
    ;;
  esac
}

main() {
  if [ $# -eq 0 ]; then
    usage
    exit
  fi
  local image="$1"
  shift
  local name="${image%%:*}" tag="${image#*:}"
  if [ "$name" = bootstrap ]; then
    bootstrap "$@"
  else
    container "$@"
  fi
}

main "$@"
