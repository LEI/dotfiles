#!/usr/bin/env bash

# https://www.chezmoi.io/reference/commands/docker/

set -euo pipefail

# EPHEMERAL="${EPHEMERAL:-false}"
# HEADLESS="${HEADLESS:-false}"
# PROFILE="${PROFILE:-minimal}"

PROVIDER="${PROVIDER:-podman}"

usage() {
  echo >&2 "Usage: container [bootstrap|<image>]"
  echo >&2
  echo >&2 "Examples:"
  # echo >&2 "  container alpine ps --all"
  echo >&2 "  container alpine up --build --detach"
  echo >&2 "  container alpine logs --follow --since=1m"
  # echo >&2 "  container alpine attach --no-stdin"
  echo >&2 "  container alpine [check|test]"
  echo >&2
  echo >&2 "Images: alpine, archlinux, debian, ubuntu, fedora"
}

compose_file() {
  local interactive=true
  # local sh_args=eux
  # if [ "$interactive" = true ]; then
  #   sh_args="i$sh_args"
  # fi
  cat <<EOF
---
services:
  $name:
    # container_name: "${name}-${tag}"
    image: "$image"
    environment:
$(for e in "${environment[@]}"; do echo "      - $e"; done)
    # entrypoint: ["/bin/sh", "-ceiux"]
    command:
      - sh
      - -ceiux
      - |
$(for c in "${command[@]}"; do echo "        $c"; done)
    volumes:
$(for v in "${volumes[@]}"; do echo "      - $v"; done)
    stdin_open: $interactive
    tty: $interactive
    user: $container_user
    working_dir: $working_dir
EOF
}

compose() {
  local home=/root
  local container_user=root
  # if [ "$user" = test ]; then
  #   container_user=root
  # fi
  if [ "$user" != root ]; then
    home="/home/$user"
  fi
  local working_dir="$home/.local/share/chezmoi"
  local bootstrap="./script/container bootstrap"
  # if [ "$user" != root ] && [ "$user" != ubuntu ]; then
  #   command+=(
  #     "if ! id $user; then useradd -ms /bin/bash $user; fi"
  #     "usermod -aG wheel $user"
  #     "sed -i 's/^# %wheel ALL=(ALL:ALL) NOPASSWD: ALL/%wheel ALL=(ALL:ALL) NOPASSWD: ALL/' /etc/sudoers"
  #     # FIXME: not compatible with mounted volume
  #     # "chown -R $user:$user $home"
  #     # "su $user"
  #   )
  #   bootstrap="su - $user -c 'ls -lah .local/share; cd \"$working_dir\"; ls -lah $bootstrap'"
  # fi
  command+=(
    "[ -f /opt/install.done ] || touch /opt/install.done"
    "$bootstrap"
  )
  volumes+=(
    # "$HOME/.local/share/chezmoi:/root/.local/share/chezmoi"
    "$HOME/.local/share/chezmoi:$home/.local/share/chezmoi"
    # ".:$working_dir"
  )
  if [ $# -eq 0 ]; then
    set -- ps --all
  elif [ $# -eq 1 ]; then
    if [ "$1" = check ]; then
      set -- exec -T "$name" ./script/check
    elif [ "$1" = test ]; then
      set -- exec -T "$name" ./script/test --pretty
    fi
  fi
  echo >&2 "$PROVIDER compose --file=- $*"
  compose_file="$(compose_file)"
  # if command -v yq >/dev/null; then
  #   if ! yq --output-format=yaml . >&2 <<<"$compose_file"; then
  #     echo >&2 "container: yaml error in compose file"
  #     echo >&2 "$compose_file"
  #   fi
  # else
  echo >&2 "$compose_file"
  # fi
  $PROVIDER compose --file=- "$@" <<EOF
$compose_file
EOF
}

bootstrap() {
  if [ $# -ne 0 ]; then
    echo >&2 "WARN: ignoring bootstrap args: $*"
  fi

  # Ensure chezmoi is available
  BIN_DIR="$HOME/.local/bin"
  PATH="$PATH:$BIN_DIR"

  set -x

  # export CHEZMOI_PROFILE=$PROFILE
  export CI=true
  ./script/bootstrap --no-tty --verbose "$@"

  # ./script/check
  # ./script/test --pretty # --filter-tags '!bench,!check,!chezmoi'

  # Keep the container running
  bash -i
  # bash -l
  # watch -n60 chezmoi status
}

container() {
  local user=root
  local environment=()
  # NOTE: container is recreated when command changes
  local command=()
  local volumes=()
  # if [ -z "$tag" ]; then
  #   image="$name:latest"
  #   tag=latest
  # fi
  if [ -n "${GITHUB_TOKEN:-}" ]; then
    env+=("GITHUB_TOKEN=$GITHUB_TOKEN")
  fi
  case "$name" in
  alpine)
    environment+=(
      "LANG=C"
      "USER=$user"
    )
    command+=(
      "[ -f /opt/install.done ] || apk update --quiet"
      "[ -f /opt/install.done ] || apk add bash curl" # sudo unzip
    )
    compose "$@"
    ;;
  archlinux)
    environment+=(
      "LANG=C"
      "USER=$user"
    )
    command+=(
      # "pacman -Sy --needed --noconfirm --quiet sudo which"
      "[ -f /opt/install.done ] || pacman --sync --needed --noconfirm --quiet --refresh sudo which"

      # user=$user
      # pacman --sync --needed --noconfirm --quiet --refresh sudo which
      # useradd -ms /bin/bash "$user"
      # usermod -aG wheel "$user"
      # sed -i 's/^# %wheel ALL=(ALL:ALL) NOPASSWD: ALL/%wheel ALL=(ALL:ALL) NOPASSWD: ALL/' /etc/sudoers
      # echo -n "$user:$user" | chpasswd -e "$user"
    )
    compose "$@"
    ;;
  debian | ubuntu)
    if [ "$image" = ubuntu ]; then
      user=ubuntu
    fi
    environment+=(
      "DEBIAN_FRONTEND=noninteractive"
      "LANG=C"
      "TZ=${TZ:-Etc/UTC}" # ubuntu
      "USER=$user"
    )
    command+=(
      "[ -f /opt/install.done ] || apt-get update --quiet"
      "[ -f /opt/install.done ] || apt-get install --no-install-recommends --quiet --yes ca-certificates curl locales" # sudo unzip
      # "rm -rf /var/lib/apt/lists/*"
    )
    compose "$@"
    ;;
  fedora)
    environment+=(
      "DEBIAN_FRONTEND=noninteractive"
      "LANG=C"
      "USER=$user"
    )
    command+=(
      "[ -f /opt/install.done ] || dnf update --assumeyes --quiet"
      "[ -f /opt/install.done ] || dnf install -y -q which unzip"
      # "dnf clean all"
    )
    compose "$@"
    ;;

  # macOS
  # https://github.com/sickcodes/Docker-OSX#building-a-headless-osx-container
  # https://github.com/sickcodes/Docker-OSX/issues/492
  macos)
    # Arch: sudo pacman -S xorg-xhost && xhost +
    # Windows: /mnt/wslg/.X11-unix:/tmp/.X11-unix
    image=docker.io/sickcodes/docker-osx:${tag:-auto}
    environment+=(
      # "GENERATE_UNIQUE=true"
      # "MASTER_PLIST_URL="
      # "NONINTERACTIVE=1"
      # "OSX_COMMANDS='echo OK; ioreg -l | grep IOPlatformSerialNumber'"
    )
    # command+=()
    volumes+=("/tmp/.X11-unix:/tmp/.X11-unix")
    compose "--publish=50922:10022" "$@"
    ;;

  android | termux)
    image=docker.io/termux/termux-docker:${tag:-x86_64}
    environment+=()
    # command+=()
    compose "$@"
    ;;

  *)
    echo >&2 "container: invalid image: $image"
    usage
    exit 1
    ;;
  esac
}

main() {
  if [ $# -eq 0 ]; then
    usage
    exit
  fi
  local image="$1"
  shift
  local name="${image%%:*}" tag="${image#*:}"
  if [ "$name" = bootstrap ]; then
    bootstrap "$@"
  else
    container "$@"
  fi
}

main "$@"

