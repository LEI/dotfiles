#!/usr/bin/env bash
#MISE alias="ct"
#MISE description="Run container pipeline for one image"
#MISE hide=true
#USAGE arg "[image]" help="Image name, :version suffix, or subcommand (default: status)" {
#USAGE   choices "alpine" "archlinux" "debian" "fedora" "opensuse" "termux" "ubuntu"
#USAGE }
#USAGE arg "[cmd]..." help="Command to run in the container (default: mise run pipeline)"

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo "${0##*/}: bash 4+ required, found $BASH_VERSION" >&2
  exit 1
fi

: "${CONTAINER_PROVIDER:?}"
readonly DEV_USER="${DEV_USER:-test}"
readonly tag_prefix="${PWD##*/}"
readonly images="alpine archlinux debian fedora opensuse termux ubuntu"

container() { "$CONTAINER_PROVIDER" "$@"; }

log() {
  echo "${0##*/}: $*" >&2
}

trace() {
  echo "+ $*" >&2
  "$@"
}

# Resolve image-specific variables from an image arg (name or name:version).
# Sets: image_name, version, image, image_tag, container, prefix,
#       home, exec_user, chezmoi_root
resolve() {
  local arg="$1"
  local version_arg repo arch

  image_name="${arg%%:*}"
  version_arg="${arg#*:}"
  [ "$version_arg" = "$arg" ] && version_arg=""

  repo="$image_name"
  version="${version_arg:-latest}"
  prefix=""

  # arm64 = macOS/Darwin, aarch64 = Linux; both indicate ARM64
  arch="$(uname -m)"

  case "$image_name" in
  archlinux)
    if [ "$arch" = arm64 ] || [ "$arch" = aarch64 ]; then
      repo="docker.io/ogarcia/archlinux"
    fi
    ;;
  opensuse)
    repo="opensuse/tumbleweed"
    ;;
  termux)
    repo="docker.io/termux/termux-docker"
    if [ -z "$version_arg" ]; then
      version="x86_64"
    fi
    if [ "$arch" = arm64 ] || [ "$arch" = aarch64 ]; then
      version="aarch64"
    fi
    prefix="/data/data/com.termux/files"
    ;;
  esac

  image="$repo:$version"
  image_tag="ct-$image_name-$version"
  container="$tag_prefix-$image_name-$version"
  home="$prefix/home/$DEV_USER"
  if [ "$image_name" = termux ]; then
    home="$prefix/home"
  fi
  exec_user="$DEV_USER"
  if [ "$image_name" = termux ]; then
    exec_user="system"
  fi
  chezmoi_root="$home/.local/share/chezmoi"
}

container_exec() {
  local flags log
  flags=(
    --env="CHEZMOI_UPGRADE=true"
    --env="MISE_TRUSTED_CONFIG_PATHS=$chezmoi_root"
    --user="$exec_user"
    --workdir="$chezmoi_root"
  )
  if [ -n "${CI:-}" ]; then
    flags+=(--env="CI=$CI")
  fi
  if [ -n "${GITHUB_TOKEN:-}" ]; then
    flags+=(--env="GITHUB_TOKEN=$GITHUB_TOKEN")
  fi
  if [ -t 0 ]; then
    flags+=(--interactive)
  fi
  if [ -t 1 ]; then
    flags+=(--tty)
  fi

  # Redact GITHUB_TOKEN in logs
  log=("${flags[@]/GITHUB_TOKEN=*/GITHUB_TOKEN=***}")
  echo "+ $CONTAINER_PROVIDER exec ${log[*]} $container $*" >&2
  container exec "${flags[@]}" "$container" "$@"
}

container_exec_mise() {
  local cmd

  # Quote all arguments for safe shell execution
  cmd="$(printf '%q ' "$@")"

  # bash -l skips environment.d in non-interactive shells; source it explicitly
  # eval mise activate: adds shims for mise-managed tools (check tasks use task env instead)
  # shellcheck disable=SC2016
  container_exec bash -c -l '
    source ~/.config/sh/lib/export.sh
    source ~/.config/sh/lib/pathmunge.sh
    export_env ~/.config/environment.d/*.conf
    source ~/.config/sh/environment.sh
    source ~/.config/mise/init.sh
    '"$cmd"
}

build() {
  if container image inspect "$image_tag" >/dev/null 2>&1; then
    log "build $image_name: reusing $image_tag"
    return 0
  fi
  trace container build . --file=Containerfile --build-arg="IMAGE=$image" --tag="$image_tag"
}

start() {
  local status

  if ! container container inspect "$container" >/dev/null 2>&1; then
    trace container create --name="$container" --env="DEV_USER=$DEV_USER" "$image_tag"
  fi

  status="$(container container inspect "$container" --format '{{.State.Status}}')"
  if [ "$status" != running ]; then
    trace container start "$container"
  fi

  # Entrypoint creates the dev user asynchronously; wait for it
  if [ "$image_name" != termux ]; then
    # shellcheck disable=SC2016
    trace container exec "$container" \
      sh -c 'until id -u "$1" >/dev/null 2>&1; do sleep 1; done' -- "$DEV_USER"
  fi
}

sync() {
  local item

  # shellcheck disable=SC2016
  trace container exec "$container" sh -c 'rm -rf "$1" && mkdir -p "$1"' -- "$chezmoi_root"

  for item in .chezmoiroot .chezmoiversion .editorconfig .gitignore .pre-commit-config.yaml mise.toml home script test; do
    trace container cp "$item" "$container:$chezmoi_root/"
  done

  trace container exec "$container" chown -R "$exec_user:$exec_user" "$home"

  # Pre-commit expects a git repo
  if ! container exec "$container" test -d "$chezmoi_root/.git"; then
    trace container exec "$container" git config --global --add safe.directory "$chezmoi_root"
    trace container exec "$container" git -C "$chezmoi_root" init --quiet
    trace container exec "$container" git -C "$chezmoi_root" add --all
  fi
}

bootstrap() {
  if [ "$image_name" = termux ]; then
    # shellcheck disable=SC2016
    trace container exec "$container" \
      sh -c 'ln -sf ${PREFIX}/etc/termux/mirrors/default ${PREFIX}/etc/termux/chosen_mirrors'
    trace container exec --user="$exec_user" "$container" \
      sh -c 'pkg update --quiet && pkg install --quiet --yes chezmoi proot'
    CI=true container_exec proot \
      -b "$prefix/usr/etc/resolv.conf:/etc/resolv.conf" \
      -b "$prefix/usr/etc/tls:/etc/ssl" \
      ./script/bootstrap --verbose --no-tty
  else
    CI=true container_exec ./script/bootstrap --verbose --no-tty
  fi
}

# Persists trust so later runs skip the prompt; no-op if mise not yet installed
trust() {
  # shellcheck disable=SC2016
  trace container exec --user="$exec_user" "$container" \
    sh -c 'mise=$(command -v mise 2>/dev/null || echo "$HOME/.local/bin/mise")
if [ -x "$mise" ]; then
  "$mise" trust --yes "$1"
fi' \
    -- "$chezmoi_root/mise.toml"
}

list() {
  echo "$images" | tr ' ' '\n'
}

status() {
  for name in $images; do
    resolve "$name"
    local s="none"
    if container container inspect "$container" >/dev/null 2>&1; then
      s="$(container container inspect "$container" \
        --format '{{.State.Status}}{{if and (eq .State.Status "exited") (ne .State.ExitCode 0)}} ({{.State.ExitCode}}){{end}}')"
    fi
    printf "%-12s  %-30s  %s\n" "$name" "$container" "$s"
  done
}

pipeline() {
  build
  start
  sync
  trust
  bootstrap
  # word-split intentional: CONTAINER_CMD may contain flags
  # shellcheck disable=SC2086
  container_exec_mise ${CONTAINER_CMD:-mise run pipeline}
  trace container stop "$container"
}

main() {
  case "${1:-}" in
  -h | --help)
    if command -v usage >/dev/null; then
      usage exec --help bash "$0"
    else
      echo "Usage: container [image] [cmd...]"
    fi
    return
    ;;
  --usage)
    grep '^#USAGE' "$0" | sed 's/^#USAGE //'
    return
    ;;
  --)
    shift
    ;;
  esac

  local image="${1:-}"
  case "$image" in
  '' | s | st | status)
    status
    return
    ;;
  l | ls | list)
    list
    return
    ;;
  esac
  resolve "$image"
  shift
  if [ $# -gt 0 ]; then
    container_exec_mise "$@"
  else
    pipeline
  fi
}

# Allow sourcing for testing (e.g. bats)
if [ -z "${BATS_TEST_FILENAME:-}" ] && [ "${BASH_SOURCE[0]}" = "$0" ]; then
  main "$@"
fi
