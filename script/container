#!/usr/bin/env bash
#MISE description="Build and test chezmoi in a container"
#USAGE arg "<name>" help="Distro name(s), comma-separated, or 'all'"
#USAGE arg "[subcommand]" help="build|sync|bootstrap|check|update|test|shell|run" default="run"

# https://www.chezmoi.io/reference/commands/docker/

set -euo pipefail

PROVIDER="${PROVIDER:-podman}"
tag_prefix=chezmoi

usage() {
  cat >&2 <<'EOF'
Usage: container <name>[,<name>...] [subcommand] [args...]
       container all [subcommand]

Subcommands:
  build      Build the image and create/start the container
  sync       Wipe and re-copy source files into the container
  bootstrap  Run chezmoi bootstrap inside the container
  check      Run script/check inside the container
  update     Run script/update inside the container
  test       Run script/test inside the container
  shell      Open an interactive shell (default: chezmoi package diff)
  run        Full pipeline: build, sync, bootstrap, check, update, test (default)
EOF
  exit 1
}

container_status() {
  $PROVIDER container inspect --format '{{.State.Status}}' "$1" 2>/dev/null || echo missing
}

# Sets: image_name, image_version, image_name_arg, image_version_arg, user, home, prefix, chezmoi_root, container
resolve() {
  local spec="$1"
  image_name="${spec%:*}"
  image_version="${spec#*:}"
  [ "$image_version" = "$spec" ] && image_version=latest

  image_name_arg="$image_name"
  image_version_arg="$image_version"
  prefix=""

  case "$image_name" in
  archlinux)
    [ "$(uname -m)" = arm64 ] && image_name_arg=docker.io/ogarcia/archlinux
    ;;
  macos)
    image_name_arg=docker.io/sickcodes/docker-osx
    ;;
  termux)
    image_name_arg=docker.io/termux/termux-docker
    image_version_arg=x86_64
    [ "$(uname -m)" = arm64 ] && image_version_arg=aarch64
    prefix=/data/data/com.termux/files
    ;;
  esac

  user=test
  home="/home/$user"
  [ "$image_name" = macos ] && home="/Users/$user"
  if [ "$image_name" = termux ]; then
    home="$prefix/home"
    user=root
  fi
  chezmoi_root="$home/.local/share/chezmoi"
  container="$tag_prefix-$image_name-$image_version"
}

exec_as() {
  $PROVIDER exec --user="$user" --workdir="$chezmoi_root" \
    --env=PATH="$home/.local/bin:/usr/local/bin:/usr/bin:/bin" \
    "$container" "$@"
}

exec_tty() {
  $PROVIDER exec --tty --interactive --user="$user" --workdir="$chezmoi_root" \
    --env=PATH="$home/.local/bin:/usr/local/bin:/usr/bin:/bin" \
    "$container" "$@"
}

cmd_build() {
  resolve "$1"

  $PROVIDER build . \
    --file=Containerfile \
    --build-arg=IMAGE_NAME="$image_name_arg" \
    --build-arg=IMAGE_VERSION="$image_version_arg" \
    --tag="$container"

  $PROVIDER container inspect "$container" >/dev/null 2>&1 ||
    $PROVIDER create --name="$container" "$container"

  [ "$(container_status "$container")" = running ] ||
    $PROVIDER start "$container"

  if [ "$image_name" = macos ]; then
    $PROVIDER run -it --name="$container" \
      -device /dev/kvm \
      -p 50922:10022 \
      -p 22222:22 \
      -p 5999:5999 \
      -v /tmp/.X11-unix:/tmp/.X11-unix \
      -e "DISPLAY=:1" \
      -e AUDIO_DRIVER=pa,server=unix:/tmp/pulseaudio.socket \
      -v "/run/user/$(id -u)/pulse/native:/tmp/pulseaudio.socket" \
      -e MASTER_PLIST_URL="https://raw.githubusercontent.com/sickcodes/osx-serial-generator/master/config-custom.plist" \
      -e EXTRA="-vnc 0.0.0.0:99,password=off" \
      -e SHORTNAME=tahoe \
      "$container"
    return
  fi

  status="$(container_status "$container")"
  if [ "$status" != running ]; then
    echo >&2 "container $container is not running (status: $status)"
    exit 1
  fi

  if [ "$image_name" != termux ]; then
    $PROVIDER exec "$container" sh -euxc "
      until id -u $user >/dev/null 2>&1; do
        echo 'Waiting for $user user...'
        sleep 1
      done
    "
  fi
}

cmd_sync() {
  resolve "$1"

  $PROVIDER exec "$container" mkdir -p "$chezmoi_root"

  for f in .chezmoiroot .chezmoiversion mise.toml home script test; do
    $PROVIDER container cp "$f" "$container:$chezmoi_root/"
  done
  for d in test_helper test_support; do
    [ -d "$d" ] && $PROVIDER container cp "$d" "$container:$chezmoi_root/"
  done

  $PROVIDER exec "$container" chown -R "$user:$user" "$home"
}

cmd_bootstrap() {
  resolve "$1"

  if [ "$image_name" = termux ]; then
    $PROVIDER exec "$container" \
      sh -euxc 'ln -sf ${PREFIX}/etc/termux/mirrors/default ${PREFIX}/etc/termux/chosen_mirrors'
    $PROVIDER exec --user=system "$container" \
      sh -euxc 'pkg update --quiet && pkg install --quiet --yes chezmoi proot'
    $PROVIDER exec \
      --env=CHEZMOI_UPGRADE=true \
      --env=CI=true \
      --user="$user" \
      --workdir="$chezmoi_root" \
      "$container" \
      proot \
      -b "$prefix/usr/etc/resolv.conf:/etc/resolv.conf" \
      -b "$prefix/usr/etc/tls:/etc/ssl" \
      ./script/bootstrap --verbose
  else
    $PROVIDER exec \
      --env=CHEZMOI_UPGRADE=true \
      --env=CI=true \
      --user="$user" \
      --workdir="$chezmoi_root" \
      "$container" ./script/bootstrap --verbose
  fi
}

cmd_check() {
  resolve "$1"
  exec_as ./script/check
}

cmd_update() {
  resolve "$1"
  exec_as ./script/update
}

cmd_test() {
  resolve "$1"
  shift
  $PROVIDER exec --tty --user="$user" --workdir="$chezmoi_root" "$container" ./script/test "$@"
}

cmd_shell() {
  resolve "$1"
  shift
  local cmd
  if [ "$image_name" = termux ]; then
    cmd=(bash --version)
  else
    cmd=(bash -ic "chezmoi package diff all 2>/dev/null || true")
  fi
  [ $# -gt 0 ] && cmd=("$@")
  $PROVIDER exec --interactive --tty --user="$user" --workdir="$chezmoi_root" "$container" "${cmd[@]}"
}

cmd_exec() {
  $PROVIDER exec --tty --user="$user" --workdir="$chezmoi_root" \
    --env=PATH="$home/.local/bin:/usr/local/bin:/usr/bin:/bin" \
    "$container" "$@"
}

cmd_pipeline() {
  resolve "$1"
  cmd_exec mise trust --yes
  cmd_exec mise run pipeline
}

cmd_run() {
  cmd_build "$1"
  cmd_sync "$1"
  cmd_bootstrap "$1"
  cmd_pipeline "$1"
}

run_one() {
  local name="$1"
  shift
  case "$SUBCMD" in
  build) cmd_build "$name" ;;
  sync) cmd_sync "$name" ;;
  bootstrap) cmd_bootstrap "$name" ;;
  check) cmd_check "$name" ;;
  update) cmd_update "$name" ;;
  test) cmd_test "$name" "$@" ;;
  shell) cmd_shell "$name" "$@" ;;
  pipeline) cmd_pipeline "$name" ;;
  run) cmd_run "$name" ;;
  *)
    echo >&2 "Unknown subcommand: $SUBCMD"
    usage
    ;;
  esac
}

SUBCMD=run

main() {
  [ $# -eq 0 ] && usage

  local NAME="$1"
  shift
  SUBCMD="${1:-run}"
  if [ $# -gt 0 ]; then
    shift
  fi

  if [ "$NAME" = all ]; then
    NAME=alpine,archlinux,debian,ubuntu,fedora
    [ "$PROVIDER" != docker ] && NAME=$NAME,termux
  fi

  local extra=("$@")
  local failed=()

  for name in ${NAME//,/ }; do
    local rc=0
    time run_one "$name" "${extra[@]}" || rc=$?
    [ $rc -ne 0 ] && failed+=("$name")
  done

  if [ ${#failed[@]} -gt 0 ]; then
    echo >&2 "FAILED: ${failed[*]}"
    exit 1
  fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
