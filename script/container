#!/usr/bin/env bash
#MISE alias="ct"
#MISE description="Run container pipeline by image"
#USAGE flag "-h --help" help="Show help"
#USAGE flag "-u --usage" help="Show usage specification"
#USAGE arg "[image]" help="Image name, :version suffix, or subcommand (default: status)"
#USAGE complete "image" run="./script/container --list-images"
#USAGE arg "[cmd]..." help="Command to run in the container (default: mise run pipeline)"

set -Eeuo pipefail

lib_dir="${BASH_SOURCE[0]%/*}/../home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
source "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/usage.sh
source "$lib_dir/sh/usage.sh"
# shellcheck source=home/dot_local/lib/bash/require.sh
source "$lib_dir/bash/require.sh"

trap 'err "line $LINENO: $BASH_COMMAND (${FUNCNAME[*]:-main})"' ERR

readonly DEV_USER="${DEV_USER:-test}"
readonly CONTAINER_SOURCE="${CONTAINER_SOURCE:-mount}"
readonly CHEZMOI_PROFILE="${CHEZMOI_PROFILE:-minimal}"
export CHEZMOI_PROFILE
readonly tag_prefix="${PWD##*/}"
readonly images="alpine archlinux debian fedora opensuse termux ubuntu"

ct() { trace "$CONTAINER_PROVIDER" "$@"; }

# Init image-specific config from "<name>" or "<name>:<version>"
# Globals modified: chezmoi_root, container, exec_user, file_owner, home, image, image_name, image_tag, prefix, version
resolve() {
  local arg="$1"
  local version_arg repo arch

  image_name="${arg%%:*}"
  version_arg="${arg#*:}"
  [ "$version_arg" = "$arg" ] && version_arg=""

  repo="$image_name"
  version="${version_arg:-latest}"
  prefix=""
  exec_user="$DEV_USER"
  file_owner="$DEV_USER"
  local home_subdir="home/$DEV_USER"
  arch="$(uname -m)"

  case "$image_name" in
  archlinux)
    if [ "$arch" = arm64 ] || [ "$arch" = aarch64 ]; then
      repo="docker.io/ogarcia/archlinux"
    fi
    ;;
  opensuse)
    repo="opensuse/tumbleweed"
    ;;
  termux)
    repo="docker.io/termux/termux-docker"
    if [ -z "$version_arg" ]; then
      version="x86_64"
    fi
    if [ "$arch" = arm64 ] || [ "$arch" = aarch64 ]; then
      version="aarch64"
    fi
    prefix="/data/data/com.termux/files"
    exec_user=""
    file_owner="system"
    home_subdir="home"
    ;;
  esac

  image="$repo:$version"
  image_tag="ct-$image_name-$version"
  container="$tag_prefix-$image_name-$version"
  home="$prefix/$home_subdir"
  chezmoi_root="$home/.local/share/chezmoi"
  if [ "$CONTAINER_SOURCE" = mount ]; then
    chezmoi_root="/src"
  fi
}

ct_exec() {
  local flags
  flags=(
    --env="CHEZMOI_UPGRADE=true"
    --env="HOME=$home"
    --env="MISE_TRUSTED_CONFIG_PATHS=$chezmoi_root"
    --workdir="$chezmoi_root"
  )
  [ -n "$exec_user" ] && flags+=(--user="$exec_user")
  [ -n "${CI:-}" ] && flags+=(--env=CI)
  [ -n "${CHEZMOI_PROFILE:-}" ] && flags+=(--env=CHEZMOI_PROFILE)
  [ -n "${GITHUB_TOKEN:-}" ] && flags+=(--env=GITHUB_TOKEN)
  if [ "$image_name" = termux ]; then
    # Android system user (UID 1000); numeric avoids /etc/passwd lookup in non-standard container root
    flags+=(--user=1000 --env=PATH="$home/.local/bin:$prefix/usr/bin:/usr/bin:/bin")
    flags+=(--env=SHELL="$prefix/usr/bin/bash")
  fi
  [ -t 0 ] && flags+=(--interactive)
  [ -t 1 ] && flags+=(--tty)
  ct exec "${flags[@]}" "$container" "$@"
}

ct_exec_mise() {
  # init.sh only activates an already-installed mise, so put its bindir on
  # PATH first; pathmunge is idempotent so it won't duplicate the entry
  # shellcheck disable=SC2016  # inner shell expands $HOME and $@, not this one
  local prog='
. ~/.local/lib/bash/pathmunge.sh
pathmunge "$HOME/.local/bin"
[ -f ~/.config/mise/init.sh ] && . ~/.config/mise/init.sh
exec "$@"
'
  ct_exec bash -lc "$prog" -- "$@"
}

build() {
  if ct image inspect "$image_tag" >/dev/null 2>&1; then
    info "build $image_name: reusing $image_tag"
    return 0
  fi
  ct build . --file=Containerfile --build-arg="IMAGE=$image" --tag="$image_tag"
}

# Quietly check whether the running container's bind config matches create_flags.
# podman reports .Mode empty for bind mounts and encodes read-only via .RW=false;
# .RW is present under Docker too, so compare it rather than the mode string
mount_config_matches() {
  [ "$CONTAINER_SOURCE" = mount ] || return 0
  local src dst rw
  {
    read -r src
    read -r dst
    read -r rw
  } < <(
    "$CONTAINER_PROVIDER" container inspect "$container" \
      --format $'{{range .Mounts}}{{if eq .Type "bind"}}{{.Source}}\n{{.Destination}}\n{{.RW}}\n{{end}}{{end}}' \
      2>/dev/null
  )
  [ "$src" = "$PWD" ] && [ "$dst" = "$chezmoi_root" ] && [ "$rw" = false ]
}

start() {
  local status
  local create_flags=(--name="$container" --env="DEV_USER=$DEV_USER")
  local create_cmd=()
  if [ "$CONTAINER_SOURCE" = mount ]; then
    if [ ! -f "$PWD/.chezmoiroot" ]; then
      err "mount mode: $PWD lacks .chezmoiroot"
      return 1
    fi
    create_flags+=(--volume="$PWD:$chezmoi_root:ro")
    # Trust the host-owned mount for every git binary and user without writing a
    # config file: a --global write lands in the chezmoi-managed ~/.config/git/config
    # and drifts on every apply. GIT_CONFIG_* is inherited by all exec sessions.
    create_flags+=(
      --env=GIT_CONFIG_COUNT=1
      --env=GIT_CONFIG_KEY_0=safe.directory
      --env=GIT_CONFIG_VALUE_0="$chezmoi_root"
    )
  fi
  # Termux lacks /bin/sh for the wrapper shebang
  if [ "$image_name" = termux ]; then
    create_flags+=(--entrypoint=/entrypoint.sh)
    create_cmd=(tail -f /dev/null)
  fi

  if ct container inspect "$container" >/dev/null 2>&1 &&
    ! mount_config_matches; then
    info "recreating $container: mount config out of date"
    ct rm --force "$container" >/dev/null
  fi

  if ! ct container inspect "$container" >/dev/null 2>&1; then
    ct create "${create_flags[@]}" "$image_tag" ${create_cmd[@]+"${create_cmd[@]}"}
  fi

  status="$(ct container inspect "$container" --format '{{.State.Status}}')"
  if [ "$status" != running ]; then
    ct start "$container"
    status="$(ct container inspect "$container" --format '{{.State.Status}}')"
    if [ "$status" != running ]; then
      info "recreating $container: crashed on start"
      ct rm --force "$container" >/dev/null
      ct create "${create_flags[@]}" "$image_tag" ${create_cmd[@]+"${create_cmd[@]}"}
      ct start "$container"
    fi
  fi

  # Wait for the dev user that the entrypoint creates asynchronously
  if [ "$image_name" != termux ]; then
    # shellcheck disable=SC2016
    ct exec "$container" \
      sh -c 'until id -u "$1" >/dev/null 2>&1; do sleep 1; done' -- "$DEV_USER"
  fi

}

sync_source() {
  if [ "$CONTAINER_SOURCE" = mount ]; then
    warn "host mount: $PWD -> $chezmoi_root (ro)"
    return
  fi
  # Stale files persist until the container is recreated
  local item
  ct exec "$container" mkdir -p "$chezmoi_root"
  for item in .chezmoiroot .chezmoiversion .editorconfig .gitignore .pre-commit-config.yaml mise.toml home script test; do
    ct cp "$item" "$container:$chezmoi_root/"
  done
  ct exec "$container" chown -R "$file_owner:$file_owner" "$home"
}

bootstrap() {
  local cmd=(./script/bootstrap --source="$chezmoi_root" --no-tty --verbose)
  if [ "$image_name" = termux ]; then
    # Resolve standard shebang paths and network configs to termux equivalents
    # shellcheck disable=SC2016
    ct exec --env="p=$prefix" "$container" sh -c '
      mkdir -p /bin /usr/bin
      safe_ln() {
        # Skip if target is a symlink pointing back to link (loop)
        case $(readlink "$1" 2>/dev/null) in "$2") return 0 ;; esac
        # Skip if both already resolve to the same file
        t=$(readlink -f "$1" 2>/dev/null)
        l=$(readlink -f "$2" 2>/dev/null)
        [ -n "$t" ] && [ "$t" = "$l" ] && return 0
        ln -sf "$1" "$2"
      }
      safe_ln "$p/usr/bin/sh" /bin/sh
      safe_ln "$p/usr/bin/env" /usr/bin/env
      safe_ln "$p/usr/bin/bash" /usr/bin/bash
      # resolv.conf: Docker always bind-mounts this; skip if it is a regular file
      [ -f /etc/resolv.conf ] && ! [ -L /etc/resolv.conf ] || ln -sf "$p/usr/etc/resolv.conf" /etc/resolv.conf
      # ssl: only create if absent
      [ -e /etc/ssl ] || ln -sf "$p/usr/etc/tls" /etc/ssl
      # EU group reaches grimler.se when packages-cf.termux.dev is unreachable
      ln -sf "$p/usr/etc/termux/mirrors/eu" "$p/usr/etc/termux/chosen_mirrors"
      # ln -sf "$p/usr/etc/termux/mirrors/default" "$p/usr/etc/termux/chosen_mirrors"
      # /etc/passwd and /etc/group are absolute symlinks to /system/etc;
      # crun resolves absolute symlinks from the host root (RESOLVE_BENEATH), so they
      # escape the container storage root and exec with --user fails; copy real files
      for f in passwd group; do
        if [ -L "/etc/$f" ]; then
          rm -f "/etc/$f"
          cp "/system/etc/$f" "/etc/$f"
        fi
      done
    '
    if ! ct_exec pkg update; then
      warn "termux: EU mirrors failed, falling back to bundled default"
      # shellcheck disable=SC2016
      ct exec --env="p=$prefix" "$container" sh -c '
        ln -sf "$p/usr/etc/termux/mirrors/default" "$p/usr/etc/termux/chosen_mirrors"
      '
      ct_exec pkg update
    fi
    ct_exec pkg install --yes chezmoi git
  fi
  ct_exec "${cmd[@]}"
}

init_repo() {
  if [ "$image_name" != termux ]; then
    return 0
  fi
  if ct exec "$container" test -d "$chezmoi_root/.git"; then
    return 0
  fi
  # shellcheck disable=SC2016
  ct exec ${exec_user:+--user="$exec_user"} "$container" \
    sh -c '
      git -C "$1" init --quiet
      git -C "$1" add --all
    ' -- "$chezmoi_root"
}

list() {
  echo "$images" | tr ' ' '\n'
}

status() {
  for name in $images; do
    resolve "$name"
    local s="none"
    if ct container inspect "$container" >/dev/null 2>&1; then
      s="$(ct container inspect "$container" \
        --format '{{.State.Status}}{{if and (eq .State.Status "exited") (ne .State.ExitCode 0)}} ({{.State.ExitCode}}){{end}}')"
    fi
    printf "%-12s  %-30s  %s\n" "$name" "$container" "$s"
  done
}

pipeline() {
  build
  start
  sync_source
  bootstrap
  init_repo
  # shellcheck disable=SC2086
  ct_exec_mise ${CONTAINER_CMD:-mise run pipeline}
  ct stop "$container" >/dev/null
}

main() {
  case "${1:-}" in
  -h | --help)
    usage_help
    return
    ;;
  --usage)
    usage_spec
    return
    ;;
  --list-images)
    list
    return
    ;;
  --)
    shift
    ;;
  esac

  require_bash 4

  : "${CONTAINER_PROVIDER:?}"

  local image="${1:-}"
  case "$image" in
  '' | l | ls | list | s | st | status)
    status
    return
    ;;
  esac
  resolve "$image"
  shift
  if [ $# -gt 0 ]; then
    ct_exec_mise "$@"
  else
    pipeline
  fi
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  main "$@"
fi
