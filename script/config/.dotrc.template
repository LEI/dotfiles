#!/usr/bin/env bash

# .dotrc

[user]
name = DOT_USER_NAME
email = DOT_USER_EMAIL
nick = DOT_USER_NICK

[config]
debug = true
dry_run = false
timestamps = false

[files] # Dotfiles
# If the source contains a wildcard, the destination must be a directory
# where all matching files will be symlinked.
#
# Patterns:
#   src:(~/)dst
#   src:(~/src)
#   src(:~/.)
bin/*:bin
config/*
git/*
shell/*
vim/bundle:vim/bundle
vim/vimrc:.vimrc

# [ignore]
# *.template
# *.sh
# [brew]
# [cask]
