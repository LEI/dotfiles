#!/usr/bin/env bash
#MISE description="mise coverage"

set -Eeuo pipefail

COVERAGE_OUTPUT="${COVERAGE_OUTPUT:-./coverage}"

coverage() {
  local dir="$TEST_TMPDIR/.chezmoiscripts,home/dot_config/sh/lib,home/dot_local/bin,script"

  local kcov_args=(
    --clean
    --bash-dont-parse-binary-dir
    --bash-parser="$(which bash)"
    --bash-parse-files-in-dir="$dir"
    --include-path="$dir"
    --exclude-pattern=coverage
    --path-strip-level=1
    --strip-path="$PWD"
  )

  if [ "$(uname -s)" = Linux ]; then
    kcov_args+=(--bash-handle-sh-invocation)
  fi

  kcov "${kcov_args[@]}" "$COVERAGE_OUTPUT" ./script/test "$@"
}

main() {
  export TEST_JOBS=1

  TEST_TMPDIR="$PWD/tmp"
  mkdir -p "$TEST_TMPDIR"
  export TEST_TMPDIR
  trap 'rm -rf "$TEST_TMPDIR"' ERR EXIT

  rm -rf ./coverage

  mkdir -p "$TEST_TMPDIR/.chezmoiscripts"
  mkdir -p "$TEST_TMPDIR/.local/bin"

  coverage "$@"
}

main "$@"
