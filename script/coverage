#!/usr/bin/env bash
#MISE alias="cov"
#MISE description="Run tests with kcov coverage"
#USAGE arg "[filter]..." help="Extra arguments passed to bats via script/test"
#USAGE complete "filter" run="git ls-files 'test/*.bats'"

set -Eeuo pipefail

COVERAGE_OUTPUT="${COVERAGE_OUTPUT:-./coverage}"

coverage() {
  local dir="$TEST_TMPDIR/.chezmoiscripts,home/dot_config/sh/lib,home/dot_local/bin,script"

  local kcov_args=(
    --clean
    --bash-dont-parse-binary-dir
    --bash-parser="$(which bash)"
    --bash-parse-files-in-dir="$dir"
    --include-path="$dir"
    --exclude-pattern=coverage
    --path-strip-level=1
    --strip-path="$PWD"
    --dump-summary
  )

  # FIXME: --bash-handle-sh-invocation loads libbash_execve_redirector.so
  # via LD_PRELOAD, which pollutes stderr with errors when child processes
  # change cwd (relative .so path breaks). Not needed since run_src sources
  # scripts in-process for coverage tracking.
  # if [ "$(uname -s)" = Linux ]; then
  #   kcov_args+=(--bash-handle-sh-invocation)
  # fi

  kcov "${kcov_args[@]}" "$COVERAGE_OUTPUT" ./script/test "$@"
}

main() {
  case "${1:-}" in
  -h | --help)
    if command -v usage >/dev/null; then
      usage exec --help bash "$0"
    else
      echo "Usage: coverage [filter...]"
    fi
    return
    ;;
  --usage)
    grep '^#USAGE' "$0" | sed 's/^#USAGE //'
    return
    ;;
  --)
    shift
    ;;
  esac

  export TEST_JOBS=1

  TEST_TMPDIR="$PWD/tmp"
  mkdir -p "$TEST_TMPDIR"
  # FIXME: merged coverage common path
  # TEST_TMPDIR="$(mktemp -d)"
  export TEST_TMPDIR
  trap 'rm -rf "$TEST_TMPDIR"' ERR EXIT

  rm -rf ./coverage

  mkdir -p "$TEST_TMPDIR/.chezmoiscripts"
  mkdir -p "$TEST_TMPDIR/.local/bin"

  # # Pre-render templates so run_chezmoi can skip chezmoi cat under kcov
  # chezmoi-render "$TEST_TMPDIR" --quiet

  coverage "$@"
}

main "$@"
