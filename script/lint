#!/usr/bin/env bash
#MISE alias="l"
#MISE description="Render and lint chezmoi templates"

set -euo pipefail

repo_dir="$PWD"
render_dir=$(mktemp -d)
prek_args=()

# shellcheck disable=SC2329
cleanup() { rm -rf "$render_dir"; }
trap cleanup EXIT

# Separate our flags from template paths
templates=()
for arg in "$@"; do
  case "$arg" in
  --quiet)
    prek_args+=(--quiet)
    ;;
  *) templates+=("$arg") ;;
  esac
done

{
  printf 'root = true\n\n'
  cat "$repo_dir/.editorconfig"
  printf '\n[*]\nindent_style = space\nindent_size = 2\ninsert_final_newline = false\n'
} >"$render_dir/.editorconfig"
printf 'disable=SC1090,SC2034,SC2248\n' >"$render_dir/.shellcheckrc"

chezmoi-render "$render_dir" --quiet "${templates[@]}" >&2

# Remove empty files (templates that render to nothing on this OS)
find "$render_dir" -type f -empty -delete

if [ -z "$(find "$render_dir" -type f -print -quit)" ]; then
  echo "lint: no rendered files" >&2
  exit 0
fi

# Isolate from parent git environment set during hooks
unset GIT_INDEX_FILE # GIT_DIR

# Isolated git repo outside the main repo so prek can discover files
git -C "$render_dir" init --quiet
git -C "$render_dir" add --all

# prek resolves hook entries and config paths relative to --cd
cp -a "$repo_dir/script" "$render_dir/script"
ln -s "$repo_dir/home" "$render_dir/home"

prek run \
  "${prek_args[@]}" \
  --cd="$render_dir" \
  --config="$repo_dir/.pre-commit-config.yaml" \
  --skip=gitleaks \
  --skip=lint-templates \
  --skip=zizmor \
  --all-files &&
  exit_code=0 || exit_code=$?

if [ "$exit_code" -ne 0 ]; then
  echo "lint: failed with exit code $exit_code" >&2
fi
exit "$exit_code"
