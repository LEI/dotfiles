#!/usr/bin/env bash
#MISE alias="l"
#MISE description="Render chezmoi templates and run all linters"

set -euo pipefail

prek_dir="$PWD/output/prek"
mkdir -p "$prek_dir"
rm -rf "$prek_dir"/tmp.*

render_dir="$(mktemp -d -p "$prek_dir")"
# trap 'rm -rf "$render_dir"' EXIT

# Pass args through to chezmoi-render
# Use -q/--quiet to suppress output
chezmoi-render "$render_dir" "$@" >&2

mapfile -t files < <(find "$render_dir" -type f | sed "s|$render_dir/||")

cat >"$render_dir/.shellcheckrc" <<'EOF'
disable=SC1090,SC2034,SC2154,SC2248
EOF

if [ ${#files[@]} -eq 0 ]; then
  echo >&2 "lint: no files to lint"
  exit 1
fi

flags=()
for arg in "$@"; do
  case "$arg" in
  -*)
    flags+=("$arg")
    shift
    ;;
  *) ;;
  esac
done
args=(
  --cd="${render_dir#"$PWD"/}"
  # TODO: relative "${PWD/$HOME/\~}/.pre-commit-config.yaml"
  --config="$PWD/.pre-commit-config.yaml"
  --skip=check-added-large-files
  --skip=lint-templates
  --skip=zizmor
  "${flags[@]}"
)
set -- "${args[@]}" --files "${files[@]}"
# echo >&2 "lint debug: prek run ${args[*]}"
prek run "$@" && exit_code=0 || exit_code=$?
if [ "$exit_code" -ne 0 ]; then
  echo >&2 "lint failed: exit code $exit_code"
fi
exit "$exit_code"
