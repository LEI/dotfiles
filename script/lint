#!/usr/bin/env bash
#MISE alias="l"
#MISE description="Render and lint chezmoi templates"
#USAGE flag "-k --keep" help="Keep render dir for debugging"
#USAGE flag "-q --quiet" help="Suppress output"
#USAGE flag "-v --verbose" help="Show render dir and file list"
#USAGE arg "[templates]..." help="Template paths to render (default: all)"
#USAGE complete "templates" run="chezmoi managed --path-style=relative"
# FIXME: carapace timeout

set -euo pipefail

repo_dir="$PWD"
render_dir=$(mktemp -d)
render_args=()
prek_args=()
keep="${LINT_KEEP:-false}"
quiet="${LINT_QUIET:-false}"
verbose="${LINT_VERBOSE:-false}"

while [ $# -gt 0 ]; do
  case "$1" in
  -k | --keep)
    keep=true
    shift
    ;;
  -q | --quiet)
    quiet=true
    render_args+=(--quiet)
    prek_args+=(--quiet)
    shift
    ;;
  -v | --verbose)
    verbose=true
    render_args+=(--verbose)
    prek_args+=(--verbose)
    shift
    ;;
  -h | --help)
    if command -v usage >/dev/null; then
      usage exec --help bash "$0"
    else
      echo "Usage: lint [-k] [-q] [-v] [templates...]"
    fi
    exit
    ;;
  --usage)
    grep '^#USAGE' "$0" | sed 's/^#USAGE //'
    exit
    ;;
  --)
    shift
    break
    ;;
  *) break ;;
  esac
done
templates=("$@")

# shellcheck disable=SC2329
cleanup() {
  if [ "$keep" = true ]; then
    echo "lint: render dir kept: $render_dir" >&2
  else
    if [ "$verbose" = true ]; then
      echo "lint: cleanup $render_dir" >&2
    fi
    rm -rf "$render_dir"
  fi
}
trap cleanup EXIT

cp "$repo_dir/.editorconfig" "$render_dir/.editorconfig"
printf 'disable=SC1090,SC1091,SC2034,SC2317\n' >"$render_dir/.shellcheckrc"

chezmoi-render "$render_dir" "${render_args[@]}" "${templates[@]}" >&2

# Remove empty files (templates that render to nothing on this OS)
find "$render_dir" -type f -empty -delete

if [ -z "$(find "$render_dir" -type f -print -quit)" ]; then
  echo "lint: no rendered files" >&2
  exit 0
fi

# Isolate from parent git environment set during hooks
unset GIT_INDEX_FILE # GIT_DIR

# Isolated git repo outside the main repo so prek can discover files
git -C "$render_dir" init --quiet
git -C "$render_dir" add --all

# prek resolves hook entries and config paths relative to --cd
cp -a "$repo_dir/script" "$render_dir/script"
ln -s "$repo_dir/home" "$render_dir/home"

export VALIDATE_KEEP="$keep"
export VALIDATE_QUIET="$quiet"
export VALIDATE_VERBOSE="$verbose"

exit_code=0
prek run \
  "${prek_args[@]}" \
  --cd="$render_dir" \
  --config="$repo_dir/.pre-commit-config.yaml" \
  --skip=gitleaks \
  --skip=lint-templates \
  --skip=zizmor \
  --all-files || exit_code=$?

if [ "$exit_code" -ne 0 ] && [ "$quiet" = false ]; then
  echo "lint: failed with exit code $exit_code" >&2
fi
exit "$exit_code"
