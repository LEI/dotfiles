#!/usr/bin/env bash
#MISE alias="l"
#MISE description="Render and lint chezmoi templates"

set -euo pipefail

repo_dir="$PWD"
render_dir=$(mktemp -d)
prek_args=()

# shellcheck disable=SC2329
cleanup() { rm -rf "$render_dir"; }
trap cleanup EXIT

# Separate our flags from template paths
templates=()
for arg in "$@"; do
  case "$arg" in
  --quiet)
    prek_args+=(--quiet)
    ;;
  *) templates+=("$arg") ;;
  esac
done

printf 'disable=SC1090,SC2034,SC2154,SC2248\n' >"$render_dir/.shellcheckrc"

chezmoi-render "$render_dir" --quiet "${templates[@]}" >&2

if [ -z "$(find "$render_dir" -type f -print -quit)" ]; then
  echo >&2 "lint: no rendered files"
  exit 0
fi

# Isolated git repo outside the main repo so prek can discover files
git -C "$render_dir" init --quiet
git -C "$render_dir" add --all

# prek resolves hook entries and config paths relative to --cd
cp -a "$repo_dir/script" "$render_dir/script"
ln -s "$repo_dir/home" "$render_dir/home"

# prek splits --files on spaces; remove affected files with a warning
while IFS= read -r f; do
  echo >&2 "lint: skip (space in path): $f"
  git -C "$render_dir" rm --quiet --cached "$f"
done < <(git -C "$render_dir" ls-files | grep ' ')

prek run \
  "${prek_args[@]}" \
  --cd="$render_dir" \
  --config="$repo_dir/.pre-commit-config.yaml" \
  --skip=check-added-large-files \
  --skip=lint-templates \
  --skip=zizmor \
  --all-files &&
  exit_code=0 || exit_code=$?

if [ "$exit_code" -ne 0 ]; then
  echo >&2 "lint: failed with exit code $exit_code"
fi
exit "$exit_code"
