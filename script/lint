#!/usr/bin/env bash
#MISE alias="l"
#MISE depends="render"
#MISE description="Run prek on chezmoi templates"

set -euo pipefail

render_dir="$PWD/output/prek"

if [ ! -d "$render_dir" ]; then
  printf >&2 'lint: %s not found, run render first\n' "$render_dir"
  exit 1
fi

mapfile -t files < <(fd --type f . "$render_dir" | sed "s|$render_dir/||")

if [ ${#files[@]} -eq 0 ]; then
  printf >&2 'lint: no files to lint\n'
  exit 1
fi

prek run \
  --cd="${render_dir#"$PWD"/}" \
  --config="$PWD/.pre-commit-config.yaml" \
  --skip=check-added-large-files \
  --skip=lint-templates \
  --skip=zizmor \
  --files "${files[@]}" &&
  exit_code=0 || exit_code=$?

if [ "$exit_code" -ne 0 ]; then
  printf >&2 'lint: failed with exit code %s\n' "$exit_code"
fi
exit "$exit_code"
