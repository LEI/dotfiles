#!/bin/sh
#MISE description="Install chezmoi and apply dotfiles"
#MISE hide=true

# https://github.com/twpayne/dotfiles/blob/master/install.sh
# https://docs.github.com/en/codespaces/setting-your-user-preferences/personalizing-github-codespaces-for-your-account#dotfiles

set -eu

PATH="$PATH:$HOME/.local/bin"

if ! chezmoi="$(command -v chezmoi)" || [ ! -s "$chezmoi" ]; then
  chezmoi="$HOME/.local/bin/chezmoi"
  if command -v curl >/dev/null; then
    installer="$(curl -fsLS https://get.chezmoi.io)"
  elif command -v wget >/dev/null; then
    installer="$(wget -qO- https://get.chezmoi.io)"
  else
    echo "To install chezmoi, you must have curl or wget installed." >&2
    exit 1
  fi
  if [ -z "$installer" ]; then
    echo "Failed to download chezmoi installer from get.chezmoi.io" >&2
    exit 1
  fi
  sh -c "$installer" -- -b "$HOME/.local/bin"
fi

if [ "${CI:-${CODESPACES:-}}" = "true" ]; then
  # POSIX way to get script's dir: https://stackoverflow.com/a/29834779/12156188
  script_dir="$(cd -P -- "$(dirname -- "$(command -v -- "$0")")" && pwd -P)"
  if [ ! -d "$script_dir" ]; then
    echo "Missing source directory: $script_dir" >&2
    exit 1
  fi
  # set -- init --apply --source="$script_dir"
  # NOTE: the bootstrap script is in a subdirectory
  set -- init --apply --source="$(dirname "$script_dir")" "$@"
else
  if [ $# -eq 0 ]; then
    echo "Missing user name or repository (chezmoi init user)" >&2
    exit 1
  fi
  set -- init --apply "$@"
fi

if [ "${DRY_RUN:-}" = true ]; then
  printf >&2 "DRY-RUN: "
fi
echo "Running 'chezmoi $*'" >&2
# exec: replace current process with chezmoi
if [ "${DRY_RUN:-}" != true ]; then
  exec "$chezmoi" "$@"
fi
