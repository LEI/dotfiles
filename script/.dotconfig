# vim: filetype=gitconfig

; Settings
[core]
	debug = false
	dryrun = true

[log]
	#color = true
	time = true

[link]
	target = $HOME
	prefix = .
[link ":home"]
	bash = *
	config = *
	git = *
[link "bin"]
	source = bin/*
[link ".irssi"]
	source = irssi/*
[link ".mutt"]
	source = mutt/*
[link ".tmux"]
	source = tmux/*
	dst = .tmux
	exclude = bin
[link ".tmux.conf"]
	source = tmux/tmux.conf
[link ".vim"]
	source = vim/*

[include]
	path = .dotconfig.local

