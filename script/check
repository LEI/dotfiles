#!/usr/bin/env bash

set -euo pipefail

source home/.chezmoitemplates/helpers.sh

PATH="$HOME/.local/bin:$PATH"
# Add shims on PATH unless mise is already activated
if [ -z "${MISE_SHELL:-}" ]; then
  PATH="$PATH:$HOME/.local/share/mise/shims"
fi

DOCTOR="${DOCTOR:-false}"
TOPGRADE="${TOPGRADE:-false}"
UPDATE="${UPDATE:-false}"

check_chezmoi() {
  # set -- --debug --verbose "$@"
  # NOTE: template output changes after installation (starship preset, gen config...)
  # out="$(chezmoi diff --exclude=scripts)"
  # if [ "$out" != "" ]; then
  #   echo >&2 "$out"
  #   echo >&2 "Expected empty diff without scripts, see output above"
  #   exit 1
  # fi
  cmd chezmoi apply
  out="$(cmd chezmoi diff)"
  if [ "$out" != "" ]; then
    echo >&2 "Expected empty diff: $out"
    exit 1
  fi
  out="$(cmd chezmoi status)"
  if [ "$out" != "" ]; then
    echo >&2 "Expected empty status: $out"
    exit 1
  fi
}

has_feature() {
  local name="$1"
  local features="$2"
  cmd yq --exit-status ".$name" <<<"$features" >/dev/null 2>&1
}

check_version() {
  echo >&2 "Checking versions..."

  local features
  features="$(chezmoi cat-config "$@" | yq .data.features)"

  os="$(uname -s)"

  # coreutils
  if [ "$os" = Darwin ]; then
    cmd gdd --version | head -n1
  else
    cmd dd --version | head -n1

    if command -v lsblk >/dev/null; then
      cmd lsblk --version # util-linux
    fi
  fi

  if has_feature atuin "$features"; then
    cmd atuin --version
    # cmd atuin dotfiles alias list
    # if [ "$DOCTOR" = true ]; then
    #   cmd atuin doctor
    # fi
  fi

  cmd bash --version | head -n1

  if command -v batcat >/dev/null; then
    cmd batcat --version
  else
    cmd bat --version
  fi

  ble="$HOME/.local/share/blesh/ble.sh"
  if [ -f "$ble" ]; then
    cmd "$SHELL" "$ble" --version
  fi

  if has_feature brew "$features"; then
    if [ -d /home/linuxbrew/.linuxbrew ]; then
      eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    fi
    cmd brew --version
    if [ "$DOCTOR" = true ]; then
      # FIXME: ignore deprecated or disabled formulaes
      cmd brew doctor || true
    fi
  fi

  if command -v btm >/dev/null; then
    cmd btm --version
  fi

  # cmd bws --version
  cmd carapace --version

  if command -v direnv >/dev/null; then
    cmd direnv --version
    cmd direnv export bash # "${SHELL##*/}"
  fi

  if command -v eza >/dev/null; then
    cmd eza --version | head -n2 | tail -n1
  fi

  cmd fd --version
  # cmd ghostty --version | head -n1

  if has_feature helix "$features"; then
    cmd hx --version
  fi

  cmd jq --version

  if has_feature mise "$features"; then
    # cmd mise trust # --all
    cmd mise --version | head -n1
    # cmd mise ls
    # cmd mise trust --show
    if [ "$DOCTOR" = true ]; then
      cmd mise doctor
    fi
  fi

  if has_feature node "$features"; then
    cmd node --version
  fi

  if has_feature nushell "$features"; then
    cmd nu --version
  fi

  if has_feature neovim "$features"; then
    cmd nvim --version 2>/dev/null | head -n1
    if [ "$UPDATE" = true ]; then
      # if [ "$(nvim --headless -u NONE "+echo has('nvim-0.8')" +qa 2>&1)" = 1 ]; then
      cmd timeout 5m nvim --headless +LazyUpdate! +qa # >/dev/null
      echo
      # fi
    fi
    if [ "$DOCTOR" = true ]; then
      cmd timeout 5m nvim --headless +checkhealth +qa # >/dev/null
      echo
    fi
  fi

  if has_feature python "$features"; then
    if command -v pipx >/dev/null; then
      cmd pipx --version
    fi
    cmd uvx --version
  fi

  cmd progress --version
  if [ "$os" != Darwin ]; then
    cmd ps --version
  fi
  cmd rg --version | head -n1

  if has_feature tmux "$features"; then
    tmux -V 2>/dev/null
    if [ "$UPDATE" = true ]; then
      export TMUX_PLUGIN_MANAGER_PATH="$HOME/.config/tmux/plugins/"
      cmd timeout 5m ~/.config/tmux/plugins/tpm/bin/update_plugins all
    fi
  fi

  if command -v topgrade >/dev/null; then
    cmd topgrade --version
    if [ "$TOPGRADE" = true ]; then
      cmd topgrade \
        --disable=chezmoi \
        --dry-run # >/dev/null
    fi
  fi

  if has_feature vim "$features"; then
    vim --version | head -n1
  fi

  cmd yq --version

  if has_feature zellij "$features"; then
    cmd zellij --version
  fi

  cmd zoxide --version

  if command -v needs >/dev/null; then
    cmd needs \
      atuin \
      bash \
      bat \
      btm \
      carapace \
      chezmoi \
      dd \
      direnv \
      eza \
      fd \
      ghq \
      hx \
      jq \
      lazygit \
      mise \
      node \
      nu \
      nvim \
      pipx \
      progress \
      ps \
      rg \
      tmux \
      topgrade \
      uvx \
      vim \
      yq \
      zellij \
      zoxide \
      "$@"
  fi

  if [ "${DEBUG:-}" = true ]; then
    echo >&2 "DEBUG enabled"
    bash
  fi
}

check_chezmoi # "$@"
check_version "$@"
