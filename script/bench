#!/bin/sh
#MISE description="Named component timing for shell init"
#USAGE arg "<shell>" help="Shell to benchmark" default="bash" {
#USAGE   choices "bash" "zsh"
#USAGE }
set -eu

shell="${1:-bash}"

case "$shell" in
  bash|zsh)
    SHELL_BENCH=true "$shell" -ic exit
    ;;
  *)
    echo >&2 "bench: invalid shell '$shell', expected bash or zsh"
    exit 2
    ;;
esac
