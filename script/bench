#!/usr/bin/env bash
#MISE description="Show per-component shell init timing via SHELL_BENCH"
#USAGE arg "[shell]" help="Shell to benchmark (default: current shell)" {
#USAGE   choices "bash" "zsh"
#USAGE }

set -eu

case "${1:-}" in
-h | --help)
  if command -v usage >/dev/null; then
    usage exec --help sh "$0"
  else
    echo "Usage: bench [shell]"
  fi
  exit
  ;;
--usage)
  grep '^#USAGE' "$0" | sed 's/^#USAGE //'
  exit
  ;;
--)
  shift
  ;;
esac

# shellcheck disable=SC1091
. "$XDG_CONFIG_HOME/sh/lib/bench.sh"

shell="${1:-${SHELL##*/}}"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT
sheldon_data="${SHELDON_DATA_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/sheldon}"
if [ -d "$sheldon_data" ]; then
  cp -R "$sheldon_data" "$tmpdir/sheldon-data"
fi
export SHELDON_DATA_DIR="$tmpdir/sheldon-data"

case "$shell" in
bash | zsh)
  SHELL_BENCH=true bench total "$shell" -ic exit
  ;;
*)
  echo "${0##*/}: invalid shell '$shell', expected bash or zsh" >&2
  exit 2
  ;;
esac
