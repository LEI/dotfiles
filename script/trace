#!/bin/sh
#MISE description="Trace sourced files during shell init"
#USAGE arg "[shell]" help="Shell to trace (default: current shell)" {
#USAGE   choices "bash" "zsh"
#USAGE }

set -eu

case "${1:-}" in
-h | --help)
  if command -v usage >/dev/null; then
    usage exec --help sh "$0"
  else
    echo "Usage: trace [shell]"
  fi
  exit
  ;;
--usage)
  grep '^#USAGE' "$0" | sed 's/^#USAGE //'
  exit
  ;;
--)
  shift
  ;;
esac

shell="${1:-${SHELL##*/}}"

case "$shell" in
bash)
  PS4='+ ${BASH_SOURCE[0]##*/}:${LINENO}: ' \
    bash -xic exit 2>&1 |
    grep -E '^\+* [^:]+:[0-9]+: (\. |source )' |
    sed "s|$HOME|~|g"
  ;;
zsh)
  zsh --source-trace -ic exit 2>&1 |
    sed "s|$HOME|~|g"
  ;;
*)
  echo "trace: invalid shell '$shell', expected bash or zsh" >&2
  exit 2
  ;;
esac
