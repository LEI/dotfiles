#!/usr/bin/env bash
#MISE alias="vb"
#MISE description="Check for blank lines at start/end and consecutive"
#USAGE flag "-l --list" help="List tracked files"
#USAGE arg "[files]..." help="Files to check (default: all tracked)"
#USAGE complete "files" run="./script/validate-blank --list"

set -euo pipefail

lib_dir="${BASH_SOURCE[0]%/*}/../home/dot_local/lib/bash"
# shellcheck source=home/dot_local/lib/bash/log.sh
source "$lib_dir/log.sh"
# shellcheck source=home/dot_local/lib/bash/require.sh
source "$lib_dir/require.sh"
# shellcheck source=home/dot_local/lib/bash/usage.sh
source "$lib_dir/usage.sh"

require_bash 4

script_dir="${BASH_SOURCE[0]%/*}"

while [ $# -gt 0 ]; do
  case "$1" in
  -l | --list)
    git ls-files
    exit 0
    ;;
  -h | --help)
    usage_help "[-l] [files...]"
    exit
    ;;
  --usage)
    usage_spec
    exit
    ;;
  --)
    shift
    break
    ;;
  -*)
    echo "${0##*/}: unknown option: $1" >&2
    exit 2
    ;;
  *)
    break
    ;;
  esac
done

if [ $# -eq 0 ]; then
  mapfile -t files < <("$0" --list)
  set -- "${files[@]}"
fi

# Skip binary files
text_files=()
for f in "$@"; do
  [ -f "$f" ] || continue
  file --brief --mime-encoding "$f" | grep -q binary && continue
  text_files+=("$f")
done
set -- "${text_files[@]}"

if [ $# -eq 0 ]; then
  echo "no files to validate" >&2
  exit 0
fi

awk -f "$script_dir/validate-blank.awk" "$@" >&2
