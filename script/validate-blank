#!/usr/bin/env bash
#MISE alias="vb"
#MISE description="Check for blank lines at start/end and consecutive"
#USAGE flag "-l --list" help="List tracked files"
#USAGE arg "[files]..." help="Files to check (default: all tracked)"
#USAGE complete "files" run="./script/validate-blank --list"

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo "bash 4+ required, found $BASH_VERSION" >&2
  exit 1
fi

script_dir="$(cd "$(dirname "$0")" && pwd)"

while [ $# -gt 0 ]; do
  case "$1" in
  -l | --list)
    git ls-files
    exit 0
    ;;
  -h | --help)
    if command -v usage >/dev/null; then
      usage exec --help bash "$0"
    else
      echo "Usage: validate-blank [-l] [files...]"
    fi
    exit 0
    ;;
  --usage)
    grep '^#USAGE' "$0" | sed 's/^#USAGE //'
    exit 0
    ;;
  --)
    shift
    break
    ;;
  -*)
    echo "${0##*/}: unknown option: $1" >&2
    exit 2
    ;;
  *)
    break
    ;;
  esac
done

if [ $# -eq 0 ]; then
  mapfile -t files < <("$0" --list)
  set -- "${files[@]}"
fi

# Skip binary files
text_files=()
for f in "$@"; do
  [ -f "$f" ] || continue
  file --brief --mime-encoding "$f" | grep -q binary && continue
  text_files+=("$f")
done
set -- "${text_files[@]}"

if [ $# -eq 0 ]; then
  echo "no files to validate" >&2
  exit 0
fi

awk -f "$script_dir/validate-blank.awk" "$@" >&2
