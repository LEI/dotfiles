#!/usr/bin/env bash
#MISE description="Check for blank lines at start/end and consecutive"

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo >&2 "bash 4+ required, found $BASH_VERSION"
  exit 1
fi

script_dir="$(cd "$(dirname "$0")" && pwd)"

if [ $# -eq 0 ]; then
  mapfile -t files < <(git ls-files -z | tr '\0' '\n')
  set -- "${files[@]}"
fi

if [ $# -eq 0 ]; then
  echo >&2 "no files to validate"
  exit 0
fi

awk -f "$script_dir/validate-blank.awk" "$@" >&2
