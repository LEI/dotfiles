#!/usr/bin/env bash
#MISE alias="t"
#MISE description="Run bats test suite"
#USAGE flag "-l --list" help="List test files"
#USAGE arg "[filter]..." help="Extra arguments passed to bats"
#USAGE complete "filter" run="./script/test --list"

# https://github.com/shunk031/dotfiles/blob/master/scripts/run_unit_test.sh

set -euo pipefail

lib_dir="${BASH_SOURCE[0]%/*}/../home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/parallel.sh
source "$lib_dir/sh/parallel.sh"

# PATH="$PATH:$HOME/.local/bin"
if [ -x /home/linuxbrew/.linuxbrew/bin/brew ] && ! command -v brew >/dev/null; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
if command -v mise >/dev/null; then
  if [ -z "${MISE_SHELL:-}" ]; then
    eval "$(mise activate bash)"
  else
    PATH="${MISE_DATA_DIR:-$HOME/.local/share/mise}/shims:$PATH"
  fi
fi
# if [ -z "${USER:-}" ]; then
#   USER="$(id -un)"
# fi

case "$(uname -s)" in
Linux)
  case "$(uname -o)" in
  Android)
    # Android 12+ phantom killer 32-process limit without adb/root
    ANDROID_SDK_INT=$(getprop ro.build.version.sdk)
    # ANDROID_RELEASE=$(getprop ro.build.version.release)
    case "$ANDROID_SDK_INT" in
    31 | 32) DEFAULT_JOBS=4 ;;      # Android 12/12L
    33 | 34 | 35) DEFAULT_JOBS=4 ;; # Android 13, 14, 15
    esac
    ;;
  esac
  ;;
esac

if [ "${CI:-}" = true ] && command -v mise >/dev/null; then
  mise trust --all --quiet --yes
fi

# FIXME(termux): ble.sh updating binders segfaults `bash -i`; if it recurs, gate `BLE_ENABLED=false` on termux detection

main() {
  while [ $# -gt 0 ]; do
    case "$1" in
    -l | --list)
      git ls-files 'test/*.bats'
      return
      ;;
    -h | --help)
      if command -v usage >/dev/null; then
        usage exec --help bash "$0"
      else
        echo "Usage: test [-l] [filter...]"
      fi
      return
      ;;
    --usage)
      grep '^#USAGE' "$0" | sed 's/^#USAGE //'
      return
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
    esac
  done

  # Set BATS_LIB_PATH: local test_helper + system libs (if available)
  # Allow override: BATS_LIB_PATH=my/custom/path bats ...
  if [ -z "${BATS_LIB_PATH:-}" ]; then
    local path="${PWD}/test_helper"
    if [ -d /usr/lib/bats ]; then
      path="$path:/usr/lib/bats"
    elif [ "$(uname -s)" = Darwin ] && [ -d "$(brew --prefix)/lib/bats" ]; then
      path="$path:$(brew --prefix)/lib/bats"
    fi
    path="$path:$PWD/test"
    export BATS_LIB_PATH="$path"
  fi

  # chezmoi.bats uses BATS_NO_PARALLELIZE_WITHIN_FILE due to chezmoi state lock
  local jobs="${TEST_JOBS:-${DEFAULT_JOBS:-$(default_jobs)}}"
  local has_path=false
  for arg in "$@"; do
    case "$arg" in -*) ;; *) [ -e "$arg" ] && has_path=true && break ;; esac
  done
  if ! $has_path; then
    set -- --recursive ./test "$@"
  fi
  set -- \
    --jobs "$jobs" \
    --print-output-on-failure \
    --timing \
    "$@"
  if [ -n "${TERM:-}" ] && [ "$TERM" != dumb ]; then
    set -- --pretty "$@"
  fi
  # set -- --trace "$@"
  echo "bats $*" >&2
  bats "$@"
  local exit_code=$?

  # Fail if 0 tests were run
  if [ $exit_code -eq 0 ]; then
    local test_count
    test_count=$(bats --count "$@" 2>/dev/null)
    if [ "$test_count" = "0" ]; then
      echo "bats error: 0 tests found ($*)" >&2
      exit 1
    fi
  fi

  exit $exit_code
}

main "$@"
