#!/usr/bin/env bash
#MISE alias="t"
#MISE description="Run bats test suite"
#USAGE flag "-l --list" help="List test files"
#USAGE arg "[filter]..." help="Extra arguments passed to bats"
#USAGE complete "filter" run="./script/test --list"
# TODO: --base-directory test

# https://github.com/shunk031/dotfiles/blob/master/scripts/run_unit_test.sh

set -euo pipefail

# PATH="$PATH:$HOME/.local/bin"
if [ -x /home/linuxbrew/.linuxbrew/bin/brew ] && ! command -v brew >/dev/null; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
if [ -z "${MISE_SHELL:-}" ] && command -v mise >/dev/null; then
  eval "$(mise activate bash)"
  # PATH="$PATH:$HOME/.local/share/mise/shims"
fi
# if [ -z "${USER:-}" ]; then
#   USER="$(id -un)"
# fi

if [ "${CI:-}" = true ] && command -v mise >/dev/null; then
  mise trust --all --quiet --yes
fi

# FIXME(termux): ble.sh: updating binders..../script/container: line 112:
# 2764 Segmentation fault (core dumped) bash -i
# export BLE_ENABLED=false

# export CHEZMOI_PROFILE="$PROFILE"
# export CHEZMOI_ROOT="$PWD"
# export CHEZMOI_UPGRADE=true
# export CI=true

main() {
  while [ $# -gt 0 ]; do
    case "$1" in
    -l | --list)
      git ls-files 'test/*.bats'
      return
      ;;
    -h | --help)
      if command -v usage >/dev/null; then
        usage exec --help bash "$0"
      else
        echo "Usage: test [-l] [filter...]"
      fi
      return
      ;;
    --usage)
      grep '^#USAGE' "$0" | sed 's/^#USAGE //'
      return
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
    esac
  done

  # Set BATS_LIB_PATH: local test_helper + system libs (if available)
  # Allow override: BATS_LIB_PATH=my/custom/path bats ...
  if [ -z "${BATS_LIB_PATH:-}" ]; then
    local path="${PWD}/test_helper"
    if [ -d /usr/lib/bats ]; then
      path="$path:/usr/lib/bats"
    elif [ "$(uname -s)" = Darwin ] && [ -d "$(brew --prefix)/lib/bats" ]; then
      path="$path:$(brew --prefix)/lib/bats"
    fi
    path="$path:$PWD/test"
    export BATS_LIB_PATH="$path"
  fi

  # chezmoi.bats uses BATS_NO_PARALLELIZE_WITHIN_FILE due to chezmoi state lock
  local jobs
  if [ -n "${TEST_JOBS:-}" ]; then
    jobs="$TEST_JOBS"
  elif command -v nproc >/dev/null; then
    jobs=$(nproc)
  elif command -v sysctl >/dev/null; then
    jobs=$(sysctl -n hw.ncpu)
  else
    jobs=4
  fi
  if [ $# -eq 0 ]; then
    set -- --recursive ./test "$@"
  fi
  set -- \
    --jobs "$jobs" \
    --print-output-on-failure \
    --timing \
    "$@"
  if [ -n "${TERM:-}" ] && [ "$TERM" != dumb ]; then
    set -- --pretty "$@"
  fi
  # set -- --trace "$@"
  echo "bats $*" >&2
  bats "$@"
}

main "$@"
