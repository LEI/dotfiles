#!/usr/bin/env bash
#MISE description="Validate SKILL.md files against Agent Skills specification"
# Requires: skill-validator (brew install agent-ecosystem/tap/skill-validator)

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo "bash 4+ required, found $BASH_VERSION" >&2
  exit 1
fi

if ! command -v skill-validator >/dev/null 2>&1; then
  echo 'error: skill-validator is required' >&2
  exit 1
fi

quiet="${VALIDATE_SKILL_QUIET:-${VALIDATE_QUIET:-false}}"
verbose="${VALIDATE_SKILL_VERBOSE:-${VALIDATE_VERBOSE:-false}}"

# shellcheck disable=SC2329
validate_skill() {
  local path="$1" skill_dir target_path name output

  if [ ! -e "$path" ]; then
    echo "FAIL $path (not found)"
    return 1
  fi

  path=$(realpath "$path")

  if [ -d "$path" ]; then
    skill_dir="$path"
  else
    skill_dir=$(dirname "$path")
  fi

  # Resolve effective name via chezmoi (strips exact_, dot_, etc.)
  target_path="$(chezmoi target-path "$skill_dir" 2>/dev/null || echo "$skill_dir")"
  name=$(basename "$target_path")
  if [ "$name" != "$(basename "$skill_dir")" ]; then
    local tmp_dir
    tmp_dir=$(mktemp --directory)
    trap 'rm -rf "$tmp_dir"' RETURN
    ln -s "$skill_dir" "$tmp_dir/$name"
    skill_dir="$tmp_dir/$name"
  fi

  if [ "$verbose" = true ]; then
    echo "validate-skill: $name" >&2
  fi

  # NOTE: exit code 2 means warnings
  if output=$(skill-validator check "$skill_dir" 2>&1); then
    if [ "$quiet" = false ]; then
      echo "PASS $path"
    fi
  else
    echo "FAIL $path"
    echo "$output"
    return 1
  fi
}
export -f validate_skill

# Collect files: from args (pre-commit) or find all
if [ $# -eq 0 ]; then
  mapfile -t files < <(git ls-files -z 'SKILL.md' '**/SKILL.md' | tr '\0' '\n')
  set -- "${files[@]}"
fi

if [ $# -eq 0 ]; then
  echo "validate-skill: no files to validate" >&2
  exit 0
fi

export quiet verbose
# shellcheck disable=SC2016
results=$(printf '%s\n' "$@" | xargs -P "$(nproc 2>/dev/null || echo 4)" -n1 bash -euc 'validate_skill "$1"' _ || true)

passed=$(grep -c '^PASS ' <<<"$results") || passed=0
failed=$(grep -c '^FAIL ' <<<"$results") || failed=0

if [ "$quiet" = false ]; then
  echo "$results" | grep -E '^(PASS|FAIL) ' || true
fi
if [ "$failed" -gt 0 ]; then
  echo "$results" | grep -vE '^(PASS|FAIL) ' || true
fi
if [ "$quiet" = false ] && [ "$((passed + failed))" -gt 0 ]; then
  echo "validate-skill: $passed passed, $failed failed"
fi
exit $((failed > 0 ? 1 : 0))
