#!/usr/bin/env bash
#MISE description="Validate SKILL.md files against Agent Skills specification"
# Requires: skill-validator (brew install agent-ecosystem/tap/skill-validator)

set -euo pipefail

if ! command -v skill-validator >/dev/null 2>&1; then
  echo >&2 'error: skill-validator is required'
  exit 1
fi

validate_skill() {
  local path="$1" skill_dir output

  if [ ! -e "$path" ]; then
    echo "FAIL $path (not found)"
    return 1
  fi

  path=$(realpath "$path")

  if [ -d "$path" ]; then
    skill_dir="$path"
  else
    skill_dir=$(dirname "$path")
  fi

  # NOTE: exit code 2 means warnings
  if output=$(skill-validator check "$skill_dir" 2>&1); then
    echo "PASS $path"
  else
    printf 'FAIL %s\n%s\n' "$path" "$output"
    return 1
  fi
}
export -f validate_skill

# Collect files: from args (pre-commit) or find all
if [ $# -eq 0 ]; then
  mapfile -t files < <(git ls-files -z 'SKILL.md' '**/SKILL.md' | tr '\0' '\n')
  set -- "${files[@]}"
fi

if [ $# -eq 0 ]; then
  echo >&2 "no files to validate"
  exit 0
fi

results=$(printf '%s\n' "$@" | xargs -P "$(nproc 2>/dev/null || echo 4)" -n1 bash -c 'validate_skill "$1"' _ 2>&1 || true)

passed=$(echo "$results" | grep -c '^PASS ' || true)
failed=$(echo "$results" | grep -c '^FAIL ' || true)

if [ "$failed" -gt 0 ]; then
  echo "$results" | grep -v '^PASS ' >&2
fi
echo >&2 "$passed passed, $failed failed"
exit $((failed > 0 ? 1 : 0))
