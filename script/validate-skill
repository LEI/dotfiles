#!/usr/bin/env bash
#MISE description="Validate SKILL.md files against Agent Skills specification"
# Requires: skill-validator (brew install agent-ecosystem/tap/skill-validator)

set -euo pipefail

if ! command -v skill-validator >/dev/null 2>&1; then
  printf >&2 'error: skill-validator is required\n'
  exit 1
fi

# Validator (exported for parallel execution)
validate_skill() {
  path="$1"

  if [ ! -e "$path" ]; then
    printf >&2 "FAIL: %s (not found)\n" "$path"
    return 1
  fi

  # Resolve to absolute path
  path=$(realpath "$path")

  # Determine skill directory: if SKILL.md file, use parent; if dir, use as-is
  if [ -d "$path" ]; then
    skill_dir="$path"
  else
    skill_dir=$(dirname "$path")
  fi

  # Get skill name from directory
  dir_name=$(basename "$skill_dir")

  # printf >&2 "validating skill: %s\n" "$skill_dir"

  # Validate one file
  # NOTE: exit code 2 means warnings
  if output=$(skill-validator check "$skill_dir" 2>&1); then
    printf >&2 "ok: %s\n" "$path"
  else
    printf >&2 "FAIL: %s (content: %s)\n" "$path" "$content"
    printf >&2 "%s\n" "$output"
    return 1
  fi
}
export -f validate_skill

# Collect skill files
if [ $# -eq 0 ]; then
  mapfile -t files < <(
    find . -type f -name SKILL.md \
      -not -path './output/*' \
      -not -path './.git/*'
  )
else
  files=("$@")
fi

if [ ${#files[@]} -eq 0 ]; then
  printf >&2 "No skills to validate\n"
  exit 0
fi

# TODO: --halt now,fail=1
printf '%s\n' "${files[@]}" |
  parallel --line-buffer -P "$(getconf _NPROCESSORS_ONLN)" validate_skill 2>/dev/null

# TODO: count errors, warnings, skipped...
printf >&2 "%d skill(s) validated\n" "${#files[@]}"
