#!/usr/bin/env bash
#MISE alias="vsk"
#MISE description="Validate SKILL.md files against Agent Skills specification"
# Requires skill-validator: brew install agent-ecosystem/tap/skill-validator
#USAGE flag "-l --list" help="List SKILL.md files"
#USAGE flag "-q --quiet" help="Only print errors and summary"
#USAGE flag "-v --verbose" help="Show validation details"
#USAGE arg "[files]..." help="SKILL.md files to validate (default: all tracked)"
#USAGE complete "files" run="./script/validate-skill --list"

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo "bash 4+ required, found $BASH_VERSION" >&2
  exit 1
fi

if ! command -v skill-validator >/dev/null 2>&1; then
  echo "error: skill-validator is required" >&2
  exit 1
fi

jobs="${NPROC:-$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4)}"

prog="${0##*/}"
verbosity="${VALIDATE_SKILL_VERBOSITY:-${VALIDATE_VERBOSITY:-1}}"

while [ $# -gt 0 ]; do
  case "$1" in
  -l | --list)
    git ls-files 'SKILL.md' '**/SKILL.md'
    exit
    ;;
  -q | --quiet)
    verbosity=0
    shift
    ;;
  -v | --verbose)
    verbosity=2
    shift
    ;;
  -h | --help)
    if command -v usage >/dev/null; then
      usage exec --help bash "$0"
    else
      echo "Usage: validate-skill [-l] [-q] [-v] [files...]"
    fi
    exit
    ;;
  --usage)
    grep '^#USAGE' "$0" | sed 's/^#USAGE //'
    exit
    ;;
  --)
    shift
    break
    ;;
  -*)
    echo "${0##*/}: unknown option: $1" >&2
    exit 2
    ;;
  *) break ;;
  esac
done

# shellcheck disable=SC2329
validate_skill() {
  local path="$1"
  local skill_dir target_path name output display_path

  path=$(realpath "$path" 2>/dev/null || echo "$path")
  display_path="${path#"$PWD/"}"
  display_path="${display_path/#"$HOME"/\~}"

  if [ ! -e "$path" ]; then
    echo "FAIL $display_path (not found)"
    return 1
  fi

  if [ -d "$path" ]; then
    skill_dir="$path"
  else
    skill_dir=$(dirname "$path")
  fi

  # Resolve effective name via chezmoi: strips exact_, dot_, etc.
  if ! target_path="$(chezmoi target-path --no-tty "$skill_dir")"; then
    # persistent_state="$(mktemp -d)/chezmoi-state.json"
    # --persistent-state="$persistent_state"
    echo "FAIL $display_path (chezmoi target-path failed)"
    return 1
  fi
  name=$(basename "$target_path")
  if [ "$name" != "$(basename "$skill_dir")" ]; then
    local tmp_dir
    tmp_dir=$(mktemp -d)
    trap 'rm -rf "$tmp_dir"' RETURN
    ln -s "$skill_dir" "$tmp_dir/$name"
    skill_dir="$tmp_dir/$name"
  fi

  if [ "$verbosity" -ge 2 ]; then
    echo "$prog: $name" >&2
  fi

  # exit code 2 means warnings
  if output=$(skill-validator check "$skill_dir" 2>&1); then
    echo "PASS $display_path"
  else
    echo "FAIL $display_path"
    echo "$output"
    return 1
  fi
}
export -f validate_skill

# Collect files: from args or find all
if [ $# -eq 0 ]; then
  mapfile -t files < <("$0" --list)
  set -- "${files[@]}"
fi

if [ $# -eq 0 ]; then
  echo "${0##*/}: no files to validate" >&2
  exit 0
fi

export prog verbosity
# shellcheck disable=SC2016
results=$(printf '%s\0' "$@" | xargs -0 -P "$jobs" -n1 bash -euc 'validate_skill "$1"' _ || true)

passed=$(grep -c '^PASS ' <<<"$results") || passed=0
failed=$(grep -c '^FAIL ' <<<"$results") || failed=0

if [ "$verbosity" -ge 2 ]; then
  echo "$results" | grep -E '^(PASS|FAIL) ' || true
else
  echo "$results" | grep -E '^FAIL ' || true
fi
if [ "$failed" -gt 0 ]; then
  echo "$results" | grep -vE '^(PASS|FAIL) ' || true
fi
if [ "$verbosity" -ge 1 ] && [ "$((passed + failed))" -gt 0 ]; then
  echo "${0##*/}: $passed passed, $failed failed" >&2
fi
exit $((failed > 0 ? 1 : 0))
