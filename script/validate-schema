#!/usr/bin/env bash
#MISE hide=true
#MISE description="Validate files against their declared $schema"
# Validates files against their declared $schema.
# Handles jsonc/json5 via json5, toml/yaml via yq.
# Templates and modify scripts must be rendered before passing to this script.
# Requires: jq, uvx, yq
# Optional: json5 (for .jsonc/.json5 files)

set -euo pipefail

for cmd in jq uvx yq; do
  command -v "$cmd" >/dev/null || {
    printf >&2 'error: %s is required\n' "$cmd"
    exit 1
  }
done

passed=0
failed=0
skipped=0

# Returns the file extension
file_ext() {
  echo "${1##*.}"
}

# Reads content from stdin, extracts $schema based on effective extension
get_schema() {
  case "$(file_ext "$1")" in
  json) jq -r 'if type == "object" then .["$schema"] // empty else empty end' 2>/dev/null ;;
  jsonc | json5)
    if ! command -v json5 >/dev/null; then
      cat >/dev/null
      return 1
    fi
    json5 2>/dev/null | jq -r 'if type == "object" then .["$schema"] // empty else empty end' 2>/dev/null
    ;;
  toml) yq -p toml 'select(."$schema") | ."$schema"' 2>/dev/null ;;
  yaml | yml) yq 'select(."$schema") | ."$schema"' 2>/dev/null ;;
  *)
    cat >/dev/null
    return 1
    ;;
  esac
}

# Reads content from stdin, converts to plain json for validation
normalize() {
  case "$(file_ext "$1")" in
  jsonc | json5) json5 ;;
  toml) yq -p toml -o json ;;
  yaml | yml) yq -o json ;;
  *) cat ;;
  esac
}

for file in "$@"; do
  content=$(cat "$file")
  schema=$(get_schema "$file" <<<"$content") || {
    skipped=$((skipped + 1))
    continue
  }
  if [[ -z "$schema" ]]; then
    skipped=$((skipped + 1))
    continue
  fi

  if output=$(normalize "$file" <<<"$content" | uvx check-jsonschema --schemafile "$schema" - 2>&1); then
    passed=$((passed + 1))
    printf 'ok: %s\n' "$file"
  else
    failed=$((failed + 1))
    printf 'FAIL: %s\n%s\n' "$file" "$output"
  fi
done

total=$((passed + failed))
if ((total > 0 || skipped > 0)); then
  msg="${passed}/${total} ok"
  ((skipped > 0)) && msg+=" (${skipped} skipped)"
  printf '%s\n' "$msg"
fi

exit $((failed > 0 ? 1 : 0))
