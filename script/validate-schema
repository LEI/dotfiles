#!/usr/bin/env bash
#MISE description="Validate files against their declared $schema"
#MISE alias="vs"
#USAGE flag "-k --keep" help="Keep temp files for debugging"
#USAGE flag "-l --list" help="List validatable files"
#USAGE flag "-q --quiet" help="Suppress output"
#USAGE flag "-r --refresh" help="Wipe schema cache before validating"
#USAGE flag "-t --tap" help="Emit TAP version 14 output"
#USAGE flag "-v --verbose" help="Show validation details"
#USAGE arg "[files]..." help="Files to validate (default: all tracked)"
#USAGE complete "files" run="./script/validate-schema --list"

set -euo pipefail

lib_dir="${BASH_SOURCE[0]%/*}/../home/dot_local/lib"
# shellcheck source=home/dot_local/lib/bash/parallel.sh
source "$lib_dir/bash/parallel.sh"
# shellcheck source=home/dot_local/lib/bash/report.sh
source "$lib_dir/bash/report.sh"
# shellcheck source=home/dot_local/lib/bash/validate.sh
source "$lib_dir/bash/validate.sh"

require_bash 4

prog="${0##*/}"
keep="${VALIDATE_SCHEMA_KEEP:-${VALIDATE_KEEP:-false}}"
refresh=false
tap=false
verbosity="${VALIDATE_SCHEMA_VERBOSITY:-${VALIDATE_VERBOSITY:-1}}"

while [ $# -gt 0 ]; do
  case "$1" in
  -k | --keep)
    keep=true
    shift
    ;;
  -l | --list)
    git ls-files \
      '*.json' '*.jsonc' '*.json5' '*.toml' '*.yaml' '*.yml' \
      ':(exclude)home/.chezmoitemplates/' \
      ':(exclude)**/modify_*'
    exit
    ;;
  -q | --quiet)
    verbosity=0
    shift
    ;;
  -r | --refresh)
    refresh=true
    shift
    ;;
  -t | --tap)
    tap=true
    shift
    ;;
  -v | --verbose)
    verbosity=2
    shift
    ;;
  -h | --help)
    usage_help "[-k] [-l] [-q] [-r] [-t] [-v] [files...]"
    exit
    ;;
  --usage)
    usage_spec
    exit
    ;;
  --)
    shift
    break
    ;;
  -*)
    echo "$prog: unknown option: $1" >&2
    exit 2
    ;;
  *) break ;;
  esac
done

case "$(uname -s)" in
Darwin) cache_dir="$HOME/Library/Caches/check_jsonschema" ;;
*) cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/check_jsonschema" ;;
esac

if [ "$refresh" = true ] && [ -d "$cache_dir" ]; then
  find "$cache_dir" -type f -delete
fi

# Read the $schema URL from a file; empty when absent or on parse error
# shellcheck disable=SC2329
extract_schema() {
  local path="$1" base ext schema=""
  base="$(basename "$path")"
  ext="${path##*.}"
  case "$base" in
  cspell.json | devcontainer.json) ext=jsonc ;;
  esac
  case "$ext" in
  json)
    schema=$(jq -r 'if type == "object" then ."$schema" // empty else empty end' "$path") || schema=
    ;;
  jsonc | json5)
    if command -v json5 >/dev/null; then
      schema=$(json5 "$path" | jq -r 'if type == "object" then ."$schema" // empty else empty end') || schema=
    else
      schema=$(jq -r 'if type == "object" then ."$schema" // empty else empty end' "$path") || schema=
    fi
    ;;
  toml)
    # shellcheck disable=SC2016
    schema=$(yq '."$schema"' "$path") || schema=
    ;;
  yaml | yml)
    # shellcheck disable=SC2016
    schema=$(yq 'select(kind == "map") | ."$schema"' "$path") || schema=
    ;;
  esac
  [ "$schema" = "null" ] && schema=
  printf '%s\n' "$schema"
}
export -f extract_schema

# Invalidate the cached schema for a URL when its ETag/Last-Modified changed
# check-jsonschema's Last-Modified-only freshness misses changes when servers
# omit that header (e.g. bifrost, Vercel-hosted schemas); offline: keep cache
preflight_schema() {
  local url="$1" hash basename ext cache_file meta_file
  local headers etag last_mod current
  hash=$(printf '%s' "$url" | shasum -a 256 | awk '{print $1}')
  basename="${url##*/}"
  case "$basename" in
  *.*) ext=".${basename##*.}" ;;
  *) ext="" ;;
  esac
  cache_file="$cache_dir/schemas/$hash$ext"
  meta_file="$cache_dir/schemas/$hash.meta"
  [ -f "$cache_file" ] || return 0
  if ! headers=$(curl --silent --head --location --max-time 5 "$url"); then
    return 0
  fi
  # Normalize so weak (W/"abc") and strong ("abc") forms compare equal
  etag=$(printf '%s\n' "$headers" | awk -F': ' 'tolower($1)=="etag"{print $2; exit}' | tr -d '\r"' | sed 's|^W/||')
  last_mod=$(printf '%s\n' "$headers" | awk -F': ' 'tolower($1)=="last-modified"{print $2; exit}' | tr -d '\r')
  current="$etag|$last_mod"
  if [ -f "$meta_file" ] && [ "$(cat "$meta_file")" = "$current" ]; then
    return 0
  fi
  rm -f "$cache_file"
  printf '%s\n' "$current" >"$meta_file"
}

# shellcheck disable=SC2329
validate_file() {
  local path="$1" ext content schema tmp_dir="" schema_path content_path
  ext="${path##*.}"

  if [ ! -e "$path" ]; then
    echo "FAIL $path schema= (file not found)"
    return 1
  fi

  schema=$(extract_schema "$path")

  if [ -z "$schema" ]; then
    echo "SKIP $path # no \$schema"
    return 0
  fi

  case "$(basename "$path")" in
  cspell.json | devcontainer.json) ext=jsonc ;;
  esac

  case "$ext" in
  jsonc | json5)
    if command -v json5 >/dev/null; then
      content=$(json5 "$path")
    else
      content=$(jq '.' "$path")
    fi
    if [ "$content" = "null" ]; then
      content='{}'
    fi
    tmp_dir=$(mktemp -d)
    # shellcheck disable=SC2064
    trap "rm -rf '$tmp_dir'" EXIT
    content_path="$tmp_dir/${path#/}"
    content_path="${content_path%.*}.json"
    mkdir -p "$(dirname "$content_path")"
    printf '%s' "$content" >"$content_path"
    ;;
  *)
    content_path="$path"
    ;;
  esac

  schema_path="$schema"
  case "$schema" in
  https://aka.ms/winget-packages.schema.2.0.json)
    case "$(uname -s)" in
    MINGW* | MSYS* | CYGWIN* | Windows*) ;;
    *)
      echo "SKIP $path # windows-only schema"
      return 0
      ;;
    esac
    if [ -z "${tmp_dir:-}" ]; then
      tmp_dir=$(mktemp -d)
      # shellcheck disable=SC2064
      trap "rm -rf '$tmp_dir'" EXIT
    fi
    schema_path="$tmp_dir/schema.json"
    if ! curl -fsSL "$schema" -o "$schema_path"; then
      echo "FAIL $path schema=$schema: failed to download schema"
      return 1
    fi
    jq 'del(.properties.WinGetVersion)' "$schema_path" >"$schema_path.tmp"
    mv "$schema_path.tmp" "$schema_path"
    if [ "$verbosity" -ge 2 ]; then
      echo "$prog: downloaded and modified schema: $schema_path" >&2
    fi
    ;;
  esac

  if [ "$verbosity" -ge 2 ]; then
    echo "$prog: validating $path${tmp_dir:+ (temp dir: $tmp_dir)}" >&2
  fi

  local result
  if result=$(check-jsonschema --schemafile "$schema_path" "$content_path" 2>&1); then
    echo "PASS $path schema=$schema"
    return 0
  else
    echo "FAIL $path schema=$schema"
    if [ "$keep" = true ] && [ -n "$tmp_dir" ]; then
      echo "  file: $content_path" >&2
      echo "  schema: $schema_path" >&2
      trap - EXIT
    fi
    echo "$result"
    return 1
  fi
}
export -f validate_file

# shellcheck disable=SC2329
validate_schema() {
  local output exit_code=0
  output=$(validate_file "$1") || exit_code=$?
  echo "$output"
  if [ "$exit_code" -ne 0 ]; then
    if ! echo "$output" | grep -qE '^FAIL '; then
      echo "FAIL $1 schema= (crashed with exit $exit_code)" >&2
    fi
    return 1
  fi
  if [ -n "$output" ] && ! echo "$output" | grep -qE '^(PASS|FAIL|SKIP) '; then
    echo "FAIL $1 schema= (unexpected output)" >&2
    return 1
  fi
  return 0
}
export -f validate_schema

for cmd in check-jsonschema jq yq; do
  if ! command -v "$cmd" >/dev/null; then
    echo "error: $cmd is required" >&2
    exit 1
  fi
done

if ! yq --version 2>&1 | grep -q 'mikefarah/yq'; then
  echo "error: yq (mikefarah/yq) is required; found $(yq --version 2>&1 | head -1)" >&2
  exit 1
fi

if [ $# -eq 0 ]; then
  mapfile -t files < <("$0" --list)
  set -- "${files[@]}"
fi

jobs="$(default_jobs)"

if [ "$verbosity" -ge 2 ]; then
  echo "$prog: validating $# files (jobs=$jobs)" >&2
fi

if [ $# -eq 0 ]; then
  if [ "$verbosity" -ge 1 ]; then
    echo "$prog: no files to validate" >&2
  fi
  exit 0
fi

# Pre-flight: invalidate cached schemas whose ETag/Last-Modified shifted upstream
if [ "$refresh" != true ] && [ -d "$cache_dir/schemas" ]; then
  for f in "$@"; do
    extract_schema "$f"
  done | sort -u | while IFS= read -r url; do
    if [ -n "$url" ]; then
      preflight_schema "$url"
    fi
  done
fi

export prog verbosity keep
# shellcheck disable=SC2016
results=$(printf '%s\0' "$@" | xargs -0 -P "$jobs" -n1 bash -euc 'validate_schema "$1"' _ || true)

report_collect "$results"
if [ "$tap" = true ]; then
  report_tap "$prog"
else
  report_human "$prog" "$verbosity"
fi
