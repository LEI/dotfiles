#!/usr/bin/env bash
#MISE description="Validate files against their declared $schema"
#MISE alias="vs"
#USAGE flag "-k --keep" help="Keep temp files for debugging"
#USAGE flag "-l --list" help="List validatable files"
#USAGE flag "-q --quiet" help="Suppress output"
#USAGE flag "-v --verbose" help="Show validation details"
#USAGE arg "[files]..." help="Files to validate (default: all tracked)"
#USAGE complete "files" run="./script/validate-schema --list"

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo "bash 4+ required, found $BASH_VERSION" >&2
  exit 1
fi

prog="${0##*/}"
keep="${VALIDATE_SCHEMA_KEEP:-${VALIDATE_KEEP:-false}}"
verbosity="${VALIDATE_SCHEMA_VERBOSITY:-${VALIDATE_VERBOSITY:-1}}"

while [ $# -gt 0 ]; do
  case "$1" in
  -k | --keep)
    keep=true
    shift
    ;;
  -l | --list)
    git ls-files \
      '*.json' '*.jsonc' '*.json5' '*.toml' '*.yaml' '*.yml' \
      ':(exclude)home/.chezmoitemplates/' \
      ':(exclude)**/modify_*'
    exit
    ;;
  -q | --quiet)
    verbosity=0
    shift
    ;;
  -v | --verbose)
    verbosity=2
    shift
    ;;
  -h | --help)
    if command -v usage >/dev/null; then
      usage exec --help bash "$0"
    else
      echo "Usage: validate-schema [-k] [-l] [-q] [-v] [files...]"
    fi
    exit
    ;;
  --usage)
    grep '^#USAGE' "$0" | sed 's/^#USAGE //'
    exit
    ;;
  --)
    shift
    break
    ;;
  -*)
    echo "${0##*/}: unknown option: $1" >&2
    exit 2
    ;;
  *) break ;;
  esac
done

# shellcheck disable=SC2329
validate_file() {
  local path="$1" base ext content schema="" tmp_dir="" schema_path content_path
  base="$(basename "$path")"
  ext="${path##*.}"

  if [ ! -e "$path" ]; then
    echo "FAIL $path schema= (file not found)"
    return 1
  fi

  case "$base" in
  cspell.json | devcontainer.json)
    ext=jsonc
    ;;
  esac

  case "$ext" in
  json)
    schema=$(jq -r 'if type == "object" then ."$schema" // empty else empty end' "$path") || schema=
    ;;
  jsonc | json5)
    if command -v json5 >/dev/null; then
      schema=$(json5 "$path" | jq -r 'if type == "object" then ."$schema" // empty else empty end') || schema=
    else
      schema=$(jq -r 'if type == "object" then ."$schema" // empty else empty end' "$path") || schema=
    fi
    ;;
  toml)
    # shellcheck disable=SC2016
    schema=$(yq '."$schema"' "$path") || schema=
    ;;
  yaml | yml)
    # shellcheck disable=SC2016
    schema=$(yq 'select(kind == "map") | ."$schema"' "$path") || schema=
    ;;
  esac
  if [ "$schema" = "null" ]; then
    schema=
  fi

  if [ -z "$schema" ]; then
    echo "SKIP $path (no \$schema)"
    return 0
  fi

  # Convert .jsonc/.json5 to .json for validation
  case "$ext" in
  jsonc | json5)
    if command -v json5 >/dev/null; then
      content=$(json5 "$path")
    else
      content=$(jq '.' "$path")
    fi
    if [ "$content" = "null" ]; then
      content='{}'
    fi
    tmp_dir=$(mktemp -d)
    # shellcheck disable=SC2064
    trap "rm -rf '$tmp_dir'" EXIT
    content_path="$tmp_dir/${path#/}"
    content_path="${content_path%.*}.json"
    mkdir -p "$(dirname "$content_path")"
    printf '%s' "$content" >"$content_path"
    ;;
  *)
    content_path="$path"
    ;;
  esac

  schema_path="$schema"
  case "$schema" in
  https://aka.ms/winget-packages.schema.2.0.json)
    case "$(uname -s)" in
    MINGW* | MSYS* | CYGWIN* | Windows*) ;;
    *)
      echo "SKIP $path (windows)"
      return 0
      ;;
    esac
    if [ -z "${tmp_dir:-}" ]; then
      tmp_dir=$(mktemp -d)
      # shellcheck disable=SC2064
      trap "rm -rf '$tmp_dir'" EXIT
    fi
    schema_path="$tmp_dir/schema.json"
    if ! curl -fsSL "$schema" -o "$schema_path"; then
      echo "FAIL $path schema=$schema: failed to download schema"
      return 1
    fi
    jq 'del(.properties.WinGetVersion)' "$schema_path" >"$schema_path.tmp"
    mv "$schema_path.tmp" "$schema_path"
    if [ "$verbosity" -ge 2 ]; then
      echo "$prog: downloaded and modified schema: $schema_path" >&2
    fi
    ;;
  esac

  if [ "$verbosity" -ge 2 ]; then
    echo "$prog: validating $path${tmp_dir:+ (temp dir: $tmp_dir)}" >&2
  fi

  local result
  if result=$(check-jsonschema --schemafile "$schema_path" "$content_path" 2>&1); then
    echo "PASS $path schema=$schema"
    return 0
  else
    echo "FAIL $path schema=$schema"
    if [ "$keep" = true ] && [ -n "$tmp_dir" ]; then
      echo "  file: $content_path" >&2
      echo "  schema: $schema_path" >&2
      trap - EXIT
    fi
    echo "$result"
    return 1
  fi
}
export -f validate_file

# shellcheck disable=SC2329
validate_schema() {
  local output exit_code=0
  output=$(validate_file "$1") || exit_code=$?
  echo "$output"
  if [ "$exit_code" -ne 0 ]; then
    if ! echo "$output" | grep -qE '^FAIL '; then
      echo "FAIL $1 schema= (crashed with exit $exit_code)" >&2
    fi
    return 1
  fi
  # Silent exit 0 is valid when SKIP lines are suppressed in non-verbose mode
  if [ -n "$output" ] && ! echo "$output" | grep -qE '^(PASS|FAIL|SKIP) '; then
    echo "FAIL $1 schema= (unexpected output)" >&2
    return 1
  fi
  return 0
}
export -f validate_schema

for cmd in check-jsonschema jq yq; do
  if ! command -v "$cmd" >/dev/null; then
    echo "error: $cmd is required" >&2
    exit 1
  fi
done

if ! yq --version 2>&1 | grep -q 'mikefarah/yq'; then
  echo "error: yq (mikefarah/yq) is required; found $(yq --version 2>&1 | head -1)" >&2
  exit 1
fi

if [ $# -eq 0 ]; then
  mapfile -t files < <("$0" --list)
  set -- "${files[@]}"
fi

jobs="${NPROC:-$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4)}"

if [ "$verbosity" -ge 2 ]; then
  echo "${0##*/}: validating $# files (jobs=$jobs)" >&2
fi

if [ $# -eq 0 ]; then
  if [ "$verbosity" -ge 1 ]; then
    echo "${0##*/}: no files to validate" >&2
  fi
  exit 0
fi

export prog verbosity keep
# shellcheck disable=SC2016
results=$(printf '%s\0' "$@" | xargs -0 -P "$jobs" -n1 bash -euc 'validate_schema "$1"' _ || true)

passed=$(echo "$results" | grep -c '^PASS ' || true)
failed=$(echo "$results" | grep -c '^FAIL ' || true)
skipped=$(echo "$results" | grep -c '^SKIP ' || true)

if [ "$verbosity" -ge 2 ]; then
  echo "$results" | grep -E '^(PASS|FAIL|SKIP) ' || true
else
  echo "$results" | grep -E '^FAIL ' || true
fi
if [ "$failed" -gt 0 ]; then
  echo "$results" | grep -vE '^(PASS|FAIL|SKIP) ' || true
fi
if [ "$verbosity" -ge 1 ] && [ "$((passed + failed + skipped))" -gt 0 ]; then
  echo "${0##*/}: $passed passed, $failed failed, $skipped skipped" >&2
fi
if [ "$failed" -gt 0 ]; then
  exit 1
fi
exit 0
