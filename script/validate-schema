#!/usr/bin/env bash
#MISE description="Validate files against their declared $schema"
# Requires: check-jsonschema, jq, yq

set -euo pipefail

for cmd in check-jsonschema jq yq; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf >&2 'error: %s is required\n' "$cmd"
    exit 1
  fi
done

# Validator (exported for parallel execution)
validate_schema() {
  path="$1"
  ext="${path##*.}"

  if [[ "$path" == *"/sandboxed/"* ]]; then
    printf >&2 "skip: %s (sandboxed)\n" "$path"
    return 0
  fi

  if [ ! -e "$path" ]; then
    printf >&2 "FAIL: %s (not found)\n" "$path"
    return 1
  fi

  # printf >&2 "validating schema: %s\n" "$path"

  if [ "$(basename "$path")" = devcontainer.json ]; then
    ext=jsonc
  fi

  # Extract $schema
  schema=
  if [ "$ext" = "json" ]; then
    schema=$(jq -r '."$schema" // empty' "$path" 2>/dev/null)
  elif [ "$ext" = "jsonc" ] || [ "$ext" = "json5" ]; then
    if command -v json5 >/dev/null 2>&1; then
      schema=$(json5 "$path" 2>/dev/null | jq -r '."$schema" // empty' 2>/dev/null)
    fi
  elif [ "$ext" = "toml" ]; then
    # shellcheck disable=SC2016
    schema=$(yq -p toml '."$schema"' "$path" 2>/dev/null)
  elif [ "$ext" = "yaml" ] || [ "$ext" = "yml" ]; then
    # shellcheck disable=SC2016
    schema=$(yq '."$schema"' "$path" 2>/dev/null)
  fi
  if [ "$schema" = "null" ]; then
    schema=
  fi

  # Normalize content
  if [ "$ext" = "jsonc" ] || [ "$ext" = "json5" ]; then
    content=$(json5 "$path" 2>/dev/null)
  elif [ "$ext" = "toml" ]; then
    content=$(yq -p toml -o json "$path" 2>/dev/null)
  elif [ "$ext" = "yaml" ] || [ "$ext" = "yml" ]; then
    content=$(yq -o json "$path" 2>/dev/null)
  else
    content=$(cat "$path")
  fi
  if [ "$content" = "null" ]; then
    content={}
  fi

  # Build check-jsonschema arguments
  # TODO: ensure schema is inferred from path, name or content when possible
  args=()
  if [ -n "$schema" ]; then
    args+=(--schemafile "$schema")
  else
    args+=(--check-metaschema)
  fi

  # Validate one file
  if output=$(printf "%s" "$content" | check-jsonschema "${args[@]}" - 2>&1); then
    printf >&2 "ok: %s\n" "$path"
  else
    printf >&2 "FAIL: %s (content: %s)\n" "$path" "$content"
    printf >&2 "%s\n" "$output"
    return 1
  fi
}
export -f validate_schema

# Collect schema files
if [ $# -eq 0 ]; then
  mapfile -t files < <(
    find . -type f \
      \( -name "*.json" -o -name "*.jsonc" -o -name "*.json5" \
      -o -name "*.toml" -o -name "*.yaml" -o -name "*.yml" \) \
      -not -path './output/*' \
      -not -path './.git/*' \
      -not -path './home/.chezmoitemplates/*' \
      -not -path '*/modify_*'
  )
else
  files=("$@")
fi

if [ ${#files[@]} -eq 0 ]; then
  printf >&2 "No schemas to validate\n"
  exit 0
fi

# TODO: --halt now,fail=1
printf '%s\n' "${files[@]}" |
  parallel --line-buffer -P "$(getconf _NPROCESSORS_ONLN)" validate_schema 2>/dev/null

# TODO: count errors, warnings, skipped, and ignored (no schema)
printf >&2 "%d schemas(s) validated\n" "${#files[@]}"
