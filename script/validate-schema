#!/usr/bin/env bash
#MISE description="Validate files against their declared $schema"
# Validates files with an inline $schema against it.
# Files without $schema are skipped (use check-jsonschema builtin hooks
# in .pre-commit-config.yaml for SchemaStore auto-detection).

set -euo pipefail

for cmd in check-jsonschema jq yq; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo >&2 "error: $cmd is required"
    exit 1
  fi
done

# shellcheck disable=SC2329
validate_schema() {
  local path="$1" base ext content schema output
  base="$(basename "$path")"
  ext="${path##*.}"

  if [ ! -e "$path" ]; then
    echo "FAIL $path (not found)"
    return 1
  fi

  case "$base" in
  cspell.json | devcontainer.json) ext=jsonc ;;
  esac

  # Extract $schema
  schema=
  # shellcheck disable=SC2016
  case "$ext" in
  json) schema=$(jq -r '."$schema" // empty' "$path" 2>/dev/null) ;;
  jsonc | json5) command -v json5 >/dev/null 2>&1 && schema=$(json5 "$path" 2>/dev/null | jq -r '."$schema" // empty' 2>/dev/null) ;;
  toml) schema=$(yq -p toml '."$schema"' "$path" 2>/dev/null) ;;
  yaml | yml) schema=$(yq '."$schema"' "$path" 2>/dev/null) ;;
  esac
  if [ "${schema:-null}" = "null" ]; then
    schema=
  fi

  if [ -z "$schema" ]; then
    echo "SKIP $path"
    return 0
  fi

  # Normalize content to JSON
  case "$ext" in
  jsonc | json5) content=$(json5 "$path" 2>/dev/null) ;;
  toml) content=$(yq -p toml -o json "$path" 2>/dev/null) ;;
  yaml | yml) content=$(yq -o json "$path" 2>/dev/null) ;;
  *) content=$(<"$path") ;;
  esac
  if [ "$content" = "null" ]; then
    content='{}'
  fi

  if output=$(printf '%s' "$content" | check-jsonschema --schemafile "$schema" - 2>&1); then
    echo "PASS $path"
  else
    printf 'FAIL %s\n%s\n' "$path" "$output"
    return 1
  fi
}
export -f validate_schema

# Collect files: from args (pre-commit) or find all
if [ $# -eq 0 ]; then
  mapfile -t files < <(
    git ls-files -z \
      '*.json' '*.jsonc' '*.json5' '*.toml' '*.yaml' '*.yml' \
      ':(exclude)home/.chezmoitemplates/' \
      ':(exclude)**/modify_*' |
      tr '\0' '\n'
  )
  set -- "${files[@]}"
fi

if [ $# -eq 0 ]; then
  echo >&2 "no files to validate"
  exit 0
fi

# shellcheck disable=SC2016
results=$(printf '%s\n' "$@" | xargs -P "$(nproc 2>/dev/null || echo 4)" -n1 bash -c 'validate_schema "$1"' _ 2>&1 || true)

passed=$(echo "$results" | grep -c '^PASS ' || true)
failed=$(echo "$results" | grep -c '^FAIL ' || true)
skipped=$(echo "$results" | grep -c '^SKIP ' || true)

if [ "$failed" -gt 0 ]; then
  echo "$results" | grep -v '^PASS \|^SKIP ' >&2
fi
echo >&2 "$passed passed, $failed failed, $skipped skipped"
exit $((failed > 0 ? 1 : 0))
