#!/usr/bin/env bash
#MISE hide=true
#MISE description="Validate files against their declared $schema"
# Requires: check-jsonschema, jq, yq

set -euo pipefail

for cmd in check-jsonschema jq yq; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf >&2 'error: %s is required\n' "$cmd"
    exit 1
  fi
done

# Validator (exported for parallel execution)
validate_schema() {
  file="$1"
  ext="${file##*.}"

  # Check existence
  if [ ! -e "$file" ]; then
    printf "FAIL: %s (not found)\n" "$file"
    return 1
  fi

  # Extract $schema - skip silently if can't parse
  schema=""
  if [ "$ext" = "json" ]; then
    schema=$(jq -r '."$schema" // empty' "$file" 2>/dev/null)
  elif [ "$ext" = "jsonc" ] || [ "$ext" = "json5" ]; then
    if command -v json5 >/dev/null 2>&1; then
      schema=$(json5 "$file" 2>/dev/null | jq -r '."$schema" // empty' 2>/dev/null)
    fi
  elif [ "$ext" = "toml" ]; then
    # shellcheck disable=SC2016
    schema=$(yq -p toml '."$schema"' "$file" 2>/dev/null)
  elif [ "$ext" = "yaml" ] || [ "$ext" = "yml" ]; then
    # shellcheck disable=SC2016
    schema=$(yq '."$schema"' "$file" 2>/dev/null)
  fi

  # Skip if no schema
  if [ -z "$schema" ] || [ "$schema" = "null" ]; then
    # printf "skip: %s (no \$schema)\n" "$file"
    return 0
  fi

  # printf "validate: %s\n" "$file"

  # Normalize content
  if [ "$ext" = "jsonc" ] || [ "$ext" = "json5" ]; then
    content=$(json5 "$file" 2>/dev/null) || return 0
  elif [ "$ext" = "toml" ]; then
    content=$(yq -p toml -o json "$file" 2>/dev/null) || return 0
  elif [ "$ext" = "yaml" ] || [ "$ext" = "yml" ]; then
    content=$(yq -o json "$file" 2>/dev/null) || return 0
  else
    content=$(cat "$file")
  fi

  # Validate
  if output=$(printf "%s" "$content" | check-jsonschema --schemafile "$schema" - 2>&1); then
    printf "ok: %s\n" "$file"
  else
    printf "FAIL: %s\n" "$file"
    printf "%s\n" "$output"
    return 1
  fi
}
export -f validate_schema

# Collect files
if [ $# -eq 0 ]; then
  mapfile -t files < <(
    find . -type f \
      \( -name "*.json" -o -name "*.jsonc" -o -name "*.json5" \
         -o -name "*.toml" -o -name "*.yaml" -o -name "*.yml" \) \
      -not -path './output/*' \
      -not -path './.git/*' \
      -not -path './home/.chezmoitemplates/*' \
      -not -path '*/modify_*'
  )
else
  files=("$@")
fi

[ ${#files[@]} -eq 0 ] && exit 0

printf '%s\n' "${files[@]}" \
  | parallel --line-buffer --halt now,fail=1 -P "$(getconf _NPROCESSORS_ONLN)" validate_schema 2>/dev/null
