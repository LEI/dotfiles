#!/usr/bin/env bash
#MISE alias="vm"
#MISE description="Run VM by image alias (tart/vetu)"
#USAGE flag "-d... --dir <dir>" help="Mount host directory in the VM (name:path)"
#USAGE flag "-g --gui" help="Open native window (tart only; default headless)"
#USAGE flag "-h --help" help="Show help"
#USAGE flag "-k --keep" help="Keep VM running after exit"
#USAGE flag "-l --list-images" help="List available images for current architecture"
#USAGE flag "-n --name <name>" help="VM name (default: same as image alias)"
#USAGE flag "-q --quiet" help="Use quiet output"
#USAGE flag "-t --tmux" help="Run VM in a tmux session"
#USAGE flag "-u --usage" help="Show usage specification"
#USAGE flag "-v --verbose" help="Use verbose output"
#USAGE arg "[image]" help="Image alias or provider subcommand (default: --help)"
#USAGE complete "image" run="./script/vm --list-images"
#USAGE arg "[args]..." help="Command to run in the VM (alias mode), or provider args (passthrough)"

set -euo pipefail
shopt -s inherit_errexit

lib_dir="${BASH_SOURCE[0]%/*}/../home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
source "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/usage.sh
source "$lib_dir/sh/usage.sh"
# shellcheck source=home/dot_local/lib/bash/require.sh
source "$lib_dir/bash/require.sh"

require_bash 4
trap 'log "error at line $LINENO"' ERR

: "${VM_HEALTH_TARGET:=github.com:443}"

if [ -z "${VM_PROVIDER:-}" ]; then
  case "$(uname -s)" in
  Darwin) VM_PROVIDER=tart ;;
  Linux) VM_PROVIDER=vetu ;;
  *)
    err "unsupported OS: $(uname -s)"
    exit 1
    ;;
  esac
fi

case "$(uname -m)" in
x86_64) ARCH=amd64 ;;
aarch64 | arm64) ARCH=arm64 ;;
*)
  err "unsupported arch: $(uname -m)"
  exit 1
  ;;
esac

declare -gA IMAGES=(
  ["ubuntu-runner"]="ghcr.io/cirruslabs/ubuntu-runner-$ARCH:24.04|ubuntu-runner|linux"
  ["ubuntu-runner-gpu"]="ghcr.io/cirruslabs/ubuntu-runner-amd64-gpu:latest|ubuntu-runner-gpu|linux"
)
if [ "$ARCH" = arm64 ]; then
  IMAGES+=(["debian"]="ghcr.io/cirruslabs/debian:latest|debian|linux")
  IMAGES+=(["fedora"]="ghcr.io/cirruslabs/fedora:latest|fedora|linux")
  IMAGES+=(["rocky"]="ghcr.io/cirruslabs/rocky:latest|rocky|linux")
  IMAGES+=(["ubuntu"]="ghcr.io/cirruslabs/ubuntu:latest|ubuntu|linux")
  IMAGES+=(["tahoe"]="ghcr.io/cirruslabs/macos-tahoe-base:latest|tahoe-base|darwin")
fi
readonly IMAGES

vm() { trace "$VM_PROVIDER" "$@"; }

state() {
  case "$VM_PROVIDER" in
  tart) vm list --format json |
    jq --raw-output --arg name "$1" '.[] | select(.Name==$name) | .State' ;;
  *) vm list | awk -v n="$1" '$0 ~ ("\t" n " ") {print $4}' ;;
  esac
}

clone() {
  log "cloning $image as $name"
  vm clone "$image" "$name"
}

start() {
  log "starting $name"
  local args=()
  if [ "$VM_PROVIDER" = tart ]; then
    [ "$gui" = true ] || args+=(--no-graphics)
    local entry
    for entry in $dirs; do
      args+=("--dir=$entry")
    done
  elif [ "$gui" = true ]; then
    warn "$VM_PROVIDER: --gui not supported, running headless"
  fi
  if [ "$tmux" = true ] && ! tmux ls 2>/dev/null | grep -q '^vm: '; then
    trace tmux new-session -d -s vm "$VM_PROVIDER run ${args[*]} $name"
    return
  fi
  local vm_log="/tmp/${VM_PROVIDER}-${name}.log"
  if [ "$verbosity" -ge 2 ]; then
    vm run "${args[@]}" "$name" 2>&1 | tee "$vm_log" &
  else
    vm run "${args[@]}" "$name" 2>&1 1>/dev/null | tee "$vm_log" >&2 &
  fi
  sleep 1
}

fmt_duration() {
  local total=$1
  if [ "$total" -ge 3600 ]; then
    printf '%dh %dm' $((total / 3600)) $(((total % 3600) / 60))
  elif [ "$total" -ge 60 ]; then
    printf '%dm %ds' $((total / 60)) $((total % 60))
  else
    printf '%ds' "$total"
  fi
}

with_timeout() {
  if command -v gtimeout >/dev/null 2>&1; then
    gtimeout "$1" "${@:2}"
  elif command -v timeout >/dev/null 2>&1; then
    timeout "$1" "${@:2}"
  else
    "${@:2}"
  fi
}

wait_for() {
  local label="$1" timeout_sec="$2"
  shift 2
  local out start deadline rc=0 per_attempt
  start=$SECONDS
  deadline=$((SECONDS + timeout_sec))
  per_attempt=$((timeout_sec < 5 ? timeout_sec : 5))
  out=$(mktemp)
  log "waiting for $label (up to $(fmt_duration "$timeout_sec"))"
  until with_timeout "$per_attempt" "$@" </dev/null >"$out" 2>&1; do
    if [ "$SECONDS" -ge "$deadline" ]; then
      printf '\n' >&2
      err "timeout waiting for $label after $(fmt_duration "$((SECONDS - start))")"
      if [ -s "$out" ]; then
        log "last attempt:"
        sed 's/^/  /' "$out" >&2
      fi
      rc=1
      break
    fi
    printf '.' >&2
    sleep 1
  done
  if [ "$rc" = 0 ]; then
    [ "$SECONDS" -gt "$start" ] && printf '\n' >&2
    log "$label ready after $(fmt_duration "$((SECONDS - start))")"
  fi
  rm -f "$out"
  return "$rc"
}

host_route_iface() {
  case "$(uname -s)" in
  Darwin) route -n get "$1" 2>/dev/null | awk '/interface:/ {print $2}' ;;
  Linux) ip -o route get "$1" 2>/dev/null | awk '/dev/ {for (i=1; i<=NF; i++) if ($i == "dev") print $(i+1)}' ;;
  esac
}

wait_reachable() {
  local timeout=120
  [ "$guest_os" = darwin ] && timeout=500
  if [ "$VM_PROVIDER" = tart ]; then
    wait_for "host->guest agent" "$timeout" "$VM_PROVIDER" exec "$name" true
  else
    log "waiting for IP"
    ssh_host="$(vm ip --wait=30 "$name")"
    wait_for "host->guest $ssh_host:$ssh_port" "$timeout" nc -z -w2 "$ssh_host" "$ssh_port"
  fi
}

wait_network() {
  local host="${VM_HEALTH_TARGET%:*}" port="${VM_HEALTH_TARGET#*:}"
  local iface
  iface="$(host_route_iface "$host")"
  log "host route to $host: ${iface:-unknown}"
  case "$iface" in
  utun*)
    err "$host is tunneled via $iface; guest cannot reach internet"
    log "hint: split-tunnel or disconnect, then retry"
    return 1
    ;;
  esac
  local probe=()
  if [ "$VM_PROVIDER" = tart ]; then
    probe=("$VM_PROVIDER" exec "$name")
  else
    : "${ssh_host:=$(vm ip "$name")}"
    probe=(sshpass -e ssh -o StrictHostKeyChecking=no -p "$ssh_port" "admin@$ssh_host")
    export SSHPASS=admin
  fi
  if [ "$guest_os" = linux ]; then
    wait_for "guest->net DNS $host" 10 "${probe[@]}" getent hosts "$host" || return 1
  fi
  wait_for "guest->net TCP $VM_HEALTH_TARGET" 10 "${probe[@]}" nc -z -w3 "$host" "$port"
}

mount_dirs() {
  [ -n "$dirs" ] || return 0
  if [ "$VM_PROVIDER" != tart ]; then
    warn "$VM_PROVIDER does not support host directory sharing"
    return 0
  fi
  if [ "$guest_os" = darwin ]; then
    log "skipping virtiofs mount (auto-mounted on macOS guests)"
    return 0
  fi
  local entry tag
  for entry in $dirs; do
    case "$entry" in
    *:*) tag="${entry%%:*}" ;;
    *) tag="${entry##*/}" ;;
    esac
    log "mounting $tag"
    # shellcheck disable=SC2016
    vm_exec sh -euc '
      mp="$HOME/.local/share/$1"
      mkdir -p "$mp"
      sudo modprobe virtiofs 2>/dev/null
      sudo mount -t virtiofs "$1" "$mp"
    ' -- "$tag"
  done
}

real_tty() { [ -t 0 ] && [ -t 1 ]; }

vm_exec() {
  if [ "$VM_PROVIDER" = tart ]; then
    local flags=()
    real_tty && flags=(-it)
    vm exec "${flags[@]}" "$name" "$@"
  else
    local ssh_args=(
      -o StrictHostKeyChecking=no
      -o ConnectTimeout=60
      -p "$ssh_port"
    )
    real_tty && ssh_args=(-t "${ssh_args[@]}")
    # shellcheck disable=SC2209
    SSHPASS=admin trace sshpass -e ssh "${ssh_args[@]}" "admin@$ssh_host" "$@"
  fi
}

vm_exec_cmd() {
  local env_args=(
    CHEZMOI_UPGRADE=true
    "MISE_TRUSTED_CONFIG_PATHS=$chezmoi_root"
  )
  [ -n "${CI:-}" ] && env_args+=("CI=$CI")
  env_args+=("CHEZMOI_PROFILE=${CHEZMOI_PROFILE:-minimal}")
  [ -n "${GITHUB_TOKEN:-}" ] && env_args+=("GITHUB_TOKEN=$GITHUB_TOKEN")
  [ -n "${TERM:-}" ] && env_args+=("TERM=$TERM")
  # bash -l sources ~/.profile for PATH and environment.d setup.
  # mise activate runs only after chezmoi has installed mise.
  # shellcheck disable=SC2016
  vm_exec env "${env_args[@]}" bash -lc '
    cd "$1" || exit
    shift
    [ "$BASH" = "$SHELL" ] || export SHELL="$BASH"
    [ -f ~/.config/mise/init.sh ] && . ~/.config/mise/init.sh
    exec "$@"
  ' -- "$chezmoi_root" "$@"
}

stop() {
  log "stopping $name"
  vm stop "$name"
}

restore_tty() {
  [ -n "${tty_state:-}" ] && stty "$tty_state" </dev/tty 2>/dev/null || true
}

teardown() {
  if [ "$tmux" = true ] && tmux ls 2>/dev/null | grep -q '^vm: '; then
    log "killing tmux session"
    trace tmux kill-session -t vm
  fi
  stop
}

# tart 2.32.1 lacks cp and crashes on stdin redirect through tart exec -i
# Refuse to clean any path that does not look like a chezmoi root inside a guest
assert_safe_chezmoi_root() {
  case "$1" in
  /Volumes/*)
    err "refusing to clean mount_dirs path: $1"
    return 1
    ;;
  */.local/share/chezmoi) return 0 ;;
  *)
    err "refusing to clean unexpected path: $1"
    return 1
    ;;
  esac
}

cp_chmod() {
  local src="$1" dst="$2" b64
  if [ "$VM_PROVIDER" = tart ]; then
    b64="$(base64 <"$src")"
    # shellcheck disable=SC2016
    vm_exec sh -euc \
      'printf "%s" "$1" | base64 -d >"$2" && chmod +x "$2"' \
      -- "$b64" "$dst"
  else
    : "${ssh_host:=$(vm ip "$name")}"
    # shellcheck disable=SC2209
    SSHPASS=admin trace sshpass -e scp -o StrictHostKeyChecking=no -P "$ssh_port" \
      "$src" "admin@$ssh_host:$dst"
  fi
}

sync_source() {
  if [ "$VM_PROVIDER" = tart ] && [ "$guest_os" = darwin ]; then
    return 0
  fi
  assert_safe_chezmoi_root "$chezmoi_root" || return 1
  if [ "$VM_PROVIDER" = tart ]; then
    require_cmd tar
    log "copying $PWD to $name:$chezmoi_root via tar stream"
    # Host tar may emit AppleDouble entries; exclude ._* on both ends
    if ! trace tar --no-xattrs \
      --exclude='.DS_Store' --exclude='._*' --exclude='*/._*' \
      -cf - -C "$PWD" . |
      "$VM_PROVIDER" exec -i "$name" bash -euc "rm -rf '$chezmoi_root' && mkdir -p '$chezmoi_root' && tar xf - -C '$chezmoi_root' --exclude='._*'"; then
      err "tar stream failed: $PWD to $name:$chezmoi_root"
      return 1
    fi
    return 0
  fi
  log "syncing chezmoi to $chezmoi_root"
  : "${ssh_host:=$(vm ip "$name")}"
  local ssh_args=(-o StrictHostKeyChecking=no -p "$ssh_port")
  # shellcheck disable=SC2209
  SSHPASS=admin trace sshpass -e ssh "${ssh_args[@]}" "admin@$ssh_host" \
    "rm -rf '$chezmoi_root' && mkdir -p '$chezmoi_root'"
  # shellcheck disable=SC2209
  trace tar c .chezmoiroot .chezmoiversion .editorconfig .gitignore \
    .pre-commit-config.yaml mise.toml home script test |
    SSHPASS=admin trace sshpass -e ssh "${ssh_args[@]}" "admin@$ssh_host" \
      "tar x -C '$chezmoi_root'"
}

resolve() {
  local target="$1"
  if [ -n "${IMAGES[$target]:-}" ]; then
    IFS='|' read -r image default_name guest_os <<<"${IMAGES[$target]}"
  elif [[ $target == */* ]]; then
    image="$target"
    default_name="${target##*/}"
    default_name="${default_name%:*}"
    guest_os="${VM_GUEST_OS:-linux}"
  else
    local available
    available="$(printf '%s\n' "${!IMAGES[@]}" | sort | tr '\n' ' ' | sed 's/ $//')"
    err "unknown image: $target"
    log "available images for $ARCH: $available"
    return 1
  fi

  case "$guest_os" in
  darwin) home=/Users/admin ;;
  *) home=/home/admin ;;
  esac

  chezmoi_root="$home/.local/share/chezmoi"
  if [ "$VM_PROVIDER" = tart ] && [ "$guest_os" = darwin ]; then
    chezmoi_root="/Volumes/My Shared Files/chezmoi"
    : "${dirs:=chezmoi:$PWD:ro}"
  fi
}

ensure_vm() {
  : "${name:=$default_name}"
  ssh_host=""
  ssh_port=22
  state="$(state "$name")"

  [ -z "$state" ] && clone

  if [ "$state" != running ]; then
    start
    wait_reachable
    mount_dirs
  else
    log "reusing running VM"
    [ "$dirs_explicit" = true ] && warn "--dir mounts require a fresh start"
    wait_reachable
  fi
  wait_network
}

# Persist mise trust so later runs skip the prompt
trust() {
  # shellcheck disable=SC2016
  vm_exec sh -euc '
    [ -f "$1" ] && command -v mise >/dev/null && mise trust --yes "$1" || true
  ' -- "$chezmoi_root/mise.toml"
}

bootstrap() {
  vm_exec_cmd ./script/bootstrap --no-tty --source="$chezmoi_root" --verbose
}

init_repo() {
  # Skip if no chezmoi source yet so bootstrap can populate first.
  # Skip if .git already present from mount or clone.
  if ! vm_exec test -f "$chezmoi_root/.chezmoiroot"; then
    return 0
  fi
  if vm_exec test -d "$chezmoi_root/.git"; then
    return 0
  fi
  # shellcheck disable=SC2016
  vm_exec sh -euc '
    git config --global --add safe.directory "$1"
    git -C "$1" init --quiet
    git -C "$1" add --all
  ' -- "$chezmoi_root"
}

pipeline() {
  sync_source
  trust
  bootstrap
  init_repo
  vm_exec_cmd mise run pipeline
}

cmd_run() {
  local target="$1"
  shift

  resolve "$target"
  ensure_vm

  if [ "$#" -eq 0 ]; then
    pipeline
  else
    vm_exec_cmd "$@"
  fi

  # Stop only if we started it and user did not pass -k
  if [ "$state" != running ] && [ "$keep" != true ]; then
    teardown
  fi
}

# Parse flags from "$@" and store remaining args in ARGS
# Globals modified: dirs, gui, keep, name, tmux, verbosity, ARGS
parse_flags() {
  ARGS=()
  while [ $# -gt 0 ]; do
    case "$1" in
    -h | --help)
      usage_help
      exit 0
      ;;
    --usage)
      usage_spec
      exit 0
      ;;
    -d | --dir)
      dirs="${dirs:+$dirs }$2"
      dirs_explicit=true
      shift 2
      ;;
    -g | --gui)
      gui=true
      shift
      ;;
    -k | --keep)
      keep=true
      shift
      ;;
    -n | --name)
      name="$2"
      shift 2
      ;;
    -q | --quiet)
      verbosity=0
      shift
      ;;
    -t | --tmux)
      tmux=true
      shift
      ;;
    -v | --verbose)
      verbosity=2
      shift
      ;;
    --)
      shift
      break
      ;;
    --*)
      err "unknown option: $1"
      exit 2
      ;;
    -*)
      local opt="${1#-}"
      shift
      while [ -n "$opt" ]; do
        case "${opt:0:1}" in
        d)
          dirs="${dirs:+$dirs }$1"
          dirs_explicit=true
          shift
          ;;
        g) gui=true ;;
        k) keep=true ;;
        n)
          name="$1"
          shift
          ;;
        q) verbosity=0 ;;
        t) tmux=true ;;
        v) verbosity=2 ;;
        *)
          err "unknown option: -${opt:0:1}"
          exit 2
          ;;
        esac
        opt="${opt:1}"
      done
      ;;
    *) break ;;
    esac
  done
  ARGS=("$@")
}

main() {
  case "${1:-}" in
  '' | -h | --help)
    usage_help
    return
    ;;
  --usage)
    usage_spec
    return
    ;;
  --list-images)
    printf '%s\n' "${!IMAGES[@]}" | sort
    return
    ;;
  --)
    shift
    exec "$VM_PROVIDER" "$@"
    ;;
  esac

  tty_state=$(stty -g </dev/tty 2>/dev/null || true)
  trap restore_tty EXIT

  require_cmd "$VM_PROVIDER"
  [ "$VM_PROVIDER" = tart ] || require_cmd sshpass

  if [ -n "${IMAGES[$1]:-}" ] || [[ $1 == */* ]]; then
    local target="$1"
    shift
    dirs="${VM_DIRS:-}"
    dirs_explicit=false
    gui="${VM_GUI:-false}"
    keep="${VM_KEEP:-false}"
    name="${VM_NAME:-}"
    tmux="${VM_TMUX:-false}"
    verbosity="${VM_VERBOSITY:-1}"
    parse_flags "$@"
    cmd_run "$target" "${ARGS[@]}"
  else
    exec "$VM_PROVIDER" "$@"
  fi
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  main "$@"
fi
