#!/usr/bin/env bash
#MISE alias="vm"
#MISE description="Run VM by image alias (tart/vetu)"
#USAGE flag "-d... --dir <dir>" help="Mount host directory in the VM (name:path)"
#USAGE flag "-g --gui" help="Open native window (tart only; default headless)"
#USAGE flag "-h --help" help="Show help"
#USAGE flag "-k --keep" help="Keep VM running after exit"
#USAGE flag "-l --list-images" help="List available images for current architecture"
#USAGE flag "-n --name <name>" help="VM name (default: same as image alias)"
#USAGE flag "-q --quiet" help="Use quiet output"
#USAGE flag "-t --tmux" help="Run VM in a tmux session"
#USAGE flag "-u --usage" help="Show usage specification"
#USAGE flag "-v --verbose" help="Use verbose output"
#USAGE arg "[image]" help="Image alias or provider subcommand (default: --help)"
#USAGE complete "image" run="./script/vm --list-images"
#USAGE arg "[args]..." help="Command to run in the VM (alias mode), or provider args (passthrough)"

set -euo pipefail
shopt -s inherit_errexit

lib_dir="${BASH_SOURCE[0]%/*}/../home/dot_local/lib"
# shellcheck source=home/dot_local/lib/sh/log.sh
source "$lib_dir/sh/log.sh"
# shellcheck source=home/dot_local/lib/sh/usage.sh
source "$lib_dir/sh/usage.sh"
# shellcheck source=home/dot_local/lib/bash/require.sh
source "$lib_dir/bash/require.sh"

require_bash 4
trap 'log "error at line $LINENO"' ERR

readonly PROG="${0##*/}"

if [ -z "${VM_PROVIDER:-}" ]; then
  case "$(uname -s)" in
  Darwin) VM_PROVIDER=tart ;;
  Linux) VM_PROVIDER=vetu ;;
  *)
    msg "$PROG: unsupported OS: $(uname -s)"
    exit 1
    ;;
  esac
fi

case "$(uname -m)" in
x86_64) ARCH=amd64 ;;
aarch64 | arm64) ARCH=arm64 ;;
*)
  msg "$PROG: unsupported arch: $(uname -m)"
  exit 1
  ;;
esac

declare -gA IMAGES=(
  ["ubuntu-runner"]="ghcr.io/cirruslabs/ubuntu-runner-$ARCH:24.04|ubuntu-runner|linux"
  ["ubuntu-runner-gpu"]="ghcr.io/cirruslabs/ubuntu-runner-amd64-gpu:latest|ubuntu-runner-gpu|linux"
)
if [ "$ARCH" = arm64 ]; then
  IMAGES+=(["debian"]="ghcr.io/cirruslabs/debian:latest|debian|linux")
  IMAGES+=(["fedora"]="ghcr.io/cirruslabs/fedora:latest|fedora|linux")
  IMAGES+=(["rocky"]="ghcr.io/cirruslabs/rocky:latest|rocky|linux")
  IMAGES+=(["ubuntu"]="ghcr.io/cirruslabs/ubuntu:latest|ubuntu|linux")
  IMAGES+=(["tahoe"]="ghcr.io/cirruslabs/macos-tahoe-base:latest|tahoe-base|darwin")
fi
readonly IMAGES

vm() { "$VM_PROVIDER" "$@"; }

vm_state() {
  case "$VM_PROVIDER" in
  tart) vm list --format json |
    jq --raw-output --arg name "$1" '.[] | select(.Name==$name) | .State' ;;
  *) vm list | awk -v n="$1" '$0 ~ ("\t" n " ") {print $4}' ;;
  esac
}

vm_clone() {
  log "cloning $image as $name"
  trace vm clone "$image" "$name"
}

vm_start() {
  log "starting $name"
  local args=()
  if [ "$VM_PROVIDER" = tart ]; then
    [ "$gui" = true ] || args+=(--no-graphics)
    local entry
    for entry in $dirs; do
      args+=("--dir=$entry")
    done
  elif [ "$gui" = true ]; then
    warn "$VM_PROVIDER: --gui not supported, running headless"
  fi
  if [ "$tmux" = true ] && ! tmux ls 2>/dev/null | grep -q '^vm: '; then
    trace tmux new-session -d -s vm "$VM_PROVIDER run ${args[*]} $name"
    return
  fi
  local vm_log="/tmp/${VM_PROVIDER}-${name}.log"
  if [ "$verbosity" -ge 2 ]; then
    vm run "${args[@]}" "$name" 2>&1 | tee "$vm_log" &
  else
    vm run "${args[@]}" "$name" 2>&1 1>/dev/null | tee "$vm_log" >&2 &
  fi
  sleep 1
}

vm_wait() {
  if [ "$VM_PROVIDER" = tart ]; then
    log "waiting for guest agent"
    # shellcheck disable=SC2016
    timeout 500 sh -c 'until "$1" exec "$2" true >/dev/null 2>&1; do sleep 2; done' \
      -- "$VM_PROVIDER" "$name"
  else
    log "waiting for IP"
    ssh_host="$(vm ip --wait=30 "$name")"
    log "waiting for SSH on $ssh_host:$ssh_port"
    # shellcheck disable=SC2016
    timeout 500 sh -c 'until nc -z -w2 "$@"; do sleep 2; done' -- "$ssh_host" "$ssh_port"
  fi
}

vm_mount() {
  [ -n "$dirs" ] || return 0
  if [ "$VM_PROVIDER" != tart ]; then
    warn "$VM_PROVIDER does not support host directory sharing"
    return 0
  fi
  if [ "$guest_os" = darwin ]; then
    log "skipping virtiofs mount (auto-mounted on macOS guests)"
    return 0
  fi
  local entry tag
  for entry in $dirs; do
    case "$entry" in
    *:*) tag="${entry%%:*}" ;;
    *) tag="${entry##*/}" ;;
    esac
    log "mounting $tag"
    vm exec "$name" sh -c "mp=\$HOME/.local/share/$tag && mkdir -p \"\$mp\" && sudo modprobe virtiofs 2>/dev/null; sudo mount -t virtiofs $tag \"\$mp\""
  done
}

vm_exec() {
  if [ "$VM_PROVIDER" = tart ]; then
    local flags=()
    [ -t 0 ] && flags=(-it)
    vm exec "${flags[@]}" "$name" "$@"
  else
    local ssh_args=(
      -o StrictHostKeyChecking=no
      -o ConnectTimeout=60
      -p "$ssh_port"
    )
    [ -t 0 ] && ssh_args=(-t "${ssh_args[@]}")
    sshpass -padmin ssh "${ssh_args[@]}" "admin@$ssh_host" "$@"
  fi
}

vm_exec_cmd() {
  log "running command: $*"
  local dir="${XDG_DATA_HOME:-$HOME/.local/share}/chezmoi"
  [ "$VM_PROVIDER" = tart ] && dir="/Volumes/My Shared Files/chezmoi"
  vm_exec sh -l -c "cd \"$dir\" && exec \"\$@\"" -- "$@"
}

vm_stop() {
  log "stopping $name"
  trace vm stop "$name"
}

restore_tty() {
  [ -n "${tty_state:-}" ] && stty "$tty_state" 2>/dev/null || true
}

cleanup() {
  restore_tty
  if [ "$tmux" = true ] && tmux ls 2>/dev/null | grep -q '^vm: '; then
    log "killing tmux session"
    trace tmux kill-session -t vm
  fi
  vm_stop
}

# Copy a host file into the VM. Tart lacks a native cp, and `tart exec -i name
# cmd <file` crashes in 2.32.1 on Linux guests (getTerminalSize ioctl). Avoid
# stdin redirect by base64-encoding the file into the command line for tart;
# vetu has working SSH so sshpass+scp is fine there.
vm_cp() {
  local src="$1" dst="$2" b64
  if [ "$VM_PROVIDER" = tart ]; then
    b64="$(base64 <"$src")"
    # shellcheck disable=SC2016
    vm exec "$name" sh -c \
      'printf "%s" "$1" | base64 -d >"$2" && chmod +x "$2"' \
      -- "$b64" "$dst"
  else
    : "${ssh_host:=$(vm ip "$name")}"
    sshpass -padmin scp -o StrictHostKeyChecking=no -P "$ssh_port" \
      "$src" "admin@$ssh_host:$dst"
  fi
}

# Sets BOOTSTRAP_PATH; not stdout, since `$(...)` capture turns tart exec
# stdout into a pipe and trips tart 2.32.1's terminal-size probe.
copy_bootstrap() {
  local vm_home
  case "$guest_os" in
  darwin) vm_home=/Users/admin ;;
  *) vm_home=/home/admin ;;
  esac
  BOOTSTRAP_PATH="$vm_home/.local/bin/bootstrap"
  log "copying bootstrap script to $BOOTSTRAP_PATH"
  vm_exec mkdir -p "${BOOTSTRAP_PATH%/*}"
  vm_cp ./script/bootstrap "$BOOTSTRAP_PATH"
}

resolve_image() {
  local target="$1"
  if [ -n "${IMAGES[$target]:-}" ]; then
    IFS='|' read -r image default_name guest_os <<<"${IMAGES[$target]}"
    [ "$VM_PROVIDER" = tart ] && [ "$guest_os" = darwin ] && : "${dirs:=chezmoi:$PWD:ro}"
    return 0
  fi

  if [[ $target == */* ]]; then
    image="$target"
    default_name="${target##*/}"
    default_name="${default_name%:*}"
    guest_os="${VM_GUEST_OS:-linux}"
    return 0
  fi

  local available
  available="$(printf '%s\n' "${!IMAGES[@]}" | sort | tr '\n' ' ' | sed 's/ $//')"
  msg "$PROG: unknown image: $target"
  msg "$PROG: available images for $ARCH: $available"
  return 1
}

ensure_vm() {
  : "${name:=$default_name}"
  ssh_host=""
  ssh_port=22
  local state
  state="$(vm_state "$name")"

  [ -z "$state" ] && vm_clone

  if [ "$state" != running ]; then
    [ "$keep" = true ] || trap cleanup EXIT
    vm_start
    vm_wait
    vm_mount
  elif [ -n "$dirs" ]; then
    log "VM already running; --dir mounts require a fresh start"
  fi
}

init_repo() {
  local vm_home
  case "$guest_os" in
  darwin) vm_home=/Users/admin ;;
  *) vm_home=/home/admin ;;
  esac
}

run_pipeline() {
  init_repo
  copy_bootstrap
  vm_exec_cmd env CI=true CHEZMOI_PROFILE="${CHEZMOI_PROFILE:-minimal}" \
    "$BOOTSTRAP_PATH" \
    --no-tty \
    --verbose \
    LEI
  vm_exec_cmd mise run pipeline
}

cmd_run() {
  local target="$1"
  shift

  resolve_image "$target" || return 1
  ensure_vm || return 1

  if [ "$#" -eq 0 ]; then
    run_pipeline
  else
    vm_exec_cmd "$@"
  fi
}

# Parse flags from "$@" and store remaining args in ARGS.
# Globals: dirs, gui, keep, name, tmux, verbosity, ARGS (modified)
parse_flags() {
  ARGS=()
  while [ $# -gt 0 ]; do
    case "$1" in
    -h | --help)
      usage_help
      exit 0
      ;;
    --usage)
      usage_spec
      exit 0
      ;;
    -d | --dir)
      dirs="${dirs:+$dirs }$2"
      shift 2
      ;;
    -g | --gui)
      gui=true
      shift
      ;;
    -k | --keep)
      keep=true
      shift
      ;;
    -n | --name)
      name="$2"
      shift 2
      ;;
    -q | --quiet)
      verbosity=0
      shift
      ;;
    -t | --tmux)
      tmux=true
      shift
      ;;
    -v | --verbose)
      verbosity=2
      shift
      ;;
    --)
      shift
      break
      ;;
    --*)
      msg "$PROG: unknown option: $1"
      exit 2
      ;;
    -*)
      local opt="${1#-}"
      shift
      while [ -n "$opt" ]; do
        case "${opt:0:1}" in
        d)
          dirs="${dirs:+$dirs }$1"
          shift
          ;;
        g) gui=true ;;
        k) keep=true ;;
        n)
          name="$1"
          shift
          ;;
        q) verbosity=0 ;;
        t) tmux=true ;;
        v) verbosity=2 ;;
        *)
          msg "$PROG: unknown option: -${opt:0:1}"
          exit 2
          ;;
        esac
        opt="${opt:1}"
      done
      ;;
    *) break ;;
    esac
  done
  ARGS=("$@")
}

main() {
  case "${1:-}" in
  '' | -h | --help)
    usage_help
    return
    ;;
  --usage)
    usage_spec
    return
    ;;
  --list-images)
    printf '%s\n' "${!IMAGES[@]}" | sort
    return
    ;;
  --)
    shift
    exec "$VM_PROVIDER" "$@"
    ;;
  esac

  tty_state=$(stty -g 2>/dev/null || true)
  trap restore_tty EXIT

  require_cmd "$VM_PROVIDER"
  [ "$VM_PROVIDER" = tart ] || require_cmd sshpass

  if [ -n "${IMAGES[$1]:-}" ] || [[ $1 == */* ]]; then
    local target="$1"
    shift
    dirs="${VM_DIRS:-}"
    gui="${VM_GUI:-false}"
    keep="${VM_KEEP:-false}"
    name="${VM_NAME:-}"
    tmux="${VM_TMUX:-false}"
    verbosity="${VM_VERBOSITY:-1}"
    parse_flags "$@"
    cmd_run "$target" "${ARGS[@]}"
  else
    exec "$VM_PROVIDER" "$@"
  fi
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  main "$@"
fi
