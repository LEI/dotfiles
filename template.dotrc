#!/usr/bin/env bash

# .dotrc

[author]
    name = AUTHOR_NAME
    email = AUTHOR_EMAIL

[config]
    debug = true
    dry_run = false
    timestamps = false

[ignore]
    template.*
    *.sh

[files]
    bin/*
    .bash_profile
    .config/*
    .gitconfig
    .gitignore
    .inputrc
    .vim/*
    .vimrc
