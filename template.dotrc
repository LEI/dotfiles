#!/usr/bin/env bash

# .dotrc

[author]
name = AUTHOR_NAME
email = AUTHOR_EMAIL
username = AUTHOR_USERNAME

[config]
debug = true
dry_run = false
timestamps = false

# Dotfiles patterns
#
# src:dst
# src:      The destination will be the full path of the source
# src       The destination will be the source prefixed with a dot without its path
#
[files]
bin/*:bin
config/*
git/*
shell/*
vim/bundle:vim/bundle
vim/vimrc:.vimrc

# [ignore]
# *.template
# *.sh

# [brew]
#
# [cask]
