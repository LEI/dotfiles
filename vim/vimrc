" Customize invisible characters color
hi NonText ctermfg=11
hi SpecialKey ctermfg=11

" Custom autocmd
hi ExtraWhitespace ctermbg=1 guibg=red

" Interface {{{1

" Line numbers
set number

" Use relative line numbers
if exists("&relativenumber")
  set relativenumber
  au BufReadPost * set relativenumber
endif

" Disable cursor blinking
"set guicursor=a:blinkon0

" Do not show matching brackets when text indicator is over them
set noshowmatch
" How many tenths of a second to blink when matching brackets
"set mat=2

" HTML brackets
set matchpairs+=<:>

set visualbell
set t_vb=

" Recognize escape immediately
set esckeys

set timeout
set timeoutlen=1000 ttimeoutlen=0

" Mode switch fix?
" https://powerline.readthedocs.org/en/latest/tipstricks.html#vim
"if !has('gui_running')
"  "set ttimeoutlen=10
"  augroup FastEscape
"    au!
"    au InsertEnter * set timeoutlen=0
"    au InsertLeave * set timeoutlen=1000
"  augroup END
"endif

"if has("mouse")
set mouse=a
"endif

" Natural new split focus
set splitbelow
set splitright

" Shorter messages
set shortmess=atI

" Set the window title
set title

" Always show the status line
set laststatus=2

" Do not display current mode
set noshowmode

" Display incomplete commands
set showcmd

" Height of the command bar
set cmdheight=1

" Always show current position
"set rulerformat=%l,%c%V%=%P
set ruler

" Spacing {{{1

"if !exists("g:loaded_sleuth")
"endif

let s:tabsize=4

" Indent commands
let &shiftwidth = s:tabsize
" Set the number of columns for a tab
let &softtabstop = s:tabsize
" Visual width of a tabulation
let &tabstop = s:tabsize

" Use spaces instead of tabs
set expandtab

" Automatically insert idents
set autoindent
set smartindent
" Make <Tab> insert indents instead of tabs at the beginning of a line
set smarttab

" Don't wrap lines by default (see ftplugin)
set nowrap
" Break lines at convenient points (soft wrap)
set linebreak
" Line break on 500 characters
set textwidth=500
" Display line breaks
let &showbreak='↳'

" Show invisible character (highlighted with NonText and SpecialKey)
set list
set listchars=tab:▸\ ,trail:·,extends:❯,precedes:❮,nbsp:_,eol:¬

" Folding {{{1

" Add a bit extra margin to the left
"set foldcolumn=1

set foldmethod=indent
set foldnestmax=3
set nofoldenable

" Scrolling {{{1

" Start scrolling before the window border
if !&scrolloff
  set scrolloff=3
endif

if !&sidescrolloff
  set sidescrolloff=5
endif

if !&sidescroll
  set sidescroll=1
endif

" Enable soft wrap with ':Wrap'
command! -nargs=* Wrap setl wrap linebreak nolist

"set display+=lastline

" Search {{{1

set gdefault

" Highlight search results
set hlsearch
" Search act like in modern browsers
set incsearch

" Ignore case when searching
set ignorecase
" Try to be smart about cases
set smartcase

" Turn magic on for regular expressions
set magic

" Autocmd {{{1

if has("autocmd")
  " FIXME use :so % instead
  augroup reload_vimrc
    au!
    au BufWritePost $MYVIMRC nested source $MYVIMRC
  augroup END

  " Highlight trailing witespaces in red
  match ExtraWhitespace /\s\+$/
  au BufWinEnter * match ExtraWhitespace /\s\+$/
  au InsertEnter * match ExtraWhitespace /\s\+\%#\@<!$/
  au InsertLeave * match ExtraWhitespace /\s\+$/
  au BufWinLeave * call clearmatches()

  " Show cursor line on active window only
  au WinEnter * set cursorline
  au WinLeave * set nocursorline

  augroup resCur
    au!
    au BufReadPost * call ResCur()
  augroup END
endif

" Restore cursor position
function! ResCur()
  if line("'\"") > 0 && line("'\"") <= line("$")
    normal! g`"
    return 1
  endif
endfunction

" Platform {{{1

let OS=substitute(system('uname -s'),"\n","","")
if (OS == "Darwin")
