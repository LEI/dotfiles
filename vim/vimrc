" ~/.vimrc
" vim: foldenable foldmethod=marker et sts=2 sw=2 ts=2

" zi Folding on/off
" zR Open all
" zM Close all
" za Toggle current
" zj Down to the start of the next
" zk Up to the end of the previous

" github.com/mathiasbynens/dotfiles/blob/master/.vimrc
" github.com/tpope/vim-sensible/blob/master/plugin/sensible.vim"

set nocompatible

" Plugins {{{1

