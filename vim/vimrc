  " File format
  "let l:l.='%( %{&fileformat} %)'
  "let l:l.=g:statusline.symbol.sep
  " File encoding
  "let l:l.='%( %{(&fenc!=''?&fenc:&enc)} %)'
endfunc

function! StatusLineSyntastic()
  "if exists("SyntasticStatuslineFlag")
