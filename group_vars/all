---
# vi: ft=yaml

# {{ inventory_dir }}
# Source and destination
dot_home: "{{ '~' | expanduser }}"
dot_root: "{{ dot_home }}/{{ dot_dir|default('.dotfiles') }}"
# dot_repo: git@github.com:LEI/dotfiles.git

# Options
find_options: -maxdepth 0 -print ! -name '*~'
log_enable: yes
# backup_enable: yes
# backup_files: yes
# backup_symlinks: no
# backup_templates: yes
# backup_log: no
# packages_update: yes
# packages_upgrade: yes
# packages_install: yes

# git
git_name: "{{ full_name }}"
git_email: "{{ email }}"
git_credential_helper: cache

# npm
npm_user: "{{ user_name }}"
npm_email: "{{ email }}"

npm_packages:
  - name: bower
  - name: gulp
  - name: jshint
