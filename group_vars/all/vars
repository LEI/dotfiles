---
# vi: ft=yaml

# Identity
git_name: "{{ full_name }}"
git_email: "{{ email }}"
git_credential_helper: cache
npm_user: "{{ user_name }}"
npm_email: "{{ email }}"
irc_freenode_nick: "{{ user_name }}"
# Vault: docs.ansible.com/ansible/playbooks_vault.html
irc_freenode_pass: "{{ vault_irc_freenode_pass }}"
ssh_config: "{{ vault_ssh_config }}"

# Targets
dot_home: "{{ '~' | expanduser }}"
# dot_root: "{{ dot_home }}/{{ dot_dir | default('.dotfiles') }}"
# FIXME: get actual home from remote hosts!
dot_root: "{{ dot_home + '/' + dot_dir if dot_dir is defined else inventory_dir }}"
tmp_dir: "{{ ansible_env.TMPDIR | default('/tmp/') }}"

