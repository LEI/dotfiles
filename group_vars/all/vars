---
# vi: ft=yaml

# {{ inventory_dir }}
# Source and destination
dot_home: "{{ '~' | expanduser }}"
dot_root: "{{ dot_home }}/{{ dot_dir|default('.dotfiles') }}"

# Options
find_options: -maxdepth 0 -print ! -name '*~'
log_enable: yes
# backup_enable: yes
# backup_files: yes
# backup_symlinks: no
# backup_templates: yes
# backup_log: no
# packages_update: yes
# packages_upgrade: yes
# packages_install: yes

tmp_dir: "{{ ansible_env.TMPDIR | default('/tmp/') }}"
