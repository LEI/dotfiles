---
# vi: ft=yaml

git_name: "{{ full_name }}"
git_email: "{{ email }}"
git_credential_helper: cache

npm_user: "{{ user_name }}"
npm_email: "{{ email }}"

irc_freenode_nick: "{{ user_name }}"
# Vault: docs.ansible.com/ansible/playbooks_vault.html
irc_freenode_pass: "{{ vault_irc_freenode_pass }}"

# NodeJS modules
npm_packages:
  - bower
  - gulp
  - jshint

composer_packages: []
  # - laravel/laravel
  # - name: phpunit/phpunit
  # - { name: phpunit/phpunit, release: "4.7.*" }

common_dot_files:

  symlinks:
    bash:
      prefix: .
    bin:
      src: bin
      dest: bin
        # prefix:
    git:
      prefix: .
    home:
      prefix: .
    irssi:
      dest: .irssi
    vim:
      dest: .vim

  templates:
    git:
      prefix: .
    home:
      prefix: .
    irssi:
      dest: .irssi
    tmux:
      dest: .tmux
