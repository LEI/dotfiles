---
# vi: ft=yaml

# Git identity
git_name: "{{ full_name }}"
git_email: "{{ email }}"
git_credential_helper: cache

# npm identity
npm_user: "{{ user_name }}"
npm_email: "{{ email }}"

# NodeJS modules
npm_packages:
  - bower
  - gulp
  - jshint

# PHP dependencies
composer_packages:
  - phpunit/phpunit
  # - name: laravel/laravel
  # - { name: phpunit/phpunit, release: "4.7.*" }

# IRC identity
irc_freenode_nick: "{{ user_name }}"
# Vault: docs.ansible.com/ansible/playbooks_vault.html
irc_freenode_pass: "{{ vault_irc_freenode_pass }}"
