composer_packages: []

# NodeJS modules
npm_packages:
  - bower
  - gulp
  - jshint
  # - localtunnel

go_packages:
  - go

pip_packages:
  # Update pip
  - { name: pip, extra_args: --upgrade } # TODO Debian sudo
  # Python packages
  - bashate
  - pygments
  # - vim-vint

ruby_gems:
  - bundler
  # - compass

# MacOSX reattach to user namespace (pbcopy) / xclip
tmux_plugins:
  - tmux-plugins/tpm
  - tmux-plugins/tmux-resurrect
