composer_packages: []

# NodeJS modules
# npm_packages: []

# go_packages:
#   - go

# Python packages
pip_packages:
  - bashate
  - pygments
  # - vim-vint

ruby_gems:
  - bundler
  # - compass

# rxvt_packages:
#   - rxvt-unicode

# MacOSX reattach to user namespace (pbcopy) / xclip
tmux_plugins:
  - tmux-plugins/tpm
  - tmux-plugins/tmux-resurrect
  # - tmux-plugins/tmux-continuum
  # - tmux-plugins/tmux-sessionist
  # - tmux-plugins/vim-tmux-focus-events
  # - nhdaly/tmux-scroll-copy-mode
  # - tmux-plugins/tmux-cpu
  # - tmux-plugins/tmux-battery
  # - thewtex/tmux-mem-cpu-load

tmux_options:
  - resurrect-capture-pane-contents 'on'
  # vi vim nvim emacs man less more tail top htop irssi mutt
  - resurrect-processes 'ssh'
  - resurrect-strategy-vim 'session'
  - resurrect-strategy-nvim 'session'
