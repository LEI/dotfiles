- include: osx.yml
  when: ansible_os_family == 'Darwin'

- include: debian.yml
  when: ansible_os_family == 'Debian'

- name: Check if .tmux exists
  file:
    path: "{{ dot_home }}/.tmux"
    state: directory

- name: Symlink tmux configuration
  file:
    src: "{{ dot_root }}/tmux/{{ item }}"
    dest: "{{ dot_home }}/.tmux/{{ item }}"
    state: link
  with_items:
   - tmux.conf
   - plugins
