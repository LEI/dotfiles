# .tmux.conf
# vim: foldenable foldmethod=marker foldmarker={,}

# ! https://github.com/tmux-plugins/tpm

# ? https://github.com/edkolev/tmuxline.vim

# github.com/tmux/tmux/blob/master/example_tmux.conf
# github.com/demure/dotfiles/blob/master/tmux.conf
# github.com/tangledhelix/dotfiles/blob/master/tmux.conf
#
# Seamless tmux/vim navigation?
# https://github.com/christoomey/vim-tmux-navigator
# https://gist.github.com/mislav/5189704

# https://github.com/alexanderjeurissen/dotfiles

# Main {1
#
# Turn on xterm key bindings so that additional function keys get escape sequences
set -g xterm-keys on

# Set colors
set -g default-terminal "xterm-256color" #xterm|screen

# Scrollback size
set -g history-limit 10000

# Don't wait for escape characters
set -sg escape-time 1
# -s 10 ?

# Locks
set -g lock-after-time 1800

# Keep windows around after they exit
#set -g remain-on-exit on

# General {1

setw -g utf8 on

# Start numbering at 1
set -g base-index 1
setw -g pane-base-index 1

# Automatically renumber windows
set -g renumber-windows on

# No bells at all
set -g bell-action none

# Disable window activity message
set -g visual-activity off

# Enable activity alerts
setw -g monitor-activity on

# Terminal title
# #  #H  Hostname of local host
# #  #I  Current window index
# #  #P  Current pane index
# #  #S  Session name
# #  #T  Current window title
# #  #W  Current window name
set -g set-titles on
set -g set-titles-string '#S #I.#P #W #T'

# Window renaming
setw -g allow-rename on
setw -g automatic-rename on

# Pane borders
set -g pane-border-style fg=colour10,bg=black
set -g pane-active-border-style fg=colour11,bg=black

# Status {1

set -g status on
set -g status-interval 2
set -g status-justify left #centre
set -g status-position bottom
set -g status-utf8 on
set -g status-keys emacs

# Lengths
set -g status-left-length 60
set -g status-right-length 80

# Styles
setw -g status-style fg=white,bg=colour10
setw -g status-left-style fg=colour12,bg=colour10
setw -g status-right-style fg=colour12,bg=colour10

# Left section {2

setw -g status-left ''
# Host
setw -ga status-left '#[fg=black,bg=blue]'
setw -ga status-left '#{?client_prefix,#[bg=green],}'
setw -ga status-left ' #H '
#setw -ga status-left '#[nobold]'
setw -ga status-left '#[fg=colour7,bg=colour11]'
# Session name, index and panel index
setw -ga status-left ' #S #I.#P '
# User
#setw -ga status-left '#[fg=white,bg=brightblack] #(whoami) '
# System
#setw -ga status-left '#[fg=white,bg=default] #(uname -r | cut -c 1-6) #(echo $MACHTYPE) '
setw -ga status-left '#[fg=colour11,bg=default] '

# Right section {2

setw -g status-right ''

# Memory (npm install -g tmux-mem)
# Format ":currentBytes #[fg=:color]:percent#[fg=default] │#[fg=:color]:spark#[fg=default]│"
#setw -ga status-right '#(tmux-mem --format "#[fg=:color]:spark#[fg=default]") '
# CPU (npm install -g tmux-cpu)
# Format ":load #[fg=:color]:percent#[fg=default] │#[fg=:color]:spark#[fg=default]│"
#setw -ga status-right '#(tmux-cpu --format "#[fg=:color]:spark#[fg=default]") '

# IP
setw -ga status-right '#[fg=brightblack]'
setw -ga status-right '#(curl ipecho.net/plain;echo)'
# Battery level TODO: hide if not a laptop
setw -ga status-right ' #{battery_percentage}#[bg=default] '
setw -ga status-right '#[fg=colour7,bg=colour11]'
# Date
setw -ga status-right ' %a %b %d '
setw -ga status-right '#[fg=black,bg=blue]'
setw -ga status-right '#{?client_prefix,#[bg=green],}'
# Time
setw -ga status-right ' %H:%M '
# Session and panel index
#setw -ga status-right '#[fg=black,bg=blue]#{?client_prefix,#[bg=green],} #I: #P '

# Windows {2

setw -g window-status-style fg=colour11,bg=colour10
setw -g window-status-format '#[fg=brightblack] #I#[fg=default]#{?window_flags,#F, }#[fg=brightblack]#W '

# Current window
setw -g window-status-current-style fg=colour11,bg=black
setw -g window-status-current-format '#[fg=brightblack] #I#[fg=default]#{?window_flags,#F, }#[fg=white]#W '

# Active window
setw -g window-status-activity-style fg=colour12,bg=colour10 #fg=black,bg=brightblue

# Activity message
set -g message-style fg=black,bg=green

#(ifstat)
#(cpu-load 1)

# Input {1

# Mouse
#
set -g mouse-utf8 on
set -g mouse on

# https://github.com/tmux/tmux/issues/145
bind -n WheelUpPane if-shell -F -t = "#{mouse_any_flag}" "send-keys -M" "if -Ft= '#{pane_in_mode}' 'send-keys -M' 'select-pane -t=; copy-mode -e; send-keys -M'"
bind -n WheelDownPane select-pane -t= \; send-keys -M

#bind -n C-WheelUpPane select-pane -t= \; copy-mode -e \; send-keys -M
#bind -t vi-copy    C-WheelUpPane   halfpage-up
#bind -t vi-copy    C-WheelDownPane halfpage-down
#bind -t emacs-copy C-WheelUpPane   halfpage-up
#bind -t emacs-copy C-WheelDownPane halfpage-down

# Mouse ithout copy mode dragging?
# unbind -n MouseDrag1Pane
# unbind -temacs-copy MouseDrag1Pane
# Vi copypaste mode
# bind-key -t vi-copy 'v' begin-selection
# bind-key -t vi-copy 'y' copy-selection

# Key maps

# Use emacs bindings?
setw -g mode-keys emacs

# Change the prefix key to C-a
set -g prefix C-a
unbind C-b
bind C-a send-prefix

# Switch to last window
bind a last-window

# Open windows and splits in the current directory
bind c new-window -c '#{pane_current_path}'
bind '"' split-window -c '#{pane_current_path}'
bind % split-window -h -c '#{pane_current_path}'

# Vim style pane navigation
unbind-key j
bind-key j select-pane -D
unbind-key k
bind-key k select-pane -U
unbind-key h
bind-key h select-pane -L
unbind-key l
bind-key l select-pane -R

# Pane resizing
bind H resize-pane -L 5
bind J resize-pane -D 5
bind K resize-pane -U 5
bind L resize-pane -R 5

# Quick pane cycling
# unbind ^A
# bind ^A select-pane -t :.+

# Some extra key bindings to select higher numbered windows
bind F1 selectw -t:10
bind F2 selectw -t:11
bind F3 selectw -t:12
bind F4 selectw -t:13
bind F5 selectw -t:14
bind F6 selectw -t:15
bind F7 selectw -t:16
bind F8 selectw -t:17
bind F9 selectw -t:18
bind F10 selectw -t:19
bind F11 selectw -t:20
bind F12 selectw -t:21

# Reload config
bind r source-file ~/.tmux.conf \; display-message 'Reloaded ~/.tmux.conf'

# Plugins {1

# Tmux Plugin Manager
set -g @plugin 'tmux-plugins/tpm'

{% for plugin in tmux_plugins %}
set -g @plugin '{{ plugin }}'
{% endfor %}

# Examples:
# set -g @plugin 'tmux-plugins/tmux-sensible'
# set -g @plugin 'github_username/plugin_name'
# set -g @plugin 'git@github.com/user/plugin'
# set -g @plugin 'git@bitbucket.com/user/plugin'

# CPU
#set -g @plugin 'tmux-plugins/tmux-cpu'
#{cpu_icon} #{cpu_percentage}
# Battery
#set -g @plugin 'tmux-plugins/tmux-battery'
#:( 'thewtex/tmux-mem-cpu-load'

# Keep this line at the very bottom of tmux.conf
run '~/.tmux/plugins/tpm/tpm'
