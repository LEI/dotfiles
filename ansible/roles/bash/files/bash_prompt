# Export prompt
export PROMPT_COMMAND=prompt_command

PROMPT_SYMBOL="›" #→
PROMPT_SYMBOL_ERROR="×"

prompt_git() {
  local prefix="$1"
  local sign_prefix="$2"
  local branch_color="$3"
  local master_color="$4"
  local branch=
  local sign=

  # Check if the current directory is in a Git repository.
  if [ $(git rev-parse --is-inside-work-tree &>/dev/null; echo "${?}") == '0' ]; then

    # Check if the current directory is in .git before running git checks
    if [ "$(git rev-parse --is-inside-git-dir 2> /dev/null)" == 'false' ]; then

      # Ensure the index is up to date.
      git update-index --really-refresh -q &>/dev/null

      # Check for uncommitted changes in the index.
      if ! $(git diff --quiet --ignore-submodules --cached); then
        sign+='+'
      fi

      # Check for unstaged changes.
      if ! $(git diff-files --quiet --ignore-submodules --); then
        sign+='!'
      fi

      # Check for untracked files.
      if [ -n "$(git ls-files --others --exclude-standard)" ]; then
        sign+='?'
      fi

      # Check for stashed files.
      if $(git rev-parse --verify refs/stash &>/dev/null); then
        sign+='$'
      fi

    fi

    # Get the short symbolic ref
    # If HEAD isn’t a symbolic ref, get the short SHA for the latest commit
    # Otherwise, just give up
    branch="$(git symbolic-ref --quiet --short HEAD 2> /dev/null || \
      git rev-parse --short HEAD 2> /dev/null || \
      echo '(unknown)')"

    if [[ -n "$branch" ]]; then
      if [[ "$branch" != master ]]; then
        branch="${branch_color}${branch}"
      else
        branch="${master_color}${branch}"
      fi
    fi

    if [[ -n "${sign}" ]]; then
      sign="${sign_prefix}${sign}"
    fi

    printf "%s" "${prefix}${branch}${sign}"
  else
    return
  fi
}

prompt_jobs() {
  local str
  local b s
  # Check backgrounded running jobs
  local bg_jobs=$(jobs -r | wc -l | tr -d ' ')
  # Check stopped jobs
  local stp_jobs=$(jobs -s | wc -l | tr -d ' ')

  # Display running and stopped jobs if any
  if [[ ${bg_jobs} -gt 0 ]] || [[ ${stp_jobs} -gt 0 ]]; then
    if [[ ${bg_jobs} -gt 2 ]]; then
      b="${red}"
    elif [[ ${bg_jobs} -gt 0 ]]; then
      b="${yellow}"
    fi

    if [[ ${stp_jobs} -gt 2 ]]; then
      s="${red}"
    elif [[ ${stp_jobs} -gt 0 ]]; then
      s="${yellow}"
    fi

    str="${reset} [${b}${bg_jobs}${reset}:${s}${stp_jobs}${reset}]"
  fi

  # jobs[bg:stp]
  printf "%s" "$str"
}

# ✓
# ×
prompt_status() {
  local exit=$1
  local default="> "
  local default_error="x "
  local success="${2-$default}"
  local error="${3-$default_error}"
  local str=

  if [[ $exit -eq 0 ]]; then
    str="$success"
  else
    str="$error"
  fi

  printf "%b" "$str"
}

prompt_right() {
  local date="$(date +%H:%M:%S)"

  if [[ ! -n $COLUMNS ]]; then
    COLUMNS=$(tput cols)
  fi

  #$(prompt_jobs)
  printf ${bblack}"%*s" $COLUMNS "$date"
}

prompt_command() {
  local EXIT=$? # Must be first
  local user=$(whoami)
  local host=$(hostname)
  # Must be global to be available in single quote PS1
  text_color="$bblack"
  user_color=
  host_color=

  # Set the terminal title to the current working directory
  PS1='\[\033]0;\w\007\]'

  PS1+='\n'
  PS1+='\[$(tput sc; prompt_right; tput rc)\]'

  # Highlight the username when logged in as root
  if [[ "${USER}" == "root" ]]; then
    user_color="${red}"
  else
    user_color="${cyan}" #orange
  fi

  # Username
  PS1+='\[${user_color}\]\u'

  # Display the hostname when != username
  if [[ "$user" != "$host" ]]; then
    # Highlight the hostname when connected via SSH
    if [[ -n "${SSH_TTY}" ]]; then
      host_color="${bold}${red}"
    else
      host_color="${blue}"
    fi

    # @hostname
    PS1+='\[${text_color}\] at '
    PS1+='\[${host_color}\]\h' # host
  fi

  # Working directory
  PS1+='\[${text_color}\] in '
  PS1+='\[${white}\]\w'

  # Git repository details
  PS1+='$(prompt_git "\[${text_color}\] on " "\[${white}\] " "\[${yellow}\]" "\[${red}\]")'

  PS1+='\n'
  # Command line
  PS1+='\[${white}\]'
  PS1+=$(prompt_status $EXIT "\[${white}\]${PROMPT_SYMBOL} " "\[${red}\]${PROMPT_SYMBOL_ERROR} " )
  PS1+='\[${reset}\]'
  export PS1

  PS2='\[${text_color}\]${PROMPT_SYMBOL} \[${reset}\]'
  export PS2
}
