#!/usr/bin/env bash

# Usage: man ansible-playbook

set -o nounset
set -o errexit
set -o pipefail

DOT_ROOT="${DOT_ROOT:-$HOME/.dotfiles}"
DOT_REQUIREMENTS="$DOT_ROOT/requirements"
DOT_PLAYBOOK="$DOT_ROOT/playbook.yml"

run_playbook() {
  local args="$@"
  # if [[ $? -gt 0 ]]; then
  #   [[ "$1" == "--force-install" ]] && shift \
  #     && ansible_install
  # fi

  if ! has ansible
  then
    ansible_install
  elif rm_arg "--force-install"
  then
    ansible_install true
  fi

  if ! arg "--ask-vault-pass"
  then
    local vault_file="$(ansible_vault)"
    if [[ -n "$vault_file" ]]
    then
      args+=("--vault-password-file "$vault_file"")
      chmod 700 "$vault_file" &>/dev/null
    fi
  fi

  if rm_arg "--debug"
  then
    # Check mode (dry run)
    args+=("--check")
    args+=("--diff")
  fi

  # Ansible root directory
  cd "$DOT_ROOT"

  # ansible-galaxy install -r "$DOT_REQUIREMENTS/galaxy.yml"

  # Inventory file defined in ansible.cfg

  # Run the main playbook
  ansible-playbook "$DOT_PLAYBOOK" ${args[@]}
}

ansible_vault() {
  local file=
  # Vault file path
  if [[ -z "${ANSIBLE_VAULT_PASSWORD_FILE:-}" ]]
  then
    # export ANSIBLE_VAULT_PASSWORD_FILE="$HOME/.vault_pass.txt"
    file="$HOME/.vault_pass.txt"
  fi

  # Create the vault file if it does not exists
  if [[ -n "$file" ]] && [[ ! -f "$file" ]]
  then local vault_pass=$(prompt "Vault password:" | base64)
    echo -e "#!/usr/bin/env bash\necho \""$vault_pass"\" | base64 --decode" > $file
  fi

  [[ -f "$file" ]] && echo "$file"
}

ansible_install() {
  local force="${1:-}"
  local os=$(uname -s) # -o Cygwin?

  case $os in
    Darwin)
      # If /usr/bin/gcc is absent
      if ! has gcc
      then
        # Install Xcode
        _do "xcode-select --install"
      fi
      # Install ansible with homebrew?
      if ! has ansible || [[ -n "$force" ]]
      then ! has pip && su_do easy_install pip
        # Install dependencies
        _do pip install --user python -r "$DOT_REQUIREMENTS/pip.txt"
      fi
      ;;
    Linux)

      # pip cryptography on raspbian ->
      # ERROR! Unexpected Exception: 'EntryPoint' object has no attribute 'resolve'
      if has apt-get
      then
        # Debian/Ubuntu:
        su_do apt-get install -yq build-essential python-setuptools python-dev libffi-dev libssl-dev
        # gcc make... python-dev
        # apt-transport-https ansible (1.7)
        if ! has aptitude
        then
          su_do apt-get install -yq aptitude
        fi
      elif has pacman
      then
        # Archlinux: (requires sudo, git)
        # http://github.com/palazzem/hanzo/blob/master/bin/bootstrap.sh
        su_do pacman -Syu --noconfirm
        su_do pacman -S git python2 python2-setuptools python2-pip ansible --noconfirm
        # python2-crypto / python2-cryptography / pyhton2-packaging
      elif has yum
      then
        # CentOS, RHEL... (install the epel-release RPM if needed)
        su_do yum install -y epel-release
        su_do yum install -y ansible
      else
        die "Unknown package manager"
      fi

      # Fedora/CentOS:
      # sudo yum install gcc libffi-devel openssl-devel python-devel

      # If Ansible is still not present
      if ! has ansible || [[ -n "$force" ]]
      then ! has pip && su_do easy_install pip
        # Install dependencies
        su_do pip install -r "$DOT_REQUIREMENTS/pip.txt"
      fi
      ;;
    CYGWIN*) # uname -o = Cygwin
      # https://github.com/grlee/ansible-galaxy.ansible-init/blob/develop/files/setup.sh
      if ! has apt-cyg; then
        echo 'lynx -source rawgit.com/transcode-open/apt-cyg/master/apt-cyg > apt-cyg'
        echo 'install apt-cyg /bin'
      fi
      echo '
            apt-cyg install git python-{crypto,jinja2,six,yaml}
            ANSIBLE="$HOME/ansible"
            git clone --depth 1 git://github.com/ansible/ansible "$ANSIBLE"
            cd ~/ansible
            git submodule update --init lib/ansible/modules/{core,extras}
            PATH="$PATH:$ANSIBLE/bin"
            PYTHONPATH="$ANSIBLE/lib"
            ANSIBLE_LIBRARY="$ANSIBLE/library"'
      ;;
    *)
      die "Unsupported platform: $os"
      ;;
  esac
}

arg() {
  local arg="$1"
  local pattern="* $arg *"

  # Match the argument
  [[ " ${args[@]} " = $pattern ]]
}

rm_arg() {
  local arg="$1"

  arg "$@"
  local rc=$?

  if [[ $rc -eq 0 ]]
  then
    # Remove if found
    args="${args/$arg/}"
  fi

  return $rc
}

has() {
  [[ "$1" == "sudo" ]] && shift
  local cmd="$1"

  # Test if the program can be executed
  hash $cmd 2>/dev/null

  if [[ $? != 0 ]]
  then
    # Display warning
    error "! $cmd is not installed"
  fi
}

_do() {
  local cmd="$@"

  if has $cmd
  then
    log "› $cmd"
    # Execute the command
    $cmd
  else
    # Die
    die "× $cmd"
  fi
}

su_do() {
  _do sudo "$@"
}

prompt() {
  local q="$1"
  log "$q" >&2

  local a=
  read -e -r -s a

  if [[ -n "$a" ]]
  then
    # Echo answer
    printf "%s" "$a"
  else
    # No answer, ask again
    prompt "$@" && return
  fi
}

log() {
  printf "%s\r\n" "$@"
}

error() {
  log >&2 "$@"
  return 1
}

die() {
  error "$@"
  exit 1
}

[[ "$0" == "$BASH_SOURCE" ]] && time run_playbook "$@"
