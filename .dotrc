#!/usr/bin/env bash

# .dotrc

[author]
name = "Guillaume FrichetGuillaume Frichet"
email = "guillaume.frichet@gmail.comguillaume.frichet@gmail.com"
username = "LEILEI"

[config]
debug = true
dry_run = false
timestamps = false

[files] # Dotfiles
# If the source contains a wildcard, the destination must be a directory
# where all matching files will be symlinked.
#
# Patterns:
#   src:(~/)dst
#   src:(~/src)
#   src(:~/.)
bin/*:bin
config/*
git/*
shell/*
vim/bundle:vim/bundle
vim/vimrc:.vimrc

# [ignore]
# *.template
# *.sh
# [brew]
# [cask]
