#!/usr/bin/env bash

# .dotrc

[user]
name = Guillaume Frichet
email = guillaume.frichet@gmail.com
nick = LEI

[config]
debug = false
dry_run = true # Change to false when confident
timestamps = false
prefix = .

[files] # Dotfiles
# If the source contains a wildcard, the destination must be a directory
# where all matching files will be symlinked.
# Patterns:
# src:(~/)dst -> $HOME/$dst    Full expression, source will be linked in
# src:(~/src) -> $HOME/$src    Source ending with delimiter ':' will be used as destination
# src(:~/.)   -> $HOME/.$src   No destination or delimiter, source will be prefixed with '.'
atom/*:.atom
# bin/test/*:bin/test
bin/*:bin
config/*
git/*
shell/*
tmux/tmux.conf
tmux/bin/*:bin
vim/bundle:vim/bundle
vim/vimrc:.vimrc

# [ignore]
# *.template
# *.sh
# [brew]
# [cask]
