#!/usr/bin/env bash

# .dotrc

[user]
name = Guillaume Frichet
email = guillaume.frichet@gmail.com
nick = LEI

[config]
debug = false
dry_run = false
timestamps = false
prefix = .

# Symlink patterns

# If the source contains a wildcard, the destination must be a directory
# where all matching files will be symlinked.

# Full expression, source will be linked in the specified directory
# src:(~/)dst -> $HOME/$dst

# Source ending with delimiter ':' will be used as destination
# src:(~/src) -> $HOME/$src

# No destination or delimiter, source will be prefixed with '.'
# src(:~/.)   -> $HOME/.$src

[symlink]
# atom/*:.atom
# bin/test/*:bin/test
bash/*
bin/*:bin
config/*
git/*
irssi/*:.irssi
tmux/tmux.conf
tmux/plugins:.tmux/plugins
vim/*:.vim

# [ignore]
# *.template
# *.sh
# [brew]
# [cask]
