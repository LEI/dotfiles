#!/usr/bin/env bash

# .dotrc

[author]
name = "Guillaume Frichet"
email = "guillaume.frichet@gmail.com"
username = "LEI"

[config]
debug = true
dry_run = false
timestamps = false

# Dotfiles patterns
# src:dst
# src:      The destination will be the full path of the source
# src       The destination will be the source prefixed with a dot without its path
[files]
bin/*:bin
config/*
git/*
shell/*
vim/bundle:vim/bundle
vim/vimrc:.vimrc

# [ignore]
# *.template
# *.sh

# [brew]
#
# [cask]
