#!/usr/bin/env bash

# .dotrc

[user]
name = Guillaume Frichet
email = guillaume.frichet@gmail.com
nick = LEI

[config]
debug = true
dry_run = true
timestamps = false

[files] # Dotfiles
# If the source contains a wildcard, the destination must be a directory
# where all matching files will be symlinked.
#
# Patterns:
#   src:(~/)dst
#   src:(~/src)
#   src(:~/.)
bintest/*:bntst
bin/*:bin
config/*
git/*
shell/*
vim/bundle:vim/bundle
vim/vimrc:.vimrc

# [ignore]
# *.template
# *.sh
# [brew]
# [cask]
