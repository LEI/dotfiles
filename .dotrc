#!/usr/bin/env bash

# .dotrc

[user]
name = Guillaume Frichet
email = guillaume.frichet@gmail.com
nick = LEI

[config]
debug = false
dry_run = false
timestamps = false
prefix = .

# Symlink patterns

# If the source contains a wildcard, the destination must be a directory
# where all matching files will be symlinked.

# Full expression, source will be linked in the specified directory
# src:(~/)dst -> $HOME/$dst

# Source ending with delimiter ':' will be used as destination
# src:(~/src) -> $HOME/$src

# No destination or delimiter, source files will be prefixed in ~
# src/*(:~/.file)   -> $HOME/$prefix$file

[symlink]
# atom/*:.atom
# bin/test/*:bin/test
bash/*
bin/*:bin
config/*
git/*
irssi/*:.irssi
#irssi/config:.irssi/config
#irssi/*.theme:.irssi
#irssi/scripts/*:.irssi/scripts/autorun
mutt/*:.mutt
tmux/tmux.conf
tmux/plugins:.tmux/plugins
vim/*:.vim

mintty/*

[ignore]
.DS_Store
# *.template
# *.sh
# [brew]
# [cask]
