#!/usr/bin/env bash

# .dotrc

[author]
    name = "Guillaume Frichet"
    email = "guillaume.frichet@gmail.com"

[config]
    debug = true
    dry_run = false
    timestamps = false
    
[ignore]
    template.*
    *.sh

[files]
    bin/*
    .bash_profile
    .config/*
    .gitconfig
    .gitignore
    .inputrc
    .vim/*
    .vimrc
