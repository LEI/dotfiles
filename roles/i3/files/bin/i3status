i3status "$@" | while :
do
  read line

  [[ -z "$line" ]] && continue
  [[ "$line" == '[' ]] && echo "$line" && continue
  [[ "$line" == '{"version":1}' ]] && line='{"version":1,"click_events":true}'

  append=
  prepend=

  # Network speed
  net=$(~/.config/i3/bin/net-speed)

  prepend+="{\"full_text\":\"$net\"}"
  # prepend+="$(json "name" "networkspeed" "full_text" "$net")"

  # append+="{\"name\":\"calendar\",\"full_text\":\"$(date)\"}" # ,\"click_events\":true}"

  if [[ -n "$append" ]]
  then
    append=",${append}]"
    line="${line/]/$append}"
  fi

  if [[ -n "$prepend" ]]
  then
    prepend="[${prepend},"
    line="${line/[/$prepend}"
  fi

  echo "$line" >> ~/.i3debug
  echo "${line}" || exit 1
done
