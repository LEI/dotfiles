#!/bin/bash

# escape() {
#   echo "\"${1}\":\"${2}\""
# }

# json() {
#   local arr=("$@")
#   local len="${#arr[@]}"

#   str="{"
#   for i in "${!arr[@]}"
#   do
#     # Skip values
#     [[ "$(($i % 2))" -ne 0 ]] && continue

#     # Build key/value pair
#     # str+="\"${arr[$i]}\":\"${arr[$(($i + 1))]}\""
#     str+="$(escape "${arr[$i]}" "${arr[$(($i + 1))]}")"

#     # Add separator if needed
#     [[ "$i" -lt "$(($len - 2))" ]] && str+=","
#   done
#   str+="}"

#   echo "$str"
