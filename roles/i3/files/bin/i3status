#!/bin/bash

escape() {
  echo "\"${1}\":\"${2}\""
}

json() {
  local arr=("$@")
  local len="${#arr[@]}"

  str="{"
  for i in "${!arr[@]}"
  do
    # Skip values
    [[ "$(($i % 2))" -ne 0 ]] && continue

    # Build key/value pair
    # str+="\"${arr[$i]}\":\"${arr[$(($i + 1))]}\""
    str+="$(escape "${arr[$i]}" "${arr[$(($i + 1))]}")"

    # Add separator if needed
    [[ "$i" -lt "$(($len - 2))" ]] && str+=","
  done
  str+="}"

  echo "$str"
}

i3status "$@" | while :
do
  read line
  str=

  # Network speed
  net=$(~/.config/i3/bin/net-speed)
  # net="[{ \"full_text\": \"${net}\" },"
  # str+="{ $(escape "full_text" "$net") }"
  str+="$(json "full_text" "$net")"

  prepend="[${str},"
  append=",{\"full_text\":\"test\"}]"
  line="${line/[/$prepend}"
  line="${line/]/$append}"
  echo "${line}" || exit 1
done
