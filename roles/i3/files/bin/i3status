escape() {
  echo "\"${1}\":\"${2}\""
}

i3status "$@" | while :
do
  read line
  str=

  # Network speed
  net=$(~/.config/i3/bin/net-speed)
  # net="[{ \"full_text\": \"${net}\" },"
  str+="{ $(escape "full_text" "$net") }"

  prepend="[${str},"
  echo "${line/[/$prepend}" || exit 1
done
