" Base configuration
" vim: et sts=2 sw=2 ts=2

set nocompatible

" runtime plug.vim
if filereadable(expand('~/.vim/plug.vim'))
  source ~/.vim/plug.vim
endif

" Load matchit.vim, but only if a newer version isn't installed
if !exists('g:loaded_matchit') && findfile('plugin/matchit.vim', &runtimepath) ==# ''
  runtime macros/matchit.vim
endif

if has("autocmd")
  " Enable filetype detection
  filetype plugin indent on
endif

if &history < 1000
  set history=1000
endif

" Disable swapfiles and backups
set noswapfile
set nobackup
set nowritebackup

" Keep undo history across sessions, by storing in file.
if has('persistent_undo') && !isdirectory(expand('~').'/.vim/backups')
  silent !mkdir ~/.vim/backups > /dev/null 2>&1
  set undodir=~/.vim/backups
  set undofile
endif

if !has('nvim')
  " Fast terminal connection
  set ttyfast
endif

" Enable per-directory .vimrc files and disable unsafe commands in them
set exrc
set secure

" Buffers can exist in the background
set hidden

" Don't redraw while executing macros
set lazyredraw

" Enable syntax highlighting
if has('syntax')
  syntax enable
endif

set number

" set cursorline

" Always show the status line
set laststatus=2

" Display current mode
set showmode

" Display incomplete commands
set showcmd

" Height of the command bar
set cmdheight=1

" Always show current position
set ruler
"set rulerformat=%l,%c%V%=%P

" Allow backspace in insert mode
set backspace=indent,eol,start

" set modeline
" set modelines=2

" Terminal {{{1

if has('mouse')
  set mouse+=a
endif

if !has('nvim')
  " Fix mouse inside screen and tmux (e.g. drag splits)
  if &term =~# '^screen' || strlen($TMUX) > 0
      set ttymouse=xterm2
  endif
" Fast terminal connection
  set ttyfast
endif

" FIXME: Graphical issues if not xterm-256color (currently set by tmux)
" set term=$TERM screen-256color xterm-256color

if &term =~# '256color'
  " Disable Background Color Erase (BCE) so that color schemes
  " work properly when Vim is used inside tmux and GNU screen.
  " See also http://snk.tuxfamily.org/log/vim-256color-bce.html
  set t_ut=
endif

" " Allow color schemes to do bright colors without forcing bold
if &t_Co == 8 && $TERM !~# '^linux\|^Eterm'
  set t_Co=16
endif

" Colors {{{1

" Enable syntax highlighting
if has('syntax') && (&t_Co > 2 || has('gui_running')) && !exists('syntax_on')
  syntax enable
endif

set synmaxcol=500

if exists('+colorcolumn')
  " set colorcolumn=80
  " Relative to textwidth
  set colorcolumn=+1
  "let &colorcolumn=join(range(1,80),",")
endif

call background#set()
try
  " let g:solarized_termtrans = 1
  colorscheme solarized
  call togglebg#map('<F5>')
catch /E185:/
  " Default color scheme
  colorscheme desert
endtry

" 1}}

if exists('g:vim_config') && filereadable(expand(g:vim_config))
  exec 'source ' . g:vim_config
endif
