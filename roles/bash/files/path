#
# ~/.path
#
# require ~/.functions

pathmunge /usr/local/sbin

# ~/bin
pathmunge "$HOME/bin" after

# Composer packages
# COMPOSER_HOME="$HOME/.composer"
# COMPOSER_BIN_DIR="vendor/bin"
# pathmunge "$COMPOSER_HOME/$COMPOSER_BIN_DIR" after
pathmunge "$(composer config -g home)/$(composer config -g bin-dir)" after

# NodeJS modules (npm config get > 400ms)
# [[ "$(which npm)" ]] && pathmunge "$(npm config get prefix)/bin" after
pathmunge "$HOME/.node_modules/bin" after

# Ruby gems
pathmunge "$(ruby -e 'print Gem.user_dir')/bin" after

