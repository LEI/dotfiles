#!/usr/bin/env bash
#
# ~/.bash_prompt
#
# github.com/necolas/dotfiles
# github.com/mathiasbynens/dotfiles/blob/master/.bash_prompt
# github.com/demure/dotfiles/blob/master/subbash/prompt

# user=$(whoami)
# host=$(hostname)

# No color (reset)
NC='\[${bblack}\]'

# Exit status symbol
PROMPT_SYMBOL="›" #→
PROMPT_SYMBOL_ERROR="×"

# ~/.git-prompt.sh
# Show dirty state next to the branch name
#   '*' unstaged changes
#   '+' staged changes
GIT_PS1_SHOWDIRTYSTATE=1
#   '$': stashed items
GIT_PS1_SHOWSTASHSTATE=1
#   '%': untracked files
GIT_PS1_SHOWUNTRACKEDFILES=1
# Difference between HEAD and its upstream:
#   '<'           behind
#   '>'           ahead
#   '<>'          diverged
#   '='           no difference
# Other values:
#   verbose       show number of commits ahead/behind (+/-) upstream
#   name          if verbose, then also show the upstream abbrev name
#   legacy        don't use the '--count' option available in recent
#                 versions of git-rev-list
#   git           always compare HEAD to @{upstream}
#   svn           always compare HEAD to your SVN upstream
GIT_PS1_SHOWUPSTREAM="auto"
# Colored dirty state hints
GIT_PS1_SHOWCOLORHINTS=1

prompt_right() {
  local date="$(date +%H:%M:%S)"

  if [[ ! -n $COLUMNS ]]; then
    COLUMNS=$(tput cols)
  fi

  #$(prompt_jobs)
  printf ${bblack}"%*s" $COLUMNS "$date"
}

# ✓
# ×
prompt_status() {
  local exit=$1
  local default="> "
  local default_error="x "
  local success="${2-$default}"
  local error="${3-$default_error}"
  local str=

  if [[ $exit -eq 0 ]]; then
    str="$success"
  else
    str="$error"
  fi

  printf "%b" "$str"
}

prompt_command() {
  # Exit code
  EXIT=$?
  EXIT_STATUS=$(prompt_status $EXIT "${white}${PROMPT_SYMBOL} " "${red}${PROMPT_SYMBOL_ERROR} " )

  # Git branch
  GIT_PROMPT=$(__git_ps1 "${bblack} on %s" | sed -re "s/(on\s)(.*)\s(.*)/\1$red\2$white\3/")
}

# Set the terminal title to the current working directory
PS1='\[\033]0;\w\007\]'

# Right align datetime
PS1+='\[$(tput sc; prompt_right; tput rc)\]'

if [[ "$USER" == "root" ]]; then
  PS1+='\[${red}\]'
else
  PS1+='\[${cyan}\]'
fi
# User
PS1+='\u'
PS1+='\[${reset}\]'

# Display the hostname when != username
# FIXME: $(hostname) & $HOST != \h
if [[ "$USER" != "$HOSTNAME" ]]; then
  PS1+=$NC
  PS1+=' at '
  # Highlight the hostname when connected via SSH
  if [[ -n "${SSH_TTY}" ]]; then
	PS1+='\[${bold}\]'
	PS1+='\[${red}\]'
  else
	PS1+='\[${blue}\]'
  fi
  # Host
  PS1+='\h'
  PS1+='\[${reset}\]'
fi

PS1+=$NC
PS1+=' in '
PS1+='\[${white}\]'
# Working directory
PS1+='\w'
PS1+='\[${reset}\]'

# Git branch
PS1+='$GIT_PROMPT'
# PS1+='\[${reset}\]'

# Command line
PS1+='\n'
PS1+='$EXIT_STATUS'
PS1+='\[${reset}\]'

PROMPT_COMMAND='prompt_command'
# PROMPT_COMMAND='__git_ps1 "\@\h:\w" "\\\$ "'

PS2='$PROMPT_SYMBOL '
