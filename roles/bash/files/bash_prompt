#!/usr/bin/env bash
#
# ~/.bash_prompt
#
# github.com/necolas/dotfiles
# github.com/mathiasbynens/dotfiles/blob/master/.bash_prompt
# github.com/demure/dotfiles/blob/master/subbash/prompt

# user=$(whoami)
# host=$(hostname)

PROMPT_SYMBOL="› " # $ ✓ →
PROMPT_SYMBOL_ERROR="× " # ! ×

PS2="${PROMPT_SYMBOL:->} "

PROMPT_COMMAND='prompt_command'

# ~/.git-prompt.sh
# PROMPT_COMMAND='__git_ps1 "\u at \h in \w" "\n\\\$ "'

# Show state next to the branch name
#   '*' unstaged changes
#   '+' staged changes
GIT_PS1_SHOWDIRTYSTATE=1
#   '$': stashed items
GIT_PS1_SHOWSTASHSTATE=1
#   '%': untracked files
GIT_PS1_SHOWUNTRACKEDFILES=1

# Difference between HEAD and its upstream:
#   '<'           behind
#   '>'           ahead
#   '<>'          diverged
#   '='           no difference
GIT_PS1_SHOWUPSTREAM="auto"
#   auto
#   verbose       show number of commits ahead/behind (+/-) upstream
#   name          if verbose, then also show the upstream abbrev name
#   legacy        don't use the '--count' option available in recent
#                 versions of git-rev-list
#   git           always compare HEAD to @{upstream}
#   svn           always compare HEAD to your SVN upstream

# Colored hints (only when used with 2 arguments as prompt command)
GIT_PS1_SHOWCOLORHINTS=1

prompt_right() {
  local date="$(date +%H:%M:%S) "
  local color=${1:-}

  if [[ ! -n $COLUMNS ]]; then
    COLUMNS=$(tput cols)
  fi

  printf ${color}"%*s" $COLUMNS "$date"
}

prompt_command() {
  # Exit code
  local exit=$?
  # Start of PS1
  local p=
  # End of PS1 (before symbol)
  local p_end='\n'
  # Default symbols
  local p_symbol="${PROMPT_SYMBOL:-$ }"
  local p_symbol_error="${PROMPT_SYMBOL_ERROR:-! }"

  # Colors
  local c_text='\['${bblack}'\]'
  local c_reset='\['${reset}'\]'
  local c_bold='\['${bold}'\]'
  local c_blue='\['${blue}'\]'
  local c_cyan='\['${cyan}'\]'
  local c_red='\['${red}'\]'
  local c_white='\['${white}'\]'
  local c_yellow='\['${yellow}'\]'

  # Set the terminal title to the current working directory
  p+='\[\033]0;\w\007\]'

  # Right align datetime
  p+='\[$(tput sc; prompt_right '${c_text}'; tput rc)\]'

  # User
  if [[ "$USER" == "root" ]]; then
    p+="$c_red"
  else
    p+="$c_blue"
  fi
  p+='\u'
  p+="$c_reset"

  # Display the hostname only if it is different
  # FIXME: $(hostname) & $HOST != \h
  # if [[ ! "$HOSTNAME" =~ "$USER" ]]; then
  if [[ "$USER" != "$HOSTNAME" ]]; then
    p+="$c_text"
    p+=' at '
    p+="$c_reset"
    # Highlight the hostname when connected via SSH
    if [[ -n "${SSH_TTY}" ]]; then
      p+="$c_bold"
      p+="$c_red"
    else
      p+="$c_cyan"
    fi
    # Host
    p+='\h'
    p+="$c_reset"
  fi

  p+="$c_text"
  p+=' in '
  p+="$c_reset"
  # Working directory
  p+="$c_white"
  p+='\w'
  p+="$c_reset"

  # Exit code
  if [[ $exit -eq 0 ]]; then
    p_end+="${c_white}${p_symbol}${c_reset}"
  else
    p_end+="${c_red}${p_symbol_error}${c_reset}"
  fi

  local git_printf_format="${c_text} on ${c_reset}%s"
  __git_ps1 "${p}" "${p_end}" "${git_printf_format}"

  if [[ "$__git_ps1_branch_name" == "master" ]]; then
    # Change master branch color from green to yellow
    PS1=${PS1/'\[\e[32m\]${__git_ps1_branch_name}'/${c_yellow}'${__git_ps1_branch_name}'}
  fi

  # if [[ "$__git_ps1_branch_name" == "master" && "$PS1" =~ '\[\e[32m\]${__git_ps1_branch_name}' ]]; then
  #   __git_ps1_branch_name="${yellow}${__git_ps1_branch_name}"
  # fi

  # echo $PS1
  # PS1=

  # __git_ps1 " on %s" | sed -re "s/(\son\s)(\W*)(\w+)(\W*)/\1\2$red\3$white\4/"
}
