#!/usr/bin/env bash
#
# ~/.bash_prompt
#
# github.com/necolas/dotfiles
# github.com/mathiasbynens/dotfiles/blob/master/.bash_prompt
# github.com/demure/dotfiles/blob/master/subbash/prompt

# user=$(whoami)
# host=$(hostname)

PROMPT_COMMAND='__ps1'
# PROMPT_COMMAND='__git_ps1 "\u at \h in \w" "\n\\\$ "'

PS2='${PROMPT_SYMBOL} '

# $ ✓ →
PROMPT_SYMBOL="›"

# ! ×
PROMPT_SYMBOL_ERROR="×"

# No color (reset)
NC="${bblack}"

# ~/.git-prompt.sh

# Show dirty state next to the branch name
#   '*' unstaged changes
#   '+' staged changes
GIT_PS1_SHOWDIRTYSTATE=1

#   '$': stashed items
GIT_PS1_SHOWSTASHSTATE=1

#   '%': untracked files
GIT_PS1_SHOWUNTRACKEDFILES=1

# Difference between HEAD and its upstream:
#   '<'           behind
#   '>'           ahead
#   '<>'          diverged
#   '='           no difference
GIT_PS1_SHOWUPSTREAM="auto"
# Other values:
#   verbose       show number of commits ahead/behind (+/-) upstream
#   name          if verbose, then also show the upstream abbrev name
#   legacy        don't use the '--count' option available in recent
#                 versions of git-rev-list
#   git           always compare HEAD to @{upstream}
#   svn           always compare HEAD to your SVN upstream

# Colored hints (only when used with 2 arguments as prompt command)
GIT_PS1_SHOWCOLORHINTS=1

prompt_right() {
  local date="$(date +%H:%M:%S)"

  if [[ ! -n $COLUMNS ]]; then
    COLUMNS=$(tput cols)
  fi

  printf ${bblack}"%*s" $COLUMNS "$date "
}

__ps1() {
  # Exit code
  local exit=$?

  # Set the terminal title to the current working directory
  local ps1='\[\033]0;\w\007\]'

  # Right align datetime
  ps1+='\[$(tput sc; prompt_right; tput rc)\]'

  if [[ "$USER" == "root" ]]; then
    ps1+='\[${red}\]'
  else
    ps1+='\[${cyan}\]'
  fi
  # User
  ps1+='\u'
  ps1+='\[${reset}\]'

  # Display the hostname when != username
  # FIXME: $(hostname) & $HOST != \h
  if [[ "$USER" != "$HOSTNAME" ]]; then
    ps1+='\[${NC}\]'
    ps1+=' at '
    ps1+='\[${reset}\]'
    # Highlight the hostname when connected via SSH
    if [[ -n "${SSH_TTY}" ]]; then
	  ps1+='\[${bold}\]'
	  ps1+='\[${red}\]'
    else
	  ps1+='\[${blue}\]'
    fi
    # Host
    ps1+='\h'
    ps1+='\[${reset}\]'
  fi

  ps1+='\[${NC}\]'
  ps1+=' in '
  ps1+='\[${reset}\]'
  # Working directory
  ps1+='\[${white}\]'
  ps1+='\w'
  ps1+='\[${reset}\]'

  # Exit code
  local ps1_end='\n'
  if [[ $exit -eq 0 ]]; then
    ps1_end+='\[${white}\]${PROMPT_SYMBOL} \[${reset}\]'
  else
    ps1_end+='\[${red}\]${PROMPT_SYMBOL_ERROR} \[${reset}\]'
  fi

  __git_ps1 "${ps1}" "${ps1_end}" ' \[${NC}\]on\[${reset}\] %s'
  # __git_ps1 " on %s" | sed -re "s/(\son\s)(\W*)(\w+)(\W*)/\1\2$red\3$white\4/"

  # if [[ "$__git_ps1_branch_name" == "master" ]]; then
  #   __git_ps1_branch_name="${yellow}${__git_ps1_branch_name}"
  # fi

  # echo $PS1
  # PS1=
}
