#
# wrapper around iii.sh
# spawns iii.sh in a tmux session named IRC with the channel as title
# accepts all env vars iii.sh accepts plus 't' which sets the terminal

in_tmux() {
  [[ -n "$TMUX" ]]
}

has_session() {
  local session="$1"
  tmux list-sessions | awk -v r=1 -v m="$session" '$1 == m":" { exit r=0 } END { exit r }'
}

has_window() {
  local session="$1" window="$2"
  tmux list-windows -t "$session" | awk -v r=1 -v m="$window" '$2 ~ "^"m"[#*!-]*$" { exit r=0 } END { exit r }'
}

go_to_window() {
  if [[ "${goto:-true}" == true ]]
  then
    local session="$1" window="$2"
    local cmd="attach-session"
    in_tmux && cmd="switch-client"
    # echo tmux "$cmd" -t "$session" \; select-window -t "$session":"$window" >> ~/tmi.txt
    tmux "$cmd" -t "$session" \; select-window -t "$session":"$window" #.
  fi
}

iii="$HOME/irc/bin/iii"

# Collect options from env - all opts to iii.sh should be set here
opts="m="${m}" h="${h}" p="${p}" n="${n}" l="${l}" r="${r}" i="${i}" s="${s}" c="${c}""
# TERM="${t:-rxvt-unicode}"

# Session name
if [[ -n "$s" ]]
then
  session="${s}"
  # Trim ^[irc.], [.net]$
  session="${session#irc.}"
  session="${session%.net}"
  # Replace dots with dashes
  session="${session//./-}"
  session="${session//:/_}"
  # To upper case
  session="$(echo "$session" | tr '[:lower:]' '[:upper:]')"
  # TODO Prefix IRC/?
else
  session="IRC"
fi

# Window name
# if [[ -n "$c" ]]
# then window="$c"
# else window="$s"
# fi
window="${c:-$s}"
# window=${window//./\\.} # Cannot contain dots
# Replace dots with 'one dot leader' (U+2024)
window="${window//./․}"

# TODO right pane /names

# Spawn a new tmux window named <channel> in a tmux session named IRC
if ! has_session "$session"
then
  # echo "no session named $session" >> ~/tmi.txt
  if in_tmux
  then
    # echo tmux new-session -d -s "$session" -n "$window" "$opts $iii" >> ~/tmi.txt
    tmux new-session -s "$session" -n "$window" -d "$opts $iii"
    go_to_window "$session" "$window"
  else
    tmux new-session -s "$session" -n "$window" "$opts $iii"
  fi
elif ! has_window "$session" "$window"
then
  # echo "no window named $window" >> ~/tmi.txt
  # echo tmux new-window -t "$session" -n "$window" -d "$opts $iii" >> ~/tmi.txt
  tmux new-window -t "$session" -n "$window" -d "$opts $iii"
  if in_tmux
  then
    go_to_window "$session" "$window"
  fi
else
  go_to_window "$session" "$window"
fi

# #TERM="${t:-rxvt-unicode}"
# opts="m=$m h=$h p=$p n=$n l=$l i=$i s=$s c=$c"
