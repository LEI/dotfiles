#!/usr/bin/env bash
# kill $(ps aux | awk '/connect/ {print $2}')

: "${ircdir:=$HOME/irc}"
: "${nick:=$USER}"

# Some privacy please, thanks
chmod 700 "$ircdir"
chmod 600 "$ircdir"/*/ident &>/dev/null

# for network in $networks
# do
#   unset server channels port
#   "$network" # Set the appropriate vars
#   ...
# done

if [[ "$#" -gt 0 ]]
then
  server="$1"
  shift
  channels=("$@")
else
  echo "No server specified"
  # echo "Usage: connect [-n nick] server[:port] [channels]"
  exit 1
  # : "${server:=irc.freenode.net}"
  # : "${channels:=}"
fi

while true
do
  # Cleanup
  rm -f "$ircdir/$server/in"

  # Flush
  rm -f "$ircdir/$server/out"
  rm -f $ircdir/$server/**/{in,out}

  # Connect to network -- password is set through the env var synonym to the network name
  # iim -i "$ircdir" -n "$nick" -k "$network" -s "$server" -p "${port:-6667}" &
  ii -i "$ircdir" -n "$nick" -k "$network" -s "$server" -p "${port:-6667}" -e ssl &
  pid="$!"

  # Wait for the connection
  while ! test -p "$ircdir/$server/in"
  do sleep .3; done

  # Auth to services
  if [[ -e "$ircdir/$server/ident" ]]
  then
    printf "/j nickserv identify %s\n" "$(cat "$ircdir/$server/ident")" > "$ircdir/$server/in" \
    && rm -f "$ircdir/$server/nickserv/out" # Clean that up - ident passwd is in there

    # Wait for NickServ identification
    while ! test -f "$ircdir/$server/nickserv/out"
    do sleep .3; done

    (tail -f "$ircdir/$server/nickserv/out" & echo $! >&3) 3>tpid | while read line
    do case "$line" in *identified*$nick*) kill $(<tpid) ;; esac
    done
  fi

  if [[ -n "$channels" ]]
  then printf "/j %s\n" "${channels[@]}" > "$ircdir/$server/in"
  fi # Join channels

  # If connection is lost reconnect
  wait "$pid"
done &
