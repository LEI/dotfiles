#!/usr/bin/env bash

: "${ircdir:=$HOME/irc}"
: "${nick:=$USER}"
: "${pass:=}" # Password environment variable name
: "${name:=}" # Full name
: "${server:=}" # irc.freenode.net
: "${port:=6697}" # 6667
: "${secure:=ssl}"
: "${cleanup:=1}"

lock="$nick@$server:$port"

# Some privacy please, thanks
chmod 700 "$ircdir"
chmod 600 "$ircdir"/*/ident &>/dev/null

# echo "Usage: connect [-n nick] server[:port] [channels]"
# : "${server:=irc.freenode.net}"
# : "${channels:=}"
  # server="$1"
  # shift
# elif [[ -z "$server" ]]
# then echo "Invalid server" && exit 1
if [[ "$#" -gt 0 ]]
then channels="$@"
fi

while true
do
  # pid="$$"
  # echo "$pid" > "$pidfile"

  # if [[ -f "$pidfile" ]]
  # then pkill -F "$pidfile" && rm "$pidfile"
  # else echo "ii error ($pidfile: No such file)" >&2
  # fi

  # Cleanup
  if [[ "$cleanup" -gt 0 ]]
  then # rm -f "$ircdir/$server/**/{in,out}"
    #rm -f $ircdir/$server{/,*/}{in,out}
    rm -f $ircdir/$server/{in,out,*.log}
    rm -f $ircdir/$server/*/{in,out}
    rmdir --ignore-fail-on-non-empty "$ircdir/$server/*"
  else rm -f "$ircdir/$server/in"
  fi

  # Connect to network
  # iim -i "$ircdir" -n "$nick" -k "$network" -s "$server" -p "${port:-6667}" &
  # -k "$pass" -f "$name"
  ii -i "$ircdir" -n "$nick" -s "$server" -p "$port" -e "$secure" &
  iipid="$!"

  # Wait for the connection
  while ! test -p "$ircdir/$server/in"
  do sleep .3; done

  # Auth to services
  if [[ -e "$ircdir/$server/ident" ]] # && [[ ! -d "$ircdir/$server/nickserv" ]]
  then
    printf "/j nickserv identify %s\n" "$(cat "$ircdir/$server/ident")" > "$ircdir/$server/in" \
      && rm -f "$ircdir/$server/nickserv/out" # Clean that up - ident passwd is in there

    # Wait for NickServ identification
    while ! test -f "$ircdir/$server/nickserv/out"
    do sleep .3; done

    # echo "Waiting for NickServ..."
    (tail -f "$ircdir/$server/nickserv/out" & echo $! >/tmp/tpid) | while read line
    do case "$line" in *identified*$nick*) kill $(</tmp/tpid) ;; *) sleep .3 ;; esac
    done
  fi

  # echo "Joining ${channels[@]}..."
  if [[ -n "$channels" ]]
  then printf "/j %s\n" $channels > "$ircdir/$server/in"
  fi

  # If connection is lost reconnect
  wait "$iipid"
done &
