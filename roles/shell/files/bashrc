#
# ~/.bashrc
#

# If not running interactively, do not do anything
[[ $- != *i* ]] && return

# $ ✓ →
PROMPT_SYMBOL="› "
# ! ×
PROMPT_SYMBOL_ERROR="× "

if ! hash add 2>/dev/null; then
  source ~/.bash.d/init.bash
fi

# Load each bash script in ~/.bash.d/$directory/*.bash
# FIXME: Load completion with ~/.bash_completion (not sourced on OSX)
add aliases completion settings

lib "colorize-cat-less.bash"
lib "colors.bash"
lib "prompt.bash"

# Load home dotfiles
# Export variables: ~/.exports
# Extend '$PATH' with pathmunge: ~/.path
# Extra settings, not committed: ~/.extra
source_files ~/.{exports,path,extra}
