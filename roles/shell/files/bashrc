#
# ~/.bashrc
#

# $ вЬУ вЖТ
PROMPT_SYMBOL="вАЇ "
# ! √Ч
PROMPT_SYMBOL_ERROR="√Ч "

if ! hash add 2>/dev/null; then
  source ~/.bash.d/init.bash
fi

# Source each bash script in ~/.bash.d/$directory
add aliases colors library plugins
# ~/.bash_completion should take care of adding 'completion'

# Source shell dotfiles
load ~/.{exports,path,extra}
# Export variables: ~/.exports
# Extend '$PATH' with pathmunge: ~/.path
# Extra settings, not committed: ~/.extra
