#
# ~/.bashrc
#

# If not running interactively, do not do anything
[[ $- != *i* ]] && return

# $ ✓ →
PROMPT_SYMBOL="› "
# ! ×
PROMPT_SYMBOL_ERROR="× "

if ! hash add 2>/dev/null; then
  source ~/.bash.d/init.bash
fi

# Source each bash script in ~/.bash.d/$directory/*.bash
# TODO: Load completion with ~/.bash_completion? (not sourced on OSX)
add aliases colors completion library plugins

# Base16 Shell (256 colors)
# BASE16_SHELL="$BASH_DIR/colors/base16-default.dark.sh"
# [[ -s $BASE16_SHELL ]] && source $BASE16_SHELL

# Source shell dotfiles
# Export variables: ~/.exports
# Extend '$PATH' with pathmunge: ~/.path
# Extra settings, not committed: ~/.extra
load ~/.{exports,path,extra}
