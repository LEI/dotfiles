#
# ~/.bashrc
#

# https://github.com/mathiasbynens/dotfiles/blob/master/.bash_profile
# https://github.com/mathiasbynens/dotfiles/blob/master/.functions
# https://github.com/Bash-it/bash-it/blob/master/lib/helpers.bash
# https://github.com/Bash-it/bash-it/blob/master/settings/available/base.plugin.bash

# If not running interactively, do not do anything
[[ $- != *i* ]] && return

# Bash directory
export BASH_DIR="$HOME/.bash.d"

# Load functions
if ! hash add 2>/dev/null; then
  source $BASH_DIR/library/utils.bash
fi

# Load directories
# TODO: Load completion with ~/.bash_completion (not sourced on OSX?)
source_dir $BASH_DIR/{aliases,completion,settings}

# Load helpers
source_files $BASH_DIR/library/{colorize-cat-less,colors,pathmunge,prompt}.bash

# Load home dotfiles
source_files ~/.{exports,path,extra}
