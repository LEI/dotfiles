#!/usr/bin/env bash
# http://ptpb.pw/#shell-functions
# https://github.com/HalosGhost/pbpst

PB_CURL_OPTS=
PB_PROVIDER="https://ptpb.pw" #-CRUShdpfuvx
PB_ARGS=("h|help" \
  "d|debug" \
  "P|provider:+string" \
  "C|create:file!uuid" \
  "U|update:file&uuid" \
  "R|remove:uuid" \
  "S|shorten:+" \
  "G|get:+" \
  "lf|list-formats" \
  "ll|list-lexers" \
  "ls|list-styles" \
  "r|render:create|update!term" \
  "t|term:create|update!render" \
  "f|file:create|update-" \
  "p|private:create" \
  "u|uuid:update|remove+string" \
  "v|vanity:create" \
  "x|sunset:create|update+duration")
PB_DESC=("This"
  "Print curl command instead of executing it" \
  "Pastebin host, default: $PB_PROVIDER" \
  "Create a new paste (required: file)" \
  "Update an existing paste (required: uuid)" \
  "Remove a paste (required: uuid)" \
  "Create a redirect url (required: file <<<)" \
  "Arbitrary GET request" \
  "(-G lf)" \
  "Pygments lexer used for syntax highlighting (-G l)" \
  "(-G ls)" \
  "Render a ReStructuredText or Markdown paste to HTML (-CU)" \
  "Handle Asciinema videos (-CU)" \
  "Content of the paste (-CUS)" \
  "The paste can only be retrieved by knowledge of its sha1 hexdigest (-C)" \
  "Shared secret allowing modification (-UR)" \
  "Custom id, prefixed with '~' (-C)" \
  "Set the paste to expire automatically (-CU)")

set -e
set -o pipefail
shopt -s extglob

# Copy the url of the uploaded paste
pbx() {
  local copy
  if hash xsel 2>/dev/null
  then copy="xsel -l /dev/null -b"
  # elif xclip[board]
  elif hash pbcopy 2>/dev/null
  then copy="pbcopy" # -pboard general
  else error "pbx: No clipboard manager found ($(uname -s))"; return 1
  fi
  local opts="--render $@" # --handler=r $@" # ?r=1
  local curl_opts="$PB_CURL_OPTS -s -w %{redirect_url} -o /dev/stderr"
  PB_CURL_OPTS="$curl_opts" pb $opts | "$copy"
  # curl -sF "c=@${1:--}" -w "%{redirect_url}" 'http://ptpb.pw/?r=1' -o /dev/stderr | "$copy"
}

# Encrypt file with GPG symetric cipher
pbg() { # Decrypt with curl <pasteurl> | gpg -d
  gpg -o - -c "$1" | pbx -C # $@
}

# Capture screenshot
pbs () {
  local win="${1:-root}"
  local tmp=/tmp/$$.png
  gm import -window $win $tmp
  pbx $tmp
}

# Record terminal
pbs () {
  local tmp=/tmp/$$.json
  asciinema rec $tmp
  pbx $tmp
}

usage() {
  local e=$?
  local err="${1:-}"
  [[ $# -gt 1 ]] && shift
  if [[ -n "$err" ]]
  then pberr "$err"; e=1
  fi
  >&2 printf "%s\n" "Usage: pb [opts]"
  >&2 printf "          %-24s%s\n" "[--version] [--help] [--debug]" "$@"
    # "[ --help | --debug ]" "$@"
  exit $e
}

# GET /f GET /s GET /l GET /lf GET /ls
# GET /<id> GET /<id>/<lexer> GET /<id>/<lexer>/<formatter> GET /<handler>/<id>
# POST /<handler> POST / POST /<vanity> POST /u
# PUT /<uuid>
# DELETE /<uuid>
full_usage() {
  local i desc=()
  for ((i=1; i<${#PB_ARGS[@]}; i++))
  do
    arg="${PB_ARGS[i]}" #; arg="${arg#*,}"; arg="${arg%%,*}"
    arg="${arg%%:*}"
    arg="-${arg/|/, --}"
    desc+=("$arg")
    desc+=("${PB_DESC[i]}")
  done
  usage "$1" "" "${desc[@]}"
}

pb() {
  local url="$PB_PROVIDER"
  local opts="$PB_CURL_OPTS"
  local args args

  # [[ -t 0 ]] && in=1 || in=
  args=("$(PARSE_ARGS="${PB_ARGS[@]}" args "$@")") || return 1
  while read -r arg
  do declare ${arg%%=*}="${arg#*=}"
  done <<< "${args[@]}"

  [[ -n "$debug" ]] && >&2 printf "%s\n" "${args[@]}"
  # for v in help get create update remove shorten; do printf "%s=%s\n" "$v" "${!v}"; done

  # local method get create update remove shorten list_formats list_lexerslist_styles # Actions
  # local help debug provider render term file private uuid vanity sunset # Parameters

  [[ -n "$provider" ]] && url="$provider"
  # [[ -n "$file" ]] && [[ ! -f "$file" ]] # Used as a string!
  [[ -n "$shorten" ]] && [[ "$shorten" != true ]] && file="$shorten" && shorten=true
  [[ -n "$get" ]] && [[ "$get" != true ]] && url+="/$get" && get=true

  # if [[ -n "$file" ]] && [[ -t 0 ]]
  # then
  # fi

  case true in
    $help) full_usage ;;
    $list_formats) get=true; url+="/lf" ;;
    $list_lexers) get=true; url+="/l" ;;
    $list_styles) get=true; url+="/ls" ;;
  esac
  case true in
    $get) method="GET"
      ;;
    $create) # POST
      [[ -n "$private" ]] && opts+=" -F p=1"
      [[ -n "$sunset" ]] && opts+=" -F sunset=$sunset"
      [[ -n "$vanity" ]] && url+="/~$vanity"
      [[ -f "$file" ]] || [[ -z "$file" ]] && file="@${file:--}"
      [[ -n "$file" ]] && opts+=" -F "c=$file""
      ;;
    $update) method="PUT"
      url+="/$uuid"
      [[ -n "$sunset" ]] && opts+=" -F sunset=$sunset"
      [[ -f "$file" ]] || [[ -z "$file" ]] && file="@${file:--}"
      [[ -n "$file" ]] && opts+=" -F "c=$file""
      ;;
    $remove) method="DELETE"
      url+="/$uuid"
      ;;
    $shorten) # POST
      url+="/u"
      [[ -f "$file" ]] || [[ -z "$file" ]] && file="@${file:--}"
      [[ -n "$file" ]] && opts+=" -F "c=$file""
      ;;
  esac

  # Handler
  [[ -n "$render" ]] && url+="?r=1"
  [[ -n "$term" ]] && url+="?t=1"

  [[ -n "$method" ]] && opts+=" -X $method"

  # Execute or debug
  if [[ -z "$debug" ]]
  then echo curl $opts $url
  else >&2 echo curl $opts $url
  fi
}

