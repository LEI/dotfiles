#!/usr/bin/env sh

export \
    g_1='create remove' \
    g_2='modify';

myscript () {
    # setup cmd; declare functions
    for i in "${!g_@}"; do
        typeset -n j=$i;
        for k in ${j}; do
            #danger
            . /dev/fd/0 <<< "function ${k} () {
                readonly action_${!j}=$k 2>/dev/null || {
                    echo error: use only one cmd of: ${j} 1>&2;
                    exit 1; 
                };
            }";
        done;
    done;

    # setup options
    :;
    
    # parse args
    typeset -a actions;
    for a; do
        if
            typeset -F "$a" 1>/dev/null 2>&1;
        then
            "$a" && {
                actions+=("$a");
                unset -f a;
            };
        else
            echo unkown cmd ... 2>&1;
            exit 1;
        fi;
    done;

    echo "$actions";
};

echo 'myscript' create modify remove;
