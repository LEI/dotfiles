#!/usr/bin/env bash

# https://github.com/Bash-it/bash-it/blob/master/plugins/available/battery.plugin.bash

battery_percentage() {
  local b
  if hash pmset 2>/dev/null; then
    pmset -g batt | awk 'NR==2 { gsub(/;/,""); print $2 }'
  elif hash upower 2>/dev/null; then
    for b in $(upower -e | grep battery); do
      upower -i $b | grep percentage | awk '{print $2}'
    done | xargs echo
  elif hash acpi 2>/dev/null; then
    acpi -b | grep -Eo "[0-9]+%"
  else
    return 1
  fi
}

