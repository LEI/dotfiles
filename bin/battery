battery_status() {
  local b
  if hash pmset 2>/dev/null; then
    pmset -g batt | awk -F '; *' 'NR==2 { print $2 }'
  elif hash upower 2>/dev/null; then
    # sort order: attached, charging, discharging
    for b in $(upower -e | grep battery); do
      upower -i $b | grep state | awk '{print $2}'
    done | sort | head -1
  elif hash acpi 2>/dev/null; then
    acpi -b | grep -oi 'discharging' | awk '{print tolower($0)}'
  fi
}

main() {
  # TODO: check has battery!
  local status="$(battery_status)"
  # [[ "$status" =~ (discharging) ]]
  # (charged), (^charging), (^discharging), (attached)

  local percentage="$(battery_percentage)"
  # local bar="$(spark 0 ${percentage%\%} 100)"
  # printf "%s" "${bar:1:1}"

  printf "%s (%s)" "$percentage" "$status"
}

main "$@"
