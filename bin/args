#!/usr/bin/env bash

# First attempt with "while read"

_contains() {
  local ret=1
  local i n="$NEEDLE"
  for i in "$@"
  do
    if [[ "$i" == *"$n"* ]]
    then # Doesn't work: export FIRSTWORD="${i%% *}"
      printf "%s\n" "$i"
      ret=0
    fi
  done

  return $ret
}

_main() {
  [[ -z "$NEEDLE" ]] && return 1

  local var
  while read -r var
  do printf "%s\n" "$var /^$FIRSTWORD/"
  done < <(_contains "$@" \
    && echo $? > /tmp/ret \
    || echo $? > /tmp/ret)

  read -r ret < /tmp/ret
  return $ret
}

# Reversed exit status with a while loop?

contains() {
  COUNT="${COUNT:-0}"
  local n="$1" # Needle
  shift
  local v="$1" # Variable name
  shift

  shift $COUNT
  # [[ "$COUNT" -gt 0 ]] && set -- "${@:$(($COUNT+1))}"

  while [[ $# -ne 0 ]]
  do
    COUNT=$(($COUNT + 1))
    if [[ "$1" == *"$n"* ]]
    then
      eval "$v=\"$1\""
      FIRSTWORD="${1%% *}"
      return 0 # Loop again?
    fi
    shift
  done

  return 1 # Stop main while loop
}

main() {
  [[ -z "$NEEDLE" ]] && return 1

  while contains "$NEEDLE" var "$@" # || return?
  do # Use $var and others predefined variables here
    printf "%s\n" "$var /^$FIRSTWORD/"
  done

  # $? -> always 0
}

# NEEDLE="test"
# main "this is a test" "and another test"
# main "that one should fail"

[[ "$0" == "$BASH_SOURCE" ]] && main "$@"
