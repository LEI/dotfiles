#!/usr/bin/env bash
# Parse arguments

set -e
set -o pipefail
shopt -s extglob

for f in functions/{time,utils}
do source "${BASH_DIR:-$HOME/.bash.d}/$f.bash"
done

err() {
  die "${0##*/}: $@"
}

parse_args() {
  local cmd=(${PARSE_ARGS[@]:0:1})
  local args=(${PARSE_ARGS[@]:1})
  local parsed=()
  while [[ $# -ne 0 ]]
  do
    case "$1" in
      -|'') err "invalid argument -" ;;
      --) break ;;
      -*) [[ "$next" -eq 1 ]] && err "illegal option $1"
        local pre="-${a%%-*}"
        local p
        for p in "${args[@]}"
        do
          local type next=0
          local req="${p#*:}"
          [[ "$p" == "$req" ]] && unset req
          if [[ "$req" == *- ]]
          then type="stdin"; req="${req%-*}"; next=1
          fi
          if [[ "$req" == *+* ]]
          then type="${req#*+}"; req="${req%+*}"; next=1
          fi
          p="${p%%:*}"
          local short="${p%|*}"
          local name="${p#*|}"
          local ptn="(-$short|--$name)([a-zA-Z]+)?" #($pre)*([a-zA-Z]+)?(=)"
          if [[ $1 =~ $ptn ]]
          then
            # >&2 echo "[[ $1 =~ $ptn ]]"
            # >&2 echo "$short,$name req $req ($next)"
            # local prefix="${BASH_REMATCH[1]}"
            local arg="${BASH_REMATCH[1]}"
            local extra="${BASH_REMATCH[2]}"
            # >&2 printf "MATCH %s\n" "${BASH_REMATCH[@]}"
            if [[ "$arg" == "--"* ]] && [[ -n "$extra" ]]
            then err "$arg: illegal option"
            elif [[ "$arg" == "-"* ]] && [[ -n "$extra" ]]
            then set -- "$arg" "-$extra" "${@:2}"
              # >&2 echo "NEXT:$next => $@"
              # if [[ "$next" -eq 1 ]]
              # then echo >&2 "THEN" "-$arg" "${@:2:1}" "-$extra" "${@:3}"
              #   set -- "-$arg" "${@:2:1}" "-$extra" "${@:3}"
              # else echo >&2 "ELSE" "-$arg" "-$extra" "${@:2}"
              #   set -- "-$arg" "-$extra" "${@:2}"
              # fi
            elif [[ -n "$extra" ]]
            then err "invalid option $arg"
            fi
            local varname="${name//-/_}"
            local res=
            if [[ "$next" -eq 1 ]]
            then
              if [[ "$type" == "stdin" ]]
              then
                if [[ $# -gt 1 ]] && [[ "$2" != -* ]]
                then [[ -f "$2" ]] && res="$varname=@$2" || res="$varname=$2"; shift
                else res="$varname=@-"; next=0 # [[ -t 0 ]]
                fi
              elif [[ $# -gt 1 ]] && [[ -n "$2" ]] && [[ "$2" != -* ]]
              then res="$varname=$2"; shift
              elif  [[ -n "$2" ]]
              then err "$1: $name requires a ${type:-value}, found: $2"
              else err "$1: $name requires a ${type:-value}"
              fi
            else res="$varname=1"
            fi
            shift # key or value
            parsed+=("$res" "${req:-}")
            printf "%s\n" "$res"
            break
          fi
          # >&2 echo "did not break /$p/ $@"
        done
        if [[ -z "$arg" ]]
        then err "illegal option $1"
        fi
        ;;
      *) err "$1? [$@] $#"
        ;;
    esac
  done

# declare -A cant_go=([create]=remove,delete,shred); declare -A cant_tbl=();add_cant() { [[ ${cant_tbl[$2,len]} ]] ||
# 2016-12-03 14:58         resh | cant_tbl[$2,len]=0;cant_tbl[$2,${cant_tbl[$2,len]}]=$1;((cant_tbl[$2,len] ++));};add_cant_row(){ local param=$1 with
# 2016-12-03 14:58         resh | w;IFS=, read -ra with;for w in "${with[@]}"; do add_cant "$w" "$param"; done;};for p in "${!cant_go[@]}";do
