  # local i requires
  # for ((i=0; i<${#parsed[@]}; i+=2))
  # do
  #   arg="${parsed[i]}"
  #   echo >&2 ">>>>>>>>>>>>>>>>>> $arg ${parsed[i+1]}"
  #   while IFS=$',' read -r req
  #   do
  #     if [[ -n "$req" ]]
  #     then
  #       case "$req" in
  #         \&*) >&2 log "$arg AND $r" ;;
  #         \|*) >&2 log "$arg OR $r" ;;
  #         \!*) >&2 log "$arg NOT $r" ;;
