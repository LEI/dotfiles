#!/usr/bin/env bash

set -e
set -o pipefail
shopt -s extglob

# get_seconds
source "${BASH_DIR:-$HOME/.bash.d}/functions/time.bash"

parse() {
  local types="bool|string|number|duration"
  local arg_pattern="($types),([a-zA-Z|\|\-]+)"
  local patterns=() args=()

  while [[ $# -ne 0 ]]
  do
    if [[ $1 =~ $arg_pattern ]]
    then local t="$1"
      case $t in
        duration,*) t="${t/duration,/number,}@get_seconds" ;;
      esac
      patterns+=("$t")
      shift
    elif [[ $1 =~ $types,* ]] # type,(p|pattern)@function"
    then >&2 printf "%s\n" "parse: invalid arg spec -- $1"; exit 1
    else break
    fi
  done # >&2 printf "%s\n" "${patterns[@]}"

  local plen="${#patterns[@]}"
  local t p func name match="$plen"
  local pre key next sep val
  while [[ $# -ne 0 ]] && [[ "$match" -ne 0 ]]
  do match="$plen"
    unset t p func name
    for p in "${patterns[@]}"
    do # >&2 echo "Arguments: '$@'"
      unset pre key next sep val
      if [[ $p == *@* ]]
      then func="${p##*@}"; [[ -n "$func" ]] && p="${p%@*}"
      fi
      t="${p%%,*}" # Type
      p="${p#*,}" # Pattern
      name="${p##*|}" # Long name
      p="(-|--)($p)+([a-zA-Z]+|-)?( |=)?(.*)" # >&2 echo "[[ $1 =~ $p ]]"
      if [[ $1 =~ $p ]]
      then
        # if [[ "${BASH_REMATCH[1]:0:1}" == "${BASH_REMATCH[1]:1:1}" ]]
        # then pre="--"
        # elif [[ "${BASH_REMATCH[1]:0:1}" ]]
        # then pre="-"
        # fi
        pre="${BASH_REMATCH[1]}"
        key="${BASH_REMATCH[2]##*-}"
        next="${BASH_REMATCH[3]:-}"
        sep="${BASH_REMATCH[4]:-}"
        val="${BASH_REMATCH[5]:-}"
        # >&2 echo "PRE: $pre" "KEY: $key" "NEXT: $next" "SEP: '$sep'"
        case $t in
          bool)
            if [[ -z "$val" ]]
            then val=true; shift
            else >&2 printf "%s\n" "error: switch '$pre$key' does not require a value'"; exit 1
            fi
            ;;
          string)
            if [[ -n "$val" ]]
            then shift
            elif [[ $# -gt 1 ]]
            then val="$2"; shift; shift
            else >&2 printf "%s\n" "parse: switch '$pre$key' requires a string"; exit 1
            fi
            ;;
          number)
            if [[ -n "$val" ]]
            then shift
            elif [[ $# -gt 1 ]]
            then val="$2"; shift; shift;
            elif [[ ! $val =~ ^-?[0-9]+$ ]]
            then >&2 printf "%s\n" "parse: switch '$pre$key' requires a number"; exit 1
            else >&2 printf "%s\n" "parse: switch '$pre$key' requires a value"; exit 1
            fi
            ;;
          *) >&2 echo "NO TYPE $1"; break ;;
        esac
        if [[ -n "$next" ]]
        then set -- "$pre$next" "${@:1:1}" "${@:2}"
        fi
        if [[ -n "$func" ]] # && hash "${func%% *}" 2>/dev/null
        then val="$($func "$val")"
        # else >&2 echo "$val ${func%% *}"
        fi
        # >&2 echo "PRE: $pre" "KEY: $key" "NEXT: $next" "SEP: '$sep', VAL: $val"
        printf "%s:%s\n" "$name" "$val"
      else
        # >&2 echo "miss /$p/ $@"
        match=$((match - 1))
        # Extra arguments
        if [[ "$match" -eq 0 ]]
        then printf ":%s\n" "$@"
        fi
      fi
    done
    # if [[ -z "$next" ]] && [[ -n "$name" ]] || [[ "$last" == "$name" ]]
    # then >&2 echo "NO MATCH $1"; shift
    # fi
  done
  # printf "%s\n" "ARGZ $@"
  # echo "pre: $pre"
  # if [[ -n "$1" ]] && [[ "$1" != -* ]]
  # then echo "remaining $1"; break
  # fi

  # echo "args: ${args[@]}"

  # printf "%s:%s\n" "${args[@]}"
  # &>3 printf "%s\n" "$@"
}

[[ "$0" == "$BASH_SOURCE" ]] && parse "$@"
