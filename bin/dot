#!/usr/bin/env bash

# Usage: man ansible-playbook

set -o nounset
set -o errexit
set -o pipefail

[[ -z "${DOT_ROOT-}" ]] && DOT_ROOT="$HOME/.dotfiles"

cd "$DOT_ROOT"

main() {
  ansible_install

  ansible_vault

  # ansible-galaxy install -r requirements/galaxy.yml

  local playbook="playbook.yml"
  ansible-playbook "$playbook" "$@" # --ask-become-pass
}

# opts() {
#   local install=
#   case ${1:-} in
#     install)
#       install=true
#       shift
#       ;;
#   esac
# }

ansible_install() {
  local uname=$(uname -s)

  case $uname in
    Darwin)
      local x="xcode-select --install"
      # If /usr/bin/gcc is absent
      if ! installed gcc; then
        echo "› $x" # Install Xcode
        $x
      fi
      ;;
    Linux)
      # pip cryptography on raspbian ->
      # ERROR! Unexpected Exception: 'EntryPoint' object has no attribute 'resolve'

      # Debian/Ubuntu:
      # sudo apt-get install python-setuptools # Installed in requirements?
      # sudo apt-get install build-essential libffi-dev libssl-dev python-dev

      # Fedora/CentOS:
      # sudo yum install gcc libffi-devel openssl-devel python-devel

      # Archlinux: http://github.com/palazzem/hanzo/blob/master/bin/bootstrap.sh
      # sudo pacman -Syu # --noconfirm
      # sudo pacman -S ansible git python2-setuptools --noconfirm
      # python2 / python2-crypto / python2-cryptography / pyhton2-packaging / python2-pip

      if ! installed ansible; then
        echo "TODO: detect distribution"
        exit 1
      fi
      ;;
    *)
      echo "Unsupported platform: $uname"
      exit 1
      ;;
  esac

  if ! installed pip; then
    # Install python package manager
    su_do easy_install pip
  fi

  if ! installed ansible; then
    # Install ansible and cryptography
    su_do pip install -r requirements/pip.txt
  fi
}

ansible_vault() {
  local vault_file="${ANSIBLE_VAULT_PASSWORD_FILE:-$HOME/.vault_pass.txt}"
  local vault_pass=

  if [[ ! -f "$vault_file" ]]; then
    echo "Vault?"
    read -e -r -s vault_pass
    if [[ -n "$vault_pass" ]]; then
      echo "$vault_pass" >> $vault_file
    else
      ansible_vault
      return
    fi
  fi

  if [[ ! -n "${ANSIBLE_VAULT_PASSWORD_FILE:-}" ]]; then
    export ANSIBLE_VAULT_PASSWORD_FILE=$vault_file
  fi
}

installed() {
  local name="$1"

  # Test if the program can be executed
  hash $name 2>/dev/null

  if [[ $? != 0 ]]; then
    echo >&2 "! $name is not installed"
    return 1
  fi
}

su_do() {
  _do sudo "$@"
}

_do() {
  local cmd="$@"

  if [[ "$1" == "sudo" ]]; then
    shift
  fi

  if installed "$1"; then
    # Execute the command
    echo "› $cmd"
    $cmd
  else
    echo >&2 "× $cmd"
    exit 1
  fi
}

[[ "$0" == "$BASH_SOURCE" ]] && time main "$@"
