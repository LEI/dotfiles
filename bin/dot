#!/usr/bin/env bash

# Usage: man ansible-playbook

set -o nounset
set -o errexit
set -o pipefail

DOT_ROOT="${DOT_ROOT:-$HOME/.dotfiles}"
DOT_REQUIREMENTS="$DOT_ROOT/requirements"
DOT_PLAYBOOK="$DOT_ROOT/playbook.yml"

main() {
  if ! has ansible; then
    ansible_install
  fi

  local vault=
  local vault_file=$(ansible_vault)
  [[ -n "$vault_file" ]] && vault="--vault-password-file=$vault_file"

  # Ansible root directory
  cd "$DOT_ROOT"

  # ansible-galaxy install -r "$DOT_REQUIREMENTS/galaxy.yml"

  # Inventory file defined in ansible.cfg

  # Run the main playbook
  echo $vault
  ansible-playbook "$DOT_PLAYBOOK" "$vault" "$@"
}

ansible_vault() {
  local file=
  # Vault file path
  if [[ -z "${ANSIBLE_VAULT_PASSWORD_FILE:-}" ]]; then
    # export ANSIBLE_VAULT_PASSWORD_FILE="$HOME/.vault_pass.txt"
    file="$HOME/.vault_pass.txt"
  fi

  # Create the vault file if it does not exists
  if [[ -n "$file" ]] && [[ ! -f "$file" ]]; then
    local vault_pass=$(prompt "Vault password?")
    echo "$vault_pass" >> $file
    chmod 0600 "$file"
  fi

  [[ -f "$file" ]] && echo "$file"
}

ansible_install() {
  local os=$(uname -s) # -o Cygwin?

  case $os in
    Darwin)
      # If /usr/bin/gcc is absent
      if ! has gcc; then
        # Install Xcode
        _do "xcode-select --install"
      fi
      # Install ansible with homebrew? (pip installs 2.0)
      ;;
    Linux)
      die "TODO: detect linux package manager"

      # pip cryptography on raspbian ->
      # ERROR! Unexpected Exception: 'EntryPoint' object has no attribute 'resolve'

      # Debian/Ubuntu:
      # sudo apt-get install python-setuptools # Installed in requirements?
      # sudo apt-get install build-essential libffi-dev libssl-dev python-dev

      # Fedora/CentOS:
      # sudo yum install gcc libffi-devel openssl-devel python-devel

      # if has pacman; then
      #   # Archlinux: http://github.com/palazzem/hanzo/blob/master/bin/bootstrap.sh
      #   su_do pacman -Syu --noconfirm
      #   su_do pacman -S ansible --noconfirm # git python2-setuptools --noconfirm
      #   # python2 / python2-crypto / python2-cryptography / pyhton2-packaging / python2-pip
      # fi
      ;;
    Cygwin)
      # https://github.com/grlee/ansible-galaxy.ansible-init/blob/develop/files/setup.sh
      # if ! has apt-cyg; then
      #   lynx -source rawgit.com/transcode-open/apt-cyg/master/apt-cyg > apt-cyg
      #   install apt-cyg /bin
      # fi
      # apt-cyg install git python-{crypto,jinja2,six,yaml}
      # ANSIBLE="$HOME/ansible"
      # git clone --depth 1 git://github.com/ansible/ansible "$ANSIBLE"
      # cd ~/ansible
      # git submodule update --init lib/ansible/modules/{core,extras}
      # PATH="$PATH:$ANSIBLE/bin"
      # PYTHONPATH="$ANSIBLE/lib"
      # ANSIBLE_LIBRARY="$ANSIBLE/library"
      ;;
    *)
      die "Unsupported platform: $os"
      ;;
  esac

  # If Ansible is still not present
  if ! has ansible; then
    if ! has pip; then
      # Install python package manager
      su_do easy_install pip
    fi

    # Install ansible, cryptography and their dependencies
    su_do pip install -r "$DOT_REQUIREMENTS/pip.txt" # --user python
  fi
}

has() {
  [[ "$1" == "sudo" ]] && shift
  local cmd="$1"

  # Test if the program can be executed
  hash $cmd 2>/dev/null

  if [[ $? != 0 ]]; then
    # Display warning
    error "! $cmd is not installed"
  fi
}

_do() {
  local cmd="$@"

  if has $cmd; then
    log "› $cmd"
    # Execute the command
    $cmd
  else
    # Die
    die "× $cmd"
  fi
}

su_do() {
  _do sudo "$@"
}

prompt() {
  local q="$1"
  log "$q" >&2

  local a=
  read -e -r -s a

  if [[ -n "$a" ]]; then
    # Echo answer
    printf "%s" "$a"
  else
    # No answer, ask again
    prompt "$@" && return
  fi
}

log() {
  printf "%s\r\n" "$@"
}

error() {
  log >&2 "$@"
  return 1
}

die() {
  error "$@"
  exit 1
}

[[ "$0" == "$BASH_SOURCE" ]] && time main "$@"
