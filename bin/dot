#!/usr/bin/env bash

# dot

# set -o xtrace
set -o nounset
set -o errexit
set -o pipefail

# # Extend matching operators
# shopt -s extglob
# # Loop on dotfiles
# shopt -s dotglob
# # Do not loop on empty directory
# shopt -s nullglob
# # Recursive globbing (bash 4)
# shopt -s globstar

MIN_BASH_VERSION=3
ENV_BASH_VERSION=${BASH_VERSION%%[^0-9]*}

function dot() {
  # Paths
  # export DOT_ROOT=$HOME/.dotfiles
  [[ -d "$DOT_ROOT" ]] || die "$DOT_ROOT: No such file or directory"
  # cd $(dirname "${BASH_SOURCE[0]}")/..
  # cd $(dirname "$(readlink "${BASH_SOURCE[0]}")")/..
  # DOT_ROOT=$(pwd -P)

  DOT_TARGET=$HOME
  DOT_SCRIPT="$DOT_ROOT/script"

  source $DOT_SCRIPT/lib/import.sh

  # Load libraries
  import "lib/log"
  import "lib/utils"
  import "lib/prompt"
  import "lib/usage"
  import "lib/config"

  # Parse command options
  parse_arguments "$@"

  # Configuration
  DOT_RC="$DOT_ROOT/.dotrc"
  DOT_RC_TEMPLATE="$DOT_SCRIPT/config/.dotrc.template"

  config "$DOT_RC" "$DOT_RC_TEMPLATE" || die "$DOT_RC"

  # ${!DOT_CONFIG_*}
  DEBUG="${DEBUG-${DOT_CONFIG_DEBUG-false}}"
  DRY_RUN="${DRY_RUN-${DOT_CONFIG_DRY_RYN-false}}"
  FORCE="${FORCE-${DOT_CONFIG_FORCE-false}}"
  TIMESTAMPS="${TIMESTAMPS-${DOT_CONFIG_TIMESTAMPS-false}}"

  log_debug "Debug mode enabled" "$BASH_VERSION"
  # debug "DOT_"

  # Platform
  UNAME=$(uname -s | to_lower) # darwin|linux

  DOT_USER_GIT_CREDENTIAL="cache"
  [[ "$UNAME" = "darwin" ]] && DOT_USER_GIT_CREDENTIAL="osxkeychain"

  # Greeting
  log_info "Hello, $DOT_USER_NICK" "$DOT_USER_NAME <$DOT_USER_EMAIL>"

  if confirm "**Homebrew install" "" Y; then
    # Install dependencies
    source $DOT_SCRIPT/install.sh || log_warn "Install aborted"
  fi

  if confirm "**Symlink files to $DOT_TARGET" "" Y; then
    # Bootstrap dotfiles
    source $DOT_SCRIPT/bootstrap.sh || log_warn "Bootstrap aborted"
  fi

  if confirm "**Setup $UNAME specific defaults" "" Y; then
    # Set platform defaults
    source $DOT_SCRIPT/defaults.sh || log_warn "Defaults aborted"
  fi

  if [[ $? -eq 0 ]]; then
    log_success "Done"
  else
    log_error "Status: $?"
  fi
}

parse_arguments() {
  while [[ $# -gt 0 ]]; do
    local key=$1
    local val=${2-}

    # echo "Parsing $1 (#$#)"

    case $key in
      # -t|--target)
      # 	shift
      #
      # 	# Loop until next '-', cannot handle ' -' without quotes
      # 	# while [[ $# -gt 0 ]] && [[ $1 != -* ]]; do
      # 	# 	DOT_TARGET+=" $1"
      # 	# 	shift
      # 	# done
      #
      # 	# Check value until the delimiter '-' is found or end of args
      # 	if [[ $# -gt 0 ]] && [[ ! -z "$val" ]] && [[ $val != -* ]]; then
      # 		shift
      # 	else
      #         # Ask for the missing value
      #         local prompt="Please specify a target path (default: $HOME): "
      #         read -e -r -p "$prompt" val # -i "$HOME"
      #         # Use default
      #         [[ -z "$val" ]] && break
      # 	fi
      # 	# Check destination path
      # 	[[ -d "$val" ]] || usage 1 "Not a directory: $key $val"
      # 	DOT_TARGET="$val"
      # 	;;
      # --uninstall)
      #   UNINSTALL=true
      #   shift
      #   ;;
      -v|--verbose|--debug)
        DEBUG=true
        shift
        ;;
      -d|--dry-run)
        DRY_RUN=true
        shift
        ;;
      -h|--help)
        usage
        ;;
      *)
        usage 1 "Unknown option: $key"
        ;;
    esac
  done
}

check_env() {
	if [[ $ENV_BASH_VERSION -lt $MIN_BASH_VERSION ]]; then
		die "This script requires bash > ${MIN_BASH_VERSION}"
	fi
}

die() {
  local message=${1:-Died}
  printf "%s\r\n" "${BASH_SOURCE[1]}: line ${BASH_LINENO[0]}: ${FUNCNAME[1]}: $message" >&2
  exit 1
}

check_env

[[ "$0" == "$BASH_SOURCE" ]] && dot "$@"
