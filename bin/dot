#!/usr/bin/env bash

[[ -z "$DOT_ROOT" ]] && DOT_ROOT="$HOME/.dotfiles"

run_ansible() {
  local uname=$(uname -s)
  local ansible=$(which ansible)
  local playbook="main.yml"

  if [[ ! -n "$ansible" ]] || [[ ! -x "$ansible" ]]; then
    case $uname in
      Darwin)
	# xcode-select --install
	# sudo easy_install pip
	# sudo pip install paramiko PyYAML jinja2 ansible
	# ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
	;;
      Linux)
	# ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/linuxbrew/go/install)"
	;;
      *)
	echo "Unsupported platform: $uname"
	exit 1
	;;
    esac
    echo "TODO Install Ansible"
    exit 1
  fi

  cd "$DOT_ROOT"

  # -i inventory
  # -K
  ansible-playbook "$playbook" "$@"
}

# dot

# if [[ -z "$DOT_ROOT" ]]; then
#    echo "\$DOT_ROOT is undefined"
#    exit 1
# fi

# # Paths
# cd "$DOT_ROOT"
# # export DOT_ROOT=$HOME/.dotfiles
# # cd $(dirname "${BASH_SOURCE[0]}")/..
# # cd $(dirname "$(readlink "${BASH_SOURCE[0]}")")/..
# # DOT_ROOT=$(pwd -P)
# DOT_TARGET=$HOME
# DOT_SCRIPT="$DOT_ROOT/script"
# DOT_RC="$DOT_ROOT/.dotrc"

[[ "$0" == "$BASH_SOURCE" ]] && run_ansible "$@"
