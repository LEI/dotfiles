#!/usr/bin/env bash

set -o nounset
set -o errexit
set -o pipefail

[[ -z "${DOT_ROOT-}" ]] && DOT_ROOT="$HOME/.dotfiles"

cd "$DOT_ROOT"

# Use ask become pass or -K instead?
# sudo -v

install_ansible() {
  local uname=$(uname -s)

  case $uname in
    Darwin)
      if [[ ! -x /usr/bin/gcc ]]; then
        # Command Line Tools
        local x="xcode-select --install"
        echo "Run: $x"
        exit 0
      fi
      ;;
    Linux)
      # sudo apt-get install python-dev python-pip # libffi-dev
      # Fedora/CentOS: sudo yum install python-devel
      ;;
    *)
      echo "Unsupported platform: $uname"
      exit 1
      ;;
  esac

  sudo easy_install pip
  sudo pip install -r requirements.txt
  # pip cryptography on raspbian ->
  # ERROR! Unexpected Exception: 'EntryPoint' object has no attribute 'resolve'
}

vault_ansible() {
  local extra_file="$HOME/.extra"
  local vault_file="$HOME/.vault_pass.txt"
  local vault_pass=


  if [[ ! -f "$vault_file" ]]; then
    echo "Vault?"
    read -e -r -s vault_pass
    if [[ -n "$vault_pass" ]]; then
      echo "$vault_pass" >> $vault_file
      # if [[ ! -f "$extra_file" ]] && [[ ! -n "$ANSIBLE_VAULT_PASSWORD_FILE" ]]; then
      #   echo "export ANSIBLE_VAULT_PASSWORD_FILE=$vault_file" >> $extra_file
      #   source $extra_file
      # fi
    else
      vault_ansible
      return
    fi
  fi

  if [[ ! -n "${ANSIBLE_VAULT_PASSWORD_FILE-}" ]]; then
    export ANSIBLE_VAULT_PASSWORD_FILE=$vault_file
  fi
}

run_ansible() {
  local playbook="playbooks/main.yml"
  local ansible=$(which ansible)

  if [[ ! -n "$ansible" ]] || [[ ! -x "$ansible" ]]; then
    install_ansible
  fi

  if [[ $? == 0 ]]; then
    vault_ansible
    # ansible-galaxy install -r requirements.yml
    ansible-playbook "$playbook" "$@" # --ask-become-pass
  fi
}

[[ "$0" == "$BASH_SOURCE" ]] && time run_ansible "$@"
