#!/usr/bin/env bash

# dot

# set -o xtrace
set -o nounset
set -o errexit
set -o pipefail

# # Extend matching operators
# shopt -s extglob
# # Loop on dotfiles
# shopt -s dotglob
# # Do not loop on empty directory
# shopt -s nullglob
# # Recursive globbing (bash 4)
# shopt -s globstar

# Platform
UNAME=$(uname -s | tr '[:upper:]' '[:lower:]') #Darwin|Linux

# Paths
cd $(dirname "${BASH_SOURCE[0]}")/..
DOT_ROOT=$(pwd -P)
DOT_TARGET=$HOME
DOT_SCRIPT="$DOT_ROOT/script"
DOT_RC="$DOT_ROOT/.dotrc"

# Load libraries
source $DOT_SCRIPT/lib/import.sh

import "log"
import "prompt"
import "config"

function dot() {

  	if config "$DOT_RC"; then
  		log_success "Hello, $DOT_AUTHOR_NAME" "$DOT_RC"
  	else
  		log_error "Could not generate config" "$DOT_RC"
  		die "$DOT_RC"
  	fi

    # Configuration (DOT_CONFIG_*)
    # [[ -n "${DOT_CONFIG_DEBUG-}" ]] && DEBUG="$DOT_CONFIG_DEBUG"
    # [[ -n "${DOT_CONFIG_DRY_RUN-}" ]] && DRY_RUN="$DOT_CONFIG_DRY_RUN"
    # [[ -n "${DOT_CONFIG_FORCE-}" ]] && FORCE="$DOT_CONFIG_FORCE"
    # [[ -n "${DOT_CONFIG_TIMESTAMPS-}" ]] && TIMESTAMPS="$DOT_CONFIG_TIMESTAMPS"
    DEBUG="${DOT_CONFIG_DEBUG-${DEBUG-false}}"
    DRY_RUN="${DOT_CONFIG_DRY_RUN-${DRY_RYN-false}}"
    FORCE="${DOT_CONFIG_FORCE-${FORCE-false}}"
    TIMESTAMPS="${DOT_CONFIG_TIMESTAMPS-${TIMESTAMPS-false}}"

  	log_debug "Debug mode" "$BASH_VERSION"

    if confirm "Homebrew install" "" Y; then
        # Install dependencies
        source $DOT_SCRIPT/install.sh || die "Install failed"
    fi

    if confirm "Bootstrap dotfiles" "" Y; then
        # Bootstrap dotfiles
        source $DOT_SCRIPT/bootstrap.sh || die "Bootstrap failed"
    fi

    if confirm "Platform defaults" "" Y; then
        # Set platform defaults
        source $DOT_SCRIPT/defaults.sh || die "Defaults failed"
    fi

    log_success "Done" "STATUS $?"
}

die() {
	local message=$1
	[[ -z "$message" ]] && message="Died"
	printf "%s\r\n" "${BASH_SOURCE[1]}: line ${BASH_LINENO[0]}: ${FUNCNAME[1]}: $message." >&2
	exit 1
}

[[ "$0" == "$BASH_SOURCE" ]] && dot "$@"
