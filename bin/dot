#!/usr/bin/env bash

# dot

# set -o xtrace
set -o nounset
set -o errexit
set -o pipefail

# Platform
UNAME=$(uname -s | tr '[:upper:]' '[:lower:]') #Darwin|Linux

# Paths
cd $(dirname "${BASH_SOURCE[0]}")/..
DOT_ROOT=$(pwd -P)
DOT_TARGET=$HOME
DOT_FILES_ROOT="$DOT_ROOT/files"
DOT_SCRIPT="$DOT_ROOT/script"
DOT_RC="$DOT_ROOT/.dotrc"

# Configuration
DOT_CONFIG_DEBUG=${DOT_CONFIG_DEBUG-false}
DOT_CONFIG_DRY_RUN=${DOT_CONFIG_DRY_RUN-false}
DOT_CONFIG_TIMESTAMPS=${DOT_CONFIG_TIMESTAMPS-false}
# MIN_DEPTH=1
# MAX_DEPTH=1

# Load libraries
source $DOT_SCRIPT/lib/import.sh

import "log"
import "prompt"
import "config"

function dot() {
  	# DOT_CONFIG_*
  	if config "$DOT_RC"; then
  		log_success "Hello, $DOT_AUTHOR_NAME" "$DOT_RC"
  	else
  		log_error "Could not generate config" "$DOT_RC"
  		die "$DOT_RC"
  	fi

  	log_debug "Debug mode" "Enabled"

    if confirm "Defaults" "" Y; then
        # Set platform defaults
        # log_info "Setting defaults" "..."
        . $DOT_SCRIPT/defaults.sh || die "Defaults failed"
    fi

    if confirm "Dependencies" "" Y; then
        # Install dependencies
        # log_info "Installing dependencies" "..."
        . $DOT_SCRIPT/install.sh || die "Install failed"
    fi

    if confirm "Bootstrap" "" Y; then
        # Bootstrap dotfiles
        # log_info "Bootstraping" "..."
        . $DOT_SCRIPT/bootstrap.sh || die "Bootstrap failed"
    fi

    log_success "Done" "STATUS $?"
}

die() {
	local message=$1
	[[ -z "$message" ]] && message="Died"
	printf "%s\r\n" "${BASH_SOURCE[1]}: line ${BASH_LINENO[0]}: ${FUNCNAME[1]}: $message." >&2
	exit 1
}

[[ "$0" == "$BASH_SOURCE" ]] && dot "$@"
