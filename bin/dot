#!/usr/bin/env bash

# Usage: man ansible-playbook

set -o nounset
set -o errexit
set -o pipefail

DOT_ROOT="${DOT_ROOT:-$HOME/.dotfiles}"
DOT_REQUIREMENTS="$DOT_ROOT/requirements"
DOT_PLAYBOOK="$DOT_ROOT/playbook.yml"

main() {

  if ! has ansible; then
    ansible_install
  fi

  ansible_vault

  # Ansible root directory
  cd "$DOT_ROOT"

  # ansible-galaxy install -r "$DOT_REQUIREMENTS/galaxy.yml"

  # Inventory file defined in ansible.cfg

  # Run the main playbook
  ansible-playbook "$DOT_PLAYBOOK" "$@"
}

# arg() {
#   local install=
#   case ${1:-} in
#     install)
#       install=true
#       shift
#       ;;
#   esac
# }

ansible_vault() {
  if [[ -z "${ANSIBLE_VAULT_PASSWORD_FILE:-}" ]]; then
    export ANSIBLE_VAULT_PASSWORD_FILE="$HOME/.vault_pass.txt"
  fi

  # Create the vault file if needed
  if [[ ! -f "$ANSIBLE_VAULT_PASSWORD_FILE" ]]; then
    local vault_pass=$(prompt "Vault password?")
    echo "$vault_pass" >> $ANSIBLE_VAULT_PASSWORD_FILE
  fi
}

ansible_install() {
  local uname=$(uname -s)

  case $uname in
    Darwin)
      # If /usr/bin/gcc is absent
      if ! has gcc; then
        # Install Xcode
        _do "xcode-select --install"
      fi
      ;;
    Linux)
      die "TODO: detect linux package manager"

      # pip cryptography on raspbian ->
      # ERROR! Unexpected Exception: 'EntryPoint' object has no attribute 'resolve'

      # Debian/Ubuntu:
      # sudo apt-get install python-setuptools # Installed in requirements?
      # sudo apt-get install build-essential libffi-dev libssl-dev python-dev

      # Fedora/CentOS:
      # sudo yum install gcc libffi-devel openssl-devel python-devel

      # Archlinux: http://github.com/palazzem/hanzo/blob/master/bin/bootstrap.sh
      # sudo pacman -Syu # --noconfirm
      # sudo pacman -S ansible git python2-setuptools --noconfirm
      # python2 / python2-crypto / python2-cryptography / pyhton2-packaging / python2-pip
      ;;
    *)
      die "Unsupported platform: $uname"
      ;;
  esac

  # If Ansible is still not present
  if ! has ansible; then
    if ! has pip; then
      # Install python package manager
      su_do easy_install pip
    fi

    # Install ansible and cryptography and their dependencies
    su_do pip install -r "$DOT_REQUIREMENTS/pip.txt"
  fi
}

# Utils

log() {
  printf "%s\r\n" "$@"
}

error() {
  log >&2 "$@"
  return 1
}

die() {
  error "$@"
  exit 1
}

prompt() {
  local q="$1"
  log "$q" >&2

  local a=
  read -e -r -s a

  if [[ -n "$a" ]]; then
    # Echo answer
    printf "%s" "$a"
  else
    # Empty answer, ask again
    prompt "$@" && return
  fi
}

has() {
   # Skip the first parameter if it is 'sudo'
  [[ "$1" == "sudo" ]] && shift
  local name="$1"

  # Test if the program can be executed
  hash $name 2>/dev/null

  if [[ $? != 0 ]]; then
    # Display warning
    error "! $name is not installed"
  fi
}

_do() {
  local cmd="$@"

  if has $cmd; then
    log "› $cmd"
    # Execute the command
    $cmd
  else
    # Die
    die "× $cmd"
  fi
}

su_do() {
  _do sudo "$@"
}

[[ "$0" == "$BASH_SOURCE" ]] && time main "$@"
