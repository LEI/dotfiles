#!/usr/bin/env bash

# Compare 2 files and output common lines

# File or link
isfile() {
  [[ -f "$1" ]] && [[ -L "$1" ]]
}

main() {
  if [[ $# -ne 2 ]] || [[ -z "$1" ]] || [[ -z "$2" ]]
  then >&2 printf "%s\n" "$0: missing argument"
  elif ! isfile "$1" || ! isfile "$2"
  then >&2 printf "%s\n" "$0: not found"
  else comm -1 -2 <(sort "$1") <(sort "$2")
  fi
}

[[ "$0" == "$BASH_SOURCE" ]] && main "$@"
