#!/usr/bin/env bash
# Parse arguments

set -e
set -o pipefail
# shopt -s extglob
# shopt -s extdebug

for f in functions/{time,utils}
do source "${BASH_DIR:-$HOME/.bash.d}/$f.bash"
done

arrange_opts() {
  local flags args str="$1"
  shift

  while [[ $# -ne 0 ]] # (($#))
  do
    case "$1" in
      --) args+=("$@"); break ;;
      -*) local flag="${1: -1}"
        if [[ $str == *"$flag:"* ]]
        then flags+=("$1")
          if [[ $# -gt 1 ]]
          then flags+=("$2"); shift
          else err "-$flag: argument requires a value"
          fi
        elif [[ "$str" == *"$flag"* ]] && [[ "$1" != "-$flag" ]]
        then
          echo "?$flag ($1)  "${1:0:-2}" != "-" "
          if [[ "${#1}" -gt 2 ]] && [[ "${1:0:-1}" != "-" ]]
          then echo "->" "-$flag" "${1:0:-1}" "${@:2}"
            set -- "-$flag" "${1:0:-1}" "${@:2}"; continue
          else flags+=("-$flag" "${1:0:-1}")
          fi
        elif [[ "$str" == *"$flag"* ]]
        then flags+=("$1")
        else err "-$flag: unkown argument"
        fi
        ;;
      *) args+=("$1") ;;
    esac
    shift
  done
  ARR=("${flags[@]}" "${args[@]}")
}

getargs() {
  local ARR
  local str="${1}"; shift
  local var="${2}"; shift
  # local args="$@" # BASH_ARGV

  # log "[$str] $@"
  arrange_opts "$str" "$@"
  set -- "${ARR[@]}"

  log "AFTER ($@)"
  return 1 # $?
}

err() {
  die "${0##*/}: $@"
}

parse_args() {
  # local cmd=(${PARSE_ARGS[@]:0:1})
  local args=(${PARSE_ARGS[@]})
  local parsed=()
  while [[ $# -ne 0 ]]
  do
    case "$1" in
      -|'') err "invalid argument -" ;;
      --) break ;;
      -*) [[ "$next" -eq 1 ]] && err "illegal option $1"
        local pre="-${1%%-*}"
        local p
        for p in "${args[@]}"
        do
          local type next=0
          local req="${p#*:}"
          [[ "$p" == "$req" ]] && unset req
          if [[ "$req" == *- ]]
          then type="stdin"; req="${req%-*}"; next=1
          fi
          if [[ "$req" == *+* ]]
          then type="${req#*+}"; req="${req%+*}"; next=1
          fi
          p="${p%%:*}"
          local short="${p%|*}"
          local name="${p#*|}"
          local ptn="(-$short|--$name)([a-zA-Z]+)?" #($pre)*([a-zA-Z]+)?(=)"
          if [[ $1 =~ $ptn ]]
          then
            # >&2 echo "[[ $1 =~ $ptn ]]"
            # >&2 echo "$short,$name req $req ($next)"
            # local prefix="${BASH_REMATCH[1]}"
            local arg="${BASH_REMATCH[1]}"
            local extra="${BASH_REMATCH[2]}"
            # >&2 printf "MATCH %s\n" "${BASH_REMATCH[@]}"
            if [[ "$1" == "--"* ]] && [[ "$arg" == "-$short" ]] && [[ -n "$extra" ]]
            then err "illegal option $1"
            elif [[ "$1" == "-"* ]] && [[ -n "$extra" ]]
            then set -- "$arg" "-$extra" "${@:2}"
              # if [[ "$next" -eq 1 ]]
              # then echo >&2 "THEN" "-$arg" "${@:2:1}" "-$extra" "${@:3}"
              #   set -- "-$arg" "${@:2:1}" "-$extra" "${@:3}"
              # else echo >&2 "ELSE" "-$arg" "-$extra" "${@:2}"
              #   set -- "-$arg" "-$extra" "${@:2}"
              # fi
            elif [[ -n "$extra" ]]
            then err "invalid option $arg ($extra)"
            fi
            local varname="${name//-/_}"
            local val=
            if [[ "$next" -eq 1 ]]
            then
              if [[ "$type" == "stdin" ]]
              then
                if [[ $# -gt 1 ]] && [[ "$2" != -* ]]
                then [[ -f "$2" ]] && val="@$2" || val="$2"; next=0; shift
                else val="@-"; next=0 # [[ -t 0 ]]
                fi
              elif [[ $# -gt 1 ]] && [[ -n "$2" ]] && [[ "$2" != -* ]]
              then val="$2"; next=0; shift
              elif  [[ -n "$2" ]]
              then err "$1: $name requires a ${type:-value}, found: $2"
              else err "$1: $name requires a ${type:-value}"
              fi
            else val="1" # boolean
            fi
            shift # key or value

            case "$type" in
              ''|stdin|string) [[ -n "$val" ]] || err "$val: invalid $name $type" ;;
              duration) val="$(get_seconds "$val")" || err "$val: invalid $name $type" ;;
              number) [[ $val =~ ^-?[0-9]+$ ]] || err "$val: invalid $name $type" ;;
              *) err "invalid type $type ($val)"
            esac
            parsed+=("$varname=$val" "${req:-}")
            printf "%s\n" "$varname=$val"
            break
          fi
          # >&2 echo "did not break $arg /$p/ $@"
        done
        if [[ -z "$arg" ]]
        then err "illegal option $1"
        fi
        ;;
      *) err "$1? [$@] $#"
        ;;
    esac
  done
}

[[ "$0" == "$BASH_SOURCE" ]] && getargs "$@"
