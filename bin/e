#!/usr/bin/env bash
# https://github.com/holman/dotfiles/blob/master/bin/e

# Usage: e [<path>]
# Quick shortcut to an editor
# e: opens the current directory in your editor
# e /usr/local: opens the specified directory in your editor

if [[ -z "$EDITOR" ]]; then
  echo "\$EDITOR is undefined"
  exit 1
fi

if [[ "$#" -eq 0 ]] ; then
  exec $EDITOR .
else
  exec $EDITOR "$@"
fi
